Cell["ParallelTry", "Subsubsection",ExpressionUUID->"7456c435-5057-4d9d-8928-afb450f05869"],

Cell[TextData[{
 ButtonBox["ParallelTry",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/ParallelTry.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/ParallelTry.html"],
 " works like ParallelMap, but only returns the first result that has \
finishing computing."
}], "Text",ExpressionUUID->"9118af2d-04d5-4e4a-8d1e-2950e731575f"],


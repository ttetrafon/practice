Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"7d70d17b-0c8a-42c7-b892-a6eafbcd0cea"],

Cell[CellGroupData[{

Cell["Tuning", "Section",
 CellTags->"Tuning",ExpressionUUID->"c5c4cf4f-8204-4edd-8edf-42cbe4393f51"],

Cell[TextData[{
 "When parallel computing, the parallelisation method can be tuned (with the \
default being ",
 Cell[BoxData[
 "Automatic"], "Input",ExpressionUUID->"4189f1b2-02b6-44d8-8df6-effaec300047"],
 "\[LongDash]a compromise between ",
 ButtonBox["overhead",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Overhead_(computing)"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Overhead_(computing)"],
 " and ",
 ButtonBox["load balancing",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Load_balancing_(computing)"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Load_balancing_(computing)"],
 ")."
}], "Text",ExpressionUUID->"e895cf32-cb78-4ebb-a088-f224879cfdf9"],

Cell[CellGroupData[{

Cell["Small grain", "Subsubsection",ExpressionUUID->"1f94b5d6-e74e-43d4-bb2b-60543a2e7512"],

Cell["\<\
A smaller batch size means a more efficient use of CPU, at the cost of more \
communication between workers.\
\>", "Text",ExpressionUUID->"e3016b20-a945-4b53-b7e3-52252d171491"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
 "\"\<\!\(\*StyleBox[\"FinestGrained\", \"Input\"]\)\>\""], "Input",
  ExpressionUUID->"d20bef00-fa96-4c26-89aa-9a8fd06d7e7b"],
 " method will break the computation into the smallest possible calculations:"
}], "Text",ExpressionUUID->"96605c6f-5b16-4437-99c3-3de2bf937bd0"],

Cell[BoxData[
 RowBox[{"BlockRandom", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Parallelize", "[", 
     RowBox[{"Map", "[", 
      RowBox[{"Pause", ",", " ", 
       RowBox[{"RandomReal", "[", 
        RowBox[{"1", ",", " ", "12"}], "]"}]}], "]"}], "]"}], ";"}], "//", 
   "RepeatedTiming"}], "]"}]], "Input",ExpressionUUID->"45e541ad-f530-469c-\
9c38-4839a1eee0ec"],

Cell[BoxData[
 RowBox[{"BlockRandom", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Parallelize", "[", 
     RowBox[{
      RowBox[{"Map", "[", 
       RowBox[{"Pause", ",", " ", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"1", ",", " ", "12"}], "]"}]}], "]"}], ",", 
      RowBox[{"Method", " ", "->", " ", "\"\<FinestGrained\>\""}]}], "]"}], 
    ";"}], "//", "RepeatedTiming"}], "]"}]], "Input",ExpressionUUID->\
"d630a042-8009-40b3-bde8-fd0bf73fd85f"],

Cell["\<\
This method is suitable for computations involving few calculations, whose \
evaluations take different amounts of time. It leads to higher overhead, but \
maximises load balancing.\
\>", "Text",
 CellChangeTimes->{
  3.880038455048443*^9},ExpressionUUID->"748b98bb-c0ad-4616-9050-\
f78505b6a065"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Large grain", "Subsubsection",ExpressionUUID->"250003e4-77a9-4719-affb-52488b137e76"],

Cell["\<\
A larger batch size means a less efficient use of CPU, but also less \
communication needed.\
\>", "Text",ExpressionUUID->"0b710093-e039-44bd-b5a7-8f91bef05164"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
 "\"\<\!\(\*StyleBox[\"CoarsestGrained\", \"Input\"]\)\>\""], "Input",
  ExpressionUUID->"6372d2e1-3e93-4a69-ac47-60b0adc4023c"],
 " method will break the computation into as many pieces as there are \
available kernels:"
}], "Text",ExpressionUUID->"273a8453-9b2c-4f4a-8378-76e8e257b667"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ParallelSum", "[", 
   RowBox[{
    RowBox[{"N", "[", "i", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", 
      RowBox[{"10", "^", "6"}]}], "}"}]}], "]"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"aeaf50f8-5df5-42ec-88a5-\
7b2031776cd8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ParallelSum", "[", 
   RowBox[{
    RowBox[{"N", "[", "i", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", 
      RowBox[{"10", "^", "6"}]}], "}"}], ",", 
    RowBox[{"Method", "->", "\"\<CoarsestGrained\>\""}]}], "]"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"605455a3-b73d-45d2-83f5-\
196b35459489"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Parallelize", "[", 
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Labeled", "[", 
        RowBox[{
         RowBox[{"Framed", "[", "#", "]"}], ",", "$KernelID"}], "]"}], "&"}], 
      ",", 
      RowBox[{"Range", "[", "100", "]"}]}], "]"}], ",", 
    RowBox[{"Method", "\[Rule]", "\"\<CoarsestGrained\>\""}]}], "]"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"f32e7e91-4f7c-40fa-955a-\
ee8b9928cccb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Parallelize", "[", 
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Labeled", "[", 
        RowBox[{
         RowBox[{"Framed", "[", "#", "]"}], ",", "$KernelID"}], "]"}], "&"}], 
      ",", 
      RowBox[{"Range", "[", "100", "]"}]}], "]"}], ",", " ", 
    RowBox[{"Method", "\[Rule]", "\"\<FinestGrained\>\""}]}], "]"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"b3e2ceb7-8c3b-4227-8190-\
9ebc7a280e03"],

Cell["\<\
This method is suitable for computations involving many calculations, all of \
which take the same amount of time. It minimises overhead, but does not \
provide any load balancing.\
\>", "Text",ExpressionUUID->"44562296-cc58-44ff-9607-197f78cba493"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Custom grain size", "Subsubsection",ExpressionUUID->"599c8dde-8c6c-4fc2-b66a-bf6024e4aa65"],

Cell["\<\
Choosing a custom grain size can mean getting the best of both worlds.\
\>", "Text",ExpressionUUID->"c9084f43-db89-4439-948e-8502a0adbf2f"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  RowBox[{
  "\"\<\!\(\*StyleBox[\"EvaluationsPerKernel\", \"Input\"]\)\>\"", 
   "\[RightArrow]", 
   StyleBox["e", "TI"]}]], "Input",ExpressionUUID->
  "48e20b18-c949-47c5-9861-4734f7acf9cf"],
 " method will break the computation into at most ",
 Cell[BoxData[
  StyleBox["e", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5558373f-4370-4a9b-aa77-ce5353e5e70d"],
 " evaluations per kernel:"
}], "Text",ExpressionUUID->"71f120a9-1a23-43d2-b25c-3edce01b6254"],

Cell[BoxData[
 RowBox[{"Parallelize", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Labeled", "[", 
      RowBox[{
       RowBox[{"Framed", "[", "i", "]"}], ",", "$KernelID"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "20"}], "}"}]}], "]"}], ",", 
   RowBox[{"Method", "\[Rule]", 
    RowBox[{"\"\<EvaluationsPerKernel\>\"", "\[Rule]", "2"}]}]}], 
  "]"}]], "Input",
 CellLabel->"",ExpressionUUID->"ec9ddbc4-a661-4e91-86e7-1818a2faf013"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  RowBox[{
  "\"\<\!\(\*StyleBox[\"ItemsPerEvaluation\", \"Input\"]\)\>\"", 
   "\[RightArrow]", 
   StyleBox["m", "TI"]}]], "Input",ExpressionUUID->
  "8786b4f7-1be7-4690-9b14-8a507ddcfed4"],
 " method will break the computation into evaluations of at most ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b55fe4e5-2b2d-413a-b34e-9572934690f7"],
 " calculations each:"
}], "Text",ExpressionUUID->"467dfba6-2cc2-4a90-9387-6fa5f0871038"],

Cell[BoxData[
 RowBox[{"Parallelize", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Labeled", "[", 
      RowBox[{
       RowBox[{"Framed", "[", "i", "]"}], ",", "$KernelID"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "20"}], "}"}]}], "]"}], ",", 
   RowBox[{"Method", "\[Rule]", 
    RowBox[{"\"\<ItemsPerEvaluation\>\"", "\[Rule]", "3"}]}]}], 
  "]"}]], "Input",
 CellLabel->"",ExpressionUUID->"835d2ffc-e490-4e2c-9629-c88507c9fe15"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"a5f3f57a-06d6-490c-b0b2-4cbee09e93ec"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


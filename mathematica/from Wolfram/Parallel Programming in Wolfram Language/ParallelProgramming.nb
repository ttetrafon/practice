    RowBox[{"diagram", "[", 
     RowBox[{
     "\"\<ParallelTry[f, {\!\(\*SubscriptBox[\(x\), \(\(1\)\(,\)\)]\) \
\!\(\*SubscriptBox[\(x\), \(\(2\)\(,\)\)]\) \!\(\*SubscriptBox[\(x\), \
\(3\)]\), \!\(\*SubscriptBox[\(x\), \(i\)]\)}]\>\"", ",", 
      RowBox[{"{", 

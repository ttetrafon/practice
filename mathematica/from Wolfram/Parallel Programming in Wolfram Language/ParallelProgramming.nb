       RoundingRadius->5,
       StripOnInput->False], {1.125, 0}]}, 
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {2.5, 0}}], InsetBox[
      FrameBox[
       StyleBox["\<\"f[x]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",

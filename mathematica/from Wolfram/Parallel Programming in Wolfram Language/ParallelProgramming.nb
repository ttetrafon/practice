      Background->RGBColor[1, 1, 0.85],
      RoundingRadius->5,
      StripOnInput->False], {6, 1}]}},
  AspectRatio->0.6,
  ImageSize->600,
  PlotRange->{{-4, 9}, {-0.2, 1.2}}]], "Output",
 GeneratedCell->False,ExpressionUUID->"1b8ddec8-0601-413e-8176-d49e3444a140"]
}, {2}]],

Cell["Get the IDs of all running subkernels:", "Text",ExpressionUUID->"4852cd18-f321-4c4d-98f2-cc3e391ed733"],

Cell[BoxData[
 RowBox[{"kernelIDs", " ", "=", " ", 
  RowBox[{"ParallelEvaluate", "[", "$KernelID", "]"}]}]], "Input",
 CellLabel->"",ExpressionUUID->"4aef131a-94de-409a-8e7d-2f88b3cc9ae5"],

Cell["Generate a random number for each subkernel:", "Text",ExpressionUUID->"457fda81-68d0-496f-8dfc-a0636a433b03"],

Cell[BoxData[
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"Labeled", "[", 
   RowBox[{
    RowBox[{"Framed", "[", 
     RowBox[{"RandomReal", "[", "]"}], "]"}], ",", " ", "$KernelID"}], "]"}], 
  "]"}]], "Input",
 CellLabel->"",ExpressionUUID->"dc556f49-cfbf-4e00-a391-0f52625adfa6"],

Cell["Choose a specific subkernel to evaluate with:", "Text",ExpressionUUID->"ce42138e-ed2e-4553-9a40-1875f5bd5326"],

Cell[BoxData[
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{
   RowBox[{"Labeled", "[", 
    RowBox[{
     RowBox[{"Framed", "[", 
      RowBox[{"RandomReal", "[", "]"}], "]"}], ",", " ", "$KernelID"}], "]"}],
    ",", " ", 
   RowBox[{"kernelIDs", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], "]"}]], "Input",ExpressionUUID->\
"e7499e6c-b646-4cd8-a30b-e9ff667b115e"],

Cell["\<\
Symbols defined in a global context are distributed among subkernels \
automatically:\
\>", "Text",ExpressionUUID->"407267d6-b86c-49eb-a050-d1fc69628087"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "n_", "]"}], ":=", 
    RowBox[{"Labeled", "[", 
     RowBox[{
      RowBox[{"Framed", "[", 
       RowBox[{"n", "^", "2"}], "]"}], ",", " ", "$KernelID"}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"f", "[", "10", "]"}], "]"}]}], "Input",ExpressionUUID->"ac71ddd3-\
af91-4e76-bf1a-8c93f999dfb3"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"5bcd4700-8e9e-443c-b1f2-d38cdfa5af19"]
}, Open  ]]

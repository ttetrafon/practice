UUID->"0c55795b-d62c-45d7-9eb0-ee743948d182"],

Cell["\<\
For short computations, the overhead involved in ParallelTable makes it \
slower than Table:\
\>", "Text",ExpressionUUID->"26f2e486-7003-4be3-9331-a294e9f7b296"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"i", "^", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"10", "^", "4"}]}], "}"}]}], "]"}], ";"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"018086e2-e4bf-41e8-af67-\
0aaa8a41c556"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"i", "^", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"10", "^", "4"}]}], "}"}]}], "]"}], ";"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"0d781fb5-4911-4114-9f25-\
0405bbb24eec"],

Cell["\<\
For longer computations, the overhead becomes less important:\
\>", "Text",ExpressionUUID->"66580158-f02f-4c0f-8f00-957420cec919"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"FactorInteger", "[", 
       RowBox[{
        RowBox[{"10", "^", "50"}], "+", "n"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "20"}], "}"}]}], "]"}], ";"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"a0472eba-8813-49c4-bb1d-\
69389fcce54f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"FactorInteger", "[", 
       RowBox[{
        RowBox[{"10", "^", "50"}], "+", "n"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "20"}], "}"}]}], "]"}], ";"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"e20f9ab5-a6bb-4abe-b91e-\
0a28b39a54e0"],

Cell["\<\
Compare timings for Table and ParallelTable for increasingly lengthy \
computations:\
\>", "Text",ExpressionUUID->"5d0cd260-5a86-45bb-81bf-8da557086239"],

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tableTimings", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"First", "[", 
         RowBox[{"AbsoluteTiming", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"FactorInteger", "[", 
              RowBox[{
               RowBox[{"2", "^", "i"}], "+", "1"}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "1", ",", " ", "j"}], "}"}]}], "]"}], 
           ";"}], "]"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "10", ",", " ", "150", ",", " ", "5"}], 
         "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"parallelTableTimings", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"First", "[", 
         RowBox[{"AbsoluteTiming", "[", 
          RowBox[{
           RowBox[{"ParallelTable", "[", 
            RowBox[{
             RowBox[{"FactorInteger", "[", 
              RowBox[{
               RowBox[{"2", "^", "i"}], "+", "1"}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "1", ",", " ", "j"}], "}"}]}], "]"}], 
           ";"}], "]"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "10", ",", " ", "150", ",", " ", "5"}], 
         "}"}]}], "]"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tableTimings", ",", " ", "parallelTableTimings"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\[IndentingNewLine]", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<Timing\>\""}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Table\>\"", ",", " ", "\"\<ParallelTable\>\""}], "}"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"FrameTicks", " ", "->", " ", "None"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"ImageSize", " ", "->", " ", "500"}]}], "\[IndentingNewLine]", 
    "]"}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"",ExpressionUUID->"83b3a67f-03b3-47ef-9299-c0612123d02a"]
}, Open  ]],


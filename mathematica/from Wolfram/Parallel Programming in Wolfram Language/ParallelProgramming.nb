Cell["Apply two functions to a list:", "Text",ExpressionUUID->"142e8340-9b96-467b-8fee-fefb17530b11"],

Cell[BoxData[
 RowBox[{"ParallelCombine", "[", 
  RowBox[{"p", ",", 
   RowBox[{"Range", "[", 
    RowBox[{"2", "*", "$KernelCount"}], "]"}], ",", " ", "q"}], 
  "]"}]], "Input",ExpressionUUID->"f6249067-79ff-425f-9261-a5b70e3c8c2e"],

Cell[TextData[{
 "Create a parallel version of ",
 ButtonBox["MapThread",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/MapThread.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/MapThread.html"],
 ":"
}], "Text",ExpressionUUID->"37cff6d0-419c-43ad-85b7-d344a2bb3627"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"parallelMapThread", "[", 
     RowBox[{"function_", ",", "args_List"}], "]"}], ":=", 
    RowBox[{"ParallelCombine", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"MapApply", "[", 
        RowBox[{"function", ",", " ", "#"}], "]"}], "&"}], ",", 
      RowBox[{"Transpose", "[", "args", "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"parallelMapThread", "[", 
  RowBox[{"p", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<a\>\"", ",", " ", "\"\<b\>\"", ",", " ", "\"\<c\>\""}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<d\>\"", ",", " ", "\"\<e\>\"", ",", " ", "\"\<f\>\""}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<g\>\"", ",", " ", "\"\<h\>\"", ",", " ", "\"\<i\>\""}], 
      "}"}]}], "}"}]}], "]"}]}], "Input",ExpressionUUID->"c36064a0-f5ac-4002-\
8766-0430cda656f5"],

Cell["\<\
The built-in function is significantly faster when threading a small number \
of lists:\
\>", "Text",ExpressionUUID->"b95ab9e0-f669-4999-8d28-eaabf2780e5b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MapThread", "[", 
    RowBox[{"Plus", ",", " ", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "10"}], ",", " ", "10"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", 
         RowBox[{"10", "^", "4"}]}], "}"}]}], "]"}]}], "]"}], ";"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"faf942b3-c943-4ccc-92de-\
26e7e37b7f3c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"parallelMapThread", "[", 
    RowBox[{"Plus", ",", " ", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "10"}], ",", " ", "10"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", 
         RowBox[{"10", "^", "4"}]}], "}"}]}], "]"}]}], "]"}], ";"}], "//", 
  "RepeatedTiming"}]], "Input",ExpressionUUID->"3df05111-9aca-457c-aa5f-\
5b9ad74a63c2"],

Cell["But this is not so when threading many lists:", "Text",ExpressionUUID->"11552e77-939a-45d2-8183-0a819f809ea9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MapThread", "[", 
    RowBox[{"Plus", ",", " ", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "10"}], ",", " ", "10"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"10", "^", "5"}], ",", " ", "100"}], "}"}]}], "]"}]}], "]"}],
    ";"}], "//", "RepeatedTiming"}]], "Input",ExpressionUUID->"b092694b-c46e-\
455a-a37b-145f00c9be22"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"parallelMapThread", "[", 
    RowBox[{"Plus", ",", " ", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "10"}], ",", " ", "10"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"10", "^", "5"}], ",", " ", "100"}], "}"}]}], "]"}]}], "]"}],
    ";"}], "//", "RepeatedTiming"}]], "Input",ExpressionUUID->"a90b0644-2d3f-\
4a66-97ee-ee3a52f1fcf8"],

Cell["\<\
Note that ParallelCombine should generally only be used\[LongDash]as you may \
have guessed from the diagram\[LongDash]for operations where the output does \
not depend on the batching of the inputs (e.g. operations like addition or \
multiplication).\
\>", "Text",ExpressionUUID->"d59173e0-102c-4f99-8882-ba203b8635e9"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"109ec430-0571-4ca3-a2a3-76c3c81cb2a0"]
}, Open  ]]
}, Open  ]]

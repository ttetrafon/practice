Cell[CellGroupData[{

Cell["CriticalSection", "Subsubsection",ExpressionUUID->"8dc3a44d-c251-4c77-a5db-807052cf66f3"],

Cell[TextData[{
 ButtonBox["CriticalSection",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/CriticalSection.html"], 
    None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/CriticalSection.html"],
 " specifies a piece of code (known as a ",
 ButtonBox["critical section",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Critical_section"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Critical_section"],
 ") that should only be evaluated by one subkernel at a time."
}], "Text",ExpressionUUID->"93601d49-d658-41d2-8f7f-524f8cce1ab0"],

Cell["\<\
Sharing read/write operations among subkernels may lead to unexpected results:\
\>", "Text",ExpressionUUID->"c7d46381-0d05-4f33-af6e-c60698e2caaf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", 
   RowBox[{"m", "=", "0"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetSharedVariable", "[", 
   RowBox[{"n", ",", " ", "m"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{
   RowBox[{"n", "++"}], ";", " ", 
   RowBox[{"m", "=", "n"}]}], "]"}]}], "Input",ExpressionUUID->"473990a6-bda4-\
48e2-98ac-5865e8be69cc"],

Cell["\<\
CriticalSection ensures that the operation is evaluated \
\[OpenCurlyDoubleQuote]safely\[CloseCurlyDoubleQuote]:\
\>", "Text",ExpressionUUID->"71dde86a-81f9-48fb-a933-581755b7c8cb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", 
   RowBox[{"m", "=", "0"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "lockVariable", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"CriticalSection", "[", 
   RowBox[{"lockVariable", ",", " ", 
    RowBox[{
     RowBox[{"n", "++"}], ";", " ", 
     RowBox[{"m", "=", "n"}]}]}], "]"}], "]"}]}], "Input",ExpressionUUID->\
"c9ca5cb6-e9d8-4610-8624-160dc2dcbdfd"],

Cell["\<\
The locking method works by writing the current subkernel\[CloseCurlyQuote]s \
ID to the lock variable, performing the operation, then clearing the lock \
variable.\
\>", "Text",ExpressionUUID->"96814b3e-2f60-435c-bf77-bf07d790bb2c"]
}, Open  ]],


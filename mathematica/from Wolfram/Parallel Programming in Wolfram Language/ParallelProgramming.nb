Cell["Introduction", "Section",
 CellTags->
  "Introduction",ExpressionUUID->"3a0f20ee-7c2d-4532-b6a7-03765a96e6bf"],

Cell[CellGroupData[{

Cell["What is parallelisation?", "Subsubsection",ExpressionUUID->"cd2cd4a5-cde5-4fb8-9c1d-f8ba73e7f905"],

Cell[TextData[{
 StyleBox["Parallelisation",
  FontSlant->"Italic"],
 " is the ability to split a single task into multiple instructions that can \
be done simultaneously by several \[OpenCurlyDoubleQuote]workers\
\[CloseCurlyDoubleQuote] (subkernels)."
}], "Text",ExpressionUUID->"8f9fd01d-856b-4421-8611-7e4b3130ab77"],


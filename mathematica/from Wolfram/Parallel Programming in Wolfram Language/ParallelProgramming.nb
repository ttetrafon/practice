        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],
       Background->RGBColor[1, 1, 0.85],
       RoundingRadius->5,
       StripOnInput->False], {-0.25, 0}]}, 
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {1.125, 0}}], InsetBox[
      FrameBox[
       StyleBox["\<\"f[x]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],

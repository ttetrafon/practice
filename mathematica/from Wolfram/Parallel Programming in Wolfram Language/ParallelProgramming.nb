Cell["\<\
When performing a parallelised task, Mathematica will launch as many \
subkernels as there are processor cores on your machine:\
\>", "Text",ExpressionUUID->"498ba152-c2ce-4ed3-a424-5dc7c1c82b2d"],

Cell[BoxData["$ProcessorCount"], "Input",ExpressionUUID->"e7ecfab0-61de-4ed1-8515-4718a2e5cf3d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["When should you do it?", "Subsubsection",ExpressionUUID->"9e7f6051-67b1-4913-9a05-52eae61a6edd"],

Cell["Parallelisation is good for:", "Text",ExpressionUUID->"c47c07c7-ac96-41ca-bd21-2b9614a6ebae"],

Cell["Long/heavy computations", "Item",
 CellChangeTimes->{{3.880035578968652*^9, 
  3.880035579472342*^9}},ExpressionUUID->"cc185abd-71ca-4450-b44c-\
ddff167313fe"],

Cell["Tasks that can be split into subtasks", "Item",
 CellChangeTimes->{
  3.880035575941992*^9},ExpressionUUID->"bb3ea6dd-f2b1-4d3c-b42f-\
4cc99e1a5996"],

Cell["Tasks with small inputs or outputs", "Item",ExpressionUUID->"111e97e8-ef57-40b8-a456-afe1aaad552e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["How much will it help?", "Subsubsection",ExpressionUUID->"dc239ce0-b691-446b-8d7d-16b3a9384422"],

Cell["\<\
Each worker will have some overhead when sending or receiving instructions, \
so choosing whether or not to parallelise is always a balancing act.\
\>", "Item",ExpressionUUID->"8b121e4b-33c0-484a-8625-82e0a6920580"],

Cell[TextData[{
 "Any data required for a task will be sent to workers ",
 StyleBox["sequentially",
  FontSlant->"Italic"],
 ". It is therefore advisable to send each worker a ",
 StyleBox["reference",
  FontSlant->"Italic"],
 " to the data, rather than the data itself."
}], "Item",ExpressionUUID->"0bf2708d-2fec-4150-9ca4-efe39625cb40"],

Cell[TextData[{
 ButtonBox["Amdahl's Law",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Amdahl%27s_law"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Amdahl%27s_law"],
 StyleBox[": \[OpenCurlyDoubleQuote]The overall performance improvement \
gained by optimising a single part of a system is limited by the fraction of \
time that the improved part is actually used.\[CloseCurlyDoubleQuote]",
  FontSlant->"Italic"]
}], "Item",
 CellChangeTimes->{{3.880035597489279*^9, 
  3.880035606201534*^9}},ExpressionUUID->"67739c44-367f-4a6c-b583-\
b7fea8d144d9"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"dd78d2ef-3864-49e8-b170-78c2d2311274"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


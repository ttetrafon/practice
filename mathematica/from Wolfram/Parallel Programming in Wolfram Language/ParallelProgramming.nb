        "\"\<f[\!\(\*SubscriptBox[\(x\), \(i\)]\)]\>\""}], "}"}], ",", " ", 
      "\"\<f[\!\(\*SubscriptBox[\(x\), \(FirstReceived\)]\)]\>\""}], "]"}], 
    ",", "\[IndentingNewLine]", "\"\<Output\>\"", ",", "\[IndentingNewLine]", 

Cell["ParallelCombine", "Subsubsection",ExpressionUUID->"5a56e3b3-93df-469f-9105-b47e24cbfc8e"],

Cell[TextData[{
 "Although not directly related to an existing built-in function, ",
 ButtonBox["ParallelCombine",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/ParallelCombine.html"], 
    None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/ParallelCombine.html"],
 " is useful for creating your own custom parallel functions."
}], "Text",ExpressionUUID->"1f3ca313-efe9-43af-8511-0c8d5fcf5366"],

Cell[TextData[{
 "ParallelCombine deals with \[OpenCurlyDoubleQuote]chunks\
\[CloseCurlyDoubleQuote] of a task in parallel, then applies a secondary \
function (",
 ButtonBox["Join",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/Join.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/Join.html"],
 ", by default) to the result."
}], "Text",ExpressionUUID->"a4a243a5-dedc-4190-9e41-88aa4c2a3cbc"],


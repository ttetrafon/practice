   RowBox[{"{", 
    RowBox[{"i", ",", 
     RowBox[{"2", "*", "$KernelCount"}]}], "}"}]}], "]"}]], "Input",Expression\
UUID->"a49c3cd9-de20-4c38-9a63-01ccd5c7af94"],

Cell[BoxData[
 RowBox[{"ParallelTable", "[", 

, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/KernelConfiguration.html"],
 " is a wrapper that is used to specify configuration options for parallel \
kernels for RemoteEvaluate and LauchKernels which override the default kernel \
settings."
}], "Text",ExpressionUUID->"414c98b9-c66f-4c46-a08b-e6027b296371"],

Cell["\<\
For example specify a Kernel Command to run a different kernel that default:\
\>", "Text",ExpressionUUID->"49371943-e4df-3f4a-9028-621e82bb9fff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RemoteEvaluate", "[", 
   RowBox[{"\"\<localhost\>\"", ",", 
    RowBox[{"{", 
     RowBox[{
     "$MachineName", ",", "$ProcessID", ",", "$Version", ",", " ", 
      "$KernelCount"}], "}"}]}], "]"}], "//", "Column"}]], "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"c6593ffa-7564-3549-a229-48710ee684b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RemoteEvaluate", "[", 
   RowBox[{
    RowBox[{"KernelConfiguration", "[", 
     RowBox[{"\"\<localhost\>\"", ",", " ", 
      RowBox[{"\"\<KernelCommand\>\"", "->", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"ParentDirectory", "[", "$InstallationDirectory", "]"}], 
          ",", " ", "\"\<12.3\>\"", ",", " ", "\"\<WolframKernel.exe\>\""}], 
         "}"}], "]"}]}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"$MachineName", ",", "$ProcessID", ",", "$Version"}], "}"}]}], 
   "]"}], "//", "Column"}]], "Input",
 CellLabel->"In[49]:=",ExpressionUUID->"7e80545e-fd62-8145-9b4d-e693a1ea93c3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wolfram Lightweight Grid client", "Subsubsection",
 CellChangeTimes->{{3.880036080359239*^9, 3.880036081296704*^9}, {
  3.880036125990203*^9, 
  3.880036126102613*^9}},ExpressionUUID->"29faa565-499a-4ebe-9a24-\
af7f3fafd241"],

Cell[TextData[{
 "The ",
 ButtonBox["Lightweight Grid client",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/LightweightGridClient/guide/\
LightweightGridClient.html"], None},
  ButtonNote->
   "http://reference.wolfram.com/language/LightweightGridClient/guide/\
LightweightGridClient.html"],
 " is a system for launching and managing remote Mathematica kernels."
}], "Text",
 CellChangeTimes->{{3.880036131006357*^9, 
  3.880036131159149*^9}},ExpressionUUID->"fcf0a35e-446d-4a99-bbd8-\
fccd41cde060"],

Cell["Launch two local kernels:", "Text",ExpressionUUID->"fea81ea3-e7a6-4f53-84ec-2f7bf3309c94"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"CloseKernels", "[", "]"}], ";"}], "\n", 
 RowBox[{"LaunchKernels", "[", "2", "]"}]}], "Input",ExpressionUUID->\
"f6f5539c-bd90-49db-a55b-2ad4e6732ba0"],

Cell["\<\
Launch two remote kernels that have been configured with the Lightweight Grid \
client:\
\>", "Text",
 CellChangeTimes->{{3.880036137638441*^9, 
  3.880036137702826*^9}},ExpressionUUID->"e4e905a0-4e74-4339-a9fd-\
79cd432f3e32"],

Cell[BoxData[
 RowBox[{"LaunchKernels", "[", 
  RowBox[{"\"\<lwg://wreljarvis.wolfram.com\>\"", ",", "2"}], "]"}]], "Input",\
ExpressionUUID->"8041d880-5673-4069-aac8-165aa4b6da86"],

Cell["All four kernels are now available for computation:", "Text",ExpressionUUID->"5894b86c-831d-4bc3-bee6-ee99ee6197af"],

Cell[BoxData[
 RowBox[{"Kernels", "[", "]"}]], "Input",ExpressionUUID->"eee23ff3-37c2-4c2e-853b-591dfb3a921f"],

Cell[BoxData[
 RowBox[{"CloseKernels", "[", "]"}]], "Input",ExpressionUUID->"c7ad5690-038e-43fe-a46a-f94f3ba3c28c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Batch computation", "Subsubsection",ExpressionUUID->"84c1fabf-a9ae-46d7-b564-01898643f928"],

Cell[TextData[{
 "Batch computation can be done with ",
 ButtonBox["Amazon Web Services",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://aws.amazon.com/"], None},
  ButtonNote->"https://aws.amazon.com/"],
 " (AWS). This is just one of many external services available:"
}], "Text",ExpressionUUID->"fa0d45c8-78a1-4924-ba21-c4be1b3e240d"],

Cell[BoxData["$Services"], "Input",ExpressionUUID->"4c2d1a71-6c53-4834-b410-a6c5d5ac8374"],

Cell["Pros:", "Text",ExpressionUUID->"34d8ea56-33fe-467e-84e5-d14f0101eb7c"],

Cell["Remote; can be left to run in the background", "Item",
 CellChangeTimes->{
  3.880036167468615*^9},ExpressionUUID->"b4fe7014-4d2e-4b0a-ad20-\
79e61de3b253"],

Cell["Little setup required", "Item",
 CellChangeTimes->{
  3.880036168532178*^9, {3.880038486834644*^9, 
   3.880038488754857*^9}},ExpressionUUID->"90dc7cec-8377-4c47-ad45-\
b86692895008"],

Cell["Can run as many tasks as you want", "Item",
 CellChangeTimes->{
  3.88003616950856*^9},ExpressionUUID->"62b06020-1533-47bc-b362-0f04ff3dd6d0"],

Cell["Cons:", "Text",ExpressionUUID->"df0f8d63-4707-42bc-ab21-2c5f62293fb7"],

Cell["Computations may not start immediately", "Item",
 CellChangeTimes->{
  3.880036174612546*^9},ExpressionUUID->"b315be4e-b9c4-42f8-860a-\
aac6ee19602a"],

Cell["\<\
Requires a subscription (where the cost will depend on the level of service)\
\>", "Item",
 CellChangeTimes->{
  3.880036175638849*^9},ExpressionUUID->"96baa963-8ca3-4d10-ac69-\
12e51a70a621"],

Cell["\<\
Using this service requires user credentials. Here are some example inputs \
and their outputs:\
\>", "Text",ExpressionUUID->"044c9a4a-7626-477f-9684-3c64b465732c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ServiceConnect", "[", 
  RowBox[{"\"\<AWS\>\"", ",", " ", "\"\<New\>\""}], "]"}]], "Input",Expression\
UUID->"6229cc4b-ad10-4328-a7cc-4865068942c4"],


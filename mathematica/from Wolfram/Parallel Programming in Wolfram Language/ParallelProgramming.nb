Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"b0ebafa4-948d-45b0-86f7-f2403f65e760"],

Cell[CellGroupData[{

Cell["Parallel Analogues", "Section",
 CellTags->
  "ParallelAnalogues",ExpressionUUID->"70023a8e-7a91-4b17-8877-c698df5fb6e9"],

Cell["\<\
Wolfram Language has several \[OpenCurlyDoubleQuote]parallel versions\
\[CloseCurlyDoubleQuote] of built-in functions.\
\>", "Text",ExpressionUUID->"5a8d3d1a-be4a-49d4-a0e8-26f7c8ad3a19"],

Cell[CellGroupData[{

Cell["ParallelTable", "Subsubsection",ExpressionUUID->"7c2d8307-7a7d-4b70-ad02-3f123655e852"],

Cell["\<\
ParallelTable is the parallel version of Table. It automatically distributes \
iterations of a task across workers.\
\>", "Text",ExpressionUUID->"9cf690bb-be10-4f85-a330-717f5772aa43"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CellPrint", "[", "\[IndentingNewLine]", 
  RowBox[{"ExpressionCell", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"diagram", "[", 
     RowBox[{"\"\<ParallelTable[f[i], {i, 1, k}]\>\"", ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<f[1]\>\"", ",", " ", "\"\<f[2]\>\"", ",", " ", 
        "\"\<\[Ellipsis]\>\"", ",", " ", "\"\<f[k]\>\""}], "}"}], ",", 
      "\"\<{f[1], f[2], \[Ellipsis], f[k]}\>\""}], "]"}], ",", 
    "\[IndentingNewLine]", "\"\<Output\>\"", ",", "\[IndentingNewLine]", 
    RowBox[{"GeneratedCell", " ", "->", " ", "False"}]}], 
   "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}]], "Input",Expres\
sionUUID->"144e4e7f-1b3a-4c17-8180-4dcd07e1e360"],

Cell[BoxData[
 GraphicsBox[{{
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {-1.625, 0}}], 
     InsetBox[
      FrameBox[
       StyleBox["\<\"f[1]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],
       Background->RGBColor[1, 1, 0.85],
       RoundingRadius->5,
       StripOnInput->False], {-1.625, 0}]}, 
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {-0.25, 0}}], InsetBox[
      FrameBox[
       StyleBox["\<\"f[2]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],
       Background->RGBColor[1, 1, 0.85],
       RoundingRadius->5,
       StripOnInput->False], {-0.25, 0}]}, 
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {1.125, 0}}], InsetBox[
      FrameBox[
       StyleBox["\<\"\[Ellipsis]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],
       Background->RGBColor[1, 1, 0.85],
       RoundingRadius->5,
       StripOnInput->False], {1.125, 0}]}, 
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {2.5, 0}}], InsetBox[
      FrameBox[
       StyleBox["\<\"f[k]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],
       Background->RGBColor[1, 1, 0.85],
       RoundingRadius->5,
       StripOnInput->False], {2.5, 0}]}}, 
   {Arrowheads[{{0.03, 0.6}}], ArrowBox[{{0, 1}, {6, 1}}], InsetBox[
     FrameBox[
      StyleBox["\<\"ParallelTable[f[i], {i, 1, k}]\"\>",
       StripOnInput->False,
       FontFamily->"Courier",
       FontSize->Scaled[0.025]],

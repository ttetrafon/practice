Cell[CellGroupData[{

Cell["DistributeDefinitions", "Subsubsection",ExpressionUUID->"f083d0b4-5a94-467d-ba07-7a9ea1e224f4"],

Cell[TextData[{
 ButtonBox["DistributeDefinitions",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/DistributeDefinitions.\
html"], None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/DistributeDefinitions.html"],
 " distributes the definition(s) of a symbol to all parallel subkernels, \
giving each one a local copy. (Recall that for symbols defined in the global \
context, this is done automatically.)"
}], "Text",ExpressionUUID->"43cb16a0-ee29-4d71-a123-81a696bf2285"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "5ae652fe-4939-430d-8636-edc25cd251e9"],
 " is defined globally, ParallelEvaluate evaluates it in parallel:"
}], "Text",ExpressionUUID->"e5c711d9-ec7e-44ef-a8eb-545f3bf3cf8f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "n_", "]"}], " ", ":=", " ", 
   RowBox[{"Labeled", "[", 
    RowBox[{
     RowBox[{"Framed", "[", "n", "]"}], ",", " ", "$KernelID"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"Context", "[", "f", "]"}]}], "Input",ExpressionUUID->"e2f8c88c-e6c8-\
4897-b651-e1cfaa8b48fb"],

Cell[BoxData[
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"f", "[", "$KernelID", "]"}], "]"}]], "Input",ExpressionUUID->\
"210a23b9-5f04-43ec-821f-97f129e5525c"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   StyleBox["myContext`f",
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "3ff19013-5730-44f5-b252-de07cef6069f"],
 " only exists in one context, it is evaluated sequentially:"
}], "Text",ExpressionUUID->"9825d583-f9ca-46c7-82cf-6e2e6b7524df"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"myContext`f", "[", "n_", "]"}], " ", ":=", " ", 
   RowBox[{"Labeled", "[", 
    RowBox[{
     RowBox[{"Framed", "[", 
      RowBox[{"n", ",", " ", 
       RowBox[{"FrameStyle", " ", "->", " ", "Blue"}]}], "]"}], ",", " ", 
     "$KernelID"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Context", "[", "myContext`f", "]"}]}], "Input",ExpressionUUID->\
"aa11873b-5f75-4ae8-bf53-1ba476540bb9"],

Cell[BoxData[
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"myContext`f", "[", "$KernelID", "]"}], "]"}]], "Input",ExpressionUU\
ID->"dfefe814-8e08-4473-b582-8e3afc8dac37"],

Cell[TextData[{
 "After distributing its definitions, ",
 Cell[BoxData[
  FormBox[
   StyleBox["myContext`f",
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "be0eada8-3f74-4b3f-bb4f-fe02e418be0b"],
 " evaluates in parallel:"
}], "Text",ExpressionUUID->"8032d310-b7bc-40b9-998b-0a4d7f00b032"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"DistributeDefinitions", "[", "myContext`f", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"myContext`f", "[", "$KernelID", "]"}], "]"}]}], "Input",ExpressionU\
UID->"e5a87ec7-3df8-4427-aba0-59c7a6bbc903"],

Cell["\<\
To remove a distributed definition, clear and redistribute it:\
\>", "Text",ExpressionUUID->"adcc06dc-8999-4d6d-b1a1-fd95a2471cc7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "myContext`f", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DistributeDefinitions", "[", "myContext`f", "]"}], ";"}]}], "Input",\
ExpressionUUID->"bc0173ed-91e1-40a4-9235-717c49e08bd9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"myContext`f", "[", "n_", "]"}], " ", ":=", " ", 
   RowBox[{"Labeled", "[", 
    RowBox[{
     RowBox[{"Framed", "[", 
      RowBox[{"n", ",", " ", 
       RowBox[{"FrameStyle", " ", "->", " ", "Blue"}]}], "]"}], ",", " ", 
     "$KernelID"}], "]"}]}], ";"}], "\n", 
 RowBox[{"ParallelEvaluate", "[", 
  RowBox[{"myContext`f", "[", "$KernelID", "]"}], "]"}]}], "Input",ExpressionU\
UID->"c3fe6df2-6916-43b2-a421-862c98b060a0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SetSharedVariable", "Subsubsection",ExpressionUUID->"6da43e0f-0886-4042-a762-b431bf110529"],

Cell[TextData[{
 ButtonBox["SetSharedVariable",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/SetSharedVariable.html"], 
    None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/SetSharedVariable.html"],
 " distributes the definition(s) of a symbol among subkernels ",
 StyleBox["and",
  FontSlant->"Italic"],
 " synchronises them (via the master kernel)."
}], "Text",ExpressionUUID->"d6f890d4-1b28-47c1-bc1b-ed5e22a5e0ee"],


Cell["\<\
Return the result with the shortest pause, even though it was last to be \
evaluated:\
\>", "Text",ExpressionUUID->"f7582af6-e4fe-4066-ac74-67a9adcffad8"],

Cell[BoxData[
 RowBox[{"ParallelTry", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pause", "[", "#", "]"}], ";", "#"}], ")"}], "&"}], ",", 
   RowBox[{"{", 
    RowBox[{"4", ",", "3", ",", "2", ",", "1"}], "}"}]}], "]"}]], "Input",Expr\
essionUUID->"bd4c82e8-d139-4203-b18e-349b8e3deb3d"],

Cell["\<\
Find the next prime after 9\[ThinSpace]899\[ThinSpace]999\[ThinSpace]999, \
returning the results from the first three subkernels:\
\>", "Text",ExpressionUUID->"c4c8cba5-c84f-42c3-99dc-323460a1ca27"],

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"start", " ", "=", " ", "9899999999"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ParallelTry", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Pause", "[", "1", "]"}], ";", " ", 
        RowBox[{"Labeled", "[", 
         RowBox[{
          RowBox[{"Framed", "[", 
           RowBox[{"NextPrime", "[", "#", "]"}], "]"}], ",", "$KernelID"}], 
         "]"}]}], ")"}], "&"}], ",", "\[IndentingNewLine]", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"start", ",", " ", "$KernelCount"}], "]"}], ",", 
     "\[IndentingNewLine]", "3"}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",ExpressionUUID->"d64dedfa-6c2d-4fb7-\
b663-cb2c9c394c78"]
}, Open  ]],

Cell[CellGroupData[{

Cell["ParallelSubmit, WaitNext and WaitAll", "Subsubsection",ExpressionUUID->"ed66552c-175a-4b93-b923-a846b4382fe9"],

Cell[TextData[{
 ButtonBox["ParallelSubmit",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/ParallelSubmit.html"], 
    None},
  ButtonNote->"http://reference.wolfram.com/language/ref/ParallelSubmit.html"],
 " submits a task to the next available subkernel, but does not evaluate it. ",
 ButtonBox["WaitNext",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/WaitNext.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/WaitNext.html"],
 " and ",
 ButtonBox["WaitAll",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/WaitAll.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/WaitAll.html"],
 " can then be used to evaluate and return the results."
}], "Text",
 CellChangeTimes->{{3.880035836406526*^9, 
  3.88003583801082*^9}},ExpressionUUID->"725de487-41cc-4a2c-9f25-\
4dd91f4389c2"],

Cell["Submit several tasks to subkernels:", "Text",ExpressionUUID->"4e6ad812-0c0e-4ab4-b95f-f3d461996222"],

Cell[BoxData[
 RowBox[{"tasks", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"ParallelSubmit", "[", 
     RowBox[{
      RowBox[{"{", "i", "}"}], ",", 
      RowBox[{"Length", "[", 
       RowBox[{"FactorInteger", "[", 
        RowBox[{
         RowBox[{"2", "^", "i"}], "-", "1"}], "]"}], "]"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "181", ",", "184"}], "}"}]}], "]"}]}]], "Input",Express\
ionUUID->"5c12f72a-bd00-403d-8aed-5085ed038d74"],

Cell["Return the first result:", "Text",ExpressionUUID->"77cb89aa-1a27-4e76-a5f9-7a31a854ad53"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"firstResult", ",", "evalObjectID", ",", "otherTasks"}], "}"}], 
  "=", 
  RowBox[{"WaitNext", "[", "tasks", "]"}]}]], "Input",ExpressionUUID->\
"d76051e4-877d-4606-b905-40396420251b"],

Cell["Return the remaining results:", "Text",ExpressionUUID->"ecf32ff9-7568-4dac-aefe-eed674703540"],

Cell[BoxData[
 RowBox[{"WaitAll", "[", "otherTasks", "]"}]], "Input",ExpressionUUID->"b99f28c3-8ce5-4df0-b039-bb24316330aa"],

Cell["Watch the scheduling of evaluations while they are running:", "Text",ExpressionUUID->"5c6717ab-8a2f-455c-8f6a-93d750db0bb2"],

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"base", "=", 
      RowBox[{"10", "^", "1000"}]}], ",", 
     RowBox[{"r", "=", 
      RowBox[{"10", "^", "10"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"evals", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"ParallelSubmit", "[", "\[IndentingNewLine]", 
        RowBox[{"(", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"PrimeQ", "[", 
              RowBox[{"p", "=", 
               RowBox[{"RandomInteger", "[", 
                RowBox[{"{", 
                 RowBox[{"base", ",", 
                  RowBox[{"base", "+", "r"}]}], "}"}], "]"}]}], "]"}]}], ",", 
            "Null"}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"p", "-", "base"}]}], "\[IndentingNewLine]", ")"}], 
        "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", "$KernelCount", "}"}]}], "\[IndentingNewLine]", "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"PrintTemporary", "[", "evals", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"WaitAll", "[", "evals", "]"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",ExpressionUUID->"c92250f2-7f6f-4721-b245-f6039bf00edb"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"d1b7e8f9-e3c1-47ea-a5a0-931bc49de811"]
}, Open  ]]
}, Open  ]]

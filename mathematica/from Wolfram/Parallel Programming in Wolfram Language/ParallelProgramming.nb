Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"574f8f9e-04b2-4cc0-a5cd-74936599ed8a"],

Cell[CellGroupData[{

Cell["Automatic Parallelisation", "Section",
 CellTags->
  "AutomaticParallelisation",ExpressionUUID->"2c9513a8-c1fc-404d-9c9b-\
8d5b259d0d5e"],

Cell["\<\
Wolfram Language has several built-in functions designed to parallelise \
specific tasks. Where no such function exists for a particular task, it may \
still be possible to parallelise automatically.\
\>", "Text",ExpressionUUID->"d8d16b86-ae58-4ec8-89cd-8bbe6df7ead5"],

Cell[CellGroupData[{

Cell["Parallelize", "Subsubsection",ExpressionUUID->"ac29b9d0-498c-4439-a8e0-dd3e9e003fef"],

Cell[TextData[{
 ButtonBox["Parallelize",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/Parallelize.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/Parallelize.html"],
 " is an all-purpose tool that attempts to parallelise whatever computation \
is given to it:"
}], "Text",ExpressionUUID->"9c621ae9-5b17-42ba-a4cc-75947caf8a8c"],

Cell[BoxData[
 RowBox[{"LaunchKernels", "[", "4", "]"}]], "Input",ExpressionUUID->"905ad39d-4003-484d-8e6f-068e75b825a1"],

Cell[BoxData[
 RowBox[{"Parallelize", "[", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Length", "[", 
     RowBox[{"FactorInteger", "[", 
      RowBox[{
       RowBox[{"10", "^", "50"}], "+", "n"}], "]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "20"}], "}"}]}], "]"}], "]"}]], "Input",ExpressionUUID->\
"8c63b26b-516e-4515-9f84-dd97cfde34dd"],

Cell[TextData[{
 "In the case of ",
 ButtonBox["Table",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/Table.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/Table.html"],
 ", it would make more sense to use the built-in parallel version, ",
 ButtonBox["ParallelTable",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/ParallelTable.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/ParallelTable.html"],
 ":"
}], "Text",ExpressionUUID->"80b20e6f-97f2-4f0e-ab82-862f54f839bc"],

Cell[BoxData[
 RowBox[{"ParallelTable", "[", 
  RowBox[{
   RowBox[{"Length", "[", 
    RowBox[{"FactorInteger", "[", 
     RowBox[{
      RowBox[{"10", "^", "50"}], "+", "n"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"n", ",", "20"}], "}"}]}], "]"}]], "Input",ExpressionUUID->\
"500be744-226f-468b-b34c-43c7985fb242"],

Cell["Not all functions are parallelisable:", "Text",ExpressionUUID->"dd7eb3ec-325f-47d9-b15c-360b819e0337"],

Cell[BoxData[
 RowBox[{"Parallelize", "[", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"1", "/", "x"}], ",", "x"}], "]"}], "]"}]], "Input",ExpressionUUID\
->"c9dfe2b5-49a2-4502-92da-e83adad66de5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["ParallelEvaluate", "Subsubsection",ExpressionUUID->"30790e5e-5567-48b7-9e92-f3994bf4023a"],

Cell[TextData[{
 ButtonBox["ParallelEvaluate",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/ParallelEvaluate.html"], 
    None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/ParallelEvaluate.html"],
 " will run a copy of the same computation on each subkernel. This can be \
useful for checking or averaging results."
}], "Text",ExpressionUUID->"dd9383cf-39cb-4670-a45a-46ae5e03fe82"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CellPrint", "[", "\[IndentingNewLine]", 
  RowBox[{"ExpressionCell", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"diagram", "[", 
     RowBox[{"\"\<ParallelEvaluate[f[x]]\>\"", ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<f[x]\>\"", ",", " ", "\"\<f[x]\>\"", ",", " ", "\"\<f[x]\>\"", 
        ",", " ", "\"\<f[x]\>\""}], "}"}], ",", 
      "\"\<{f[x], f[x], f[x], f[x]}\>\""}], "]"}], ",", 
    "\[IndentingNewLine]", "\"\<Output\>\"", ",", "\[IndentingNewLine]", 
    RowBox[{"GeneratedCell", " ", "->", " ", "False"}]}], 
   "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}]], "Input",Expres\
sionUUID->"35c316b2-b886-42ac-92fd-4156149829f1"],

Cell[BoxData[
 GraphicsBox[{{
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {-1.625, 0}}], 
     InsetBox[
      FrameBox[
       StyleBox["\<\"f[x]\"\>",
        StripOnInput->False,
        FontFamily->"Courier",
        FontSize->Scaled[0.025]],
       Background->RGBColor[1, 1, 0.85],
       RoundingRadius->5,
       StripOnInput->False], {-1.625, 0}]}, 
    {Arrowheads[{0, -0.03, 0.03, 0}], ArrowBox[{{0, 1}, {-0.25, 0}}], InsetBox[
      FrameBox[

Cell[CellGroupData[{

Cell["Time Between Geyser Eruptions", "Subsection",
 CellChangeTimes->{{3.983335308612896*^9, 
  3.983335315181675*^9}},ExpressionUUID->"0c5142c2-8247-9243-86f5-\
f294fbef5bfe"],

Cell["\<\
Obtain the data for waiting times of Old Faithful geyser eruptions:\
\>", "Text",
 CellChangeTimes->{{3.9847673537621155`*^9, 
  3.9847673727057114`*^9}},ExpressionUUID->"32e7ce27-faf3-bc4b-971a-\
bf63f8dd4bf9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"waitingTimes", "=", 
   RowBox[{
    RowBox[{"ExampleData", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<Statistics\>\"", ",", "\"\<OldFaithful\>\""}], "}"}], 
     "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.984767243369665*^9, 3.9847672439684086`*^9}},
 CellLabel->"In[21]:=",
 CellID->576243958,ExpressionUUID->"0a0d6968-5e04-c445-a8b0-b4eb9f07c9e9"],

Cell["A histogram shows that the data exhibits two modes:", "Text",
 CellChangeTimes->{{3.9847673656029854`*^9, 3.9847673887217197`*^9}},
 CellID->766201915,ExpressionUUID->"a7888949-5706-1146-b6de-f846021fe8a5"],

Cell[BoxData[
 RowBox[{"h", "=", 
  RowBox[{"Histogram", "[", 
   RowBox[{"waitingTimes", ",", "20", ",", "\"\<ProbabilityDensity\>\""}], 
   "]"}]}]], "Input",
 CellChangeTimes->{3.984767395386244*^9},
 CellLabel->"In[22]:=",
 CellID->1928437783,ExpressionUUID->"d6b0503b-87e2-2e48-9d2e-42aa80f8daa9"],

Cell[TextData[{
 "Fit a ",
 ButtonBox["MixtureDistribution",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/MixtureDistribution.html"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/MixtureDistribution.html"],
 " to the data: "
}], "Text",
 CellChangeTimes->{{3.967736984737565*^9, 3.96773699189799*^9}, {
  3.967737027060088*^9, 3.967737027061491*^9}},
 CellID->1825417927,ExpressionUUID->"290b14ec-8c83-b648-8ed1-057cb375c2e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mDist", "=", 
   RowBox[{"MixtureDistribution", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1", "/", "3"}], ",", 
       RowBox[{"2", "/", "3"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"a", ",", "b"}], "]"}], ",", 
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"c", ",", "d"}], "]"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9677021990744877`*^9, 3.9677022069986057`*^9}, {
  3.984767400797697*^9, 3.9847674177031803`*^9}},
 CellLabel->"In[23]:=",
 CellID->1629250273,ExpressionUUID->"1b669dee-2f3d-0d46-a8fe-17faee0e2df0"],

Cell[BoxData[
 RowBox[{"eDist", "=", 
  RowBox[{"EstimatedDistribution", "[", 
   RowBox[{"waitingTimes", ",", "mDist", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "55"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"b", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"c", ",", "80"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"d", ",", "1"}], "}"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9677022105292835`*^9, 3.9677022115061626`*^9}, {
  3.967702316283327*^9, 3.96770233774317*^9}, {3.967702374156454*^9, 
  3.9677023849577427`*^9}, {3.967702447362444*^9, 3.967702474032507*^9}, {
  3.967702511274431*^9, 3.967702533972767*^9}, {3.9847674044855423`*^9, 
  3.9847674106280155`*^9}},
 CellLabel->"In[24]:=",
 CellID->468782131,ExpressionUUID->"ba1e101a-580c-9e49-adab-ada2929f06fb"],

Cell["\<\
Compare the histogram to the PDF of the estimated distribution:\
\>", "Text",
 CellID->1052121547,ExpressionUUID->"1762fa81-6859-de44-bef7-c64e0a7c742d"],

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{"h", ",", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"PDF", "[", 
      RowBox[{"eDist", ",", "x"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "100"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9847674274794292`*^9, 3.9847674330385*^9}},
 CellLabel->"In[25]:=",
 CellID->2063343729,ExpressionUUID->"6201a7d2-6621-2641-832e-0e21344b0ef3"],

Cell["\<\
Find the probability that the waiting time is over 80 minutes:\
\>", "Text",
 CellID->322436776,ExpressionUUID->"82707ba3-e102-4e46-8df3-ef43214bcd48"],

Cell[BoxData[
 RowBox[{"NProbability", "[", 
  RowBox[{
   RowBox[{"x", ">", "80"}], ",", 
   RowBox[{"x", "\[Distributed]", "eDist"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9847674406026554`*^9, 3.98476744090292*^9}},
 CellLabel->"In[26]:=",
 CellID->1093652851,ExpressionUUID->"8b06f780-a6f2-ed46-8f89-7a7d5aebc7ed"],

Cell["Simulate waiting times for the next 60 eruptions:", "Text",
 CellID->1824011765,ExpressionUUID->"ac339c76-e15d-1646-a7ef-943bc9959a40"],

Cell[BoxData[
 RowBox[{
  RowBox[{"simulatedWaitingTimes", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{"eDist", ",", "60"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.984767446547453*^9, 3.9847674560366*^9}},
 CellLabel->"In[27]:=",
 CellID->361196603,ExpressionUUID->"055fb0f3-3a39-cc4b-b195-4f6fff8ddd1e"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"simulatedWaitingTimes", ",", 
   RowBox[{"Filling", "\[Rule]", "Axis"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.984767523218292*^9, 3.9847675261561737`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"9a765f33-d241-2a44-b702-6aaa55e253d3"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"e3c90c29-364f-624b-956b-1b440e10fdf1"],

Cell[CellGroupData[{

Cell["Intermediate Examples", "Section",
 CellChangeTimes->{{3.98137718030402*^9, 
  3.9813771886912785`*^9}},ExpressionUUID->"ec7c44c2-230c-a041-8ea1-\
851da2211251"],

Cell[CellGroupData[{

Cell["Optimize Cell Tower Locations", "Subsection",
 CellChangeTimes->{{3.983335308612896*^9, 3.983335315181675*^9}, {
  3.984767787211031*^9, 
  3.984767796761015*^9}},ExpressionUUID->"967037b7-babb-1642-92af-\
4f1367338d6f"],

Cell[TextData[{
 "We wish to find the positions ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["j", "TI"]], TraditionalForm]], "InlineMath",ExpressionUUID->
  "76ee8587-9194-4540-92d6-d61f5d9cac43"],
 " and ranges ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["j", "TI"]], TraditionalForm]], "InlineMath",ExpressionUUID->
  "6414696d-9dec-7748-ae6d-7d364b0b7144"],
 " of various cell towers needed to serve customers located at positions ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["x", "TI"], 
    StyleBox["i", "TI"]], TraditionalForm]], "InlineMath",ExpressionUUID->
  "48cec2f9-4a56-9c4f-9c2a-42d6de895ca1"],
 " that minimize the power consumed:"
}], "Text",
 CellChangeTimes->{{3.9847678043174915`*^9, 
  3.9847678060326595`*^9}},ExpressionUUID->"4ef1dc8b-5fa3-924e-96bb-\
c3f7cdbf6e0d"],

Cell["\<\
Define the positions of the customers and the number of towers used to cover \
them:\
\>", "Text",
 CellChangeTimes->{
  3.9847678122106247`*^9},ExpressionUUID->"2daf7518-b63f-e24d-9e47-\
7953e36fbbac"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"customerPos", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"3", "/", "2"}], ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}], ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{"3", "/", "2"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"1", "/", "2"}], ",", 
       RowBox[{"1", "/", "2"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"3", "/", "2"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"3", "/", "2"}], ",", 
       RowBox[{"3", "/", "2"}]}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nTowers", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nCustomers", "=", 
   RowBox[{"Length", "[", "customerPos", "]"}]}], ";"}]}], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"83a24f16-67e4-c049-946e-c01d51880b06"],

Cell[TextData[{
 "Each cell tower consumes power that depends on its range according to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "fab2d098-fbde-8346-8d7d-170f5352a50e"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Proportional]", 
    RowBox[{"Erf", "(", 
     SubsuperscriptBox["r", "j", "1.5"], ")"}]}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"c661aaf8-71e4-4747-b266-cbcbd007c236"],
 ". The objective is to minimize the power consumption:"
}], "Text",
 CellChangeTimes->{
  3.98476782774*^9},ExpressionUUID->"c1f271a7-8aca-6b40-abf8-a18ddebc0053"],

Cell[BoxData[
 RowBox[{
  RowBox[{"objective", "=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"Erf", "[", 
      RowBox[{
       RowBox[{"r", "[", "i", "]"}], "^", "1.5"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "nTowers"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{3.9847678431489162`*^9},
 CellLabel->"In[32]:=",ExpressionUUID->"c2c606d5-db9c-bd45-a9fa-b270db23d567"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["z", "TI"], 
    RowBox[{"i", ",", "j"}]], TraditionalForm]], "InlineMath",ExpressionUUID->
  "9545cf34-66c1-694d-bcc4-6d4b1bb340df"],
 " be a decision variable indicating that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], 
     RowBox[{"i", ",", "j"}]], "=", "1"}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"722a8fef-070d-0a4d-873a-7c5878c27ee6"],
 " if client ",
 Cell[BoxData[
  FormBox[
   StyleBox["i", "TI"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "4012b1df-4753-354a-a80c-80e062fed302"],
 StyleBox[" is covered by cell tower ",
  Deletable->True],
 Cell[BoxData[
  FormBox[
   StyleBox["j", "TI"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "c334ad2f-b59c-184b-8695-31f5c9fe3b3c"],
 ":"
}], "Text",
 CellChangeTimes->{
  3.9847678492317867`*^9},ExpressionUUID->"bd839f91-41d2-fa44-9163-\
06f9df76c3b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"decisionConstraint", " ", "=", " ", 
   RowBox[{"0", "\[VectorLessEqual]", "z", "\[VectorLessEqual]", "1"}]}], 
  ";"}]], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"6efb857a-2de8-ae40-865f-54012b9445af"],

Cell["\<\
Each cell tower must be located such that its range covers some of the \
clients:\
\>", "Text",
 CellChangeTimes->{
  3.984767861886732*^9},ExpressionUUID->"037eb83a-fe12-d348-bd47-\
fb35ca3a2e51"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"m", "=", "20"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"distConstraint", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"p", "[", 
            RowBox[{"j", ",", "1"}], "]"}], ",", 
           RowBox[{"p", "[", 
            RowBox[{"j", ",", "2"}], "]"}]}], "}"}], "-", 
         RowBox[{
         "customerPos", "\[LeftDoubleBracket]", "i", 
          "\[RightDoubleBracket]"}]}], "]"}], "-", 
       RowBox[{"m", "*", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Indexed", "[", 
           RowBox[{"z", ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "j"}], "}"}]}], "]"}]}], ")"}]}]}], "\[LessEqual]", 
      RowBox[{"r", "[", "j", "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"i", ",", "nCustomers"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"j", ",", "nTowers"}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9847678713040066`*^9, 3.9847678922076473`*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"82a090ea-164a-eb41-bd5f-bebc59198d56"],

Cell["Each cell tower can cover multiple clients:", "Text",
 CellChangeTimes->{
  3.98476790204558*^9},ExpressionUUID->"b273854b-4e03-1841-ad5a-73b71569b69d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"coverageConstraint", "=", 
   RowBox[{
    RowBox[{"Total", "[", 
     RowBox[{"z", ",", 
      RowBox[{"{", "2", "}"}]}], "]"}], "\[VectorGreaterEqual]", "1"}]}], 
  ";"}]], "Input",
 CellLabel->"In[36]:=",ExpressionUUID->"10897846-66d6-7c40-969f-c34c124f67e9"],

Cell["Each cell tower has a minimum and maximum coverage:", "Text",
 CellChangeTimes->{
  3.9847679121985016`*^9},ExpressionUUID->"af83ea57-ce03-ed4f-a5b9-\
e9275e68c6f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"maxCoverageConstraint", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"0", "\[LessEqual]", 
      RowBox[{"r", "[", "j", "]"}], "\[LessEqual]", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "nTowers"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"83d676ea-0ab2-0e49-b019-ccc6f04bfbe1"],

Cell["Collect all the variables:", "Text",
 CellChangeTimes->{
  3.9847679245098686`*^9},ExpressionUUID->"c3cea7d2-0671-7242-bafd-\
7382fba4da70"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vars", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"p", "[", 
           RowBox[{"j", ",", "1"}], "]"}], ",", 
          RowBox[{"p", "[", 
           RowBox[{"j", ",", "2"}], "]"}], ",", 
          RowBox[{"r", "[", "j", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "nTowers"}], "}"}]}], "]"}], ",", 
      RowBox[{"z", "\[Element]", 
       RowBox[{"Matrices", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"nCustomers", ",", "nTowers"}], "}"}], ",", "Integers"}], 
        "]"}]}]}], "}"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[38]:=",ExpressionUUID->"e0a85ca6-a0ee-5f40-b5f6-b3fd6638708e"],

Cell["Find the cell tower positions and their ranges:", "Text",
 CellChangeTimes->{
  3.9847679402152233`*^9},ExpressionUUID->"c19a9b0f-7232-2a49-ab25-\
af6c97298a37"],

Cell[BoxData[
 RowBox[{"Quiet", "[", "\[IndentingNewLine]", 
  RowBox[{"res", "=", "\[IndentingNewLine]", 
   RowBox[{"NMinimize", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "objective", ",", "decisionConstraint", ",", "distConstraint", ",", 
       "coverageConstraint", ",", "maxCoverageConstraint"}], "}"}], ",", 
     "\[IndentingNewLine]", "vars"}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9847679478904934`*^9, 3.9847679591936665`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"b9dd5664-9493-c04b-b380-450ee45f67f7"],

Cell["Extract the values:", "Text",
 CellChangeTimes->{
  3.984767969719988*^9},ExpressionUUID->"5278db5b-7031-b142-bb33-\
99a88f7b1e3e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"towerPos", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"p", "[", 
         RowBox[{"i", ",", "1"}], "]"}], ",", 
        RowBox[{"p", "[", 
         RowBox[{"i", ",", "2"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "nTowers"}], "}"}]}], "]"}], "/.", 
    RowBox[{"res", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"towerRange", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"r", "[", "i", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "nTowers"}], "}"}]}], "]"}], "/.", 
    RowBox[{"res", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}]}],
   ";"}]}], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"8bae470d-518a-c248-89f3-61f8e85e7a58"],

Cell["\<\
Visualize the positions and ranges of the towers with respect to client \
locations:\
\>", "Text",
 CellChangeTimes->{
  3.984767982627775*^9},ExpressionUUID->"cb57f664-15f0-1c4e-aa10-\
18e6985ec717"],

Cell[BoxData[
 RowBox[{"Graphics", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Orange", ",", 
       RowBox[{"PointSize", "[", "0.04", "]"}], ",", 
       RowBox[{"Point", "[", "towerPos", "]"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Black", ",", 
       RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
       RowBox[{"Point", "[", "customerPos", "]"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Red", ",", 
       RowBox[{"EdgeForm", "[", "Thick", "]"}], ",", 
       RowBox[{"MapThread", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Circle", "[", 
           RowBox[{"#1", ",", 
            RowBox[{
             RowBox[{"Abs", "[", "#2", "]"}], "+", "0.04"}]}], "]"}], "&"}], ",", 
         RowBox[{"{", 
          RowBox[{"towerPos", ",", "towerRange"}], "}"}]}], "]"}]}], "}"}]}], 
    "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Frame", "\[Rule]", "True"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.984767990892889*^9, 3.9847680127322254`*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"b2b810c3-94b9-ef4b-b967-1eee1edc9dfe"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"f68d94f3-d636-b948-8445-1be86b01f183"],

Cell[CellGroupData[{

Cell["Intermediate Examples", "Section",
 CellChangeTimes->{{3.98137718030402*^9, 
  3.9813771886912785`*^9}},ExpressionUUID->"c0cb7ab3-79f7-b349-9136-\
5e75753b52ec"],

Cell[CellGroupData[{

Cell["Special Functions", "Subsection",
 CellChangeTimes->{{3.9833354764879055`*^9, 
  3.9833354786541996`*^9}},ExpressionUUID->"45f725c9-c332-a242-bd85-\
f3db3c049451"],

Cell[TextData[{
 "Consider the following second-order differential equation. The solution is \
given in terms of a ",
 ButtonBox["Heun function",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/guide/HeunAndRelatedFunctions.\
html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/guide/HeunAndRelatedFunctions.\
html"],
 ":"
}], "Text",ExpressionUUID->"cbce896f-9164-6744-b51d-fc1ef88662f3"],

Cell[BoxData[
 RowBox[{"DSolveValue", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        SuperscriptBox["x", "2"]}], ")"}], " ", 
      RowBox[{
       RowBox[{"y", "''"}], "[", "x", "]"}]}], "+", 
     RowBox[{"a", " ", "x", " ", 
      RowBox[{
       RowBox[{"y", "'"}], "[", "x", "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", 
        RowBox[{"c", " ", "x"}], "+", 
        RowBox[{"b", " ", 
         SuperscriptBox["x", "2"]}]}], ")"}], " ", 
      RowBox[{"y", "[", "x", "]"}]}]}], "\[Equal]", "0"}], ",", 
   RowBox[{"y", "[", "x", "]"}], ",", "x"}], "]"}]], "Input",
 CellLabel->"In[52]:=",ExpressionUUID->"a310f29c-7e4f-204a-98cb-43551293f562"],

Cell[TextData[{
 "Wolfram Language has this function (and many other ",
 ButtonBox["special functions",
  BaseStyle->"Hyperlink",

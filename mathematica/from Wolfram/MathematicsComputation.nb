095b82b249f5"],

Cell[CellGroupData[{

Cell["Find an Equational Proof of a Symbolic Theorem", "Subsection",
 CellChangeTimes->{{3.983335209854374*^9, 
  3.9833352448359756`*^9}},ExpressionUUID->"9bf949d0-c626-a14e-a814-\
71a7a264eedc"],

Cell["Specify the axioms of group theory:", "Text",ExpressionUUID->"ed04f73e-d6f3-df40-bae6-43082840aa82"],

Cell[BoxData[
 RowBox[{"groupTheory", "=", "\[IndentingNewLine]", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ForAll", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"a", ",", 
         RowBox[{"g", "[", 
          RowBox[{"b", ",", "c"}], "]"}]}], "]"}], "\[Equal]", 
       RowBox[{"g", "[", 
        RowBox[{
         RowBox[{"g", "[", 
          RowBox[{"a", ",", "b"}], "]"}], ",", "c"}], "]"}]}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"ForAll", "[", 
     RowBox[{"a", ",", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"a", ",", "e"}], "]"}], "\[Equal]", "a"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"ForAll", "[", 
     RowBox[{"a", ",", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"a", ",", 
         RowBox[{"inv", "[", "a", "]"}]}], "]"}], "\[Equal]", "e"}]}], 
     "]"}]}], "\[IndentingNewLine]", "}"}]}]], "Input",
 CellChangeTimes->{3.984823685455269*^9},
 CellLabel->"In[63]:=",ExpressionUUID->"2f6201cd-aa8a-1740-a3ce-29b3d810ae91"],

Cell["Prove the existence of the left identity:", "Text",ExpressionUUID->"0649e146-9a88-1e41-a572-1229ab4ca521"],

Cell[BoxData[
 RowBox[{"proof", "=", 
  RowBox[{"FindEquationalProof", "[", 
   RowBox[{
    RowBox[{"ForAll", "[", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"e", ",", "x"}], "]"}], "\[Equal]", "x"}]}], "]"}], ",", 
    "groupTheory"}], "]"}]}]], "Input",
 CellLabel->"In[64]:=",ExpressionUUID->"662df26e-0b68-b145-afa4-9ab7bd0041d7"],

Cell[BoxData[
 RowBox[{"proof", "[", "\"\<ProofNotebook\>\"", "]"}]], "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"61bd3f5d-60ca-5745-b2c3-96a89eb1cf2f"],

Cell["Show the abstract proof network:", "Text",ExpressionUUID->"f93318be-9431-fb41-9d62-d60372b3c333"],

Cell[BoxData[
 RowBox[{"proof", "[", "\"\<ProofGraph\>\"", "]"}]], "Input",
 CellLabel->"In[66]:=",ExpressionUUID->"877b637a-b06a-1d41-8b8c-166ba399cf74"],

Cell["Show the proof dataset:", "Text",ExpressionUUID->"77be789d-bb4c-fd4b-91b2-160e69c29f02"],

Cell[BoxData[
 RowBox[{"proof", "[", "\"\<ProofDataset\>\"", "]"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"b3e910b6-ebfa-0243-8acb-b94c2aba143a"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"56d5a4e7-146a-9c47-baa6-6e3fa931fb47"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


Cell[CellGroupData[{

Cell["Introductory Examples", "Section",ExpressionUUID->"fc31d06e-0d88-6049-99a7-35fc5fbea5d3"],

Cell[CellGroupData[{

Cell["The Birthday Problem", "Subsection",
 CellChangeTimes->{{3.9833351659121456`*^9, 3.983335179389328*^9}, {
  3.984766796390835*^9, 
  3.984766799174841*^9}},ExpressionUUID->"0800a6a0-5abe-9c4b-ad05-\
e0654bedb073"],

Cell["\<\
According to the Birthday Problem, if birthdays are uniformly distributed \
across a 365-day year, a group of just 23 people has approximately a 50.7% \
chance of at least one shared birthday.\
\>", "Text",
 CellChangeTimes->{{3.9847668066811123`*^9, 
  3.984766808820381*^9}},ExpressionUUID->"fd617f48-4661-5e41-b9af-\
3f6d6e78f547"],

Cell["Generate a list of all possible days in a non-leap year:", "Text",
 CellChangeTimes->{{3.984766822436754*^9, 
  3.9847668233799877`*^9}},ExpressionUUID->"2a980620-190c-c749-b8a6-\
2c5227b96364"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aYear", "=", 
   RowBox[{"DayRange", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2007", ",", "1", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2007", ",", "12", ",", "31"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9847668259979897`*^9, 3.9847668260016823`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"a7f69215-5e4a-da43-ba2b-339518c42514"],

Cell["\<\
Format the output to display only the month and day, removing the year:\
\>", "Text",
 CellChangeTimes->{{3.9847668330607605`*^9, 
  3.984766834201536*^9}},ExpressionUUID->"43b42185-253a-cb4c-9429-\
2ee363cdebcb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"birthdays", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"DateString", "[", 
      RowBox[{"#", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<MonthName\>\"", ",", "\"\< \>\"", 
         ",", "\"\<DayShort\>\""}], "}"}]}], "]"}], "&"}], "/@", "aYear"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9847668368003387`*^9, 3.9847668427635593`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"80212f84-be99-c148-99a8-19345ada1f20"],

Cell["\<\
Simulate one million random groups of 23 people from the formatted birthday \
list:\
\>", "Text",
 CellChangeTimes->{{3.984766850268503*^9, 
  3.9847668511561146`*^9}},ExpressionUUID->"e73a1f04-56c7-2349-ab80-\
ac7296ff9c7a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"millionGroups", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"RandomChoice", "[", 
      RowBox[{"birthdays", ",", "23"}], "]"}], ",", "1000000"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.984766853729122*^9, 3.9847668537331104`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"fdf28a6a-39da-0b4f-a079-28e9411e80b2"],

Cell["\<\
Detect the existence of shared birthdays within each group, returning 1 if \
there is a match and 0 if there is not:\
\>", "Text",
 CellChangeTimes->{{3.984766863287792*^9, 
  3.984766864204006*^9}},ExpressionUUID->"ec26fe0d-d946-704f-b474-\
6d701d41a839"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Boole", "[", 
      RowBox[{"Not", "[", 
       RowBox[{"DuplicateFreeQ", "[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
    "millionGroups"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9847668715352592`*^9, 3.984766871540251*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"7c3eaa89-2e76-ea4c-986e-95a9dcd86b4e"],

Cell["\<\
Count occurrences of groups with and without shared birthdays:\
\>", "Text",
 CellChangeTimes->{{3.984766882503376*^9, 
  3.9847668832835464`*^9}},ExpressionUUID->"e4a69ca3-86bc-594e-affb-\
c0afb5afb5ec"],

Cell[BoxData[
 RowBox[{"counts", "=", 
  RowBox[{"Counts", "[", "results", "]"}]}]], "Input",
 CellChangeTimes->{{3.984766885872244*^9, 3.9847668858762302`*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"6a8df276-42f1-1e4f-94ba-e2421934ccd3"],

Cell["Create a histogram to visualize the result:", "Text",
 CellChangeTimes->{{3.9847669026304417`*^9, 
  3.984766903275984*^9}},ExpressionUUID->"a18678b7-56bc-8044-a763-\
70dc350d8ab8"],

Cell[BoxData[
 RowBox[{"Histogram", "[", "\[IndentingNewLine]", 
  RowBox[{"results", ",", "\[IndentingNewLine]", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", 
       StyleBox[
       "\"PlotOptions\"", "IconizedCustomName", StripOnInput -> False], 
       GridBox[{{
          RowBox[{
            TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["Sequence", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["7", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["1568", "IconizedItem"]}]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    Sequence[ChartStyle -> Directive[
       RGBColor[0, 1, 1], 
       Opacity[0.3]], GridLines -> {None, Automatic}, Frame -> True, 
     FrameTicks -> {{Automatic, None}, {{0, 1}, None}}, FrameStyle -> 
     Directive[
       GrayLevel[0], 16], 
     FrameLabel -> {"Shared Birthday? (0 = No, 1 = Yes)", "Frequency"}, 
     LabelingFunction -> (Placed[
       Style[#, 17], Center]& )],
    SelectWithContents->True,
    Selectable->False]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.984766906091549*^9, 3.9847669534108124`*^9}, {
  3.9847669951600647`*^9, 3.9847670454257545`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"c122f034-d375-8243-a66b-b6f993a5ddf1"],

Cell["\<\
The simulation confirms the result of the Birthday Problem: in a million \
random groups of 23 people, approximately 50.7% of the groups had at least \
one shared birthday, closely matching the theoretical probability.\
\>", "Text",
 CellChangeTimes->{{3.984767056390524*^9, 
  3.9847670592517967`*^9}},ExpressionUUID->"561ca8fb-39c1-2b4e-9fc3-\
848ac34f2871"],

Cell[BoxData[""], "EndOfSlide",ExpressionUUID->"9b8eeaeb-322c-2241-840f-2bdd36bba6fb"]
}, Open  ]]
}, Open  ]]

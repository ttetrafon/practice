Cell["The Prose of Mathematics", "Subsection",
 CellChangeTimes->{{3.983334770433029*^9, 3.983334776238224*^9}, {
  3.9847655885638924`*^9, 
  3.984765594619213*^9}},ExpressionUUID->"c0f821c8-4df6-1d4e-9e99-\
87ba52d58059"],

Cell["\<\
Wolfram Language keeps extending its lead in symbolic integration.\
\>", "Text",
 CellChangeTimes->{{3.9676284469127464`*^9, 3.9676284535616646`*^9}, {
  3.9676294730728493`*^9, 
  3.9676294915624046`*^9}},ExpressionUUID->"6dc4c429-a69f-8f42-a9d6-\
3e7d0c46e8dd"],

Cell["Compute an integral in terms of elementary functions:", "Text",ExpressionUUID->"1909c44e-4605-d24d-8c5c-34399a0607fd"],

Cell[BoxData[
 RowBox[{"\[Integral]", 
  RowBox[{
   FractionBox[
    RowBox[{
     SqrtBox[
      RowBox[{
       SuperscriptBox["x", "3"], "-", "1"}]], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["x", "3"], "+", "2"}], ")"}]}], 
    RowBox[{
     SuperscriptBox["x", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["x", "3"]}], "-", 
       RowBox[{"4", " ", 
        SuperscriptBox["x", "2"]}], "-", "2"}], ")"}]}]], 
   RowBox[{"\[DifferentialD]", "x"}]}]}]], "Input",
 CellChangeTimes->{{3.8413325293122773`*^9, 3.8413325465841537`*^9}, 
   3.841652460367704*^9, 3.841654827076832*^9, {3.841655061782079*^9, 
   3.841655061782079*^9}, 3.8418738257447844`*^9, {3.8418738803755655`*^9, 
   3.841873883528993*^9}, {3.855392838016033*^9, 3.855392845343548*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"d120517b-e6db-0a47-af0a-32ff42750bd9"],

Cell["Compute a more difficult integral:", "Text",
 CellChangeTimes->{
  3.9847657125625134`*^9},ExpressionUUID->"7b68e189-c8c8-e346-b362-\
0934bb8abfe0"],

Cell[BoxData[
 RowBox[{"\[Integral]", 
  RowBox[{
   FractionBox[
    SqrtBox[
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      RowBox[{"x", " ", 
       SqrtBox[
        RowBox[{"x", "+", 
         SuperscriptBox["x", "2"]}]]}]}]], 
    SqrtBox[
     RowBox[{"x", "+", 
      SuperscriptBox["x", "2"]}]]], 
   RowBox[{"\[DifferentialD]", "x"}]}]}]], "Input",
 CellChangeTimes->{{3.839743975648342*^9, 3.839743981166156*^9}, {
   3.839744018177835*^9, 3.839744021369636*^9}, {3.8412703886749377`*^9, 
   3.8412703905273657`*^9}, {3.841270445214404*^9, 3.8412704707709675`*^9}, 
   3.841270662946147*^9, 3.841654827076832*^9, {3.841655074848324*^9, 
   3.841655089402929*^9}, 3.8418738257760735`*^9, {3.8418738756904545`*^9, 
   3.8418738923432865`*^9}, {3.855392861728891*^9, 3.855392882492053*^9}, 
   3.8553929817275677`*^9},
 CellLabel->"In[3]:=",ExpressionUUID->"f586e12e-9c42-5346-8b27-e33e823b6cc1"],

Cell[TextData[{
 "Compute the first four derivatives of ",
 ButtonBox["Cos",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Cos.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Cos.html"],
 ":"
}], "Text",ExpressionUUID->"d50144b1-f016-c440-befa-542fd14ba386"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "n"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Table", "[", 
  RowBox[{"%", ",", 
   RowBox[{"{", 
    RowBox[{"n", ",", "1", ",", "4"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{
  3.9833351906200047`*^9, 3.9847666641329765`*^9, {3.984766718619871*^9, 
   3.9847667216680393`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"5231f382-dda5-2d4f-a2f3-6147a9baf3b7"],

Cell[TextData[{
 "Compute the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["n", "th"], TraditionalForm]],ExpressionUUID->
  "4b6fc017-5ad1-604d-84df-bf946675b550"],
 " derivative of ",
 ButtonBox["Cos",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Cos.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Cos.html"],
 ":"
}], "Text",
 CellChangeTimes->{{3.984766761389517*^9, 
  3.9847667617442856`*^9}},ExpressionUUID->"71fadbea-67ff-bd4d-afca-\
700b022f33c0"],

Cell[BoxData[
 RowBox[{"D", "[", 
  RowBox[{
   RowBox[{"Cos", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "n"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"4813fd16-e693-254b-a6b2-132c3b31de4b"],

Cell["Plots are things to compute with, not simply outputs:", "Text",
 CellChangeTimes->{{3.984765855377447*^9, 
  3.984765910911434*^9}},ExpressionUUID->"bfc921c9-5a5b-0749-8da8-\
504a4281cffd"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ContourPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       RowBox[{"a", "*", 
        SuperscriptBox["z", "3"]}]}], "==", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", 
       RowBox[{"-", "1"}]}], "}"}], ",", "1", ",", 
     RowBox[{"-", "1"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9847659205303535`*^9, 3.9847659238997784`*^9}, {
  3.9851535977275467`*^9, 3.985153604946043*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"af36af2b-ed55-2c48-8f17-ce5d9b318815"],

Cell["Explore prime numbers:", "Text",
 CellChangeTimes->{{3.9847661558780975`*^9, 
  3.9847661713764553`*^9}},ExpressionUUID->"6a158395-e9d6-9a49-a0fb-\
e8da644937b1"],

Cell[BoxData[
 RowBox[{"DiscretePlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Prime", "[", 
     RowBox[{"n", "+", "1"}], "]"}], "-", 
    RowBox[{"Prime", "[", "n", "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"n", ",", "1", ",", "100"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"cc153a29-a547-d845-a1e5-68dcb3b3bed4"],

Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{"Line", "[", 
   RowBox[{
    RowBox[{"AnglePath", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Prime", "[", "n", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "1000"}], "}"}]}], "]"}], "]"}], ",", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", 
        RowBox[{"Rule", "[", 
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], "]"}], 
        GridBox[{{
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["504", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     VertexColors -> Table[
       ColorData["Rainbow"][$CellContext`n], {$CellContext`n, 0, 1, 1/1000}],
     SelectWithContents->True,
     Selectable->False]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.984766184873268*^9, 3.984766190236019*^9}, 
   3.9847665364142685`*^9},
 CellLabel->"In[11]:=",ExpressionUUID->"fc36dc16-c883-0e47-a335-fc0ff0afdf81"],

Cell["Solve a system of vector inequalities:", "Text",ExpressionUUID->"871e6471-08d0-3345-ad90-88669efa2390"],

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"Reduce", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "\[VectorLess]", 
      RowBox[{"x", "^", "3"}]}], "&&", 
     RowBox[{
      RowBox[{"x", ".", "x"}], "\[LessEqual]", "9"}], "&&", 
     RowBox[{"x", "\[Element]", 
      RowBox[{"Vectors", "[", 
       RowBox[{"2", ",", "Reals"}], "]"}]}]}], ",", "x"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9846797347846413`*^9, 3.9846797352763653`*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"badd5ca4-ebf8-064d-b94d-b26b9c9a6b4e"],

Cell["Find a particular solution:", "Text",ExpressionUUID->"383c79fd-a509-6548-82c5-9d83336fbd4d"],

Cell[BoxData[
 RowBox[{"FindInstance", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "\[VectorLess]", 
     RowBox[{"x", "^", "3"}]}], "&&", 
    RowBox[{
     RowBox[{"x", ".", "x"}], "\[LessEqual]", "9"}], "&&", 
    RowBox[{"x", "\[Element]", 
     RowBox[{"Vectors", "[", 
      RowBox[{"2", ",", "Reals"}], "]"}]}]}], ",", "x"}], "]"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"e80f75f4-97fa-734c-8e34-faf4c7916212"],

Cell["Visualise the solution set:", "Text",ExpressionUUID->"3b4b6b4c-d3d4-594f-ae24-f8846a23c5ac"],

Cell[BoxData[
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{"sol", "/.", " ", 
     RowBox[{"x", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", 
     RowBox[{"-", "1.2"}], ",", "3.2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"b", ",", 
     RowBox[{"-", "1.2"}], ",", "3.2"}], "}"}], ",", 
   RowBox[{"PlotPoints", "\[Rule]", "50"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9846797432913494`*^9, 3.984679747581917*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"8862f581-6ca1-2d4f-8bc0-348f8af3b2ce"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->

Cell[CellGroupData[{

Cell["Non-Commutative Algebra", "Subsection",
 CellChangeTimes->{{3.983335209854374*^9, 3.9833352448359756`*^9}, {
  3.9847702707812996`*^9, 
  3.984770280677971*^9}},ExpressionUUID->"cb075b9f-6a4b-8947-99e2-\
eb53565c935a"],

Cell[TextData[{
 "Version 1.0 of Mathematica had the function ",
 ButtonBox["NonCommutativeMultiply",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/NonCommutativeMultiply.\
html"], None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/NonCommutativeMultiply.html"],
 ", intended to represent a \[OpenCurlyDoubleQuote]general non-commutative \
form of multiplication\[CloseCurlyDoubleQuote]:"
}], "Text",
 CellChangeTimes->{{3.9848237759353065`*^9, 3.984823830085081*^9}, {
  3.9848242601367607`*^9, 
  3.984824261729639*^9}},ExpressionUUID->"8ee4673e-ec79-7341-b3a5-\
c588871ca90e"],

Cell[BoxData[
 RowBox[{"Expand", "[", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"a", "+", "b"}], ")"}], "2"], "]"}]], "Input",
 CellChangeTimes->{{3.9847697833076744`*^9, 3.9847697883448353`*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"0b51331d-bbf1-f546-9f7f-4f49f5911bc9"],

Cell[BoxData[
 RowBox[{"NonCommutativeMultiply", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"a", "+", "b"}], ")"}], ",", 
   RowBox[{"(", 
    RowBox[{"a", "+", "b"}], ")"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9848242662893753`*^9, 3.984824289392378*^9}},
 CellLabel->"In[94]:=",ExpressionUUID->"a8440881-1d72-e746-9d3e-445cad5e2298"],

Cell[TextData[{
 " ",
 ButtonBox["GeneralizedPower",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/GeneralizedPower.html"], 
    None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/GeneralizedPower.html"],
 " represents repeated non-commutative multiplication:"
}], "Text",
 CellChangeTimes->{{3.9848239405447273`*^9, 
  3.984823972595087*^9}},ExpressionUUID->"4ea3f023-aaed-3c40-a364-\
5216910d40f1"],

Cell[BoxData[
 RowBox[{"GeneralizedPower", "[", 
  RowBox[{"NonCommutativeMultiply", ",", 
   RowBox[{"a", "+", "b"}], ",", "2"}], "]"}]], "Input",
 CellChangeTimes->{{3.984769758337866*^9, 3.984769761627199*^9}},
 CellLabel->"In[95]:=",ExpressionUUID->"5964734a-eef1-c343-a6e3-a5fdb796ea37"],

Cell[TextData[{
 "In Version 14.3 we added ",
 ButtonBox["NonCommutativeExpand",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/NonCommutativeExpand.html"]\
, None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/NonCommutativeExpand.html"],
 ":"
}], "Text",
 CellChangeTimes->{{3.9848243634879246`*^9, 
  3.984824379807823*^9}},ExpressionUUID->"c0e2341a-f973-2d4e-b104-\
1fa50732dd37"],

Cell[BoxData[
 RowBox[{"NonCommutativeExpand", "[", "%", "]"}]], "Input",
 CellChangeTimes->{{3.9847697729697475`*^9, 3.984769777814476*^9}},
 CellLabel->"In[96]:=",ExpressionUUID->"618ac9d4-e396-3f4b-8327-e79c87d09e8f"],

Cell[BoxData[
 RowBox[{"NonCommutativeExpand", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"x", "+", 
     RowBox[{"2", "y"}]}], ")"}], "**", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"3", "x"}], "+", 
     RowBox[{"4", "y"}]}], ")"}], "**", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"5", "x"}], "+", 
     RowBox[{"6", "y"}]}], ")"}]}], "]"}]], "Input",
 CellLabel->"In[54]:=",
 CellID->1020825645,ExpressionUUID->"7f0ba6df-4011-43cb-bec6-e8ba938b853a"],

Cell[TextData[{
 "We can also specify that we want to use ",
 ButtonBox["Dot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/Dot.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/Dot.html"],
 " as the multiplication operation:"
}], "Text",
 CellChangeTimes->{{3.984824456640068*^9, 
  3.984824497359293*^9}},ExpressionUUID->"a30f37d5-afe1-284f-b6cc-\
63f0b0921f66"],

Cell[BoxData[
 RowBox[{"NonCommutativeExpand", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "+", 
      RowBox[{"2", "y"}]}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", "x"}], "+", 
      RowBox[{"4", "y"}]}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"5", "x"}], "+", 
      RowBox[{"6", "y"}]}], ")"}]}], ",", "Dot"}], "]"}]], "Input",
 CellChangeTimes->{{3.9579707587412443`*^9, 3.95797079303118*^9}},
 CellLabel->"In[91]:=",
 CellID->2115186184,ExpressionUUID->"0b2ee128-0e0a-44ef-9d22-6e55d9084d8c"],

Cell[TextData[{
 "Or even define our own ",
 ButtonBox["NonCommutativeAlgebra",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/NonCommutativeAlgebra.\
html"], None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/NonCommutativeAlgebra.html"],
 ":"
}], "Text",
 CellChangeTimes->{{3.984825192678211*^9, 3.984825193922676*^9}, {
  3.984825234290825*^9, 
  3.9848252342918262`*^9}},ExpressionUUID->"138c21fd-0d27-104b-adfa-\
d6f5b9f14571"],

Cell[BoxData[
 RowBox[{
  RowBox[{"algebra", "=", "\[IndentingNewLine]", 
   RowBox[{"NonCommutativeAlgebra", "[", "\[IndentingNewLine]", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Multiplication\>\"", "->", "m"}], ",", 
      RowBox[{"\"\<Addition\>\"", "->", "a"}], ",", 
      RowBox[{"\"\<Unity\>\"", "->", "o"}], ",", 
      RowBox[{"\"\<Zero\>\"", "->", "z"}], ",", 
      RowBox[{"\"\<CommutativeVariables\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"u", ",", "v"}], "}"}]}], ",", 
      RowBox[{"\"\<ScalarVariables\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"s", ",", "t"}], "}"}]}]}], "|>"}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.984825187187559*^9, 3.984825241419628*^9}},
 CellLabel->
  "In[104]:=",ExpressionUUID->"647192a7-7103-0b48-a40a-443029d043cb"],

Cell[BoxData[
 RowBox[{"NonCommutativeExpand", "[", 
  RowBox[{
   RowBox[{"m", "[", 
    RowBox[{
     RowBox[{"a", "[", 
      RowBox[{
       RowBox[{"m", "[", 
        RowBox[{"x", ",", 
         RowBox[{"t", " ", "y"}]}], "]"}], ",", "x", ",", "y", ",", "x"}], 
      "]"}], ",", 
     RowBox[{"a", "[", 
      RowBox[{
       RowBox[{"m", "[", 
        RowBox[{"x", ",", "u", ",", "y"}], "]"}], ",", 
       RowBox[{"m", "[", 
        RowBox[{"y", ",", "s", ",", "x", ",", "t", ",", "x"}], "]"}], ",", 
       "s", ",", "u", ",", "y"}], "]"}]}], "]"}], ",", "algebra"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.984825187187559*^9, 3.984825219469015*^9}, {
  3.985161325465925*^9, 3.9851613263458366`*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"4e61b1ec-3716-2a45-aa5a-d61a3e4d7db3"],

Cell["\<\
Look out for the next release of Wolfram Language, which will formalise \
computation of Clifford, Weyl, and Grassman algebras!\
\>", "Text",
 CellChangeTimes->{{3.9848247225765114`*^9, 3.984824753004059*^9}, {
  3.9848248635254536`*^9, 3.98482489487368*^9}, {3.984824948753153*^9, 
  3.9848249689423428`*^9}, {3.9848250085468903`*^9, 
  3.98482501178467*^9}},ExpressionUUID->"9ba2ccaa-2034-6745-9e33-\
67b8f847a552"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"38097c02-06c6-a84e-b350-0f93d7c7f5cf"],

Cell[CellGroupData[{

Cell["Advanced Examples", "Section",
 CellChangeTimes->{
  3.9813771438076515`*^9},ExpressionUUID->"30722262-fe61-2246-b9c6-\
6732b91817e9"],

Cell[CellGroupData[{

Cell["Brouwer\[CloseCurlyQuote]s Fixed Point Theorem", "Subsection",
 CellChangeTimes->{{3.984770288806179*^9, 
  3.9847702960489273`*^9}},ExpressionUUID->"7a24f650-7527-d14f-8e64-\
b63355467ebe"],

Cell["\<\
Brouwer\[CloseCurlyQuote]s fixed point theorem is an important result in \
algebraic topology, stating that, in any continuous transformation of a \
compact, convex set to itself, at least one point remains unaffected.\
\>", "Text",
 CellChangeTimes->{{3.9848252953573895`*^9, 
  3.984825305403248*^9}},ExpressionUUID->"9beaaba5-b3d6-c942-b893-\
d9be5175fefd"],

Cell[TextData[{
 "This function returns the image of (u,v) under the linear transformation \
taking the 4 corners of square (0,0),(1,0),(1,1),(0,1)\n to ",
 StyleBox["ref",
  FontSlant->"Italic"],
 ". For example then, if the end points are self-mapped, then each point \
(u,v) maps to itself:"
}], "Text",
 CellChangeTimes->{{3.9848253228897343`*^9, 3.9848253660213337`*^9}, 
   3.9848254096274757`*^9},ExpressionUUID->"32636b77-186c-4044-a514-\
4000fc331d26"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "ref_List", "]"}], "[", 
   RowBox[{"u_", ",", "v_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "u"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "-", "v"}], ")"}]}], ",", 
     RowBox[{"u", 
      RowBox[{"(", 
       RowBox[{"1", "-", "v"}], ")"}]}], ",", 
     RowBox[{"u", " ", "v"}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "u"}], ")"}], "v"}]}], "}"}], ".", 
   "ref"}]}]], "Input",
 CellChangeTimes->{{3.9848253151974792`*^9, 3.984825315203125*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"52e59aad-e2cc-bb42-835a-ac03c822334e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}], "}"}], "]"}], "[", 
   RowBox[{"u", ",", "v"}], "]"}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.9848253786941547`*^9, 3.984825378701523*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"7df2057b-a782-f748-abba-80e854619f23"],

Cell[TextData[{
 "To visualize this, we can draw the following ",
 ButtonBox["DensityPlot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/DensityPlot.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/DensityPlot.html"],
 ":"
}], "Text",
 CellChangeTimes->{{3.984825390435524*^9, 
  3.98482542086487*^9}},ExpressionUUID->"369fa91c-374e-bb4a-bde9-\
2a18efec0232"],

Cell[BoxData[
 RowBox[{"DensityPlot", "[", 
  RowBox[{
   RowBox[{"Norm", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}]}], "}"}], "]"}], "[", 
      RowBox[{"u", ",", "v"}], "]"}], "-", 
     RowBox[{"{", 
      RowBox[{"u", ",", "v"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"v", ",", "0", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9848253976590824`*^9, 3.984825397667309*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"21c814eb-c4a3-d34d-b1f9-1da0be217ce2"],

Cell["\<\
This shows that the displacement of each point is same (equal to 0) as each \
point is a fixed point. Nothing exciting here. Now, let us consider a map \
that flips the square over a horizontal axis (that is, (0,\:20060) \
\[LongLeftRightArrow] (0,\:20061) and (1,\:20060) \[LongLeftRightArrow] (1,\
\:20061)):\
\>", "Text",
 CellChangeTimes->{{3.984825433079981*^9, 
  3.984825434571661*^9}},ExpressionUUID->"76062dfe-d50e-2148-9350-\
efef0f176418"],

Cell[BoxData[
 RowBox[{"VectorPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], "}"}], "]"}], "[", 
     RowBox[{"u", ",", "v"}], "]"}], "-", 
    RowBox[{"{", 
     RowBox[{"u", ",", "v"}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"v", ",", "0", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9848254435013046`*^9, 3.984825443508484*^9}},
 CellLabel->"In[61]:=",ExpressionUUID->"218d6f08-b6b6-b642-978e-98bb5ebb4fbb"],

Cell[TextData[{
 "Here, points on the line v = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],ExpressionUUID->
  "44a1c712-457e-3348-a6be-0b56ef5d75c0"],
 " are fixed points. We confirm this:"
}], "Text",
 CellChangeTimes->{{3.98482545780538*^9, 3.9848254796011066`*^9}, 
   3.9851574194375362`*^9},ExpressionUUID->"45b55e63-ce28-9b4b-844c-\
66d2cc83ea05"],

Cell[BoxData[
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], "}"}], "]"}], "[", 
     RowBox[{"u", ",", "v"}], "]"}], "\[Equal]", 
    RowBox[{"{", 
     RowBox[{"u", ",", "v"}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "v"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9848254866205463`*^9, 3.984825486626177*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"669fb411-a06d-4347-85ca-5162021acc03"],

Cell["Now let us consider (0,\:20060) \[LongLeftRightArrow] (1,\:20061) and \
(1,\:20060) \[LongLeftRightArrow] (0,\:20061):", "Text",
 CellChangeTimes->{{3.984825496480011*^9, 
  3.9848254975221024`*^9}},ExpressionUUID->"e5e72d21-ce76-1d4f-858c-\
e17e3e643f40"],

Cell[BoxData[
 RowBox[{"VectorPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}]}], "}"}], "]"}], "[", 
     RowBox[{"u", ",", "v"}], "]"}], "-", 
    RowBox[{"{", 
     RowBox[{"u", ",", "v"}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"v", ",", "0", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9848255033242645`*^9, 3.9848255033308983`*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"a7400990-8c93-404e-9d49-3cd1173940bc"],

Cell["This has a single fixed point:", "Text",
 CellChangeTimes->{{3.984825553951376*^9, 
  3.9848255591511707`*^9}},ExpressionUUID->"ceeee59b-9966-0248-9cbc-\
38b4b14b6f8f"],

Cell[BoxData[
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}]}], "}"}], "]"}], "[", 
     RowBox[{"u", ",", "v"}], "]"}], "\[Equal]", 
    RowBox[{"{", 
     RowBox[{"u", ",", "v"}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "v"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.984825552072216*^9, 3.9848255520762177`*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"c020b887-324e-1a4d-b81f-ac5a10308ce4"],

Cell[TextData[{
 "Following is an extension of this idea. We use ",
 ButtonBox["Manipulate",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/Manipulate.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/Manipulate.html"],
 " to precisely locate the end-points:"
}], "Text",
 CellChangeTimes->{{3.984825585842308*^9, 3.9848256028583336`*^9}, 
   3.9848260419796104`*^9},ExpressionUUID->"419d8873-fb68-7746-92f7-\
3ed7ad27bb22"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"VectorPlot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", "pt", "]"}], "[", 
       RowBox[{"u", ",", "v"}], "]"}], "-", 
      RowBox[{"{", 
       RowBox[{"u", ",", "v"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"u", ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"v", ",", "0", ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"ColorFunction", "->", "GrayLevel"}]}], "\[IndentingNewLine]", 
    "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pt", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], "}"}], ",", "Locator"}], 
    "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"SaveDefinitions", "->", "True"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.984825572813631*^9, 3.984825572820429*^9}, {
  3.9848256052508183`*^9, 3.9848256289228573`*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"428e2ab9-f214-5547-9d0b-6838cd4e59b4"],

Cell["\<\
This example illustrated fixed points for affine self-maps of a square \
through visualization and interactive manipulation. However Brouwer\
\[CloseCurlyQuote]s fixed point theorem goes beyond just affine maps. A very \
beautiful and classical illustration is that if you stir a glass of water, \
there is at least one point in the fluid that ends up exactly where it \
started.\
\>", "Text",
 CellChangeTimes->{
  3.9848256430033703`*^9},ExpressionUUID->"92178b26-b882-ae40-96c1-\
f2f59fd0863d"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


    URL["https://reference.wolfram.com/language/guide/SpecialFunctions.html"],
     None},
  ButtonNote->
   "https://reference.wolfram.com/language/guide/SpecialFunctions.html"],
 ") built-in."
}], "Text",
 CellChangeTimes->{{3.9848236057892437`*^9, 
  3.9848236431279926`*^9}},ExpressionUUID->"9f5a71ce-a136-6e44-b3a0-\
70d04a4c2371"],

Cell["Compute a series expansion:", "Text",ExpressionUUID->"6781747f-feba-3d47-a88e-b282c69040b0"],

Cell[BoxData[
 RowBox[{"Series", "[", 
  RowBox[{
   RowBox[{"HeunC", "[", 
    RowBox[{
    "q", ",", " ", "\[Alpha]", ",", " ", "\[Gamma]", ",", " ", "\[Delta]", ",",
      " ", "\[Epsilon]", ",", " ", "z"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", "0", ",", "3"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"febbf438-0988-644a-b0c2-b071200d9894"],

Cell[TextData[{
 "Plot a family of Heun functions, varying accessory parameter ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "5bbc9b25-659f-014d-803a-eac812dd92a9"],
 ":"
}], "Text",ExpressionUUID->"2ec6d754-e7d0-9f49-97b1-185c6ac97808"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", "\[Gamma]", ",", "\[Delta]", ",", "\[Epsilon]"}],
     "}"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"0.7", "\[VeryThinSpace]", "-", 
      RowBox[{"0.9", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{"0.3", "-", 
      RowBox[{"0.5", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{
      RowBox[{"-", "0.4"}], "+", 
      RowBox[{"0.8", " ", "\[ImaginaryI]"}]}], ",", 
     RowBox[{
      RowBox[{"-", "0.3"}], "-", 
      RowBox[{"0.6", " ", "\[ImaginaryI]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Abs", "[", 

        "q", ",", "\[Alpha]", ",", "\[Gamma]", ",", "\[Delta]", ",", 
         "\[Epsilon]", ",", "z"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"q", ",", 
        RowBox[{"-", "8"}], ",", "8", ",", "4"}], "}"}]}], "]"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{"-", "8"}], ",", 
     RowBox[{"99", "/", "100"}]}], "}"}], ",", "\[IndentingNewLine]", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", 
       StyleBox[

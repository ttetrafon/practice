Cell["Finally, visualise the field:", "Text",
 CellChangeTimes->{{3.9669388627251415`*^9, 3.966938877067425*^9}, 
   3.967206057134101*^9},ExpressionUUID->"3c26cb62-beaf-d544-bd25-\
01e1e9c41aa3"],

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", "  ", 
  RowBox[{
   RowBox[{"StreamPlot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", "bField", "]"}], ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], " ", "\[Element]", " ", 
      "airRegion"}]}], "]"}], ",", "\[IndentingNewLine]", "  ", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Opacity", "[", "0.2", "]"}], ",", "wireRegion", ",", 
      RowBox[{"Opacity", "[", "1", "]"}], ",", 
      RowBox[{"Inset", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<\[CircleDot]\>\"", ",", "16", ",", "Black", ",", 
          "Bold"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], "]"}]}], "}"}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.966938770481186*^9, 3.966938792448704*^9}, 
   3.966938853418314*^9},
 CellLabel->"In[75]:=",ExpressionUUID->"8bcf23b2-a644-0146-8cdc-5745fb0912bb"],

Cell[TextData[{
 "We can see that this field is entirely azimuthal about the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "173ea46c-4cb5-bb4c-bc1d-a53d58411035"],
 " axis. Therefore, the field due to a circular, current-carrying coil is the \
sum of lots of fields like this. "
}], "Text",
 CellChangeTimes->{{3.966938925838505*^9, 3.9669389342086105`*^9}, {
  3.966939197820503*^9, 3.966939235775152*^9}, {3.9669393826747627`*^9, 
  3.9669393997109375`*^9}, {3.9669394366079464`*^9, 3.9669394609522495`*^9}, {
  3.9672062437938833`*^9, 
  3.9672062476353827`*^9}},ExpressionUUID->"77d2201c-8410-6e45-ac33-\
a271b50f208a"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "8c3ac3f2-5c08-ab4b-9e83-3688d029fde6"],
 " axis is now through the centre of the coil:"
}], "Text",
 CellChangeTimes->{{3.966939500170372*^9, 3.9669395249651737`*^9}, {
  3.9670117570222664`*^9, 3.967011768915762*^9}, {3.967206253897917*^9, 
  3.967206257924387*^9}},ExpressionUUID->"1a43d40f-602e-b943-b36d-\
5cfcd499bbb8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rCoil", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tCoil", "=", "0.05"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Graphics3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FilledTorus", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"rCoil", "-", "tCoil"}], ",", "rCoil"}], "}"}]}], "]"}], ",", 
     RowBox[{"Arrow", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", 
          RowBox[{"-", "0.2"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0.2"}], "}"}]}], "}"}], "]"}]}], "}"}], 
   ",", 
   RowBox[{"Boxed", "->", "False"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9669395445668488`*^9, 3.966939578312332*^9}, {
  3.96693961697171*^9, 3.966939628986412*^9}, {3.967012355980345*^9, 
  3.9670124411395473`*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"42b26fe5-2520-1042-93a1-cf98185cd15b"],


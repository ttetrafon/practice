Cell[CellGroupData[{

Cell["Advanced Examples", "Section",ExpressionUUID->"941b50fb-18ac-e34f-ac9a-8dc68093623a"],

Cell[CellGroupData[{

Cell["Solving PDEs over 3D Regions", "Subsection",ExpressionUUID->"02e101f0-6616-b442-8937-28d44c44d0e2"],

Cell["\<\
We have been steadily building up symbolic PDE modelling capabilities across \
all the standard domains.\
\>", "Text",ExpressionUUID->"59a7f052-8a33-3243-993d-0231e2d6344f"],

Cell["\<\
For example, one might want to model the magnetic field around a permanent \
magnet or a current-carrying coil.\
\>", "Text",
 CellChangeTimes->{{3.9669359515561047`*^9, 3.966935978600609*^9}, 
   3.967206158071063*^9},ExpressionUUID->"73fc7858-c418-a645-9719-\
437f16d71c1a"],

Cell[TextData[{
 "First, set up the variables and parameters for a cylindrical \
current-carrying wire (magnetic potential is zero except the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "fee27ebe-ce02-c944-9da1-a49b1ec0904d"],
 " component ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        SubscriptBox[
         StyleBox["A", "TI"], 
         StyleBox["z", "TI"]], "\[RightVector]"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\vec{A_z}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d07170b-f8f9-47e1-be8e-6d84dbe6b840"],
 "):"
}], "Text",ExpressionUUID->"ba46ac30-2cd8-e545-a19d-19343e46991f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rAir", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rWire", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"airRegion", "=", 
   RowBox[{"DiscretizeRegion", "[", 
    RowBox[{"Disk", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], ",", "rAir"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"wireRegion", "=", 
   RowBox[{"Disk", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", "rWire"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Je0", "=", "100000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pars", "=", "\[IndentingNewLine]", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<ElectricalConductivity\>\"", "->", 
      RowBox[{"Piecewise", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"5.9*^7", ",", 
           RowBox[{
            RowBox[{"RegionMember", "[", "wireRegion", "]"}], "[", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y"}], "}"}], "]"}]}], "}"}], "}"}], ",", 
        "0"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<RelativePermeability\>\"", "->", "1"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"\"\<ExternalCurrentSource\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", 
        RowBox[{"Piecewise", "[", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"Je0", ",", 
            RowBox[{
             RowBox[{"RegionMember", "[", "wireRegion", "]"}], "[", 
             RowBox[{"{", 
              RowBox[{"x", ",", "y"}], "}"}], "]"}]}], "}"}], "}"}], "]"}]}], 
       "}"}]}]}], "\[IndentingNewLine]", "|>"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vars", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{"Az", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9669360788196754`*^9, 3.966936091428829*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"ef559a65-06d9-dc4e-bbf7-ff2a4f0764de"],

Cell["Now we can set up the PDE:", "Text",
 CellChangeTimes->{{3.9669382252196636`*^9, 3.9669382356848145`*^9}, {
  3.966938353361805*^9, 
  3.966938358716688*^9}},ExpressionUUID->"0e33fcc2-77ec-e748-9cad-\
ee54c4ac4043"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"op", "=", 
   RowBox[{"MagneticPDEComponent", "[", 
    RowBox[{"vars", ",", "pars"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]zero", "=", 
   RowBox[{"MagneticPotentialCondition", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], ">=", 
      RowBox[{"rAir", "^", "2"}]}], ",", "vars", ",", "pars"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"pde", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"op", "==", "0"}], ",", "\[CapitalGamma]zero"}], 
   "}"}]}]}], "Input",
 CellChangeTimes->{{3.9669360788196754`*^9, 3.966936091428829*^9}, {
  3.96693836486458*^9, 3.966938366033787*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"cdfc7d94-a8b0-864b-82c3-ce4f908a10e5"],


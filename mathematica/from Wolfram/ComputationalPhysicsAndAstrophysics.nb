Cell["Set up and solve this new PDE:", "Text",
 CellChangeTimes->{{3.966941593693144*^9, 3.966941601343113*^9}, 
   3.967206295500293*^9},ExpressionUUID->"55404a00-691d-014e-9a51-\
feede439bd83"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["\[CapitalGamma]", "p"], "=", 
   RowBox[{"MagneticPotentialCondition", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"]}], ">=", 
      SuperscriptBox["2", "2"]}], ",", "vars", ",", "pars"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"op", "=", 
   RowBox[{"MagnetostaticPDEComponent", "[", 
    RowBox[{"vars", ",", "pars"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9669416065644855`*^9, 3.966941611787489*^9}},
 CellLabel->"In[84]:=",ExpressionUUID->"b8da5500-4991-4c43-9bd4-accb785dc434"],

Cell[BoxData[
 RowBox[{"VmFun", "=", 
  RowBox[{"NDSolveValue", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"op", "==", "0"}], ",", 
      SubscriptBox["\[CapitalGamma]", "p"]}], "}"}], ",", "Vm", ",", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], "\[Element]", "mesh"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[86]:=",ExpressionUUID->"a9c4f8ab-cc15-9143-ab1f-6318d371b2a1"],


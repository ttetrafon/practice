     RowBox[{"\"\<Distance\>\"", ",", "\"\<ApparentDistanceModulus\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "Tiny"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotStyle", "->", "Black"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"e2c97da8-1801-3a4f-b499-fb02aed14a62"],

Cell[BoxData[
 RowBox[{"ListLogLinearPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"clusters", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Distance\>\"", ",", "\"\<ApparentDistanceModulus\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 

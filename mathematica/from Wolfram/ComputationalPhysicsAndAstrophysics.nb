Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"cba3ff81-f590-f14f-893c-151c1dd8b0a6"],

Cell[CellGroupData[{

Cell["Advanced Examples", "Section",ExpressionUUID->"5507d8a1-a53c-b14b-9258-9959014fb224"],

Cell[CellGroupData[{

Cell["Quantum Framework", "Subsection",ExpressionUUID->"7970f929-9a13-ce4c-a314-9cbf37ded983"],

Cell["\<\
High-level symbolic representation of quantum bases, states and operators\
\>", "Item",ExpressionUUID->"381b14ce-be9f-5448-8ad8-fcbe301a0791"],

Cell[" Model and simulate quantum circuits and algorithms", "Item",ExpressionUUID->"e4afd21d-92aa-4142-8986-dd558b88b39b"],

Cell["\<\
Interoperate with many external quantum platforms and send queries to quantum \
processing units from a Wolfram Notebook\
\>", "Item",ExpressionUUID->"f109d582-08d9-0f48-b91e-dddd0e2ad3e0"],

Cell["Install and load the QuantumFramework paclet:", "Text",ExpressionUUID->"eae2d16f-38cc-3e48-9cac-d7b0c9bf24cf"],

Cell[BoxData[{
 RowBox[{"PacletInstall", "[", "\"\<Wolfram/QuantumFramework\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Needs", "[", "\"\<Wolfram`QuantumFramework`\>\"", "]"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"cf8efb16-4e49-e043-bd00-f612c0f331c2"],

Cell[CellGroupData[{

Cell["Basis Transformation of Quantum States", "Subsubsection",ExpressionUUID->"1ba4e162-2410-7242-8c99-28f6a0f0389c"],

Cell["Define a 2D quantum state in the computational basis:", "Text",ExpressionUUID->"2d5c0557-21bc-d043-b1fd-3142b3335fd6"],

Cell[BoxData[
 RowBox[{"\[Psi]1", "=", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "\[ImaginaryI]"}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"f1c880f1-36ba-ea40-bc5b-23e61bbf1ac0"],

Cell[BoxData[
 RowBox[{"\[Psi]1", "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->"In[93]:=",ExpressionUUID->"5ca42304-0bdb-6045-8a22-831b36bd9543"],

Cell["Transform it into the Pauli-X basis and show the formula:", "Text",ExpressionUUID->"d19e193a-e9f0-4545-a752-3370b3d3b935"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Psi]2", "=", 
   RowBox[{"QuantumState", "[", 
    RowBox[{"\[Psi]1", ",", "\"\<X\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\[Psi]2", "[", "\"\<Formula\>\"", "]"}]}], "Input",
 CellLabel->"In[91]:=",ExpressionUUID->"be22201e-14c0-784b-b8bf-df8f1ec7d402"],

Cell["\<\
Test that the states are still the same, i.e. only the coordinates \
representing it in a basis have changed:\
\>", "Text",ExpressionUUID->"18c3cdff-b146-ed46-9b39-8cd9252a64ac"],

Cell[BoxData[
 RowBox[{"\[Psi]1", "\[Equal]", "\[Psi]2"}]], "Input",
 CellLabel->"In[94]:=",ExpressionUUID->"67a3076f-a35b-b343-adb9-c292ba0d56bd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumMeasurementOperator", "[", "\"\<Z\>\"", "]"}], "[", 
  "\[Psi]2", "]"}]], "Input",
 CellLabel->
  "In[101]:=",ExpressionUUID->"ef40a865-545f-ad4c-bac9-6cac8879d23a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"QuantumMeasurementOperator", "[", "\"\<Z\>\"", "]"}], "[", 
  "\[Psi]1", "]"}]], "Input",
 CellLabel->
  "In[102]:=",ExpressionUUID->"b1f6d9b4-d5bf-cc48-80af-951bdcc3b65e"],

Cell["\<\
Let\[CloseCurlyQuote]s look at another example, with a more complicated \
quantum basis.\
\>", "Text",ExpressionUUID->"f99af6a6-df80-6047-9ab1-02ddce2eb351"],

Cell["Define a random state in the Schwinger basis:", "Text",ExpressionUUID->"54dfd4e3-9e93-8b4a-9b79-58ae162fba6b"],

Cell[BoxData[
 RowBox[{"\[Psi]3", "=", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"\"\<RandomPure\>\"", ",", 
    RowBox[{"QuantumBasis", "[", "\"\<Schwinger\>\"", "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[96]:=",ExpressionUUID->"d391ca58-368a-ed49-bbbb-19eb9e6b0c1e"],

Cell[BoxData[
 RowBox[{"\[Psi]3", "[", "\"\<Formula\>\"", "]"}]], "Input",
 CellLabel->"In[97]:=",ExpressionUUID->"09cc1a34-2bba-6e47-9124-5a2f53bac1a2"],

Cell["Transform the state into a new basis:", "Text",ExpressionUUID->"fc0c9b0c-516f-1e4d-96f8-0bd0f977ccab"],

Cell[BoxData[{
 RowBox[{"\[Psi]4", "=", 
  RowBox[{"QuantumState", "[", 
   RowBox[{"\[Psi]3", ",", 
    RowBox[{"{", 
     RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"\[Psi]4", "[", "\"\<Formula\>\"", "]"}]}], "Input",
 CellLabel->"In[98]:=",ExpressionUUID->"1f1282a9-1e9f-bc4f-b243-fd6e0f830ed3"],

Cell["Test that the states are still the same:", "Text",ExpressionUUID->"e5ec6589-abfa-e040-8099-4a3cf48f700e"],

Cell[BoxData[
 RowBox[{"\[Psi]3", "\[Equal]", "\[Psi]4"}]], "Input",
 CellLabel->
  "In[100]:=",ExpressionUUID->"b494083f-2c30-3944-a8ce-a3f4c40ca72a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Numeric Evolution of a Quantum State", "Subsubsection",ExpressionUUID->"6a3cb1bb-2024-454a-adcb-a4f725bd8579"],

Cell["\<\
In the Wolfram Quantum Framework, quantum objects and operations can be \
defined symbolically and also numerically. In this regard, time evolution of \
quantum systems can be treated both symbolically and numerically.\
\>", "Text",ExpressionUUID->"72bf9a5d-294e-7441-8194-2f9b080cae10"],

Cell[TextData[{
 "Given a time-independent Hamiltonian as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"0.2", 
         SubscriptBox["\[Sigma]", 
          StyleBox["x", "TI"]], "+", "0.8", 
         SubscriptBox["\[Sigma]", 
          StyleBox["y", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "0.2\\sigma_x + 0.8\\sigma_y", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1a1138a0-ceb7-4828-ba20-2c5916e4713a"],
 ",  find the quantum state at a later time, with |",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "0"], TraditionalForm]],ExpressionUUID->
  "4befd86c-4349-1c4e-bce2-3bf9752fcf73"],
 "\[RightAngleBracket] = |0\[RightAngleBracket]:"
}], "Text",ExpressionUUID->"825719fd-22f0-8b43-9671-6f4d43162caa"],

Cell[BoxData[
 RowBox[{"\[Psi]f", "=", 
  RowBox[{"QuantumEvolve", "[", 
   RowBox[{
    RowBox[{"QuantumOperator", "[", 
     RowBox[{
      RowBox[{"0.2", "\"\<X\>\""}], "+", 
      RowBox[{"0.8", "\"\<Y\>\""}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"27c330a9-d245-1047-b218-cd304ab309ea"],

Cell["Visualise the trajectory in a Bloch sphere:", "Text",ExpressionUUID->"57c75979-b273-8d4c-951f-9ae0fb216583"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Psi]f", "[", "t", "]"}], "[", "\"\<BlochPlot\>\"", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "3", ",", "0.1"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"e4cbb6aa-91ba-2648-91ee-4e05ad59a4f2"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Psi]f", "[", "t", "]"}], 
       "[", "\"\<BlochCartesianCoordinates\>\"", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "3", ",", "0.1"}], "}"}]}], "]"}], "]"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"Joined", "\[Rule]", "True"}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<Bloch Cartesian Coordinates\>\""}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Time (0.1s)\>\"", ",", "None"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", 
    FractionBox["1", "2"]}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->
  "In[110]:=",ExpressionUUID->"575625b6-8868-164e-91b6-fe61f1c62945"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


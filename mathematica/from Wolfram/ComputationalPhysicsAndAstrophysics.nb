Cell[TextData[{
 StyleBox["\[LongDash] Kip Thorne, astrophysicist, 2017 Nobel Prize winner \
and consultant for ",
  FontSize->18,
  FontColor->GrayLevel[0.5]],
 StyleBox["Interstellar",
  FontSize->18,
  FontSlant->"Italic",
  FontColor->GrayLevel[0.5]]
}], "Text",
 TextAlignment->Right,ExpressionUUID->"b472a226-392e-1741-b635-9ea4e2a81602"]
}, Open  ]],

Cell["", "EndOfSlide",ExpressionUUID->"46c72855-53ed-4a7e-be75-c1ad1c5e1a8b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"a99cff0a-9334-47d9-a007-66c583b6224e"],

Cell[CellGroupData[{

Cell["Introductory Examples", "Section",ExpressionUUID->"447f66d5-e140-4c4d-9320-8265d576f11c"],

Cell[CellGroupData[{

Cell["Modelling a Projectile", "Subsection",ExpressionUUID->"02f573c0-881f-a141-a47d-d24acc323938"],

Cell["\<\
We can model the projectile as a point mass subject only to uniform gravity.\
\>", "Text",ExpressionUUID->"66e79540-074c-eb43-a7c0-c1668d2a66b9"],

Cell["Newton\[CloseCurlyQuote]s second law gives:", "Text",ExpressionUUID->"6e7b7c9a-e4ab-4a6f-baf2-8702071f609a"],

Cell[TextData[Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       StyleBox["m", "TI"], 
       SuperscriptBox[
        OverscriptBox[
         StyleBox["r", "TI"], "\[RightVector]"], "\[Prime]\[Prime]"], 
       "\[LongEqual]", 
       StyleBox["m", "TI"], 
       OverscriptBox[
        StyleBox["g", "TI"], "\[RightVector]"]}], TraditionalForm], 
   "errors" -> {}, "input" -> "m \\vec{r}'' = m \\vec{g}}", "state" -> 
   "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 FontSize->16,ExpressionUUID->"684e5981-d840-ec4e-9a66-96b1a39c96f1"]], "Text",\
ExpressionUUID->"fc7eb069-3c8a-d649-a394-42d83e932988"],

Cell["Define our parameters:", "Text",ExpressionUUID->"9a5e874c-5a30-b44c-94ad-e58e0708c472"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Theta]", "=", 
   RowBox[{"\[Pi]", "/", "6"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v0", "=", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"QuantityMagnitude", "[", 
    RowBox[{"UnitConvert", "[", 
     RowBox[{
      RowBox[{
       TemplateBox[{"\"Earth\"", 
         RowBox[{"Entity", "[", 
           RowBox[{"\"Planet\"", ",", "\"Earth\""}], "]"}], 
         "\"Entity[\\\"Planet\\\", \\\"Earth\\\"]\"", "\"planet\""},
        "Entity"], "[", 
       TemplateBox[{"\"gravity\"", 
         RowBox[{"EntityProperty", "[", 
           RowBox[{"\"Planet\"", ",", "\"Gravity\""}], "]"}], 
         "\"EntityProperty[\\\"Planet\\\", \\\"Gravity\\\"]\""},
        "EntityProperty"], "]"}], ",", "\"\<SI\>\""}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"e610e3e8-b22f-0946-91ef-d9355c4c91e0"],

Cell["Set up the equation (with initial conditions) to solve:", "Text",ExpressionUUID->"3233f520-1286-9b42-b506-55a3a12aa2e7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eqs", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"y", "''"}], "[", "t", "]"}], "\[Equal]", 
      RowBox[{"-", "g"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "''"}], "[", "t", "]"}], "\[Equal]", "0"}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"inits", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"x", "'"}], "[", "0", "]"}], "\[Equal]", 
      RowBox[{"v0", "*", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", 
      RowBox[{"v0", "*", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"x", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{"y", "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"cd2d5e08-b9a3-3749-82c3-f4db0f24c0af"],

Cell["Solve the system:", "Text",ExpressionUUID->"b41e3d42-8f19-b049-9ab0-6ccce19b62b1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"eqs", ",", "inits"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0.", ",", "10"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"58d68d75-23d6-ed46-9f67-a7d1efa460d2"],


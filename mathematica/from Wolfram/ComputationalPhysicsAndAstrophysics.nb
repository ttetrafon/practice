    FontWeight->"Bold"], 
   StyleBox[",",
    FontWeight->"Bold"], 
   StyleBox["\[IndentingNewLine]",
    FontWeight->"Bold"], 
   RowBox[{"PlotStyle", "->", "Black"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"b13fa223-241d-7142-bebb-f9e229c0144f"],

Cell[CellGroupData[{

Cell["Plot the 3D Distribution by Age", "Subsubsection",ExpressionUUID->"be04f824-1375-0c43-8e20-04d374d52e42"],

Cell["Remove rows where the distance or age is missing:", "Text",ExpressionUUID->"98141868-43e8-884f-842d-22bd212e9a01"],

Cell[BoxData[
 RowBox[{"nonMissingData", "=", "\[IndentingNewLine]", 
  RowBox[{"ConstructColumns", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Select", "[", 
     RowBox[{"clusters", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"!", " ", 
         RowBox[{"MissingQ", "[", "#Distance", "]"}]}], " ", "&&", " ", 
        RowBox[{"!", " ", 
         RowBox[{"MissingQ", "[", "#LogAge", "]"}]}]}], " ", "&"}]}], "]"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"\"\<Distance\>\"", ",", "\"\<RightAscension\>\"", 
      ",", "\"\<Declination\>\"", ",", "\"\<LogAge\>\""}], "}"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"49eb3b9b-91fc-5541-ae7b-8c14c547c92d"],

Cell["\<\
Find the position of each star cluster in the galactic frame:\
\>", "Text",ExpressionUUID->"8b76d52e-203f-9c4b-bee2-08cfb4f8fc56"],

Cell[BoxData[
 RowBox[{
  RowBox[{"positions", "=", "\[IndentingNewLine]", 
   RowBox[{"Map", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"AstroPosition", "[", 
       RowBox[{"#", ",", "\"\<Galactic\>\""}], "]"}], "&"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Values", "[", "\[IndentingNewLine]", 
      RowBox[{"Normal", "[", 
       RowBox[{"nonMissingData", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           
           RowBox[{"\"\<RightAscension\>\"", ",", "\"\<Declination\>\"", 
            ",", "\"\<Distance\>\""}], "}"}]}], "]"}], "]"}], "]"}], 
      "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"f22d80af-2d01-b748-8a5b-b0335698468c"],

Cell["Convert each position to Cartesian coordinates:", "Text",
 CellChangeTimes->{{3.955465881161455*^9, 
  3.955465895070675*^9}},ExpressionUUID->"bc1777d1-6c50-a047-99fb-\
d2950add10c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"positionsCartesian", "=", "\[IndentingNewLine]", 
   RowBox[{"Map", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"AstroPosition", "[", 
       RowBox[{"#", ",", "\"\<Galactic\>\"", ",", "\"\<Cartesian\>\""}], 
       "]"}], "&"}], ",", "\[IndentingNewLine]", "positions"}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"a1a07e50-78e9-144b-9f45-1c42f44e8c2e"],

Cell["\<\
While the unit is sometimes displayed in light years or kilo-light years, \
distances are stored using astronomical units:\
\>", "Text",ExpressionUUID->"9047b21a-d2eb-d444-90bb-bc6a165c051b"],

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"star", "=", 
     RowBox[{"RandomChoice", "[", "positionsCartesian", "]"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Echo", "[", 
     RowBox[{"{", 
      RowBox[{"star", ",", 
       RowBox[{"star", "[", "\"\<Data\>\"", "]"}]}], "}"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Map", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"UnitConvert", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Quantity", "[", 
          RowBox[{"#", ",", "\"\<AstronomicalUnit\>\""}], "]"}], ",", 
         "\[IndentingNewLine]", "\"\<KilolightYears\>\""}], 
        "\[IndentingNewLine]", "]"}], "&"}], ",", "\[IndentingNewLine]", 
      RowBox[{"star", "[", "\"\<Data\>\"", "]"}]}], "\[IndentingNewLine]", 

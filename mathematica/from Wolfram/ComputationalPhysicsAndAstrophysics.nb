Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"4a82ca9b-6202-cc40-8180-49a49b5316ac"],

Cell[CellGroupData[{

Cell["Intermediate Examples", "Section",ExpressionUUID->"9f138fb2-d1eb-ba45-8ebd-813a37b176f9"],

Cell[CellGroupData[{

Cell["N-Body Simulations", "Subsection",ExpressionUUID->"9b296ced-e17d-7c43-aa49-721d25bb4cbf"],

Cell["\<\
Simulate a number of objects that are being attracted by gravity:\
\>", "Text",ExpressionUUID->"2589ec44-6ad4-4848-ada4-12109986dc26"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tMax", "=", "5"}], ";", " ", 
  RowBox[{"nBodies", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"simData", "=", "\[IndentingNewLine]", 
  RowBox[{"NBodySimulation", "[", "\[IndentingNewLine]", 
   RowBox[{"\"\<InverseSquare\>\"", ",", "\[IndentingNewLine]", 
    RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Mass\>\"", "->", "1"}], ",", 
         RowBox[{"\"\<Position\>\"", "->", "#1"}], ",", 
         RowBox[{"\"\<Velocity\>\"", "->", "#2"}]}], "|>"}], "&"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"nBodies", ",", "3"}], "}"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"0.1", "*", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"nBodies", ",", "3"}], "}"}]}], "]"}]}], 
       "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
    "\[IndentingNewLine]", "tMax"}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellLabel->"In[55]:=",ExpressionUUID->"43245473-bf90-6748-a4e4-595426f7a2bf"],


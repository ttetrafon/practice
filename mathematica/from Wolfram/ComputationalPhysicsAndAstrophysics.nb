 "!"
}], "Text",ExpressionUUID->"65d5c224-c76e-164f-9d1a-6dbf6252ffc1"],

Cell[BoxData[
 RowBox[{"Grid", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<Wein Distribution Law\>\"", ",", 
       RowBox[{"wienDistributionLaw", "[", 
        RowBox[{
         RowBox[{"QuantityVariable", "[", 
          RowBox[{"\"\<T\>\"", ",", "\"\<Temperature\>\""}], "]"}], ",", 
         RowBox[{"QuantityVariable", "[", 
          RowBox[{"\"\<\[Nu]\>\"", ",", "\"\<Frequency\>\""}], "]"}]}], 
        "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Rayleigh\[Dash]Jeans' Law\>\"", ",", 
       RowBox[{"rayleighJeansLaw", "[", 
        RowBox[{
         RowBox[{"QuantityVariable", "[", 
          RowBox[{"\"\<T\>\"", ",", "\"\<Temperature\>\""}], "]"}], ",", 
         RowBox[{"QuantityVariable", "[", 
          RowBox[{"\"\<\[Nu]\>\"", ",", "\"\<Frequency\>\""}], "]"}]}], 
        "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"\"\<Planck's Radiation Law\>\"", ",", 
       RowBox[{"Last", "[", 
        RowBox[{"FormulaData", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<PlanckRadiationLaw\>\"", ",", "\"\<Frequency\>\""}], 
          "}"}], "]"}], "]"}]}], "}"}]}], "\[IndentingNewLine]", "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "\[Rule]", "All"}], ",", 
   RowBox[{"Alignment", "\[Rule]", "Left"}], ",", 
   RowBox[{"FrameStyle", "\[Rule]", "LightGray"}], ",", 
   RowBox[{"ItemStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "\"\<Text\>\"", "}"}], ",", "Automatic"}], "}"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->
  "In[118]:=",ExpressionUUID->"c8ae02ca-9982-644f-b63c-76bdba1dceda"],

Cell[TextData[{
 "Compute the values of the three formulas at 7000 K over the span of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "13"], TraditionalForm]],ExpressionUUID->
  "e2e5a41e-35d6-a343-8ca9-fe06666f5188"],
 " to ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "15"], TraditionalForm]],ExpressionUUID->
  "4d130d59-3032-0c42-8a54-6e0f3e3e0be3"],
 " Hz:"
}], "Text",ExpressionUUID->"3742e6ce-3624-604c-9a58-3005b892065f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"wienData", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       SuperscriptBox["10", "x"], ",", "\[IndentingNewLine]", 
       RowBox[{"QuantityMagnitude", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"wienDistributionLaw", "[", 
          RowBox[{
           RowBox[{"Quantity", "[", 
            RowBox[{"7000", ",", "\"\<Kelvins\>\""}], "]"}], ",", 
           RowBox[{"Quantity", "[", 
            RowBox[{
             SuperscriptBox["10", "x"], ",", "\"\<Hertz\>\""}], "]"}]}], 
          "]"}], ",", "\[IndentingNewLine]", 
         FractionBox["\"\<Watts\>\"", 
          RowBox[{"(", 
           RowBox[{"\"\<Hertz\>\"", "*", 
            SuperscriptBox["\"\<Meters\>\"", "2"], 
            "*", "\"\<Steradians\>\""}], ")"}]]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "13", ",", "15", ",", "0.1"}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rayleighJeansData", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       SuperscriptBox["10", "x"], ",", "\[IndentingNewLine]", 
       RowBox[{"QuantityMagnitude", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rayleighJeansLaw", "[", 
          RowBox[{
           RowBox[{"Quantity", "[", 
            RowBox[{"7000", ",", "\"\<Kelvins\>\""}], "]"}], ",", 
           RowBox[{"Quantity", "[", 
            RowBox[{
             SuperscriptBox["10", "x"], ",", "\"\<Hertz\>\""}], "]"}]}], 
          "]"}], ",", "\[IndentingNewLine]", 
         FractionBox["\"\<Watts\>\"", 
          RowBox[{"(", 
           RowBox[{"\"\<Hertz\>\"", "*", 
            SuperscriptBox["\"\<Meters\>\"", "2"], 
            "*", "\"\<Steradians\>\""}], ")"}]]}], "\[IndentingNewLine]", 
        "]"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "13", ",", "15", ",", "0.1"}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"planckData", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       SuperscriptBox["10", "x"], ",", "\[IndentingNewLine]", 
       RowBox[{"QuantityMagnitude", "[", 
        RowBox[{"PlanckRadiationLaw", "[", 
         RowBox[{
          RowBox[{"Quantity", "[", 
           RowBox[{"7000", ",", "\"\<Kelvins\>\""}], "]"}], ",", 
          RowBox[{"Quantity", "[", 
           RowBox[{
            RowBox[{"10", "^", "x"}], ",", "\"\<Hertz\>\""}], "]"}]}], "]"}], 
        "]"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "13", ",", "15", ",", "0.1"}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellLabel->"In[48]:=",ExpressionUUID->"846a4541-e7fa-6743-9002-30607368a2bd"],

Cell[BoxData[
 RowBox[{"ListLogLogPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"wienData", ",", "rayleighJeansData", ",", "planckData"}], "}"}], 
   ",", "\[IndentingNewLine]", 
   InterpretationBox[

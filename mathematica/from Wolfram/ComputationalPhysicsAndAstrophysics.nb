      "InactiveDiv"]}], "\[Equal]", "0"}], ",", 
   RowBox[{"DirichletCondition", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Az", "[", 
       RowBox[{"x", ",", "y"}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"]}], "\[GreaterEqual]", 
      "0.04000000000000001`"}]}], "]"}]}], "}"}]], "Output",

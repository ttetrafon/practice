 CellLabel->"In[37]:=",ExpressionUUID->"103279bc-e0ba-7d49-9389-26a4a4b4a489"],

Cell["Define the Wien distribution law and Rayleigh\[Dash]Jeans\
\[CloseCurlyQuote]s law:", "Text",ExpressionUUID->"2e621a56-bc84-044d-9e5b-\
19335ecf6411"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"wienDistributionLaw", "[", 
    RowBox[{"T_", ",", "\[Nu]_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Quantity", "[", 
     RowBox[{"2", ",", 
      FractionBox["\"\<PlanckConstant\>\"", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["\"\<SpeedOfLight\>\"", "2"], 
         "*", "\"\<Steradians\>\""}], ")"}]]}], "]"}], "*", 
    SuperscriptBox["\[Nu]", "3"], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{
        RowBox[{"Quantity", "[", 
         RowBox[{"1", ",", 
          
          FractionBox["\"\<PlanckConstant\>\"", \
"\"\<BoltzmannConstant\>\""]}], "]"}], "*", "\[Nu]"}], "T"]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rayleighJeansLaw", "[", 
    RowBox[{"T_", ",", "\[Nu]_"}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Quantity", "[", 
     RowBox[{"2", ",", 
      FractionBox["\"\<BoltzmannConstant\>\"", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["\"\<SpeedOfLight\>\"", "2"], 
         "*", "\"\<Steradians\>\""}], ")"}]]}], "]"}], "*", 
    SuperscriptBox["\[Nu]", "2"], "*", "T"}]}], ";"}]}], "Input",
 CellLabel->"In[45]:=",ExpressionUUID->"72e70511-9e35-2d48-bdc9-9526adedad29"],


      ",", "\"\<Color\>\""}], "}"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[36]:=",ExpressionUUID->"8d4733c1-54e3-c84f-a8fa-58e1c19c1c4a"],

Cell["\<\
Compare the visible spectrum with the distribution of spectral radiance for \
5000 degrees Celsius:\
\>", "Text",ExpressionUUID->"2c94d7a9-4a33-1246-ba53-959d36cd3cd8"],

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ParametricPlot", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"2", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "6"}]}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", 
       RowBox[{"10", "^", "14"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotPoints", "\[Rule]", "100"}], ",", "\[IndentingNewLine]", 
     RowBox[{"ColorFunction", "\[Rule]", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", "u"}], "}"}], ",", 
        RowBox[{
         RowBox[{"ColorData", "[", "\"\<VisibleSpectrum\>\"", "]"}], "[", 
         RowBox[{"x", " ", 
          SuperscriptBox["10", "9"]}], "]"}]}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"ColorFunctionScaling", "\[Rule]", "False"}]}], 
    "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", "srPlot", ",", 
   "\[IndentingNewLine]", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", "SequenceIcon", 
       GridBox[{{
          ItemBox[
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Sequence", "IconizedItem"]}]]}, {
          ItemBox[
           RowBox[{
             TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["4", "IconizedItem"]}]]}, {
          ItemBox[
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["968", "IconizedItem"]}]]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    Sequence[
    PlotRange -> {{0, 2 10^(-6)}, {0, 2 10^13}}, AspectRatio -> 1/GoldenRatio,
      PlotRangePadding -> 0, 
     Options[$CellContext`plot]],
    SelectWithContents->True,

  3.9587298848313885`*^9}},ExpressionUUID->"1a215544-0564-4a46-8d46-\
b8c3b72586b8"],

Cell["\<\
In 1993, a zero angular momentum solution to the three-body problem was \
found, with three equal masses moving around a figure-eight shape:\
\>", "Text",ExpressionUUID->"a49bef64-b599-f740-a87a-1abd0deda32e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", "=", "10."}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"figure8", "=", "\[IndentingNewLine]", 
   RowBox[{"NBodySimulation", "[", "\[IndentingNewLine]", 
    RowBox[{"\"\<InverseSquare\>\"", ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[LeftAssociation]", 
        RowBox[{
         RowBox[{"\"\<Mass\>\"", "\[Rule]", "1"}], ",", 
         RowBox[{"\"\<Position\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"0.97000436", ",", 
            RowBox[{"-", "0.24308753"}], ",", "0."}], "}"}]}], ",", 
         RowBox[{"\"\<Velocity\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"0.4662036850", ",", "0.4323657300", ",", 
            RowBox[{"-", "0."}]}], "}"}]}]}], "\[RightAssociation]"}], ",", 
       RowBox[{"\[LeftAssociation]", 
        RowBox[{
         RowBox[{"\"\<Mass\>\"", "\[Rule]", "1"}], ",", 
         RowBox[{"\"\<Position\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.97000436"}], ",", "0.24308753", ",", "0."}], 
           "}"}]}], ",", 
         RowBox[{"\"\<Velocity\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"0.4662036850", ",", "0.4323657300", ",", "0."}], 
           "}"}]}]}], "\[RightAssociation]"}], ",", 
       RowBox[{"\[LeftAssociation]", 
        RowBox[{
         RowBox[{"\"\<Mass\>\"", "\[Rule]", "1"}], ",", 
         RowBox[{"\"\<Position\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"0.", ",", "0.", ",", "0."}], "}"}]}], ",", 
         RowBox[{"\"\<Velocity\>\"", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "0.93240737"}], ",", 
            RowBox[{"-", "0.86473146"}], ",", "0"}], "}"}]}]}], 
        "\[RightAssociation]"}]}], "}"}], ",", "\[IndentingNewLine]", "T"}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Show", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{"figure8", "[", 
         RowBox[{"All", ",", "\"\<Position\>\"", ",", "t"}], "]"}], "]"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tCurrent"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PerformanceGoal", "->", " ", "\"\<Quality\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"PlotRange", "\[Rule]", "Automatic"}]}], "\[IndentingNewLine]",
       "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Graphics3D", "[", "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"PointSize", "[", "0.02", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Point", "[", 
         RowBox[{"figure8", "[", 
          RowBox[{"All", ",", "\"\<Position\>\"", ",", "tCurrent"}], "]"}], 
         "]"}]}], "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", 
      "]"}]}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"tCurrent", ",", " ", "0.01", ",", " ", "\"\<Time\>\""}], "}"}],
      ",", "0.01", ",", " ", "T", ",", "0.1", ",", " ", 
     RowBox[{"Exclusions", " ", "->", " ", "0"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ControlType", " ", "->", " ", "LabeledSlider"}], ",", 
   RowBox[{"SaveDefinitions", "->", "True"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
 CellChangeTimes->{{3.958729898646435*^9, 3.9587300410824757`*^9}, {
  3.958732789300167*^9, 3.958732848983555*^9}, {3.9587328792381554`*^9, 

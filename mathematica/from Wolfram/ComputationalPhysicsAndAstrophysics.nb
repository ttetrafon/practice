Cell[TextData[{
 "Find the curl of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        StyleBox["A", "TI"], "\[RightVector]"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\vec{A}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4718ac9c-ac8c-5d4c-9a8d-9bbd47cacfb0"],
 " to give ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        StyleBox["B", "TI"], "\[RightVector]"], TraditionalForm], 
     "errors" -> {}, "input" -> "\\vec{B}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "623bd5dc-1a20-b04e-83b2-9988d0e97131"],
 ". Take the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bb78c717-0e97-ef4f-93ae-1f13743cae02"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["y", "TI"], TraditionalForm], "errors" -> {}, "input" -> "y", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7c08c841-7d84-2b44-a122-3832af9cb6dd"],
 " components:"
}], "Text",ExpressionUUID->"8e7c6fc4-2544-5b49-8ea5-09b8ff9d5f90"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bField", "=", 
  RowBox[{
   RowBox[{"Curl", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{"AzFun", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", " ", ";;", " ", "2"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.966938770481186*^9, 3.966938792448704*^9}, 
   3.966938853418314*^9},
 CellLabel->"In[73]:=",ExpressionUUID->"293cdce8-51e4-0444-8629-f0a132f6f41c"],


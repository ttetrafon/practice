Cell[TextData[{
 "This superposition of fields results in a net magnetization in the +",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "31806e7c-1ac1-c149-a80e-e2473d5d3a4b"],
 " direction within the bounds of the coil, which enables us to solve a \
magnetostatic PDE with this feature."
}], "Text",
 CellChangeTimes->{{3.9669413066088734`*^9, 3.966941389907419*^9}, {
  3.9670117904369316`*^9, 3.967011833678608*^9}, {3.9672062826427317`*^9, 
  3.967206286368215*^9}},ExpressionUUID->"df35a56e-adb4-9547-b9a4-\
de186f559869"],

Cell["Again, set up the variables and parameters:", "Text",
 CellChangeTimes->{{3.9669413925224953`*^9, 3.966941401203308*^9}, {
   3.966941460180212*^9, 3.9669415037150326`*^9}, 
   3.967011837699913*^9},ExpressionUUID->"bdc0bb02-3749-534a-a466-\
a8f2072207ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vars", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Vm", "[", 
      RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rCoil", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tCoil", "=", "0.05"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"coil", "=", 
   RowBox[{"FilledTorus", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rCoil", "-", "tCoil"}], ",", "rCoil"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"xBounds", ",", "yBounds", ",", "zBounds"}], "}"}], "=", 
   RowBox[{"RegionBounds", "[", "coil", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"pars", "=", 
  RowBox[{"<|", 
   RowBox[{"\"\<Magnetization\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", 
      RowBox[{"Piecewise", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"1*^5", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"zBounds", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "<=", "z", "<=", 
             RowBox[{"zBounds", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "&&", 
            RowBox[{
             RowBox[{
              SuperscriptBox["x", "2"], "+", 
              SuperscriptBox["y", "2"]}], "<=", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"rCoil", "-", "tCoil"}], ")"}], "2"]}]}]}], "}"}], 
         "}"}], ",", "0"}], "]"}]}], "}"}]}], "|>"}]}]}], "Input",
 CellChangeTimes->{{3.966941413561224*^9, 3.966941440128401*^9}},
 CellLabel->"In[76]:=",ExpressionUUID->"c8a13e58-c49d-1e42-bba5-4ad95bfb8d93"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"Magnetization\"\>", "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", 
     TagBox[GridBox[{
        {"\[Piecewise]", GridBox[{
           {"100000", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "0.024999999999999994`"}], "\[LessEqual]", "z", "\[LessEqual]",
               "0.024999999999999994`"}], "&&", 
             RowBox[{
              RowBox[{
               SuperscriptBox["x", "2"], "+", 
               SuperscriptBox["y", "2"]}], "\[LessEqual]", "0.2025`"}]}]},
           {"0", 
            TagBox["True",
             "PiecewiseDefault",
             AutoDelete->True]}
          },
          AllowedDimensions->{2, Automatic},
          Editable->True,
          GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
          GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
          GridBoxSpacings->{"Columns" -> {
              Offset[0.27999999999999997`], {

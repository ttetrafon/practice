Cell["Visualise the trajectory:", "Text",ExpressionUUID->"394475af-f702-7f4a-bc40-45ab30d4e57c"],

Cell[BoxData[
 RowBox[{"ParametricPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "sol"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "\[Rule]", "\"\<Projectile Trajectory\>\""}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "2"}], "}"}]}], "}"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"6f9b2973-732d-a64d-9d4a-26b42a201356"],

Cell[TextData[{
 "An event corresponds to a particular time ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "a"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "1ed77b02-2eeb-4e4d-a2cf-8a23e609f266"],
 " crossed during the integration of ",
 Cell[BoxData[
  StyleBox["eqns", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "98797137-f675-9648-9874-58692deccb7b"],
 " in ",
 ButtonBox["NDSolve",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/NDSolve.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/NDSolve.html"],
 ":"
}], "Text",ExpressionUUID->"45bd8c54-7942-d042-9641-cf1edc7841d5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"event", "=", 
   RowBox[{"WhenEvent", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"y", "[", "t", "]"}], "==", "0"}], ",", 
     RowBox[{"tof", "=", "t"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"eventSol", "=", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"eqs", ",", "inits", ",", "event"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]}], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"149b40f4-253f-bd41-b148-64ab551d4ade"],

Cell[BoxData[
 RowBox[{"ParametricPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", "eventSol"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "tof"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "->", 
    RowBox[{"\"\<Time of Flight = \>\"", "<>", 
     RowBox[{"ToString", "[", "tof", "]"}], "<>", "\"\<s\>\""}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"92004b0d-62b0-584b-8243-bc1bec8b7f8c"],

Cell["\<\
Define a function to find the \[OpenCurlyQuote]time-of-flight\
\[CloseCurlyQuote] for a projectile:\
\>", "Text",ExpressionUUID->"ac125f72-a4a9-d443-8c5f-155f475c5795"],

Cell[BoxData[
 RowBox[{
  RowBox[{"findTimeOfFlight", "[", 
   RowBox[{"\[Theta]_", "?", "NumericQ"}], "]"}], ":=", "\[IndentingNewLine]",
   "  ", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"eqs", ",", "inits", ",", "event", ",", "time", ",", "sol"}], 
     "}"}], ",", "\[IndentingNewLine]", "    ", 
    RowBox[{
     RowBox[{"eqs", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"y", "''"}], "[", "t", "]"}], "==", 
         RowBox[{"-", "g"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "''"}], "[", "t", "]"}], "==", "0"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", "    ", 
     RowBox[{"inits", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v0", "*", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v0", "*", 
          RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"x", "[", "0", "]"}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "0"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", "    ", 
     RowBox[{"event", "=", 
      RowBox[{"WhenEvent", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "[", "t", "]"}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"time", "=", "t"}], ";", " ", "\"\<StopIntegration\>\""}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", "    ", 
     RowBox[{"sol", "=", 
      RowBox[{
       RowBox[{"NDSolve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"eqs", ",", "inits", ",", "event"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "10"}], "}"}]}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", "    ", 
     "time"}]}], "\[IndentingNewLine]", "  ", "]"}]}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"3fab052a-9d34-584e-a588-fba2589dc95b"],

Cell["Generate some data for a range of launch angles:", "Text",ExpressionUUID->"b170adf1-d1df-4c4a-9d5c-44ec8c048d11"],

Cell[BoxData[
 RowBox[{
  RowBox[{"projectileData", "=", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"findTimeOfFlight", "[", "\[Theta]", "]"}], ",", 
       RowBox[{"v0", "*", 
        RowBox[{"findTimeOfFlight", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0.02", ",", 
       FractionBox["\[Pi]", "2"], ",", "0.02"}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"03d6c0d6-204d-7a4c-8a6a-43c15e0150fb"],

Cell["\<\
We want to find the launch angle that maximises the horizontal range:\
\>", "Text",ExpressionUUID->"70e120b7-5f00-e445-a2c0-6cc912e6c519"],

Cell[BoxData[
 RowBox[{"MaximalBy", "[", 
  RowBox[{"projectileData", ",", 
   RowBox[{
    RowBox[{"#", "[", 
     RowBox[{"[", "3", "]"}], "]"}], "&"}]}], "]"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"10d858fa-7d6d-e94f-828e-9c4420c6d33c"],

Cell[TextData[{
 "We can also use the built-in ",
 ButtonBox["FindMaximum",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/FindMaximum.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/FindMaximum.html"],
 ":"
}], "Text",ExpressionUUID->"e0e7bd11-88f0-c643-8794-5fde8ab6decb"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "\[Theta]", "]"}], "\[IndentingNewLine]", 
 RowBox[{"FindMaximum", "[", 
  RowBox[{
   RowBox[{"findTimeOfFlight", "[", "\[Theta]", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", "0.1"}], "}"}], ",", 
   RowBox[{"AccuracyGoal", "->", "6"}]}], "]"}]}], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"92bfcb3e-d732-3346-ba98-1edd4c83629a"]
}, Open  ]]
}, Open  ]],


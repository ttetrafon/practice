Cell["\<\

Visualise the spectral radiance for the radiation emitted by a body at 5000 \
degrees Celsius, as a function of wavelength:\
\>", "Text",ExpressionUUID->"e03d031e-f309-e442-8746-f2b068926c09"],

Cell[BoxData[
 RowBox[{"srPlot", "=", 
  RowBox[{"PlanckRadiationLaw", "[", 
   RowBox[{
    TemplateBox[{
     "5000", "\"\[Degree]C\"", "degrees Celsius", "\"DegreesCelsius\""},
     "Quantity"], ",", "\"\<SpectralPlot\>\""}], "]"}]}]], "Input",
 CellLabel->"In[35]:=",ExpressionUUID->"ae55f01a-3f78-be48-9116-ee4cac9e56d6"],

Cell["\<\

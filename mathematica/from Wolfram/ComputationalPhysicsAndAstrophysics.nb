Cell["\<\
Retrieve a curated dataset of star clusters in the Milky Way:\
\>", "Text",
 CellChangeTimes->{{3.9531298808186665`*^9, 
  3.9531299063972855`*^9}},ExpressionUUID->"a65e7504-9826-d148-92ad-\
90d37e38c1c4"],

Cell[BoxData[
 RowBox[{"clusters", "=", 
  RowBox[{"ToTabular", "[", 
   RowBox[{"ResourceData", "[", 
    TagBox["\"\<Star Clusters\>\"",
     #& ,
     BoxID -> "ResourceTag-Star Clusters-Input",
     AutoDelete->True], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.953129845600178*^9, 3.953129845604624*^9}, {
  3.953129926198633*^9, 3.953129927149309*^9}, {3.953130124318903*^9, 
  3.9531301253171654`*^9}, {3.964860386567192*^9, 3.964860390275181*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"94768afd-dcdc-2b47-ad03-1ca6a8af1164"],

Cell[BoxData[
 RowBox[{"ColumnKeys", "[", "clusters", "]"}]], "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"de9ef3b5-cd90-624d-a5af-c17bea7c269e"],

Cell["\<\
A scatter plot testing the hypothesis that older clusters tend to have lower \
metallicities, because they formed when the galaxy was less enriched:\
\>", "Text",ExpressionUUID->"3706b76a-f5a8-934e-a590-34819ffba824"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"clusters", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<LogAge\>\"", ",", "\"\<Metallicity\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<LogAge\>\"", ",", "\"\<Metallicity\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "Tiny"}], "}"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"74555b1e-80e5-f045-a9d5-86d87e2010b4"],

Cell["\<\
A scatter plot testing the hypothesis that dust accumulates along the line of \
sight, so more distant clusters have larger reddening:\
\>", "Text",ExpressionUUID->"12b241f9-7823-444a-a6b8-6ec265637c9b"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"clusters", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Distance\>\"", ",", "\"\<BVColourExcess\>\""}], "}"}]}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Distance (pc)\>\"", ",", "\"\<BVColourExcess\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "Tiny"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotStyle", "->", "Red"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"f1deccca-a6fb-b841-825e-15bffc4a7973"],

Cell["Show the distance vs apparent distance modulus relationship:", "Text",ExpressionUUID->"16f5f06c-4227-e24e-8d0f-ee00eb2a35d5"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"clusters", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Distance\>\"", ",", "\"\<ApparentDistanceModulus\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 

 CellLabel->"In[26]:=",ExpressionUUID->"2717bc7c-0c39-4942-8c1c-907f081db360"],

Cell[BoxData[
 RowBox[{"relativeHeroData", " ", "=", "\[IndentingNewLine]", 
  RowBox[{"AssociationMap", "[", "\[IndentingNewLine]", 
   RowBox[{"relativeHeroes", ",", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      TemplateBox[{"\"The Sign of the Four\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"Book\"", ",", "\"TheSignOfTheFour1890\""}], "]"}], 
        "\"Entity[\\\"Book\\\", \\\"TheSignOfTheFour1890\\\"]\"", "\"book\""},
       "Entity"], ",", "\[IndentingNewLine]", 
      TemplateBox[{"\"The Adventures of Sherlock Holmes\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"Book\"", ",", "\"TheAdventuresOfSherlockHolmes\""}], 
          "]"}], "\"Entity[\\\"Book\\\", \
\\\"TheAdventuresOfSherlockHolmes\\\"]\"", "\"book\""},
       "Entity"], ",", "\[IndentingNewLine]", 
      TemplateBox[{"\"The Hound of the Baskervilles\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"Book\"", ",", "\"TheHoundOfTheBaskervilles\""}], "]"}], 
        "\"Entity[\\\"Book\\\", \\\"TheHoundOfTheBaskervilles\\\"]\"", 
        "\"book\""},
       "Entity"], ",", "\[IndentingNewLine]", 
      TemplateBox[{"\"The Return of Sherlock Holmes\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"Book\"", ",", "\"TheReturnOfSherlockHolmes1904\""}], 
          "]"}], "\"Entity[\\\"Book\\\", \
\\\"TheReturnOfSherlockHolmes1904\\\"]\"", "\"book\""},
       "Entity"]}], "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9831069819604053`*^9, 3.983106982882532*^9}},

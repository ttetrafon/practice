44c0cba20bb8"],

Cell["\<\
The repository is organized into categories for easy navigation.\
\>", "Text",
 CellChangeTimes->{
  3.9825210279245586`*^9, {3.982749268247182*^9, 
   3.982749268327663*^9}},ExpressionUUID->"d57f1fc7-76cf-5a49-8b35-\
4945e79f3aaa"],

Cell["\<\
Retrieve a curated social network, where an edge between two vertices \
indicates a social connection between two users (via online messages):\
\>", "Text",
 CellChangeTimes->{{3.9531298808186665`*^9, 3.9531299063972855`*^9}, {
  3.9825210503494263`*^9, 3.9825210537686653`*^9}, {3.982521197486822*^9, 
  3.9825211976861095`*^9}, {3.982749274431657*^9, 3.98274927930508*^9}, {
  3.9831159067327976`*^9, 
  3.983115920326103*^9}},ExpressionUUID->"3ebc16f8-e306-4b4b-84c9-\
6b3ab79fe629"],

Cell[BoxData[
 RowBox[{"g", "=", 
  RowBox[{
  "ResourceData", "[", "\"\<Online Social Network\>\"", "]"}]}]], "Input",
 CellChangeTimes->{3.983116076884821*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"9c9f987c-76e5-7840-9a1c-056f67ff2824"],

Cell["Plot the underlying graph:", "Text",ExpressionUUID->"d2a0e05e-0276-c14b-9a6e-31ce37a2cb36"],

Cell[BoxData[
 RowBox[{"Rasterize", "[", 
  RowBox[{"GraphPlot", "[", 
   RowBox[{"g", ",", 
    RowBox[{"EdgeStyle", "->", "Thin"}]}], "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9831159416406345`*^9, 3.983115966279108*^9}, 
   3.983116080190363*^9},
 CellLabel->"In[2]:=",ExpressionUUID->"d3ecb722-c5ff-ca48-a3c5-2167bee3c19d"],

Cell["Find the most popular sender and receiver:", "Text",
 CellChangeTimes->{{3.983115975240366*^9, 
  3.9831159753876953`*^9}},ExpressionUUID->"77843884-4444-e04e-a0e7-\
c792609b25bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"sender", ",", "receiver"}], "}"}], "=", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"First", "[", 
     RowBox[{"MaximalBy", "[", 
      RowBox[{
       RowBox[{"VertexList", "[", "g", "]"}], ",", 
       RowBox[{
        RowBox[{"VertexOutDegree", "[", 
         RowBox[{"g", ",", "#"}], "]"}], "&"}]}], "]"}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"First", "[", 
     RowBox[{"MaximalBy", "[", 
      RowBox[{
       RowBox[{"VertexList", "[", "g", "]"}], ",", 
       RowBox[{
        RowBox[{"VertexInDegree", "[", 
         RowBox[{"g", ",", "#"}], "]"}], "&"}]}], "]"}], "]"}]}], 
   "\[IndentingNewLine]", "}"}]}]], "Input",
 CellChangeTimes->{{3.9831160863392887`*^9, 3.9831160895052853`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"e2170ea5-5d9d-004e-9dcc-5f53984bd568"],

Cell["Get the neighbourhood of people around the receiver:", "Text",ExpressionUUID->"1d006b15-490b-0e4e-9344-0b2dad864030"],

Cell[BoxData[
 RowBox[{
  RowBox[{"receiverNeighbourhood", " ", "=", " ", 
   RowBox[{"NeighborhoodGraph", "[", 
    RowBox[{"g", ",", "receiver", ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", 
         StyleBox[
         "\"GraphOptions\"", "IconizedCustomName", StripOnInput -> False], 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["2", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["296", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[EdgeStyle -> Opacity[0.1], VertexStyle -> Opacity[0.5]],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.983115987777933*^9, 3.9831160254818554`*^9}, 
   3.9831160919028416`*^9},
 CellLabel->"In[4]:=",ExpressionUUID->"a7771721-5cf3-8940-b2c5-e1bc0f01dfe5"],

Cell["\<\
Visualize the sender\[CloseCurlyQuote]s connections within the receiver\
\[CloseCurlyQuote]s neighbourhood:\
\>", "Text",
 CellChangeTimes->{{3.98311604257996*^9, 
  3.983116045584791*^9}},ExpressionUUID->"522ae0b4-326c-7947-aeea-\
488784d77c5f"],

Cell[BoxData[
 RowBox[{"receiverGraph", "=", "\[IndentingNewLine]", 
  RowBox[{"HighlightGraph", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NeighborhoodGraph", "[", 
     RowBox[{"g", ",", "receiver", ",", 
      RowBox[{"EdgeStyle", "->", 
       RowBox[{"Opacity", "[", "0.3", "]"}]}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"NeighborhoodGraph", "[", 
         RowBox[{"g", ",", "sender"}], "]"}], ",", "Yellow"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Style", "[", 
       RowBox[{"receiver", ",", "Red"}], "]"}]}], "\[IndentingNewLine]", 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"VertexSize", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"receiver", "->", "2"}], ",", 
       RowBox[{"sender", "->", "2"}]}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{
  3.983116048919821*^9, {3.983116102676117*^9, 3.9831161519386997`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"9b2b721b-8faa-2e48-9344-d88c8695d9d3"],

Cell["\<\
Within this network, extract only the connections in which at least 20 \
messages have been exchanged:\
\>", "Text",ExpressionUUID->"058ef6d9-8571-2943-8cb7-711831c27c65"],

Cell[BoxData[
 RowBox[{"Subgraph", "[", "\[IndentingNewLine]", 
  RowBox[{"receiverGraph", ",", "\[IndentingNewLine]", 
   RowBox[{"edge_DirectedEdge", "/;", 
    RowBox[{
     RowBox[{"AnnotationValue", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"receiverGraph", ",", "edge"}], "}"}], ",", "EdgeWeight"}], 
      "]"}], ">=", "20"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"VertexSize", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"receiver", "\[Rule]", "1"}], ",", 
      RowBox[{"sender", "\[Rule]", "1"}]}], "}"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.983116179036476*^9, 3.9831161811067142`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"8c87dd69-04a9-454b-a596-4c6b0a43d4ff"],

Cell["\<\
Visualise the community structure of the network around the most popular \
receiver:\
\>", "Text",
 CellChangeTimes->{{3.9831229793705406`*^9, 
  3.9831229860458546`*^9}},ExpressionUUID->"a1037158-91c5-ef40-aafc-\
89d153bdf848"],

Cell[BoxData[
 RowBox[{"CommunityGraphPlot", "[", "receiverGraph", "]"}]], "Input",
 CellChangeTimes->{
  3.983116189989418*^9, {3.9831162229510536`*^9, 3.983116224653982*^9}},
 CellLabel->"In[81]:=",ExpressionUUID->"b8c43df0-3814-c74d-82e9-1069eae1a9d2"],

Cell[TextData[{
 "We can also create a log-log plot of the ",
 ButtonBox["VertexDegree",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/VertexDegree.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/VertexDegree.html"],
 " of all nodes in the network, and look for linearity:"
}], "Text",
 CellChangeTimes->{{3.98326573986075*^9, 3.9832657557233143`*^9}, {
  3.9832665754122257`*^9, 
  3.9832665779145947`*^9}},ExpressionUUID->"0cd93123-267f-d548-a8fd-\
cd5fb36f6203"],

Cell[BoxData[
 RowBox[{"ListLogLogPlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Tally", "[", 
    RowBox[{"VertexDegree", "[", "g", "]"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Degree\>\"", ",", "\"\<Counts\>\""}], "}"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9832651054318447`*^9, 3.9832651745249176`*^9}, 
   3.9832654939376373`*^9},
 CellLabel->"In[39]:=",ExpressionUUID->"4893c38a-7a25-754e-b10a-7828b3f46c74"],

Cell["\<\
The approximate linear trend on a log\[Dash]log plot suggests a heavy-tailed \
distribution, which is common in social networks.\
\>", "Text",
 CellChangeTimes->{{3.983266605886194*^9, 
  3.983266607858612*^9}},ExpressionUUID->"ddc8740b-2247-8448-ba4f-\
55a08e12d1e2"],

Cell[TextData[{
 "We can attempt to automatically identify a candidate distribution using ",
 ButtonBox["FindDistribution",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/FindDistribution.html"], 
    None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/FindDistribution.html"],
 " or ",
 ButtonBox["EstimatedDistribution",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/EstimatedDistribution.\
html"], None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/EstimatedDistribution.html"],
 ":"
}], "Text",
 CellChangeTimes->{{3.983123362703438*^9, 3.9831233734260635`*^9}, {
  3.983123414562525*^9, 3.9831234557278748`*^9}, {3.983264046840908*^9, 
  3.9832641203490944`*^9}, {3.9832649127761974`*^9, 3.9832649385627766`*^9}, {
  3.983266381534893*^9, 3.9832663940893784`*^9}, {3.9832666509065113`*^9, 
  3.9832666676877346`*^9}},ExpressionUUID->"9e68a4ea-082d-3249-8647-\
60da3175d707"],

Cell[BoxData[
 RowBox[{"dist", "=", 
  RowBox[{"FindDistribution", "[", 
   RowBox[{"VertexDegree", "[", "g", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.98326633949049*^9, 3.983266347653158*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"9f63a4b9-e440-5f41-9bb8-d6c0cd901e4a"],

Cell["\<\
Generate a plot of the quantiles of our data against the quantiles of the \
candidate distribution:\
\>", "Text",
 CellChangeTimes->{{3.9832666853293095`*^9, 
  3.983266719499922*^9}},ExpressionUUID->"a2c8a247-5223-b04a-85d2-\
03aa0a494ba0"],

Cell[BoxData[
 RowBox[{"QuantilePlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"VertexDegree", "[", "g", "]"}], ",", "\[IndentingNewLine]", 
   "dist", ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", "\"\<*\>\""}], ",", "\[IndentingNewLine]", 
   RowBox[{"ReferenceLineStyle", "->", "Black"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.9832662688833027`*^9, 3.983266282917734*^9}, 
   3.983266359351225*^9, {3.9832684463649673`*^9, 3.9832684465920506`*^9}, {
   3.983268617764286*^9, 3.9832686414604797`*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"5c575f7b-086c-0e4a-9f52-15a5bc7bfb94"],

Cell[TextData[{
 "We can use ",
 ButtonBox["DistributionFitTest",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/DistributionFitTest.html"],
     None},
  ButtonNote->
   "http://reference.wolfram.com/language/ref/DistributionFitTest.html"],
 " to see whether the vertex degrees are actually well described by this \
distribution:"
}], "Text",
 CellChangeTimes->{{3.9832658987157154`*^9, 3.9832659196599426`*^9}, {
  3.9832664040333214`*^9, 
  3.983266449481579*^9}},ExpressionUUID->"1c9c2405-6b76-9143-9234-\
747ccd2c4e0b"],

Cell[BoxData[
 RowBox[{"DistributionFitTest", "[", 
  RowBox[{
   RowBox[{"VertexDegree", "[", "g", "]"}], ",", " ", "dist", ",", 
   " ", "\"\<TestConclusion\>\""}], "]"}]], "Input",
 CellChangeTimes->{{3.983117626258375*^9, 3.9831176265322685`*^9}, {
  3.983123780992304*^9, 3.9831237837414227`*^9}, {3.98326538207102*^9, 
  3.9832653839642925`*^9}, {3.983266451868883*^9, 3.983266452210989*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"f9c78dff-b33e-964a-91ea-e47ee9aed6cf"],

Cell[BoxData[
 RowBox[{"DistributionFitTest", "[", 
  RowBox[{
   RowBox[{"VertexDegree", "[", "g", "]"}], ",", " ", "dist", ",", 
   " ", "\"\<TestDataTable\>\""}], "]"}]], "Input",
 CellChangeTimes->{
  3.983123795770521*^9, 3.983265388527195*^9, {3.983266455967041*^9, 
   3.9832664562790565`*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"a9e8fccb-3d19-1441-8924-bbcb8ff09697"],

Cell["\<\
The test rejects this model, indicating that the degree distribution is not \
well described by a simple parametric form. This is typical for real-world \
networks, which often exhibit complex heavy-tailed behaviour.\
\>", "Text",
 CellChangeTimes->{{3.9832667314959183`*^9, 
  3.9832667454197483`*^9}},ExpressionUUID->"4fb6c396-8bdb-d040-84c7-\
fc8e9d6fb2ba"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


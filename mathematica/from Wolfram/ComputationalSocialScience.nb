Cell["\<\
Get the geographical extent of the empire at the beginning and end:\
\>", "Text",
 CellChangeTimes->{{3.983114220037712*^9, 
  3.983114220271303*^9}},ExpressionUUID->"ef46f16a-e528-2143-9939-\
e9ec524015ff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"startMap", ",", "endMap"}], "}"}], "=", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      TemplateBox[{"\"Roman Empire\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"HistoricalCountry\"", ",", "\"RomanEmpire\""}], "]"}], 
        "\"Entity[\\\"HistoricalCountry\\\", \\\"RomanEmpire\\\"]\"", 
        "\"historical country\""},
       "Entity"], "[", 
      RowBox[{"Dated", "[", 
       RowBox[{"\"\<Polygon\>\"", ",", "#"}], "]"}], "]"}], "&"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "27"}], ",", " ", "394"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.983114166816288*^9, 3.9831142110423927`*^9}, {
  3.9831143594460278`*^9, 3.983114371929991*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"601eb490-dab9-4343-a81b-f1c257c6193f"],

Cell["Highlight the differences on a map:", "Text",ExpressionUUID->"fffa1bb4-2cf4-7a44-be25-68aea222dfca"],

Cell[BoxData[
 RowBox[{"FlipView", "[", "\[IndentingNewLine]", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"GeoGraphics", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"EdgeForm", "[", "Black", "]"}], ",", "\[IndentingNewLine]", 
        "Green", ",", "startMap", ",", "\[IndentingNewLine]", 
        RowBox[{"GeoProjection", " ", "->", " ", "\"\<Mercator\>\""}]}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"ImageSize", " ", "->", " ", "700"}]}], "\[IndentingNewLine]", 
     "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"GeoGraphics", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"EdgeForm", "[", "Black", "]"}], ",", "\[IndentingNewLine]", 
        "Red", ",", "endMap", ",", "\[IndentingNewLine]", 
        RowBox[{"GeoProjection", " ", "->", " ", "\"\<Mercator\>\""}]}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"ImageSize", " ", "->", " ", "700"}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.983114287447201*^9, 3.983114319870756*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"33136fab-23b7-0549-9b6c-57279c4eafdb"],

Cell[TextData[{
 "A ",
 ButtonBox["TimelinePlot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/TimelinePlot.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/TimelinePlot.html"],
 " of the historic countries that have contained London:"
}], "Text",
 CellChangeTimes->{{3.9831158301744137`*^9, 
  3.9831158553956966`*^9}},ExpressionUUID->"f978793b-6eb3-3244-a484-\
45d49aa1ecf7"],

Cell[BoxData[
 RowBox[{"TimelinePlot", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"MapApply", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"#2", "->", "#1"}], "&"}], ",", "\[IndentingNewLine]", 
     RowBox[{"GeoIdentify", "[", 
      RowBox[{
       RowBox[{"Dated", "[", 
        RowBox[{"\"\<HistoricalCountry\>\"", ",", "All"}], "]"}], ",", 
       TemplateBox[{"\"London\"", 
         RowBox[{"Entity", "[", 
           RowBox[{"\"City\"", ",", 
             RowBox[{"{", 
               
               RowBox[{
                "\"London\"", ",", "\"GreaterLondon\"", ",", 
                 "\"UnitedKingdom\""}], "}"}]}], "]"}], 
         "\"Entity[\\\"City\\\", {\\\"London\\\", \\\"GreaterLondon\\\", \
\\\"UnitedKingdom\\\"}]\"", "\"city\""},
        "Entity"]}], "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLayout", "->", "\"\<Vertical\>\""}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.927143843644143*^9, 3.927143894011506*^9}, {
  3.927143937601297*^9, 3.927143955518754*^9}, {3.927148090125819*^9, 
  3.927148090958596*^9}, {3.927148124919067*^9, 3.927148132083493*^9}, {

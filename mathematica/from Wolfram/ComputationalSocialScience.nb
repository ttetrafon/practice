Cell["\<\
Plot the data (as coordinates) to see which character is mentioned more \
frequently in each book:\
\>", "Text",ExpressionUUID->"bdf78930-7d4f-714d-9b13-fa6bc55b9a32"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
  RowBox[{"relativeHeroData", ",", "\[IndentingNewLine]", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", 
       StyleBox[
       "\"PlotOptions\"", "IconizedCustomName", StripOnInput -> False], 
       GridBox[{{
          RowBox[{
            TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["Sequence", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["9", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["1968", "IconizedItem"]}]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    Sequence[
    Frame -> {{True, False}, {True, False}}, 
     FrameLabel -> {"Holmes", "Watson"}, AxesOrigin -> {0, 0}, 
     PlotRange -> {{0, Automatic}, {0, Automatic}}, BaseStyle -> 13, 
     ImageSize -> 800, Epilog -> Style[
       InfiniteLine[{{0, 0}, {1, 1}}], 
       Dashing[{Small, Small}], 
       GrayLevel[0.1]], LabelingFunction -> Right, 
     PlotRangePadding -> {{0, 0.003}, {0, 0.001}}],
    SelectWithContents->True,
    Selectable->False]}], 
  StyleBox["\[IndentingNewLine]",
   StripOnInput->False,
   Dashing->{Small, Small},
   LineColor->GrayLevel[0.1],
   FrontFaceColor->GrayLevel[0.1],
   BackFaceColor->GrayLevel[0.1],
   GraphicsColor->GrayLevel[0.1],
   FontColor->GrayLevel[0.1]], "]"}]], "Input",
 CellChangeTimes->{{3.9831070185972557`*^9, 3.9831070714689255`*^9}, {
  3.9831137966805325`*^9, 3.9831138964269333`*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"ac0f052a-e8e1-8747-8092-c34c3e316907"]

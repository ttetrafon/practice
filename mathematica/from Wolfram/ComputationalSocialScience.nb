Cell["Advanced Examples", "Section",
 CellChangeTimes->{
  3.9813771438076515`*^9},ExpressionUUID->"555bc8fe-5cb8-904b-8e85-\
095b82b249f5"],

Cell[TextData[{
 "See this ",
 ButtonBox["blog post",

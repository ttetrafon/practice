  3.983269157934889*^9}},ExpressionUUID->"6315336e-c67f-7e42-a253-\
744a6e73f603"],

Cell[CellGroupData[{

Cell["Cognitive Map of the Brain", "Subsection",
 CellChangeTimes->{{3.983269951463827*^9, 
  3.9832699562576733`*^9}},ExpressionUUID->"fa80ca84-345e-5242-932f-\
2acb7ac131f5"],

Cell[TextData[{
 "Brain areas associated with specific functions such as memory, decision \
making, language, emotional state, visual perception, etc. are well \
characterized with the appropriate activity-based fMRI analysis. \nUsing ",
 ButtonBox["EntityValue",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/ref/EntityValue.html"], None},
  ButtonNote->"http://reference.wolfram.com/language/ref/EntityValue.html"],
 " with the AnatomicalFunctionalConcept entity type, we can find more \
information on hierarchically categorized brain activities:"
}], "Text",
 CellChangeTimes->{{3.9832691735897865`*^9, 3.9832692089593143`*^9}, {
  3.9832692514862423`*^9, 3.9832692538949203`*^9}, {3.9832695138489933`*^9, 
  3.9832695138489933`*^9}},ExpressionUUID->"55adbaa4-0d7f-0447-9086-\
ec419914d522"],

Cell[BoxData[
 RowBox[{"Dataset", "[", "\[IndentingNewLine]", 
  RowBox[{"EntityValue", "[", "\[IndentingNewLine]", 
   RowBox[{
    TemplateBox[{"\"decision making\"", 
      RowBox[{"Entity", "[", 
        RowBox[{
         "\"AnatomicalFunctionalConcept\"", ",", "\"DecisionMaking\""}], 
        "]"}], "\"Entity[\\\"AnatomicalFunctionalConcept\\\", \
\\\"DecisionMaking\\\"]\"", "\"anatomical functional concept\""},
     "Entity"], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{"\"definition\"", 
        RowBox[{"EntityProperty", "[", 
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", "\"Definition\""}], 
          "]"}], "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"Definition\\\"]\""},
       "EntityProperty"], ",", 
      TemplateBox[{"\"associated anatomical sites\"", 
        RowBox[{"EntityProperty", "[", 
          
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", 
            "\"AssociatedAnatomicalSites\""}], "]"}], 
        "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"AssociatedAnatomicalSites\\\"]\""},
       "EntityProperty"], ",", 
      TemplateBox[{"\"broader concepts\"", 
        RowBox[{"EntityProperty", "[", 
          
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", 
            "\"BroaderConcepts\""}], "]"}], 
        "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"BroaderConcepts\\\"]\""},
       "EntityProperty"], ",", 
      TemplateBox[{"\"narrower concepts\"", 
        RowBox[{"EntityProperty", "[", 
          
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", 
            "\"NarrowerConcepts\""}], "]"}], 
        "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"NarrowerConcepts\\\"]\""},
       "EntityProperty"], ",", 
      TemplateBox[{"\"superset concepts\"", 
        RowBox[{"EntityProperty", "[", 
          
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", 
            "\"SupersetConcepts\""}], "]"}], 
        "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"SupersetConcepts\\\"]\""},
       "EntityProperty"], ",", 
      TemplateBox[{"\"subset concepts\"", 
        RowBox[{"EntityProperty", "[", 
          
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", 
            "\"SubsetConcepts\""}], "]"}], 
        "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"SubsetConcepts\\\"]\""},
       "EntityProperty"], ",", 
      TemplateBox[{"\"standard experimental tasks\"", 
        RowBox[{"EntityProperty", "[", 
          
          RowBox[{"\"AnatomicalFunctionalConcept\"", ",", 
            "\"StandardExperimentalTasks\""}], "]"}], 
        "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"StandardExperimentalTasks\\\"]\""},
       "EntityProperty"]}], "}"}], ",", 
    "\[IndentingNewLine]", "\"\<PropertyAssociation\>\""}], 
   "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.9832692161382885`*^9, 3.983269229100939*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"c82fbd2e-5446-194b-9127-bc21c991aff0"],

Cell["\<\
Here we can look up the categories of functions associated with each cerebral \
lobe and create a simple cortical map:\
\>", "Text",
 CellID->760934327,ExpressionUUID->"e8cba9d2-8ec7-ff4c-8ecf-8356e945cfc1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"lobes", "=", 
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"\"frontal lobe\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"AnatomicalStructure\"", ",", "\"FrontalLobe\""}], "]"}], 
       "\"Entity[\\\"AnatomicalStructure\\\", \\\"FrontalLobe\\\"]\"", 
       "\"anatomical structure\""},
      "Entity"], ",", 
     TemplateBox[{"\"insula\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"AnatomicalStructure\"", ",", "\"Insula\""}], "]"}], 
       "\"Entity[\\\"AnatomicalStructure\\\", \\\"Insula\\\"]\"", 
       "\"anatomical structure\""},
      "Entity"], ",", 
     TemplateBox[{"\"parietal lobe\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"AnatomicalStructure\"", ",", "\"ParietalLobe\""}], "]"}], 
       "\"Entity[\\\"AnatomicalStructure\\\", \\\"ParietalLobe\\\"]\"", 
       "\"anatomical structure\""},
      "Entity"], ",", 
     TemplateBox[{"\"temporal lobe\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"AnatomicalStructure\"", ",", "\"TemporalLobe\""}], "]"}], 
       "\"Entity[\\\"AnatomicalStructure\\\", \\\"TemporalLobe\\\"]\"", 
       "\"anatomical structure\""},
      "Entity"], ",", 
     TemplateBox[{"\"limbic lobe\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"AnatomicalStructure\"", ",", "\"LimbicLobe\""}], "]"}], 
       "\"Entity[\\\"AnatomicalStructure\\\", \\\"LimbicLobe\\\"]\"", 
       "\"anatomical structure\""},
      "Entity"], ",", 
     TemplateBox[{"\"occipital lobe\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"AnatomicalStructure\"", ",", "\"OccipitalLobe\""}], "]"}],
        "\"Entity[\\\"AnatomicalStructure\\\", \\\"OccipitalLobe\\\"]\"", 
       "\"anatomical structure\""},
      "Entity"]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lobeToConcept", "=", "\[IndentingNewLine]", 
   RowBox[{"AssociationMap", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"EntityValue", "[", 
       RowBox[{
        RowBox[{"EntityClass", "[", 
         RowBox[{"\"\<AnatomicalFunctionalConcept\>\"", ",", 
          RowBox[{"{", 
           RowBox[{
            TemplateBox[{"\"associated anatomical sites\"", 
              RowBox[{"EntityProperty", "[", 
                
                RowBox[{
                 "\"AnatomicalFunctionalConcept\"", ",", 
                  "\"AssociatedAnatomicalSites\""}], "]"}], 
              "\"EntityProperty[\\\"AnatomicalFunctionalConcept\\\", \
\\\"AssociatedAnatomicalSites\\\"]\""},
             "EntityProperty"], "\[Rule]", "#"}], "}"}]}], "]"}], 
        ",", "\"\<Entities\>\""}], "]"}], "&"}], ",", "\[IndentingNewLine]", 
     "lobes"}], "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9832692755642014`*^9, 3.9832693260092506`*^9}, {
  3.983269749270773*^9, 3.9832697502931137`*^9}, {3.9832700242371826`*^9, 
  3.9832700427013607`*^9}},
 CellLabel->"In[82]:=",
 CellID->758116004,ExpressionUUID->"7c1817f7-e774-5048-880d-acd83dd19308"],

Cell[BoxData[
 RowBox[{"AssociationMap", "[", 
  RowBox[{
   RowBox[{

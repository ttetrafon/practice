Cell[TextData[{
 "Find the frequencies of \[OpenCurlyDoubleQuote]Holmes\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]Watson\
\[CloseCurlyDoubleQuote] in four ",
 StyleBox["Sherlock Holmes",
  FontSlant->"Italic"],
 " books:"
}], "Text",ExpressionUUID->"d4afa01d-8f6a-8840-a22b-29ece63418de"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"relativeHeroes", "[", "book_", "]"}], ":=", 
   RowBox[{"WordFrequency", "[", 
    RowBox[{
     RowBox[{"book", "[", "\"\<Plaintext\>\"", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Holmes\>\"", ",", " ", "\"\<Watson\>\""}], "}"}]}], 
    "]"}]}], ";"}]], "Input",

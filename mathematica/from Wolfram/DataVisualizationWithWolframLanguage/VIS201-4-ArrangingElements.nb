Cell[CellGroupData[{

Cell["Combine BarCharts", "Subsection",ExpressionUUID->"4ea370d7-bcb1-4b1c-ba72-e93004d2ba7f"],

Cell[TextData[{
 "Show is used here to combine two instances of ",
 ButtonBox["BarChart",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/BarChart.html?q=BarChart"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/BarChart.html?q=BarChart"],
 ". They appear stacked because the two datasets each contain three bars and \
their ",
 ButtonBox["BarSpacing",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/BarSpacing.html?q=\
BarSpacing"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/BarSpacing.html?q=BarSpacing"],
 " is the same. ",
 Cell[BoxData[
 "panelB"], "Input",ExpressionUUID->"75c5a20b-e153-419d-835f-2772f5c91f29"],
 " is drawn first, then ",
 Cell[BoxData[
 "panelA"], "Input",ExpressionUUID->"ae4ea574-1e4d-463e-8782-6592ec91be13"],
 " is drawn on a higher layer:"
}], "Text",ExpressionUUID->"452cb286-c063-4bbf-9f95-ad7f91674fdc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"panelA", ",", "panelB"}], "}"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"BarChart", "[", 
      RowBox[{"#", ",", 
       RowBox[{"ImagePadding", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"20", ",", "10"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"10", ",", "10"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "200"}], ",", 
       RowBox[{"AspectRatio", "\[Rule]", 
        RowBox[{"1", "/", "GoldenRatio"}]}]}], "]"}], "&"}], "/@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"4", ",", "5", ",", "6"}], "}"}]}], "}"}]}]}], ";"}]], "Input",
 CellLabel->
  "In[258]:=",ExpressionUUID->"dc0dbaa0-508a-4883-8ea4-7633a4abd820"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 

Cell[CellGroupData[{

Cell["Combining Graphics: Layering in a Single Panel", "Section",ExpressionUUID->"995c3bb8-6674-4196-8e40-916ed7dea7df"],

Cell[TextData[{
 "If you have multiple graphics, then you can use ",
 ButtonBox["Show",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Show.html?q=Show"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Show.html?q=Show"],
 " to combine them. It is quite simple\[LongDash]you literally just put in \
your graphics as separate arguments and then end with any options you want to \
use."
}], "Text",ExpressionUUID->"a19f7fa1-f88a-44a0-8bfe-cc4d6afbd984"],

Cell[CellGroupData[{

Cell["Specification", "Subsection",ExpressionUUID->"7a3468c0-7eab-471e-ab00-ce42012be71e"],


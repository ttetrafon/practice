Cell[CellGroupData[{
Cell["Arranging Elements", "Subtitle",ExpressionUUID->"abd2714b-c40b-491d-9b98-1f3d249655e3"],

Cell[CellGroupData[{

Cell["Learning Objectives", "Section",ExpressionUUID->"a97f34a4-babe-4547-8f90-f67ece348d5f"],

Cell[CellGroupData[{

Cell["Arranging graphics elements", "Subsubsection",ExpressionUUID->"ed6dcd4b-0dea-40f1-9b4d-c710c231e835"],

Cell["\<\
Control the appearance of your graphics by effectively arranging built-in \
chart elements. Organizing information within the available space helps \
locate key information quickly. This module demonstrates how to arrange \
static elements in a graphics expression.\
\>", "Text",ExpressionUUID->"16213b15-441b-47d0-9318-40f433365a1c"],

Cell["Graphics coordinate systems", "Item",ExpressionUUID->"cfa59993-b0de-4819-836f-8084b4628a3c"],

Cell["Functions with exclusive options", "Item",ExpressionUUID->"dd524002-1e21-4d3d-8238-c5bb3c70cd58"],

Cell["Sizing and padding", "Item",ExpressionUUID->"cfd88d59-33cb-4027-ad43-b11131fdb131"],

Cell["Layers", "Item",ExpressionUUID->"87f790a3-6de6-4de1-b2a8-bae96550457e"],

Cell["Inset", "Item",ExpressionUUID->"730e03e3-e98a-4870-b000-e5b5d4a5d7fc"],

Cell["Single- and multi-paneled graphics", "Item",ExpressionUUID->"95c515e4-e670-4880-b108-c4199bb61aa2"]
}, Open  ]]
}, Open  ]],


Cell[BoxData[
 TagBox[GridBox[{
    {
     TemplateBox[{
       StyleBox[
       "\"BarOrigin\"", 16, FontFamily -> "Helvetica", StripOnInput -> False],
        "https://reference.wolfram.com/language/ref/BarOrigin.html"},
      "HyperlinkURL"], 
     TemplateBox[{

Cell[TextData[{
 "PlotRange specifies the range of coordinates to include in your plot, while \
",
 ButtonBox["PlotRangePadding",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PlotRangePadding.html?q=\
PlotRangePadding"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/PlotRangePadding.html?q=\
PlotRangePadding"],
 " controls the amount of space that appears between the plot range and other \
objects, such as axes or other margins. If PlotRange is fully specified, then \
PlotRangePadding is not used."
}], "Text",ExpressionUUID->"13ae11fb-9256-4075-827f-f0b5a0fec09b"],

Cell[TextData[{
 ButtonBox["ImageSize",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ImageSize.html?q=\
ImageSize"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/ImageSize.html?q=ImageSize"],
 " controls the overall size of your graphic, while ImagePadding sets the \
amount of space that appears between the edge of the graphic and other \
objects, such as axes."
}], "Text",ExpressionUUID->"99f33597-72e1-40bd-9b86-00d024d30926"],

Cell[TextData[{
 ButtonBox["ImageMargins",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ImageMargins.html?q=\
ImageMargins"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/ImageMargins.html?q=\
ImageMargins"],
 " specifies the amount of space that appears outside of the graphic."
}], "Text",ExpressionUUID->"17f75afe-a6b9-4970-914b-4bbe92afc6cf"],


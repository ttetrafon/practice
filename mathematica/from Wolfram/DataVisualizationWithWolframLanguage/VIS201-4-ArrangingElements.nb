Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "For Graphics[Circle[], Frame \[Rule] True], which option would \
be used to add extra space between the circle and the frame?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["ImagePadding", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: ImagePadding is an option for graphics \
functions that specifies what absolute extra padding should be left for \
extended objects such as thick lines and annotations such as tick and axis \
labels.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["ImagePadding", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "PlotRangePadding", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: PlotRangePadding is an option for graphics \
functions that specifies how much further axes etc. should extend beyond the \
range of coordinates specified by PlotRange. ", "Text", FontColor -> 
                    RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["PlotRangePadding", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["ImageMargins", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: ImageMargins is an option that specifies the \
absolute margins to leave around the image displayed for an object. ", "Text",
                     FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["ImageMargins", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell["ImageSize", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: ImageSize is an option that specifies the \
overall size of an image to display for an object.", "Text", FontColor -> 
                    RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["ImageSize", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{859., {21.959640502929688`, 29.192062377929688`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"b37bf003-17cd-42a6-bce2-\
cafe75eda6e8"]], "Text",
 CellTags->"CYU",ExpressionUUID->"935a9445-d363-497b-b928-c7a8bc3c98ad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Prolog and Epilog", "Section",ExpressionUUID->"0c7ffa21-ef5b-47d3-9ae3-3cdbb8b28c9d"],

Cell[TextData[{
 "Graphics are drawn in a particular order. The ",
 ButtonBox["Prolog",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Prolog.html?q=Prolog"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Prolog.html?q=Prolog"],
 " layer is first, then the graphics primitives, then the labels and ticks, \
and finally the ",
 ButtonBox["Epilog",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Epilog.html?q=Epilog"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Epilog.html?q=Epilog"],
 " layer:"
}], "Text",ExpressionUUID->"7ea6d088-7268-4f04-8be5-47ac45085fc7"],

Cell[BoxData[
 RowBox[{"CellPrint", "@", 
  RowBox[{"Cell", "[", 
   RowBox[{
    RowBox[{"RawBoxes", "@", 
     RowBox[{"ToBoxes", "@", 
      RowBox[{"Graphics", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"EdgeForm", "[", "Black", "]"}], ",", "LightRed", ",", 
         RowBox[{"Rectangle", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", 
             RowBox[{"-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ",", "White", ",", 
         RowBox[{"Translate", "[", 
          RowBox[{
           RowBox[{"Rectangle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", 
               RowBox[{"-", "1"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", ".2"}], ",", 
             RowBox[{"-", ".2"}]}], "}"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "LightYellow", ",", 
         RowBox[{"Translate", "[", 
          RowBox[{
           RowBox[{"Rectangle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", 
               RowBox[{"-", "1"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", ".4"}], ",", 
             RowBox[{"-", ".4"}]}], "}"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "LightPurple", ",", 
         RowBox[{"Translate", "[", 
          RowBox[{
           RowBox[{"Rectangle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", 
               RowBox[{"-", "1"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", ".6"}], ",", 
             RowBox[{"-", ".6"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"Text", "[", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Epilog\>\"", ",", "Bold", ",", 
             RowBox[{"FontFamily", "\[Rule]", "\"\<Courier\>\""}], ",", 
             RowBox[{"GrayLevel", "[", ".2", "]"}], ",", "16"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1.5"}], ",", 
             RowBox[{"-", "1.5"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Left", ",", "Bottom"}], "}"}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Text", "[", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Labeling\>\"", ",", "Bold", ",", 
             RowBox[{"FontFamily", "\[Rule]", "\"\<Courier\>\""}], ",", 
             RowBox[{"GrayLevel", "[", ".2", "]"}], ",", "16"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{".65", ",", 
             RowBox[{"-", "1.4"}]}], "}"}], ",", 

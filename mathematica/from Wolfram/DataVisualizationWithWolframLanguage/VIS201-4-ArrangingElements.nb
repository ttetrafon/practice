Cell[CellGroupData[{

Cell["Possible Issues", "Subsection",ExpressionUUID->"ef3bdc2d-ae11-4502-985a-d8100a555807"],

Cell["\<\
Combining graphics at different scales often produces odd results. You should \
also be aware that the options for the combined graphics are inherited from \
the first argument of Show whenever there might be a conflict:\
\>", "Text",ExpressionUUID->"8424091b-84f6-4210-bb01-75029dfe394c"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"5", " ", 
      SuperscriptBox[
       RowBox[{"Sin", "[", "x", "]"}], "2"]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "\[Pi]"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}]}], "]"}], ",", 
   RowBox[{"LogPlot", "[", 
    RowBox[{
     RowBox[{"5", " ", 
      SuperscriptBox[
       RowBox[{"Cos", "[", "x", "]"}], "2"]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "\[Pi]"}], "}"}]}], "]"}]}], "]"}]], "Input",\
ExpressionUUID->"d3ec7235-9de2-4a39-826d-e2f3077fd095"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Multi-paneled Figures", "Section",ExpressionUUID->"7623996c-0b3f-47eb-b4fd-304bdb169e42"],

Cell[TextData[{
 StyleBox[ButtonBox["GraphicsGrid",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/GraphicsGrid.html?q=\
GraphicsGrid"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/GraphicsGrid.html?q=\
GraphicsGrid"],
  FontSlant->"Plain"],
 StyleBox[" is used to combine individual graphics expressions into a grid. \
Graphics that have the same ImagePadding will have their axes aligned:",
  FontSlant->"Plain"]
}], "Text",
 FontSlant->"Italic",ExpressionUUID->"3a4370f5-a30d-40f2-8d55-94a7ca8721c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"panelA", ",", "panelB", ",", "panelC"}], "}"}], "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"BarChart", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", 
       RowBox[{"ImagePadding", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"20", ",", "10"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"10", ",", "10"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"ImageSize", "\[Rule]", "200"}], ",", 
       RowBox[{"AspectRatio", "\[Rule]", 
        RowBox[{"1", "/", "GoldenRatio"}]}]}], "]"}], ",", "3"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[264]:=",ExpressionUUID->"3755dc58-d63a-4ed1-a79b-2ad6b48e7ac8"],

Cell[BoxData[
 RowBox[{"gg1", "=", 
  RowBox[{"GraphicsGrid", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"panelA", ",", "panelB", ",", "panelC"}], "}"}], "}"}], ",", 
    RowBox[{"Alignment", "\[Rule]", "Center"}], ",", 
    RowBox[{"Frame", "\[Rule]", "All"}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[265]:=",ExpressionUUID->"10ce1cad-ba1e-49ec-a4f0-223acb11bf72"],

Cell[BoxData[
 RowBox[{"Head", "[", "gg1", "]"}]], "Input",
 CellLabel->"In[45]:=",ExpressionUUID->"d6293f8d-4b18-400a-a2bb-b96ce537f4cb"],

Cell[TextData[{
 "GraphicsGrid effectively uses ",
 ButtonBox["Inset",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Inset.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Inset.html"],
 ". For better control of placement and sizing, inset the panels into a \
Graphics expression. In the following, the ",
 ButtonBox["AspectRatio",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/AspectRatio.html?q=\
AspectRatio"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/AspectRatio.html?q=\
AspectRatio"],
 " of the overall graphic is set first. The PlotRange is set to span from 0 \
to 1 in both directions:"
}], "Text",ExpressionUUID->"4fbecfb9-7695-47c9-822b-0dc268528e96"],

Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Inset", "[", 
      RowBox[{"panelA", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0.5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Left", ",", "Bottom"}], "}"}], ",", "0.4"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Inset", "[", 
      RowBox[{"panelB", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Left", ",", "Bottom"}], "}"}], ",", "0.4"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Inset", "[", 
      RowBox[{"panelC", ",", 
       RowBox[{"{", 
        RowBox[{"0.4", ",", "0.5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Left", ",", "Center"}], "}"}], ",", "0.6"}], "]"}]}], 
    "\[IndentingNewLine]", "}"}], ",", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", 
    RowBox[{"1", "/", "2"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]], "Input",ExpressionUUID\
->"b61a7c17-04cc-492c-8dce-c110080cdc76"],

Cell[TextData[{
 "GraphicsGrid creates a larger graphics expression. You can also use ",
 ButtonBox["Grid",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Grid.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Grid.html"],
 ", but then you must rasterize the result if you would like to convert it to \
a bitmap image. Not all journals accept bitmap formats for figures:"
}], "Text",ExpressionUUID->"9bf61de1-d11a-4337-af17-e764fe6f6576"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"panelCbig", "=", 
   RowBox[{"BarChart", "[", 

     RowBox[{"ImageSize", "\[Rule]", "325"}], ",", 
     RowBox[{"AspectRatio", "\[Rule]", 
      RowBox[{"1", "/", "GoldenRatio"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"combined", "=", 

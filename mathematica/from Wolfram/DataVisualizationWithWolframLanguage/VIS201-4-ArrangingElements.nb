Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "What coordinate system needs to be used to specify a location \
outside of the plot range?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["User", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The User coordinate system can only specify \
locations inside of the plot range. ", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["User", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell["ImageScaled", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Only ImageScaled can be used to specify \
locations outside of the plot range. ", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["ImageScaled", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["Scaled", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The Scaled coordinate system can only specify \
locations inside of the plot range. ", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Scaled", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell["All of the above", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Only one of the answers is correct.", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["All of the above", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],

Cell[CellGroupData[{

Cell["Labeled and LabelingFunction", "Section",ExpressionUUID->"ba43a8df-5fd7-4c10-83ad-1ae006320cf1"],

Cell[TextData[{
 ButtonBox["Labeled",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Labeled.html?q=Labeled"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Labeled.html?q=Labeled"],
 " can be used as a wrapper around any individual data point or graphics \
element. ",
 ButtonBox["LabelingFunction",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/LabelingFunction.html?q=\
LabelingFunction"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/LabelingFunction.html?q=\
LabelingFunction"],
 " is the most general way to modify all element labels simultaneously. It \
acts as a wrapper function that applies after individual data wrappers:"
}], "Text",ExpressionUUID->"86794103-dc0f-40bd-8a7c-5287d32416e4"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Labeled", "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", "Automatic"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "2"}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[182]:=",ExpressionUUID->"a09a655b-495c-43bc-8e56-1d1cf42295b7"],

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", 
     RowBox[{"Labeled", "[", 
      RowBox[{"3", ",", "\"\<A\>\""}], "]"}]}], "}"}], ",", 
   RowBox[{"LabelingFunction", "\[Rule]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Callout", "[", 
       RowBox[{"#", ",", "Automatic"}], "]"}], " ", "&"}], ")"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[183]:=",ExpressionUUID->"f4a3596c-06c5-48b7-a04d-b3e94c32aa7c"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "What is the difference between Labeled and Legended?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell[
                    "Labeled will identify an item using a graphic next to \
the plot, while Legended will identify an item using a graphic next to the \
item. ", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Labeled will not place the label next to the \
graphics, and Legended will not create a legend next to the item. ", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "Labeled will identify an item using a graphic next to \
the plot, while Legended will identify an item using a graphic next to the \
item. ", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "Labeled can only be used to label points, while Legended \

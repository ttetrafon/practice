Cell[CellGroupData[{

Cell["Ticks and FrameTicks", "Section",ExpressionUUID->"7575646f-1cbc-4a95-a407-8cd6a517102b"],

Cell[CellGroupData[{

Cell["Customizing Ticks", "Subsection",ExpressionUUID->"84ec7f38-0973-427e-b4d8-35ea96c1a345"],

Cell["\<\
Ticks are highly customizable. The syntax for creating and specifying custom \
ticks is listed here:\
\>", "Text",ExpressionUUID->"ecb230ec-4be3-46ee-88ac-2f65404f9003"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CellPrint", "[", 
  RowBox[{"TextCell", "[", 
   RowBox[{
    RowBox[{"TextGrid", "[", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"#", ",", "Bold", ",", 
            RowBox[{"FontColor", "\[Rule]", 
             RowBox[{"Darker", "@", "Gray"}]}]}], "]"}], "&"}], "/@", 
         RowBox[{"{", 
          RowBox[{"\"\<Tick list\>\"", ",", "\"\<Tick specification\>\""}], 
          "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"#", ",", "Bold", ",", 
            RowBox[{"FontSlant", "\[Rule]", "Italic"}]}], "]"}], "&"}], "/@", 
         RowBox[{"{", 
          
          RowBox[{"\"\<{tickspec1, tickspec2, ...}\>\"", 
           ",", "\"\<{position, label, {poslen, neglen}, style}\>\""}], 
          "}"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
      RowBox[{"Alignment", "\[Rule]", "Center"}], ",", 
      RowBox[{"Frame", "\[Rule]", "All"}], ",", 
      RowBox[{"FrameStyle", "\[Rule]", "Gray"}], ",", 
      RowBox[{"Spacings", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], ",", 
      RowBox[{"Background", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"White", ",", "None", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}], "\[Rule]", "LightGray"}], ",", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "2"}], "}"}], "\[Rule]", "LightGray"}]}], 
          "}"}]}], "}"}]}], ",", 
      RowBox[{"BaseStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<Text\>\"", ",", 
         RowBox[{"FontSize", "\[Rule]", "15"}]}], "}"}]}]}], "]"}], 
    ",", "\"\<Output\>\"", ",", 
    RowBox[{"GeneratedCell", "\[Rule]", "False"}]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[918]:=",ExpressionUUID->"ab63fdb9-7478-464e-ba42-f7a1a604eedb"],

Cell[BoxData[
 TagBox[GridBox[{
    {Cell["Tick list",
      FontWeight->Bold,
      FontColor->RGBColor[
       0.33333333333333337`, 0.33333333333333337`, 0.33333333333333337`],
      ExpressionUUID->"33475091-b0ba-461d-a8e0-fa418ea221bf"], Cell[
     "Tick specification",
      FontWeight->Bold,
      FontColor->RGBColor[
       0.33333333333333337`, 0.33333333333333337`, 0.33333333333333337`],
      ExpressionUUID->"89bd2b7f-0420-4ef6-b086-0ba68cfc6f66"]},
    {Cell["{tickspec1, tickspec2, ...}",
      FontWeight->Bold,
      FontSlant->Italic,ExpressionUUID->
      "86b9fdc0-4f2e-45eb-a37d-003531758553"], Cell[
     "{position, label, {poslen, neglen}, style}",
      FontWeight->Bold,
      FontSlant->Italic,ExpressionUUID->
      "50344a52-a9c1-4852-a778-68322deddf2f"]}
   },
   AutoDelete->False,
   BaseStyle->{"Text", FontSize -> 15},
   FrameStyle->GrayLevel[0.5],
   GridBoxAlignment->{"Columns" -> {{Center}}},
   GridBoxBackground->{"Columns" -> {{
        GrayLevel[1]}}, "Rows" -> {{None}}, 
     "ItemsIndexed" -> {{1, 1} -> GrayLevel[0.85], {1, 2} -> GrayLevel[0.85]}},
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
   GridBoxSpacings->{"Columns" -> {{2}}, "Rows" -> {{2}}}],
  "TextGrid"]], "Output",
 GeneratedCell->False,ExpressionUUID->"b214f560-a052-4bf8-99b5-b83b15eff644"]
}, {2}]],

Cell["\<\
To demonstrate how to construct customized ticks, generate some data \
representing the ranking of the name Mary over time:\
\>", "Text",ExpressionUUID->"c98bb34b-2b38-b142-ad43-a64d3f611c39"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Normal", "@", 
    RowBox[{
     RowBox[{"KeyValueMap", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"#1", ",", "#2"}], "}"}], "&"}], "]"}], "@", 
     RowBox[{"makeList", "[", "\"\<Mary\>\"", "]"}]}]}]}], ";"}]], "Input",Exp\
ressionUUID->"400d25df-2b4d-f842-a153-8862c51d4591"],

Cell[TextData[{
 "Here ",
 ButtonBox["Table",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Table.html?q=Table"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Table.html?q=Table"],
 " is used to create a list of fully specified ticks. ",
 ButtonBox["None",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/None.html?q=None"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/None.html?q=None"],
 " specifies no ticks for the vertical axis:"
}], "Text",ExpressionUUID->"3544cc69-94b1-4118-a156-3a80783da935"],

Cell[BoxData[
 RowBox[{"ticks", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"i", ",", "i", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0.01"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1910", ",", "2010", ",", "10"}], "}"}]}], "]"}], ",",
     "None"}], "}"}]}]], "Input",ExpressionUUID->"90848844-6de0-ab45-81c5-\
4cb6348274bd"],

Cell["\<\
Take a look at the data with the ticks that were just constructed:\
\>", "Text",ExpressionUUID->"a2f34261-7230-1f46-b131-15990ac8c511"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"data", ",", 
   RowBox[{"Ticks", "\[Rule]", "ticks"}]}], "]"}]], "Input",
 CellLabel->
  "In[159]:=",ExpressionUUID->"5efc8e88-4e6c-b645-804b-bf0f4878dd0c"],

Cell["\<\
Assume that now it is desired to highlight the tick at 1950 with a long red \
tick mark that extends into the plot. This can be done with a replacement \
rule:\
\>", "Text",ExpressionUUID->"61dc82c4-869b-0b4c-85df-bd0a61d8194c"],

Cell[BoxData[
 RowBox[{"ticks1950", "=", 
  RowBox[{"ticks", "/.", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1950", ",", "1950", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0.01"}], "}"}]}], "}"}], "->", 
    RowBox[{"{", 
     RowBox[{"1950", ",", "1950", ",", 
      RowBox[{"{", 
       RowBox[{"0.4", ",", "0"}], "}"}], ",", "Red"}], "}"}]}]}]}]], "Input",
 CellLabel->
  "In[174]:=",ExpressionUUID->"31861b69-06cc-e243-89a7-1d32afcbfce7"],

Cell["Visualize the data with the new set of ticks:", "Text",ExpressionUUID->"fdf62345-33b6-364a-9a68-eefde2f57d24"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"data", ",", 
   RowBox[{"Ticks", "\[Rule]", "ticks1950"}]}], "]"}]], "Input",
 CellLabel->
  "In[173]:=",ExpressionUUID->"01055bcf-f52a-c343-b810-09837c3125fc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Using FindDivisions", "Subsection",ExpressionUUID->"88c349e3-e65c-460a-a232-571109432376"],

Cell[TextData[{
 "If you do not know the exact ticks you should use in a graphic, you can use \
",
 ButtonBox["FindDivisions",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/FindDivisions.html?q=\
FindDivisions"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/FindDivisions.html?q=\
FindDivisions"],
 " to tell you what your tick values should be."
}], "Text",ExpressionUUID->"01ad8420-3683-4901-8fe9-0ba5400977c9"],

Cell[TextData[{
 "Here, ",
 Cell[BoxData[
  RowBox[{"FindDivisions", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1910", ",", " ", "1970"}], "}"}], ",", " ", "10"}], "]"}]], 
  "Input",ExpressionUUID->"5b7aa598-4ee5-40d1-b2f1-00678a4defdc"],
 " is saying to find a list of about 10 \[OpenCurlyDoubleQuote]nice\
\[CloseCurlyDoubleQuote] numbers that divide the interval around 1910 to 1970 \
into equally spaced parts."
}], "Text",ExpressionUUID->"80738f31-20ab-2a49-a2d8-e35016d9c139"],

Cell["\<\
In addition, a single long dashed tick on the vertical axis is specified. \
This dash is drawn at the vertical value of 5, but given the label of 1/10:\
\>", "Text",ExpressionUUID->"35255309-1020-c345-a6ea-756b73e5b8a5"],

Cell[BoxData[
 RowBox[{"ticksFindDivision", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"FindDivisions", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1910", ",", "1970"}], "}"}], ",", "10"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"{", 
      RowBox[{"5", ",", "\"\<1/10\>\"", ",", 
       RowBox[{"{", 
        RowBox[{"0.55", ",", "0"}], "}"}], ",", 
       RowBox[{"Directive", "[", 
        RowBox[{"Dashed", ",", "Blue"}], "]"}]}], "}"}], "}"}]}], 
   "}"}]}]], "Input",
 CellLabel->
  "In[175]:=",ExpressionUUID->"5d6f0433-ebfd-d94e-bbf5-2eb0ac2be59a"],

Cell["Visualize the data with these sets of ticks:", "Text",ExpressionUUID->"afe8b4b9-8220-ec4f-8343-ae154148bcbf"],

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"data", ",", 
   RowBox[{"Ticks", "\[Rule]", "ticksFindDivision"}]}], "]"}]], "Input",
 CellLabel->
  "In[176]:=",ExpressionUUID->"ee4c9455-2e40-a243-af83-471fafcf4b67"],


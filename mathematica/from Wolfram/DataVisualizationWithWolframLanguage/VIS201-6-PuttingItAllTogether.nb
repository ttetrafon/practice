Cell[CellGroupData[{
Cell["Putting It All Together", "Subtitle",ExpressionUUID->"abd2714b-c40b-491d-9b98-1f3d249655e3"],

Cell[CellGroupData[{

Cell["Learning Objectives", "Section",ExpressionUUID->"a97f34a4-babe-4547-8f90-f67ece348d5f"],

Cell[CellGroupData[{

Cell["Complete a project from start to finish", "Subsubsection",ExpressionUUID->"197e0699-e308-4f07-af49-f0ad2b84da05"],

Cell["\<\
Now that you know the ins and outs of basic visualization in Wolfram \
Language, you can create some eye-catching visualizations.\
\>", "Text",ExpressionUUID->"0454faed-ab40-49a5-abbc-270c6dabc8d7"],

Cell["\<\
Data does not have to be boring. Aesthetically pleasing visualizations are \
straightforward to create in Wolfram Language.\
\>", "Text",ExpressionUUID->"1d6dab46-1a1d-439d-8c74-9240ae91e247"],

Cell[CellGroupData[{


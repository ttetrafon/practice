Cell[CellGroupData[{

Cell["Baby Names: Arrange in a Grid", "Section",ExpressionUUID->"63e5991c-1a5c-42de-8c84-f73d54f41ee7"],

Cell["Now that the names are selected, arrange them into a grid:", "Text",ExpressionUUID->"b4eaa718-70bd-174f-8094-f421c2dee683"],

Cell[BoxData[
 RowBox[{
  RowBox[{"entries", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"#", ",", "fontOptions"}], "]"}], ",", 
       RowBox[{"rankConvert", "[", "#", "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"yearsInTop2", "[", "#", "]"}], ",", "fontOptions"}], 
        "]"}]}], "}"}], "&"}], "/@", "top2"}]}], ";"}]], "Input",
 CellLabel->"In[76]:=",ExpressionUUID->"aee5e56a-7878-49b8-9364-1f4474a83266"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{"entries", ",", "\[IndentingNewLine]", 
   RowBox[{"Spacings", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0.5", ",", "0"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Alignment", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Right", ",", "Center", ",", "Center"}], "}"}], ",", 
      "Center"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Background", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"GrayLevel", "[", "0.95", "]"}], ",", "White"}], "}"}], 
       "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[77]:=",ExpressionUUID->"e5e3bdd5-1ed1-4bd4-ac0d-fdb2902bbe87"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baby Names: Create Date Labels", "Section",ExpressionUUID->"e51d0de9-5b73-42f0-a79c-4acafaf95417"],

Cell["\<\
Construct the tick marks to be used at the bottom of the plot:\
\>", "Text",ExpressionUUID->"67ab0321-7ff9-8842-8290-2aa1be4dfbdf"],

Cell[BoxData[
 RowBox[{"dates", "=", 
  RowBox[{"Graphics", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1908.5", ",", 
         RowBox[{"2015", "+", "1.5"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "2"}], "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRangePadding", "\[Rule]", "0"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ImageSize", "\[Rule]", "1000"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Frame", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"False", ",", "False"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"FrameTicks", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"i", "+", "0.5"}], ",", "i"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1900", ",", "2014", ",", "10"}], "}"}]}], 
            "]"}], ",", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"i", "+", "0.5"}], ",", "\"\<\>\""}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1915", ",", "2014", ",", "5"}], "}"}]}], 
            "]"}]}], "]"}], ",", "None"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"LabelStyle", "\[Rule]", 
     RowBox[{"Directive", "[", 
      RowBox[{"fontOptions", ",", 
       RowBox[{"FontSize", "\[Rule]", "17"}], ",", "Plain"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[79]:=",ExpressionUUID->"cab1da0d-4814-4c46-ac62-aa41762bb4a4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baby Names: Create Color Scale", "Section",ExpressionUUID->"43bb8a46-e062-4ce8-ae9d-7e1c43240593"],

Cell["\<\
A legend must be created so that users can understand the color coding that \
defines the ranking:\
\>", "Text",ExpressionUUID->"449564d0-ee97-a341-9a8f-d788ae719b7e"],

Cell[BoxData[
 RowBox[{"scale", "=", 
  RowBox[{"Grid", "[", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Rank\>\"", ",", "fontOptions"}], "]"}], ",", 
       "SpanFromLeft", ",", "SpanFromLeft"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<1\>\"", ",", "fontOptions"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Framed", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Graphics", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"myBlend", "/@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Range", "[", 
                  RowBox[{"0", ",", "49"}], "]"}], "/", "49"}], ")"}]}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"Rectangle", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"0", "+", "#1"}], ",", "0"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"1", "+", "#1"}], ",", "10"}], "}"}]}], "]"}], 
                "&"}], "/@", 
               RowBox[{"Range", "[", 
                RowBox[{"1910", ",", "1959"}], "]"}]}]}], "}"}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"ImageSize", "\[Rule]", "150"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"PlotRangePadding", "\[Rule]", "0"}]}], 
          "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"FrameMargins", "\[Rule]", 
          RowBox[{"-", "1"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"FrameStyle", "\[Rule]", "Gray"}]}], "\[IndentingNewLine]", 
        "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Style", "[", 
        RowBox[{"\"\<50\>\"", ",", "fontOptions"}], "]"}]}], 
      "\[IndentingNewLine]", "}"}]}], "}"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[81]:=",ExpressionUUID->"cadf13ab-fc1b-47c2-b335-38f2aa4317fa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baby Names: Add Scale and Labels", "Section",ExpressionUUID->"8038539e-34f7-4ece-92c6-ca0dc9137ff8"],

Cell["\<\
Bring together the grid, tick marks and legend into a single graphic:\
\>", "Text",ExpressionUUID->"86c90e4c-00e4-9440-94af-ff6131963e49"],

Cell[BoxData[
 RowBox[{
  RowBox[{"entriesWithScales", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"scale", ",", "\"\<\>\"", ",", "\"\<\>\""}], "}"}], "}"}], ",",
      "entries", ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"\"\<\>\"", ",", "dates", ",", "\"\<\>\""}], "}"}], "}"}]}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->"In[82]:=",ExpressionUUID->"ed33c165-f4aa-4929-bb35-0fca349d63d7"],

Cell[BoxData[
 RowBox[{"Column", "[", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{"scale", ",", "\[IndentingNewLine]", 
    RowBox[{"Labeled", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Grid", "[", 
       RowBox[{
        RowBox[{"Append", "[", 
         RowBox[{"entries", ",", 
          RowBox[{"{", 
           RowBox[{"\"\<\>\"", ",", "dates", ",", "\"\<\>\""}], "}"}]}], 
         "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Spacings", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Alignment", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Right", ",", "Center", ",", "Center"}], "}"}], ",", 
           "Center"}], "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Background", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"None", ",", 
           RowBox[{"{", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"GrayLevel", "[", "0.95", "]"}], ",", "White"}], "}"}], 
            "}"}]}], "}"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Rotate", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<Years in the top 2\>\"", ",", "fontOptions", ",", 
          "Plain", ",", 
          RowBox[{"FontSize", "\[Rule]", "17"}]}], "]"}], ",", 
        RowBox[{"3", " ", 
         RowBox[{"\[Pi]", "/", "2"}]}]}], "]"}], ",", "Right"}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "}"}], 
  "]"}]], "Input",
 CellLabel->"In[83]:=",ExpressionUUID->"11dcf6e5-8485-4a7b-be9f-0ede83009e7e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baby Names: Add Button Pane for Additional Names", "Section",ExpressionUUID->"3f830ee6-cf63-4b76-8da3-586c546a8932"],

Cell[BoxData[
 RowBox[{
  RowBox[{"all", "=", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"Append", "[", 
      RowBox[{"entries", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<\>\"", ",", "dates", ",", "\"\<\>\""}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<\>\"", ",", "\"\<\>\"", ",", "\"\<\>\""}], "}"}]}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->"In[84]:=",ExpressionUUID->"a17aa7b9-b5f5-44dc-809e-f8243871f9f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nameList", "=", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", "=", "i"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Button", "[", 
        RowBox[{"i", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"all", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{"i", ",", "fontOptions"}], "]"}], ",", 
            RowBox[{"rankConvert", "[", "i", "]"}], ",", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"yearsInTop2", "[", "i", "]"}], ",", "fontOptions"}], 
             "]"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Appearance", "\[Rule]", "\"\<Palette\>\""}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "uniqueNames"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[85]:=",ExpressionUUID->"8658117b-e669-40ab-96b4-66f9cdb12b73"],

Cell[BoxData[
 RowBox[{"paneSelector", "=", 
  RowBox[{"Panel", "[", 
   RowBox[{
    RowBox[{"Pane", "[", 
     RowBox[{
      RowBox[{"Grid", "[", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "nameList", "}"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"75", ",", "100"}], "}"}], ",", 
      RowBox[{"Scrollbars", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}], ",", 
    RowBox[{"FrameMargins", "\[Rule]", "None"}]}], "]"}]}]], "Input",
 CellLabel->"In[86]:=",ExpressionUUID->"a2b99bcb-1d35-4711-92c9-b320f34653bb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baby Names: Put It All Together", "Section",ExpressionUUID->"a1555645-9569-4930-89fd-c53a500fd8fc"],

Cell["\<\
Finally, include a button that selects a particular name and displays the \
data for that name at the top of the chart:\
\>", "Text",ExpressionUUID->"a43e3a57-af1d-f046-b979-e938f57bf782"],

Cell[BoxData[
 RowBox[{"g", "=", 
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{"Grid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"scale", ",", "\[IndentingNewLine]", 
            RowBox[{"Column", "[", 
             RowBox[{
              RowBox[{"{", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"Style", "[", 
                 
                 RowBox[{"\"\<A visual history of U.S. baby names\>\"", ",", 
                  "fontOptions", ",", "Plain", ",", 
                  RowBox[{"FontSize", "\[Rule]", "24"}]}], "]"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"Style", "[", 
                 
                 RowBox[{"\"\<Baby name popularity over 100 years\>\"", ",", 
                  "fontOptions", ",", "Plain", ",", 
                  RowBox[{"FontSize", "\[Rule]", "12"}]}], "]"}]}], 
               "\[IndentingNewLine]", "}"}], ",", 
              RowBox[{"Alignment", "\[Rule]", "Center"}]}], "]"}], ",", 
            "\[IndentingNewLine]", "paneSelector"}], "}"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Alignment", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Center", ",", "Center", ",", "Center"}], "}"}], ",", 
            "Center"}], "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Frame", "\[Rule]", "None"}], ",", "\[IndentingNewLine]", 
         RowBox[{"ItemSize", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"Full", ",", "60", ",", "Full"}], "}"}], ",", 
            "Automatic"}], "}"}]}]}], "]"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"Labeled", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Grid", "[", 
            RowBox[{"all", ",", "\[IndentingNewLine]", 
             RowBox[{"Spacings", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"Alignment", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"Right", ",", "Center", ",", "Center"}], "}"}], ",", 
                "Center"}], "}"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"Background", "\[Rule]", 
              RowBox[{"{", 
               RowBox[{"None", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"GrayLevel", "[", "0.95", "]"}], ",", "White"}], 
                    "}"}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "1"}], "\[Rule]", "White"}], "}"}]}], 
                 "}"}]}], "}"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"TrackedSymbols", "\[RuleDelayed]", 
            RowBox[{"{", "all", "}"}]}]}], "\[IndentingNewLine]", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"Rotate", "[", 
          RowBox[{
           RowBox[{"Style", "[", 
            
            RowBox[{"\"\<Years in the top 2\>\"", ",", "fontOptions", ",", 
             "Plain", ",", 
             RowBox[{"FontSize", "\[Rule]", "17"}]}], "]"}], ",", 
           RowBox[{"3", " ", 
            RowBox[{"\[Pi]", "/", "2"}]}]}], "]"}], ",", "Right"}], 
        "\[IndentingNewLine]", "]"}], "}"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Frame", "\[Rule]", "None"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ItemSize", "\[Rule]", "Full"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Background", "\[Rule]", "White"}]}], "\[IndentingNewLine]", 
   "]"}], 
  RowBox[{"(*", 
   RowBox[{"//", "Deploy"}], "*)"}]}]], "Input",
 CellLabel->"In[87]:=",ExpressionUUID->"b9d7e7d6-6639-43c9-8a4e-a1e20144a24a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two-Axis Plots", "Section",ExpressionUUID->"78a280ee-cf52-4500-bed0-5661f5d05bf3"],

Cell["\<\
Two-axis plots utilize both the left and right frames to convey information. \
The two frames are not on the same scale. Typically this is used to show \
trends in data that are related but whose scales differ greatly.\
\>", "Text",ExpressionUUID->"f28941cb-4435-4916-a3b5-b6c1d1ae1ac0"],

Cell["\<\
As an example, the total population of all US baby names across the years is \
much larger than any single contribution from any one name:\
\>", "Text",ExpressionUUID->"eab2fac0-2ed7-4451-9fca-80cbb3ab16c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"population", "=", 
   RowBox[{
    RowBox[{"Normal", "[", 
     RowBox[{"genderByYear", "[", 
      RowBox[{"All", ",", "\"\<Male\>\""}], "]"}], "]"}], "+", 
    RowBox[{"Normal", "[", 
     RowBox[{"genderByYear", "[", 
      RowBox[{"All", ",", "\"\<Female\>\""}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"popChart", "=", 
  RowBox[{"DateListPlot", "[", "population", "]"}]}]}], "Input",
 CellLabel->"In[88]:=",ExpressionUUID->"6bc09d3a-2c38-4cbb-8bf4-f1827eee77e9"],

Cell["\<\
Compare the preceding scale to any one name from the top names that peak in \
population:\
\>", "Text",ExpressionUUID->"46d735fb-f536-4aad-86bf-14fbb25fac47"],

Cell[BoxData[
 RowBox[{
  RowBox[{"top10", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<Linda\>\"", ",", "\"\<James\>\"", ",", "\"\<Michael\>\"", 
     ",", "\"\<Robert\>\"", ",", "\"\<John\>\"", ",", "\"\<David\>\"", 
     ",", "\"\<Mary\>\"", ",", "\"\<William\>\"", ",", "\"\<Jennifer\>\"", 
     ",", "\"\<Lisa\>\""}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"8441f8de-6034-4733-9e73-600a0253ba3b"],

Cell[BoxData[
 RowBox[{"LindaChart", "=", 
  RowBox[{"DateListPlot", "[", 
   RowBox[{"genderlessPopularityOverTime", "[", "\"\<Linda\>\"", "]"}], 
   "]"}]}]], "Input",
 CellLabel->"In[91]:=",ExpressionUUID->"8c3d9cfe-f91f-45ed-916e-83a191c46438"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two-Axis Plots: Show", "Section",ExpressionUUID->"995c3bb8-6674-4196-8e40-916ed7dea7df"],

Cell["\<\
Naively combining the two plots makes the relevant comparison difficult:\
\>", "Text",ExpressionUUID->"a19f7fa1-f88a-44a0-8bfe-cc4d6afbd984"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"popChart", ",", "LindaChart"}], "]"}]], "Input",
 CellLabel->"In[92]:=",ExpressionUUID->"1c227fa8-7f8d-4eaf-bce4-f70e26eaa394"],

Cell["\<\
Moreover, if you scale one dataset to match the other, then the displayed \
data no longer matches the true underlying data:\
\>", "Text",ExpressionUUID->"76c10a56-a5ad-4ab5-88e7-155cfd8d3745"],

Cell[BoxData[
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"Legended", "[", 
      RowBox[{"population", ",", "\"\<Total Population\>\""}], "]"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Black"}]}], "]"}], ",", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"Legended", "[", 
      RowBox[{
       RowBox[{"40", "*", 
        RowBox[{"Normal", "[", 
         RowBox[{"genderlessPopularityOverTime", "[", "\"\<Linda\>\"", "]"}], 
         "]"}]}], ",", "\"\<Linda (scaled to 40 times its true value)\>\""}], 
      "]"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[93]:=",ExpressionUUID->"584da946-a2c1-499d-a0bf-9bb8f4ec8bff"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two-Axis Plots: Making Date Ticks", "Section",ExpressionUUID->"7623996c-0b3f-47eb-b4fd-304bdb169e42"],

Cell[TextData[{
 StyleBox["You can still use ",
  FontSlant->"Plain"],
 StyleBox[ButtonBox["Show",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Show.html?q=Show"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Show.html?q=Show"],
  FontSlant->"Plain"],
 StyleBox[" to combine graphics, but it is often best to create your own \
ticks. ",
  FontSlant->"Plain"],
 StyleBox[ButtonBox["DateListPlot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/DateListPlot.html?q=\
DateListPlot"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/DateListPlot.html?q=\
DateListPlot"],
  FontSlant->"Plain"],
 StyleBox[" uses ",
  FontSlant->"Plain"],
 StyleBox[ButtonBox["AbsoluteTime",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/AbsoluteTime.html?q=\
AbsoluteTime"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/AbsoluteTime.html?q=\
AbsoluteTime"],
  FontSlant->"Plain"],
 StyleBox[" to arrange the data along the horizontal axis. Try to mimic what \
DateListPlot does automatically:",
  FontSlant->"Plain"]
}], "Text",
 FontSlant->"Italic",ExpressionUUID->"3a4370f5-a30d-40f2-8d55-94a7ca8721c9"],

Cell[BoxData[
 RowBox[{"LindaChart", "=", 
  RowBox[{"DateListPlot", "[", 
   RowBox[{
    RowBox[{"genderlessPopularityOverTime", "[", "\"\<Linda\>\"", "]"}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "]"}]}]], "Input",
 CellLabel->"In[94]:=",ExpressionUUID->"105ec5c2-76a8-44cc-b092-e09036fe9e58"],

Cell["\<\
First, create the ticks, ignoring the labels. The dates are given as years \
that run from 1900 to 2014 in steps of 5 years. Convert the years to \
AbsoluteTime but leave the labels blank. The length of the ticks is chosen to \
mimic the automatic tick lengths:\
\>", "Text",ExpressionUUID->"347edf22-e208-44b1-a34d-b6f08f4c7af5"],

Cell[BoxData[
 RowBox[{"unlabeledDateTicks", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"dates", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1900", ",", "2015", ",", "5"}], "}"}]}], "]"}]}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"AbsoluteTime", "/@", 
        RowBox[{"List", "/@", "dates"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"\"\<\>\"", ",", 
         RowBox[{"Length", "[", "dates", "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0.0075", ",", 
            RowBox[{"Length", "[", "dates", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "dates", "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[95]:=",ExpressionUUID->"cce47f99-ad30-444c-bee0-0a959ca87404"],

Cell["\<\
Second, create the labeled ticks. Labeled ticks are only every 25 years:\
\>", "Text",ExpressionUUID->"b5bfae74-61d1-4517-8fe4-bea72712bcb8"],

Cell[BoxData[
 RowBox[{"labeledDateTicks", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"dates", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1900", ",", "2015", ",", "25"}], "}"}]}], "]"}]}],
      "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"AbsoluteTime", "/@", 
        RowBox[{"List", "/@", "dates"}]}], ",", "\[IndentingNewLine]", 
       "dates", ",", "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0.0075", ",", 
            RowBox[{"Length", "[", "dates", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "dates", "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[96]:=",ExpressionUUID->"3f0a74b7-381f-4a59-97ef-7d8577906a11"],

Cell["\<\
Combine the ticks together. You have doubled the number of ticks at the \
labeled locations, but this is OK:\
\>", "Text",ExpressionUUID->"780bcaa2-501d-4eb4-a794-97edf73a9acc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allDateTicks", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"unlabeledDateTicks", ",", "labeledDateTicks"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[97]:=",ExpressionUUID->"388f8d46-a321-4094-8d7b-aa881fc8e876"],

Cell["\<\
Check that the ticks look appropriate compared to the originals:\
\>", "Text",ExpressionUUID->"3b5617dd-fc65-431c-8888-3ebdc9a45500"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{"LindaChart", ",", "\[IndentingNewLine]", 
    RowBox[{"Graphics", "[", 
     RowBox[{
      RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"AspectRatio", "\[Rule]", 
       RowBox[{"1", "/", "GoldenRatio"}]}], ",", 
      RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"AbsoluteTime", "[", 
            RowBox[{"{", "2015", "}"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100000"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"FrameTicks", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Automatic", ",", "Automatic"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"allDateTicks", ",", "unlabeledDateTicks"}], "}"}]}], 
        "}"}]}], ",", 
      RowBox[{"PlotRangePadding", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Scaled", "[", "0.02", "]"}], ",", 
         RowBox[{"Scaled", "[", "0.04", "]"}]}], "}"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "}"}], 
  "]"}]], "Input",
 CellLabel->"In[98]:=",ExpressionUUID->"9d4e345f-b0de-400e-8c48-e1bf3dc03a29"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Two-Axis Plots: Making ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "be83dfc0-9a24-48c3-a98f-719c01948fe3"],
 " Ticks"
}], "Section",ExpressionUUID->"f638ed6b-bc22-41e3-b885-be941626907a"],

Cell["\<\
The procedure is similar to making date ticks, except that you do not need to \
scale to AbsoluteTime. First, create the ticks, ignoring the labels. The \
values are given from 0 to 100,000 in steps of 5,000. The length of the ticks \
is chosen to mimic the automatic tick lengths:\
\>", "Text",ExpressionUUID->"03623d65-f925-4072-8a44-4f7e6edbc3c6"],

Cell[BoxData[
 RowBox[{"unlabeledYTicks", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"values", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "100000", ",", "5000"}], "}"}]}], 
       "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"values", ",", "\[IndentingNewLine]", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"\"\<\>\"", ",", 
         RowBox[{"Length", "[", "values", "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0.0075", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[99]:=",ExpressionUUID->"24c67958-a982-4ecf-acc0-1d01cd8a1765"],

Cell["\<\
Second, create the labeled ticks. Labeled ticks are only every 20,000:\
\>", "Text",ExpressionUUID->"c5d33c79-9c24-4e84-8526-ad63c44fed79"],

Cell[BoxData[
 RowBox[{"labeledYTicks", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"values", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "100000", ",", "20000"}], "}"}]}], 
       "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
      "values", ",", "\[IndentingNewLine]", "values", ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0.012", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->
  "In[100]:=",ExpressionUUID->"55e8e659-710e-46e3-ac37-cc1ee42c3952"],

Cell["\<\
Combine the ticks together. You have doubled the number of ticks at the \
labeled locations, but this is OK:\
\>", "Text",ExpressionUUID->"5354458a-dadf-4710-abd1-4a02ebe92885"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allYTicks", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"unlabeledYTicks", ",", "labeledYTicks"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[101]:=",ExpressionUUID->"c6cc3dae-7d31-4fbb-a6d3-67e2dee89ca3"],

Cell["\<\
Check that the ticks look appropriate compared to the originals:\
\>", "Text",ExpressionUUID->"3d5d10d8-6ddd-4b33-be57-c53de9476812"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{"LindaChart", ",", "\[IndentingNewLine]", 
    RowBox[{"Graphics", "[", 
     RowBox[{
      RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"AspectRatio", "\[Rule]", 
       RowBox[{"1", "/", "GoldenRatio"}]}], ",", 
      RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"AbsoluteTime", "[", 
            RowBox[{"{", "2015", "}"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100000"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"FrameTicks", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"allYTicks", ",", "unlabeledYTicks"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"allDateTicks", ",", "unlabeledDateTicks"}], "}"}]}], 
        "}"}]}], ",", 
      RowBox[{"PlotRangePadding", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Scaled", "[", "0.02", "]"}], ",", 
         RowBox[{"Scaled", "[", "0.04", "]"}]}], "}"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "}"}], 
  "]"}]], "Input",
 CellLabel->
  "In[102]:=",ExpressionUUID->"f80e8a42-1af1-4601-b664-506edda22d3a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Two-Axis Plots: Making Alt-",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "d38a9509-788c-4553-83ed-d4382ebd13ff"],
 " Ticks"
}], "Section",ExpressionUUID->"41de158e-df8a-4806-94a8-88c09b385a2a"],

Cell["The total population runs from 0 to 4 million:", "Text",ExpressionUUID->"2544ea3e-6065-4317-a4f0-731b41d552d2"],

Cell[BoxData[
 RowBox[{"DateListPlot", "[", "population", "]"}]], "Input",
 CellLabel->
  "In[103]:=",ExpressionUUID->"f227c5b2-a94e-4ffd-9d0a-16742cc656c1"],

Cell[TextData[{
 "Use the ",
 ButtonBox["Rescale",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Rescale.html?q=Rescale"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Rescale.html?q=Rescale"],
 " function to convert the total population to the same scale as the peak \
population data, which runs from 0 to 100,000:"
}], "Text",ExpressionUUID->"a21dd532-3e69-4d61-b2ae-26e4b13cb943"],

Cell[BoxData[
 RowBox[{"DateListPlot", "[", 
  RowBox[{"AssociationThread", "[", 
   RowBox[{
    RowBox[{"Keys", "[", "population", "]"}], ",", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"v", "=", 
        RowBox[{"Values", "[", "population", "]"}]}], "}"}], ",", 
      RowBox[{"Rescale", "[", 
       RowBox[{"v", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"Max", "[", "v", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "100000"}], "}"}]}], "]"}]}], "]"}]}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[104]:=",ExpressionUUID->"80ca63ac-94d2-481a-b6b7-de1c13f0566d"],

Cell["\<\
The ticks undergo the same scaling. First, create the ticks, ignoring labels:\
\>", "Text",ExpressionUUID->"a2ebbf4b-f828-42fe-b58f-0f6eb684a4bf"],

Cell[BoxData[
 RowBox[{"unlabeledYaltTicks", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"values", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", 
          RowBox[{"4", " ", 
           SuperscriptBox["10", "6"]}], ",", "200000"}], "}"}]}], "]"}]}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Rescale", "[", 
        RowBox[{"values", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"QuantityMagnitude", "[", 
            RowBox[{"Max", "[", 
             RowBox[{"Values", "[", "population", "]"}], "]"}], "]"}]}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100000"}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"\"\<\>\"", ",", 
         RowBox[{"Length", "[", "values", "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0.0075", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->
  "In[105]:=",ExpressionUUID->"dfa82c53-970c-468e-beb9-82aa96021d50"],

Cell["\<\
Add those ticks that have labels. The labels are created by hand to look like \
the scientific form from the original graphics:\
\>", "Text",ExpressionUUID->"e70a537c-3e67-4e75-a081-e9d57c0118b7"],

Cell[BoxData[
 RowBox[{"labeledYaltTicks", "=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"values", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"i", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", 
          RowBox[{"4", " ", 
           SuperscriptBox["10", "6"]}], ",", 
          RowBox[{"1", " ", 
           SuperscriptBox["10", "6"]}]}], "}"}]}], "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Rescale", "[", 
        RowBox[{"values", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"QuantityMagnitude", "[", 
            RowBox[{"Max", "[", 
             RowBox[{"Values", "[", "population", "]"}], "]"}], "]"}]}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100000"}], "}"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "0", "}"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ToString", "[", "i", "]"}], 
            "<>", "\"\<\[Times]\!\(\*SuperscriptBox[\(10\), \(6\)]\)\>\""}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0.012", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"Length", "[", "values", "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "}"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->
  "In[106]:=",ExpressionUUID->"706e7237-b50d-4743-9c2a-dcbb3e91f74a"],

Cell["\<\
Combine the ticks together. You have doubled the number of ticks at the \
labeled locations, but this is OK:\
\>", "Text",ExpressionUUID->"24816fe3-a890-481f-b2dd-8e39b952af62"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allYaltTicks", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"unlabeledYaltTicks", ",", "labeledYaltTicks"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[107]:=",ExpressionUUID->"ca2eb4a6-91d7-4a2e-bdda-85406f7c15dc"],

Cell["\<\
Check that the ticks look appropriate compared to the originals:\
\>", "Text",ExpressionUUID->"1a153f26-3fb9-44e0-a0ab-1ca943efe330"],

Cell[BoxData[
 RowBox[{"DateListPlot", "[", 
  RowBox[{
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"Keys", "[", "population", "]"}], ",", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"v", "=", 
         RowBox[{"Values", "[", "population", "]"}]}], "}"}], ",", 
       RowBox[{"Rescale", "[", 
        RowBox[{"v", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"Max", "[", "v", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100000"}], "}"}]}], "]"}]}], "]"}]}], "]"}], ",", 
   RowBox[{"FrameTicks", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "allYaltTicks"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "Automatic"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "]"}]], "Input",
 CellLabel->
  "In[108]:=",ExpressionUUID->"e9603a51-890c-4b21-8472-139ebca74025"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two-Axis Plots: Add Graphic Styling", "Section",ExpressionUUID->"e051dd43-59fd-4fcf-82c5-76271493f1d2"],

Cell["\<\
Make the total population stand out, as this acts like the background:\
\>", "Text",ExpressionUUID->"0784ae29-2b25-4ff9-9aaf-5b3af55960ab"],

Cell[BoxData[
 RowBox[{"popChart", "=", 
  RowBox[{"DateListPlot", "[", 
   RowBox[{
    RowBox[{"AssociationThread", "[", 
     RowBox[{
      RowBox[{"Keys", "[", "population", "]"}], ",", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"v", "=", 
          RowBox[{"Values", "[", "population", "]"}]}], "}"}], ",", 
        RowBox[{"Rescale", "[", 
         RowBox[{"v", ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"Max", "[", "v", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "100000"}], "}"}]}], "]"}]}], "]"}]}], "]"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Black"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[109]:=",ExpressionUUID->"0d26e165-ecc2-41c9-b5fb-1279606bb88a"],

Cell["\<\
Choose a distinct set of colors for the top 10 contributors to the total \
population:\
\>", "Text",ExpressionUUID->"3d23ec8f-7460-40e5-b130-a8255166d959"],

Cell[BoxData[
 RowBox[{"colors", "=", 
  RowBox[{
   RowBox[{"ColorData", "[", "63", "]"}], "/@", 
   RowBox[{"Range", "[", "10", "]"}]}]}]], "Input",
 CellLabel->
  "In[110]:=",ExpressionUUID->"a0dfb339-a860-4a3d-98b2-a8986d5b0652"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "LindaChart", ",", "JamesChart", ",", "MichaelChart", ",", "RobertChart", 
     ",", "JohnChart", ",", "DavidChart", ",", "MaryChart", ",", 
     "WilliamChart", ",", "JenniferChart", ",", "LisaChart"}], "}"}], " ", "=", 
   RowBox[{"MapThread", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"DateListPlot", "[", 
       RowBox[{
        RowBox[{"genderlessPopularityOverTime", "[", "#1", "]"}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", "#2"}]}], "]"}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"top10", ",", "colors"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[111]:=",ExpressionUUID->"7e172216-ba8f-448c-b702-bad2f92c6a6e"],

Cell["\<\
Create a set of labels to act as a legend, following the same color scheme:\
\>", "Text",ExpressionUUID->"83480e3b-8281-46b2-9acf-5e2c04bd3e4a"],

Cell[BoxData[
 RowBox[{"labels", "=", 
  RowBox[{"MapThread", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Style", "[", 
      RowBox[{"#1", ",", "#2", ",", "Bold", ",", 
       RowBox[{"FontSize", "\[Rule]", "16"}]}], "]"}], "&"}], ",", 
    RowBox[{"{", 
     RowBox[{"top10", ",", "colors"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[112]:=",ExpressionUUID->"1e6f5c3f-429b-405c-8a94-f2e003cb8f27"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Two-Axis Plots: Dynamic Controls", "Section",ExpressionUUID->"45eadf06-5073-435a-9afa-eb59fdf8210e"],

Cell[TextData[{
 "If you show all 10 top contributors at the same time, then the graphics can \
become too busy to read. Make a ",
 ButtonBox["CheckboxBar",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/CheckboxBar.html?q=\
CheckboxBar"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/CheckboxBar.html?q=\
CheckboxBar"],
 " to select which contributors to display. This will be used as a dynamic \
legend:"
}], "Text",ExpressionUUID->"306e756e-9fb2-411f-8faf-86b8cf34278e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"selection", "=", 
   RowBox[{"{", "}"}]}], ";", 
  RowBox[{"activeLegend", "=", 
   RowBox[{"Panel", "[", 
    RowBox[{"Grid", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<Top 10 Contributors\>\"", ",", "18"}], "]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"CheckboxBar", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "selection", "]"}], ",", 
           RowBox[{"Thread", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
              "LindaChart", ",", "JamesChart", ",", "MichaelChart", ",", 
               "RobertChart", ",", "JohnChart", ",", "DavidChart", ",", 
               "MaryChart", ",", "WilliamChart", ",", "JenniferChart", ",", 
               "LisaChart"}], "}"}], "\[Rule]", "labels"}], "]"}], ",", 
           RowBox[{"Appearance", "\[Rule]", 
            RowBox[{"\"\<Horizontal\>\"", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{"Automatic", ",", "2"}], "}"}]}]}]}], "]"}], "}"}]}], 
       "}"}], ",", 
      RowBox[{"Spacings", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"2", ",", "1"}], "}"}]}]}], "]"}], "]"}]}]}]], "Input",
 CellLabel->
  "In[113]:=",ExpressionUUID->"45c7d2e7-814a-4fac-af39-83159482bcd1"],

Cell[TextData[{
 "Add labels to distinguish the two ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "cc96e228-db80-4996-9377-c4c38f4f581e"],
 " axes:"
}], "Text",ExpressionUUID->"64f44228-ecac-4523-b619-43572fa91e90"],

Cell[BoxData[
 RowBox[{"finalChart", "=", 
  RowBox[{"Dynamic", "[", "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"selection", ",", "popChart", ",", "\[IndentingNewLine]", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "100000"}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"FrameTicks", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"allYTicks", ",", "allYaltTicks"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"allDateTicks", ",", "None"}], "}"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Individual Populations\>\"", ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<Total Population\>\"", ",", "Black", ",", "Bold"}], 
           "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\"\<Date\>\"", ",", "None"}], "}"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "\[IndentingNewLine]", 
    "]"}], "]"}]}]], "Input",
 CellLabel->
  "In[114]:=",ExpressionUUID->"c29b1c50-f695-4251-aa0e-6a9e8b62de67"],

Cell[TextData[{
 "Combine the dynamic Show with the dynamic legend using ",
 ButtonBox["Legended",
  BaseStyle->"Hyperlink",
  ButtonData->{

, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Legended.html?q=Legended"],
 ":"
}], "Text",ExpressionUUID->"75cc2099-fba6-4fd1-b481-dff0329a04f3"],

Cell[BoxData[
 RowBox[{"Framed", "[", 
  RowBox[{
   RowBox[{"Legended", "[", 
    RowBox[{"finalChart", ",", "activeLegend"}], "]"}], ",", 
   RowBox[{"Background", "\[Rule]", "White"}], ",", 
   RowBox[{"FrameStyle", "\[Rule]", 
    RowBox[{"GrayLevel", "[", "0.95", "]"}]}]}], "]"}]], "Input",
 CellLabel->

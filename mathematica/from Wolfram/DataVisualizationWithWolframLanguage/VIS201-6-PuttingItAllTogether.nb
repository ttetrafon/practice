    "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1910", "-", "1.5"}], ",", 
         RowBox[{"2015", "+", "1.5"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "2"}], "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"ImageSize", "\[Rule]", "1000"}]}], "]"}]}]], "Input",
 CellLabel->"In[73]:=",ExpressionUUID->"f70a701c-a872-440d-89ca-dfa3947010ed"],

Cell["Choose a nice font:", "Text",ExpressionUUID->"3da6b206-f4c7-439d-b6ec-0ab1bb2a2753"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fontOptions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"FontColor", "\[Rule]", "Gray"}], ",", 
     RowBox[{"FontFamily", "\[Rule]", "\"\<Arial CE\>\""}], ",", "Bold"}], 
    "}"}]}], ";"}]], "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"4d50cca2-a9cc-4f3b-8f1c-867fae63d58a"],

Cell[BoxData[
 RowBox[{"Style", "[", 
  RowBox[{"\"\<Mary\>\"", ",", "fontOptions"}], "]"}]], "Input",
 CellLabel->"In[75]:=",ExpressionUUID->"2e0d3f85-1840-46b4-b90b-49c6cf4cd1e1"]

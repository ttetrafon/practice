Cell[BoxData[
 RowBox[{"DateListPlot", "[", 
  RowBox[{"maryExample", ",", "\[IndentingNewLine]", 
   RowBox[{"ColorFunction", "\[Rule]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"myBlend", "[", "#2", "]"}], "&"}], ")"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "1910", "}"}], ",", 
        RowBox[{"{", "2014", "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "50"}], "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[70]:=",ExpressionUUID->"dc9a856a-8ed5-48db-a041-854ba91703de"],

Cell["\<\
The vertical value is now correlated with a particular color value. Thus, the \
same information can be encoded as a bar of colors:\
\>", "Text",ExpressionUUID->"c4deaece-7967-42c7-8f5b-39994aafd259"],

Cell[BoxData[
 RowBox[{
  RowBox[{"convert", "[", 
   RowBox[{"date_", ",", "rank_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"myBlend", "[", 
     FractionBox[
      RowBox[{"rank", "-", "1"}], "49"], "]"}], ",", 
    RowBox[{"Rectangle", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"date", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "+", 
         RowBox[{"date", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", "2"}], "}"}]}], 
     "]"}]}], "}"}]}]], "Input",
 CellLabel->"In[71]:=",ExpressionUUID->"a6b7cd78-0c63-4283-a6b8-777c6269224a"],

Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{
   RowBox[{"Normal", "[", 
    RowBox[{"maryExample", "[", 
     RowBox[{"DeleteMissing", "/*", 
      RowBox[{"KeyValueMap", "[", "convert", "]"}]}], "]"}], "]"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1910", ",", "2015"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "2"}], "}"}]}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[72]:=",ExpressionUUID->"3e07ed38-4e8b-4b1a-b574-1d6178c69d82"],

Cell["\<\
Rank convert. Use a larger image size so the image is as large as the chosen \
font:\
\>", "Text",ExpressionUUID->"2cd2c485-4346-4615-814e-6db223b762f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rankConvert", "[", "name_String", "]"}], ":=", 
  RowBox[{"Graphics", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Normal", "[", 
     RowBox[{
      RowBox[{"genderlessTop50perYear", "[", 
       RowBox[{"All", ",", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"#Name", "\[Equal]", "name"}], "&"}], "]"}], "/*", 
         "First"}], ",", "\"\<Rank\>\""}], "]"}], "[", 
      RowBox[{"DeleteMissing", "/*", 

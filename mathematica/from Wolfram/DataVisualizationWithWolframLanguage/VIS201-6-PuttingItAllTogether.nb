Cell[BoxData[{
 RowBox[{
  RowBox[{"cExport", "[", 
   RowBox[{"filename_", ",", "data_"}], "]"}], ":=", 
  RowBox[{"Export", "[", 
   RowBox[{"filename", ",", 
    RowBox[{"Compress", "[", "data", "]"}], ",", "\"\<String\>\""}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cImport", "[", "filename_", "]"}], ":=", 
  RowBox[{"Uncompress", "[", 
   RowBox[{"Import", "[", 
    RowBox[{"filename", ",", "\"\<String\>\""}], "]"}], "]"}]}]}], "Input",
 InitializationCell->

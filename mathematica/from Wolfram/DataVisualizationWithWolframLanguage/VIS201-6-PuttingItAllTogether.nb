Cell[CellGroupData[{

Cell["Example: BubbleChart", "Section",ExpressionUUID->"be59ef5b-1e2f-4978-87a4-4063fb8076d7"],

Cell[TextData[{
 "The next few slides go over how to create and combine a couple of \
interactive charts that make use of the literacy, life expectancy and \
population data for different countries that is available as part of the \
built-in ",
 ButtonBox["CountryData",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/CountryData.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/CountryData.html"],
 ". The final result will be a bubble chart of life expectancy against the \
literacy rate for each country, along with a bar chart of the population \
trend for each country."
}], "Text",ExpressionUUID->"af2177c7-3d2e-4ab9-96b3-317b0dcd0443"],

Cell[CellGroupData[{

Cell["Get the Data", "Subsection",ExpressionUUID->"8cd3b202-42d2-4417-be55-0243b1b1d9d9"],

Cell[TextData[{
 "Additionally, you are going to keep information about what country you have \
and what the primary continent is. Because ",
 Cell[BoxData["\"\<LiteracyFraction\>\""], "Input",ExpressionUUID->
  "2d9472ed-4522-49f8-bbe0-46a0d1e1b3b0"],
 " in Wolfram Language is normally expressed as a number between 0 and 1, you \
are going to multiply it by 100 to express it as a percentage:"
}], "Text",ExpressionUUID->"1eb970b1-36e6-4c69-88b3-e92bd20218ae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"country", ",", "\[IndentingNewLine]", 
       RowBox[{"100", "*", 
        RowBox[{"CountryData", "[", 
         RowBox[{"country", ",", "\"\<LiteracyFraction\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<LifeExpectancy\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<Population\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<Continent\>\""}], "]"}]}], 
      "\[IndentingNewLine]", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"country", ",", 
       RowBox[{"CountryData", "[", "]"}]}], "}"}]}], "]"}]}], ";"}]], "Input",\
ExpressionUUID->"b04daa60-0c3d-4fd8-861f-3f9afd14f6a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"DeleteMissing", "[", 
    RowBox[{"data", ",", "1", ",", "Infinity"}], "]"}]}], ";"}]], "Input",Expr\
essionUUID->"ab0e8f12-0b94-4319-aced-bf33482831bd"],

Cell["\<\
Take a look at a sample of the data, and you can see you have the country, \
literacy fraction expressed as a percent, life expectancy, population and \
continent. Several continents are represented in the table here:\
\>", "Text",ExpressionUUID->"6a2fb885-20e0-43aa-bdb4-8142e7f455f7"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"RandomSample", "[", 
    RowBox[{"data", ",", "5"}], "]"}], ",", 
   RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}]], "Input",ExpressionUUID->\
"cd6484be-d419-4b9b-b54f-5be8d988817d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart Example: Standard Plot with Labels", "Section",ExpressionUUID->"5cbc2471-67a8-4bd4-84da-659c9ae6f6fa"],

Cell[TextData[{
 "Create a basic chart using the literacy fraction, the life expectancy and \
the population. These are in the second, third and fourth columns, \
respectively. Here, ",
 ButtonBox["All",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/All.html?q=All"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/All.html?q=All"],
 " is used to indicate that you want to extract the data for every row in the \
table."
}], "Text",ExpressionUUID->"a1a3857f-0ecf-4524-9256-481f434b7ae3"],

Cell["\<\
The BubbleChart has an automatic interaction where each bubble has a little \
highlighting effect, and the size of the bubble, which in this case is the \
population, is represented in a tooltip:\
\>", "Text",ExpressionUUID->"7c7c4a85-a2b9-49d8-ba33-d228c781a980"],

Cell[BoxData[
 RowBox[{"BubbleChart", "[", 
  RowBox[{
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "4"}], "}"}]}], "]"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Literacy rate\>\"", ",", "\"\<Life expectancy\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "\[Rule]", "\"\<Literacy Rate vs. Life Expectancy vs. Population\>\""}]}],
   "]"}]], "Input",ExpressionUUID->"7228c23a-b6ea-4b97-88cf-2aaa0f0053e0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart Example: Group Data by Continent", "Section",ExpressionUUID->"32c1ce2f-5b0b-4577-a31a-f6a36c3e1de5"],

Cell["\<\
The visualization is a little busy. To make it easier to distinguish, create \
separate datasets grouped by continent:\
\>", "Text",ExpressionUUID->"458adb96-08a4-4c22-bd37-718d22a0160c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"continentData", "=", 
   RowBox[{"SplitBy", "[", 
    RowBox[{
     RowBox[{"SortBy", "[", 
      RowBox[{"data", ",", "Last"}], "]"}], ",", "Last"}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"dd06dcc5-cdb2-4208-b6e8-007c3e9475e0"],

Cell["\<\
The first item in the new dataset is a subset representing all of the \
countries in Africa, and you have all of the same information carried through \
to that new dataset:\
\>", "Text",ExpressionUUID->"1c0ab546-c2b3-48fb-9d89-6a335e735b9f"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"RandomSample", "[", 
    RowBox[{
     RowBox[{"First", "[", "continentData", "]"}], ",", "3"}], "]"}], ",", 
   RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"146b4ff5-dcf6-44f8-a6f5-7a020c5be022"],

Cell["\<\
Since splitting the data added another level, include another All to plot the \
data:\
\>", "Text",ExpressionUUID->"73ba8db9-1a6e-4318-be4d-3d406a6802f6"],

Cell[BoxData[
 RowBox[{"BubbleChart", "[", 
  RowBox[{
   RowBox[{"continentData", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "4"}], "}"}]}], "]"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Literacy rate\>\"", ",", "\"\<Life expectancy\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "\[Rule]", "\"\<Literacy Rate vs. Life Expectancy vs. Population\>\""}]}],
   "]"}]], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"878bacc9-4032-4316-8acf-b4027003f072"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart Example: Add a Legend", "Section",ExpressionUUID->"7575646f-1cbc-4a95-a407-8cd6a517102b"],

Cell["\<\
Extract the continent from the first item in each dataset to use later for a \
legend:\
\>", "Text",ExpressionUUID->"fb265fda-a188-4c21-8382-29dde8283208"],

Cell[BoxData[
 RowBox[{"continents", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Last", "[", 
     RowBox[{"First", "[", "#", "]"}], "]"}], "&"}], "/@", 
   "continentData"}]}]], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"560a978e-bc17-4033-acbe-04945da2cd26"],

Cell[BoxData[
 RowBox[{"BubbleChart", "[", 
  RowBox[{
   RowBox[{"continentData", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "All", ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "4"}], "}"}]}], "]"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Literacy rate\>\"", ",", "\"\<Life expectancy\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "\[Rule]", "\"\<Literacy Rate vs. Life Expectancy vs. Population\>\""}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"ChartLegends", "\[Rule]", "continents"}]}], "\[IndentingNewLine]",
   "]"}]], "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"616529aa-fce1-4c04-a2c5-1459a4438b5d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart Example: Change Tooltip", "Section",ExpressionUUID->"0e0a1a23-1abf-48b0-aa77-111bbd2d1bb0"],

Cell[TextData[{
 "Now change the tooltips on the bubbles from the population to the country \
name. Write a function called ",
 Cell[BoxData[
 "label"], "Input",ExpressionUUID->"df7777f1-d6c8-4f16-bdc8-9394e18e8931"],
 " that will add explicit tooltips to each data point. You can apply this \
function to the data using ",
 ButtonBox["Map",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Map.html?q=Map"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Map.html?q=Map"],
 " with a level specification:"
}], "Text",ExpressionUUID->"beda79e0-f03d-4695-be31-71da769a7f93"],

Cell[BoxData[
 RowBox[{
  RowBox[{"label", "[", 
   RowBox[{"{", 
    RowBox[{"country_", ",", "x_", ",", "y_", ",", "z_", ",", "continent_"}], 
    "}"}], "]"}], ":=", 
  RowBox[{"Tooltip", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "country"}], 
   "]"}]}]], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"7d967be3-ce25-4d05-8ab4-f8ad8d1a9702"],

Cell[BoxData[
 RowBox[{
  RowBox[{"splitdata", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"label", ",", "continentData", ",", 
     RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"551a372e-2494-4e51-b724-4e1dc246a1d7"],

Cell[TextData[{
 "Since you have put the data into a format that is expected of BubbleChart, \
you no longer need to use the ",
 ButtonBox["Part",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Part.html?q=Part"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Part.html?q=Part"],
 " function:"
}], "Text",ExpressionUUID->"704347a2-0040-46cc-801f-1b51642da451"],

Cell[BoxData[
 RowBox[{"BubbleChart", "[", 
  RowBox[{"splitdata", ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Literacy rate\>\"", ",", "\"\<Life expectancy\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "\[Rule]", "\"\<Literacy Rate vs. Life Expectancy vs. Population\>\""}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"ChartLegends", "\[Rule]", "continents"}]}], "\[IndentingNewLine]",
   "]"}]], "Input",
 CellLabel->"In[23]:=",ExpressionUUID->"b19f5949-44d7-4bc8-979b-aec5a909b1bf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["An Aside: Add a BarChart of Populations", "Section",ExpressionUUID->"ba43a8df-5fd7-4c10-83ad-1ae006320cf1"],

Cell[TextData[{
 "Since the bubble sizes are proportional to the population of each country, \
it might be interesting to also see how the population changes over time. Use \
",
 ButtonBox["Wolfram|Alpha",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.wolframalpha.com"], None}],
 " from within the notebook to get the values, including estimated population \
for dates in the future:"
}], "Text",ExpressionUUID->"efadf2ca-7726-4533-a57b-7dac36b88851"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"years", "=", 
   RowBox[{"{", 
    RowBox[{
    "1910", ",", "1920", ",", "1930", ",", " ", "1940", ",", "1950", ",", 
     "1960", ",", "1970", ",", "1980", ",", "1990", ",", "2000", ",", "2010", 
     ",", "2020", ",", "2030"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"populationTimeSeries", "=", 
   RowBox[{
    RowBox[{"EntityProperty", "[", 
     RowBox[{"\"\<Country\>\"", ",", "\"\<Population\>\"", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", "\[Rule]", 
        RowBox[{"Interval", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"DateObject", "[", 
            RowBox[{"{", "1910", "}"}], "]"}], ",", 
           RowBox[{"DateObject", "[", 
            RowBox[{"{", "2030", "}"}], "]"}]}], "}"}], "]"}]}], "}"}]}], 
     "]"}], "[", 
    RowBox[{"Entity", "[", 
     RowBox[{"\"\<Country\>\"", ",", "\"\<US\>\""}], " ", "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dates", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"i", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1910", ",", "2030", ",", "10"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"population", "=", 
  RowBox[{"Map", "[", 
   RowBox[{"populationTimeSeries", ",", "dates"}], "]"}]}]}], "Input",
 CellLabel->"In[36]:=",ExpressionUUID->"b8cb9239-91b7-4e53-954d-06b5bcedb06c"],

Cell["\<\
When making the chart, it is easier to work with the years and populations \
separately, giving a list of years and a list of corresponding populations.\
\>", "Text",ExpressionUUID->"6986aa2b-a153-4cb7-bd4c-d9048bab05e3"],

Cell["\<\
Next, construct a bar chart of the populations and put the years as labels at \
the bottoms of the bars:\
\>", "Text",ExpressionUUID->"3bbf7fe3-7369-49e5-a819-cdc4b7ad3b0e"],

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{"population", ",", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"Placed", "[", 
     RowBox[{
      RowBox[{"{", "years", "}"}], ",", 
      RowBox[{"{", "Below", "}"}]}], "]"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]], "Input",
 CellLabel->"In[40]:=",ExpressionUUID->"df962bd8-27ca-46bd-8a99-81ed7f9aec98"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BarChart: Adjust Labels and Styling", "Section",ExpressionUUID->"0c7ffa21-ef5b-47d3-9ae3-3cdbb8b28c9d"],

Cell["\<\
Now, make the chart look a bit crisper. You can write a little bit of code to \
make the numbers easier to read by factoring out whether the population is in \
the thousands, millions or billions, and show the relevant amount of detail. \
In this case, the base is six, representing millions of people in the chart:\
\>", "Text",ExpressionUUID->"7ea6d088-7268-4f04-8be5-47ac45085fc7"],

Cell[BoxData[
 RowBox[{"base", "=", 
  RowBox[{"Floor", "[", 
   RowBox[{
    RowBox[{"Log10", "[", 
     RowBox[{"First", "[", 
      RowBox[{"QuantityMagnitude", "/@", "population"}], "]"}], "]"}], ",", 
    "3"}], "]"}]}]], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"ab35d114-6b44-44d2-9e83-144a74cfb9cc"],

Cell["\<\
Next, adjust the appearance of the chart by removing the axis and changing \
the aspect ratio. You will also adjust the labels so that the years are below \
the bars and the factored populations are above the bars. Additionally, set \
the plot label to a string that dynamically depends on the base and correctly \
updates the text accordingly. You end up with a chart that shows the \
population every decade in millions of people:\
\>", "Text",ExpressionUUID->"2c6fa7a9-a3ec-46a5-a1db-6186f3b71cb5"],

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{"population", ",", "\[IndentingNewLine]", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"Placed", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"years", ",", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"QuantityMagnitude", "/@", "population"}], ")"}], "/", 
          RowBox[{"10", "^", "base"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Below", ",", "Above"}], "}"}]}], "]"}]}], ",", 
   RowBox[{"Axes", "\[Rule]", "None"}], ",", "\[IndentingNewLine]", 
   RowBox[{"AspectRatio", "\[Rule]", 
    RowBox[{"1", "/", "3"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "\[Rule]", 
    RowBox[{"Row", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<Decennial Population in \>\"", ",", 
       RowBox[{"Switch", "[", 
        RowBox[{
        "base", ",", "0", ",", "\"\<People\>\"", ",", "3", 
         ",", "\"\<Thousands\>\"", ",", "6", ",", "\"\<Millions\>\"", ",", 
         "9", ",", "\"\<Billions\>\""}], "]"}]}], "}"}], "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[42]:=",ExpressionUUID->"454cfe7b-5846-4caa-91b7-d49760794614"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BarChart: Label Estimated Data", "Section",ExpressionUUID->"3470f51f-7278-4e3a-8827-cce8d390d27a"],

Cell[TextData[{
 "Since the 2030 data is estimated, it would be useful to change how it looks \
and label it as such. You can do this by using ",
 ButtonBox["MapAt",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/MapAt.html?q=MapAt"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/MapAt.html?q=MapAt"],
 " to apply wrappers to the last element in the list. Use the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], $CellContext`MR]],ExpressionUUID->
  "92f1c6d0-73d6-4d35-adb7-983cb85e9f1f"],
 " position to represent the last element. Specifically, you are going to use \
",
 ButtonBox["Style",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Style.html?q=Style"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Style.html?q=Style"],
 " with a light orange color and use ",
 ButtonBox["Labeled",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Labeled.html?q=Labeled"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Labeled.html?q=Labeled"],
 " to add an additional label at the top of the bar indicating that the data \
has been estimated. You can see the modified data here, which has the regular \
populations for years in which the data has been measured, and the data that \
has been augmented with wrappers for the estimated year:"
}], "Text",ExpressionUUID->"1c7c5546-51b4-47a7-8efc-8dec45134786"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"orangedata", "=", 
   RowBox[{"MapAt", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"#", ",", "LightOrange"}], "]"}], ",", "\"\<(est.)\>\"", ",",
         "Top"}], "]"}], "&"}], ",", 
     RowBox[{"(", 
      RowBox[{"QuantityMagnitude", "/@", "population"}], ")"}], ",", 
     RowBox[{"-", "1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"InputForm", "[", "orangedata", "]"}]}], "Input",
 CellLabel->"In[43]:=",ExpressionUUID->"4fb51508-a154-454c-94bc-a9f7e759f404"],

Cell["\<\
Now use the modified data to look at the final plot. You can see the bar for \
2020 has been changed in color and has gained an additional label indicating \
that the value is estimated:\
\>", "Text",ExpressionUUID->"d6731a50-9e88-4827-a580-933911c41c04"],

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{"orangedata", ",", "\[IndentingNewLine]", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"Placed", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"years", ",", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"QuantityMagnitude", "/@", "population"}], ")"}], "/", 
          RowBox[{"10", "^", "base"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Below", ",", "Above"}], "}"}]}], "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Axes", "\[Rule]", "None"}], ",", "\[IndentingNewLine]", 
   RowBox[{"AspectRatio", "\[Rule]", 
    RowBox[{"1", "/", "3"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLabel", "\[Rule]", 
    RowBox[{"Row", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<Decennial Population in \>\"", ",", 
       RowBox[{"Switch", "[", 
        RowBox[{
        "base", ",", "0", ",", "\"\<People\>\"", ",", "3", 
         ",", "\"\<Thousands\>\"", ",", "6", ",", "\"\<Millions\>\"", ",", 
         "9", ",", "\"\<Billions\>\""}], "]"}]}], "}"}], "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[45]:=",ExpressionUUID->"71c5827a-9561-4315-b02b-cf8deeefa7e2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BarChart: Label Estimated Data", "Section",ExpressionUUID->"58276564-d69b-4a4d-8b3b-4e19a8675995"],

Cell[CellGroupData[{

Cell["Put the BarChart in a Function", "Subsection",ExpressionUUID->"fda5826e-b531-4e48-8925-76d0b153fa50"],

Cell["\<\
Now you can wrap this up into a function that will work for any country, not \
just the United States:\
\>", "Text",ExpressionUUID->"451d3c16-a5cd-48cb-ae57-ee67b744cfba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getPopulationData", "[", "country_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"test", ",", "dates"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"test", "=", 
      RowBox[{
       RowBox[{"EntityProperty", "[", 
        RowBox[{"\"\<Country\>\"", ",", "\"\<Population\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<Date\>\"", "\[Rule]", 
           RowBox[{"Interval", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", "1910", "}"}], "]"}], ",", 
              RowBox[{"DateObject", "[", 
               RowBox[{"{", "2030", "}"}], "]"}]}], "}"}], "]"}]}], "}"}]}], 
        "]"}], "[", 
       RowBox[{"Entity", "[", 
        RowBox[{"\"\<Country\>\"", ",", "country"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dates", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"i", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1910", ",", "2030", ",", "10"}], "}"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"test", "/@", "dates"}], "//", "Quiet"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellLabel->"In[46]:=",ExpressionUUID->"a20b52f3-cc8f-4f39-bd4c-2d9f0217b1a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PopulationBarChart", "[", "country_", "]"}], ":=", 
  RowBox[{
   RowBox[{"PopulationBarChart", "[", "country", "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"years", ",", "values", ",", "base"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"years", ",", " ", "values"}], "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "1910", ",", "1920", ",", "1930", ",", "1940", ",", "1950", ",", 
           "1960", ",", "1970", ",", "1980", ",", "1990", ",", "2000", ",", 
           "2010", ",", "2020", ",", "2030"}], "}"}], ",", " ", 
         RowBox[{"getPopulationData", "[", "country", "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"base", "=", 
       RowBox[{"Floor", "[", 
        RowBox[{
         RowBox[{"Log10", "[", 
          RowBox[{"First", "[", 
           RowBox[{"(", 
            RowBox[{"QuantityMagnitude", "/@", "values"}], ")"}], "]"}], 
          "]"}], ",", "3"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"BarChart", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"MapAt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Labeled", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"#", ",", "LightOrange"}], "]"}], ",", "\"\<(est.)\>\"",
              ",", "Top"}], "]"}], "&"}], ",", 
          RowBox[{"(", 
           RowBox[{"QuantityMagnitude", "/@", "values"}], ")"}], ",", 
          RowBox[{"-", "1"}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"ChartLabels", "\[Rule]", 
         RowBox[{"Placed", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"years", ",", 
             RowBox[{"Round", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"QuantityMagnitude", "/@", "values"}], ")"}], "/", 
               RowBox[{"10", "^", "base"}]}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Below", ",", "Above"}], "}"}]}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Axes", "\[Rule]", "None"}], ",", "\[IndentingNewLine]", 
        RowBox[{"AspectRatio", "\[Rule]", 
         RowBox[{"1", "/", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotLabel", "\[Rule]", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"CountryData", "[", 
             RowBox[{"country", ",", "\"\<StandardName\>\""}], "]"}], 
            ",", "\"\< Decennial Population in \>\"", ",", 
            RowBox[{"Switch", "[", 
             RowBox[{
             "base", ",", "0", ",", "\"\<People\>\"", ",", "3", 
              ",", "\"\<Thousands\>\"", ",", "6", ",", "\"\<Millions\>\"", ",",
               "9", ",", "\"\<Billions\>\""}], "]"}]}], "}"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "\[IndentingNewLine]", 
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"1c132f71-c998-4718-b15c-e18977cddf29"],

Cell["Test out the function on a couple of countries:", "Text",ExpressionUUID->"320be665-f476-4184-a03e-62185edd601a"],

Cell[BoxData[
 RowBox[{"PopulationBarChart", "[", "\"\<Uganda\>\"", "]"}]], "Input",
 CellLabel->"In[48]:=",ExpressionUUID->"75d86006-1b8e-444a-acd8-648117ec1b86"],

Cell[BoxData[
 RowBox[{"PopulationBarChart", "[", "\"\<France\>\"", "]"}]], "Input",
 CellLabel->"In[49]:=",ExpressionUUID->"b4069d8d-2bdb-4014-a254-0b633b336831"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Back to BubbleChart: Adding More Data", "Section",ExpressionUUID->"c767b881-1105-4fdc-8149-0ebff575fffc"],

Cell["\<\
You will now work on a bubble chart that can be used to explore additional \
levels of information. To start with, augment the data by breaking down \
information on a per gender basis. You will group the data by continent \
again, and when you take a look at it, you will see all the additional \
columns in the table:\
\>", "Text",ExpressionUUID->"86834498-31e4-4365-8b7c-64bc7cceff4c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"richData", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"country", ",", "\[IndentingNewLine]", 
       RowBox[{"100", "*", 
        RowBox[{"CountryData", "[", 
         RowBox[{"country", ",", "\"\<LiteracyFraction\>\""}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"100", "*", 
        RowBox[{"CountryData", "[", 
         RowBox[{"country", ",", "\"\<MaleLiteracyFraction\>\""}], "]"}]}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"100", "*", 
        RowBox[{"CountryData", "[", 
         RowBox[{"country", ",", "\"\<FemaleLiteracyFraction\>\""}], "]"}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<LifeExpectancy\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<MaleLifeExpectancy\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<FemaleLifeExpectancy\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<Population\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<MalePopulation\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<FemalePopulation\>\""}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"CountryData", "[", 
        RowBox[{"country", ",", "\"\<Continent\>\""}], "]"}]}], 
      "\[IndentingNewLine]", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"country", ",", 
       RowBox[{"CountryData", "[", "]"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"6f7612af-a19f-4bdf-9e8a-fe91c7212491"],

Cell[BoxData[
 RowBox[{
  RowBox[{"splitRichData", "=", 
   RowBox[{"DeleteMissing", "[", 
    RowBox[{
     RowBox[{"SplitBy", "[", 
      RowBox[{
       RowBox[{"SortBy", "[", 
        RowBox[{"richData", ",", "Last"}], "]"}], ",", "Last"}], "]"}], ",", 
     "2", ",", "Infinity"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[51]:=",ExpressionUUID->"c09c3cb3-9c28-4c30-90e6-37a816be681c"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"RandomSample", "[", 
    RowBox[{
     RowBox[{"First", "[", "splitRichData", "]"}], ",", "3"}], "]"}], ",", 
   RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}]], "Input",
 CellLabel->"In[52]:=",ExpressionUUID->"1ef71d9a-9cab-4ddb-9146-39f1ac7ccdee"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart: Custom ChartElementFunction", "Section",ExpressionUUID->"ac5c96c3-f64c-41c0-895c-ec4cac3b50d0"],

Cell["\<\
Most of the data processing remains the same, but you can use a syntax rule \
to associate the gender breakdowns as metadata. Here, you have the primary \
data and the country tooltip on that. The metadata contains the country, male \
and female literacy rates, male and female life expectancies and the male and \
female population for each country. The data is getting a bit more \
complicated, but the key points are the main data, the tooltip and the \
metadata for each country in the datasets:\
\>", "Text",ExpressionUUID->"5dfffdca-cb81-48cb-b60e-a02caac2a04e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"metalabel", "[", 
   RowBox[{"{", 
    RowBox[{
    "country_", ",", "lit_", ",", "mlit_", ",", "flit_", ",", "exp_", ",", 
     "mexp_", ",", "fexp_", ",", "pop_", ",", "mpop_", ",", "fpop_", ",", 
     "continent_"}], "}"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Tooltip", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"lit", ",", "exp", ",", "pop"}], "}"}], ",", "country"}], "]"}],
    "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"country", ",", 
     RowBox[{"{", 
      RowBox[{"mlit", ",", "flit"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"mexp", ",", "fexp"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"mpop", ",", "fpop"}], "}"}]}], "}"}]}]}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"5307e532-495c-4cbd-9304-c3cdd6046475"],

Cell[BoxData[
 RowBox[{
  RowBox[{"metadata", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"metalabel", ",", "splitRichData", ",", 
     RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[54]:=",ExpressionUUID->"d51504f0-05b8-4f2f-af54-b18b0276b8cd"],

Cell["\<\
Now create a custom function to render the data and metadata in a meaningful \
way. In the default state, the data will show up as a disk like you have \
already seen, but when you move the mouse pointer over a disk, you will add a \
table of values to the top-left corner of the plot:\
\>", "Text",ExpressionUUID->"56961329-7434-4053-83a4-536f8c5242db"],

Cell[BoxData[
 RowBox[{
  RowBox[{"renderBubble", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"xmin_", ",", "xmax_"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"ymin_", ",", "ymax_"}], "}"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"lit_", ",", "exp_", ",", "pop_"}], "}"}], ",", "meta_"}], "]"}],
   ":=", "\[IndentingNewLine]", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "country", ",", "mlit", ",", "flit", ",", "mexp", ",", "fexp", ",", 
      "mpop", ",", "fpop"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"country", ",", 
        RowBox[{"{", 
         RowBox[{"mlit", ",", "flit"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"mexp", ",", "fexp"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"mpop", ",", "fpop"}], "}"}]}], "}"}], "=", 
      RowBox[{"First", "[", "meta", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Mouseover", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Disk", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"xmin", "+", "xmax"}], ",", 
            RowBox[{"ymin", "+", "ymax"}]}], "}"}], "/", "2"}], ",", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"xmax", "-", "xmin"}], ",", 
            RowBox[{"ymax", "-", "ymin"}]}], "}"}], "/", "2"}]}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Disk", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"xmin", "+", "xmax"}], ",", 
              RowBox[{"ymin", "+", "ymax"}]}], "}"}], "/", "2"}], ",", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"xmax", "-", "xmin"}], ",", 
              RowBox[{"ymax", "-", "ymin"}]}], "}"}], "/", "2"}]}], "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"Black", ",", "\[IndentingNewLine]", 
           RowBox[{"Inset", "[", 
            RowBox[{
             RowBox[{"Grid", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  
                  RowBox[{"\"\<\>\"", ",", "\"\<Lit.\>\"", 
                   ",", "\"\<L. Exp.\>\"", ",", "\"\<Pop\>\""}], "}"}], ",", 
                 RowBox[{"{", 
                  
                  RowBox[{"\"\<M\>\"", ",", "mlit", ",", "mexp", ",", 
                   "mpop"}], "}"}], ",", 
                 RowBox[{"{", 
                  
                  RowBox[{"\"\<F\>\"", ",", "flit", ",", "fexp", ",", 
                   "fpop"}], "}"}]}], "}"}], ",", 
               RowBox[{"Dividers", "\[Rule]", "All"}], ",", 
               RowBox[{"Background", "\[Rule]", "White"}]}], "]"}], ",", 
             RowBox[{"Scaled", "[", 
              RowBox[{"{", 
               RowBox[{"0.02", ",", "0.98"}], "}"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"Left", ",", "Top"}], "}"}]}], "]"}]}], 
          "\[IndentingNewLine]", "}"}]}], "\[IndentingNewLine]", "}"}]}], 
      "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[55]:=",ExpressionUUID->"abf74deb-a026-42d4-a700-c3b601aca887"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart: Test Custom ChartElementFunction", "Section",ExpressionUUID->"9ac14841-5d4c-4e9e-8d33-0c2d1d3c9111"],

Cell[TextData[{
 "Now ",
 ButtonBox["ChartElementFunction",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ChartElementFunction.html?\
q=ChartElementFunction"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/ChartElementFunction.html?q=\
ChartElementFunction"],
 " goes to ",
 Cell[BoxData[
 "renderBubble"], "Input",ExpressionUUID->
  "d34f6def-b14b-4fd4-a6d3-05e66b11a877"],
 " to display the data with a custom rendering function. When you mouse over \
a country, you will see the table in the top-left corner breaking down the \
literacy rates, life expectancies and population into the male and female \
components:"
}], "Text",ExpressionUUID->"fd8c6406-62fb-4166-bbde-5bfae3d647e9"],

Cell[BoxData[
 RowBox[{"BubbleChart", "[", 
  RowBox[{"metadata", ",", "\[IndentingNewLine]", 
   RowBox[{"ChartElementFunction", "\[Rule]", "renderBubble"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<Literacy rate\>\"", ",", "\"\<Life expectancy\>\""}], 
     "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "\[Rule]", "\"\<Literacy Rate vs. Life Expectancy vs. Population\>\""}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"ChartLegends", "\[Rule]", "continents"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[56]:=",ExpressionUUID->"02ac3c13-da02-4009-b594-dfbf69edb496"]
}, Open  ]],

Cell[CellGroupData[{

Cell["BubbleChart: Putting Everything Together", "Section",ExpressionUUID->"ed0d3138-97d6-4f61-897b-9a1a0ebaf7e4"],

Cell[TextData[{
 "Now make one small change from the previous function. Wrap the data in a \
button that assigns the country to a variable. Apply that function to the \
data again, and if you look at one of the items in the dataset, you can see \
the Button wrapper around the previous tooltip and metadata that you had from \
the previous slide. You can then use this button to drive additional actions \
within the chart, so you are going to take a BubbleChart with the new custom \
button function and a modified aspect ratio to act as an interface \
controlling the ",
 Cell[BoxData[
 "PopulationBarChart"], "Input",ExpressionUUID->
  "35cd1d7c-b46c-4593-8137-d4724a7f680b"],
 " that you created. You can also add a few columns and panels to lay out the \
two charts, one above the other:"
}], "Text",ExpressionUUID->"260461ad-bfb9-49f2-86de-74051ff0cd0d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"metalabelButton", "[", 
   RowBox[{"var_", ",", 
    RowBox[{"{", 
     RowBox[{
     "country_", ",", "lit_", ",", "mlit_", ",", "flit_", ",", "exp_", ",", 
      "mexp_", ",", "fexp_", ",", "pop_", ",", "mpop_", ",", "fpop_", ",", 
      "continent_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Button", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Tooltip", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lit", ",", "exp", ",", "pop"}], "}"}], ",", "country"}], 
      "]"}], "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"country", ",", 
       RowBox[{"{", 
        RowBox[{"mlit", ",", "flit"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"mexp", ",", "fexp"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"mpop", ",", "fpop"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"var", "=", "country"}]}], "]"}]}]], "Input",
 CellLabel->"In[57]:=",ExpressionUUID->"a14fa2e2-3b0d-438f-a0b4-73c5df01f5ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"metadataButton", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"metalabelButton", "[", 
       RowBox[{"currentCountry", ",", "#"}], "]"}], "&"}], ",", 
     "splitRichData", ",", 
     RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[58]:=",ExpressionUUID->"6fe8a9e0-5b9c-47ea-843d-4da6d1d1beed"],

Cell[TextData[{
 "The final result is a plot that will compute the population chart using \
information from",
 ButtonBox[" ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.wolframalpha.com/"], None}],
 "Wolfram|Alpha when you click a country:"
}], "Text",ExpressionUUID->"e763c21e-e98b-4584-a8ee-b1a77e4ef6de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"currentCountry", "=", 
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<Country\>\"", ",", "\"\<UnitedStates\>\""}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[60]:=",ExpressionUUID->"c68e2b2e-3088-4f56-897d-a3d3e1eaef66"],

Cell[BoxData[
 RowBox[{"EntityValue", "[", 
  RowBox[{"currentCountry", ",", "\"\<Name\>\""}], "]"}]], "Input",
 CellLabel->"In[61]:=",ExpressionUUID->"4d6817c2-96ab-49f4-bab4-d9af99d0773a"],

Cell[BoxData[
 RowBox[{"gg", "=", 
  RowBox[{"Style", "[", 
   RowBox[{
    RowBox[{"Panel", "[", 
     RowBox[{"Column", "[", 
      RowBox[{
       RowBox[{"Panel", "/@", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"BubbleChart", "[", 
           RowBox[{"metadataButton", ",", 
            RowBox[{"FrameLabel", "\[Rule]", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Literacy rate\>\"", 
               ",", "\"\<Life expectancy\>\""}], "}"}]}], ",", 
            RowBox[{"ChartElementFunction", "\[Rule]", "renderBubble"}], ",", 
            RowBox[{"AspectRatio", "\[Rule]", "0.6"}], ",", 
            RowBox[{
            "PlotLabel", 
             "\[Rule]", "\"\<Literacy Rate vs. Life Expectancy vs. Population\
\>\""}], ",", 
            RowBox[{"ChartLegends", "\[Rule]", 
             RowBox[{"Placed", "[", 
              RowBox[{"continents", ",", "Right"}], "]"}]}]}], "]"}], ",", 
          RowBox[{"Dynamic", "[", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"StringQ", "[", 
              RowBox[{"EntityValue", "[", 
               RowBox[{"currentCountry", ",", "\"\<Name\>\""}], "]"}], "]"}], 
             ",", 
             RowBox[{"PopulationBarChart", "[", 
              RowBox[{"currentCountry", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", "\"\<\>\""}], 
            "]"}], "]"}]}], "}"}]}], ",", 
       RowBox[{"Alignment", "\[Rule]", "Center"}]}], "]"}], "]"}], ",", 
    RowBox[{"DynamicEvaluationTimeout", "\[Rule]", "100"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[62]:=",ExpressionUUID->"e32e5b46-929e-4c6e-b1f5-2f9208dc700b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["More Baby Names", "Section",ExpressionUUID->"a2b17652-5fb2-441a-b8e5-f6bd479303bf"],

Cell["\<\
This example explores more of the US Baby Names by State dataset. The top \
names will be explored based on their popularity over time.\
\>", "Text",ExpressionUUID->"106df2a1-1307-4c18-9834-17fbbfef0121"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RandomSample", "[", 
    RowBox[{"genderlessTop50perYear", ",", "1"}], "]"}], "//", "Normal"}], "//",
   "Short"}]], "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"a69fa536-a110-4e8f-9036-586313fc59ae"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baby Names: Select for Top Two per Year", "Section",ExpressionUUID->"e42bad1e-f4dc-49c9-8e2a-239d63dde037"],

Cell["Recall plotting the ranking of the top 50 names over time:", "Text",ExpressionUUID->"96df4f0c-ba9c-421a-8436-616d4e72e75e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"uniqueNames", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"Union", "[", 
     RowBox[{"Flatten", "[", 
      RowBox[{"genderlessTop50perYear", "[", 
       RowBox[{"Values", ",", "All", ",", "\"\<Name\>\""}], "]"}], "]"}], 
     "]"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[64]:=",ExpressionUUID->"5b775919-f7bf-416b-ab4f-f51f27e6996b"],

Cell[TextData[{
 "To avoid clutter, only use those names that made the top two positions. \
Using ",
 ButtonBox["Reverse",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Reverse.html?q=Reverse"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Reverse.html?q=Reverse"],
 " and ",
 ButtonBox["DeleteDuplicates",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/DeleteDuplicates.html?q=\
DeleteDuplicates"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/DeleteDuplicates.html?q=\
DeleteDuplicates"],
 " sorts the names in order of which most recently entered the top two \
positions:"
}], "Text",ExpressionUUID->"a5cc2db4-7976-4f70-95ed-41181d09aa6c"],

Cell[BoxData[
 RowBox[{"top2", "=", 
  RowBox[{"DeleteDuplicates", "[", 
   RowBox[{"Normal", "[", 
    RowBox[{"Flatten", "[", 
     RowBox[{"Reverse", "[", 
      RowBox[{"genderlessTop50perYear", "[", 
       RowBox[{"Values", ",", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#Rank", "\[Equal]", "1"}], "||", 
           RowBox[{"#Rank", "==", "2"}]}], "&"}], "]"}], 
        ",", "\"\<Name\>\""}], "]"}], "]"}], "]"}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"76df2616-3238-4461-b42d-b99310d44901"],

Cell["Years in the top two:", "Text",ExpressionUUID->"c3171a2e-0b86-4038-b707-9ddd74e312bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"yearsInTop2", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "x", "}"}], ",", 
     RowBox[{"Length", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{"genderlessTop50perYear", "[", 
        RowBox[{"Values", ",", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"#Rank", "\[Equal]", "1"}], "||", 
              RowBox[{"#Rank", "==", "2"}]}], ")"}], "&&", 
            RowBox[{"#Name", "\[Equal]", "x"}]}], "&"}], "]"}]}], "]"}], 
       "]"}], "]"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[66]:=",ExpressionUUID->"83d9c4cd-b07e-4303-8b5b-3e8fb90c52c1"],

Cell[BoxData[
 RowBox[{"yearsInTop2", "/@", "top2"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"655f4989-fa98-4703-846c-b53454a1bc6f"]
}, Open  ]],


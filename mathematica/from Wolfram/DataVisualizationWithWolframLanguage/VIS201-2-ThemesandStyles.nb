  RowBox[{"cExport", "[", 
   RowBox[{"filename_", ",", "data_"}], "]"}], ":=", 
  RowBox[{"Export", "[", 
   RowBox[{"filename", ",", 
    RowBox[{"Compress", "[", "data", "]"}], ",", "\"\<String\>\""}], 
   "]"}]}], "\[IndentingNewLine]", 

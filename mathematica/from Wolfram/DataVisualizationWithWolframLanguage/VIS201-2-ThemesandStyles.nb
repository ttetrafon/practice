Cell[CellGroupData[{

Cell["Directives: Point Size", "Section",ExpressionUUID->"8654f6b4-8479-4216-b171-2357ee52c8cc"],

Cell[TextData[{
 ButtonBox["PointSize",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PointSize.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/PointSize.html"],
 " defines the size of points proportional to the size of the plot. ",
 ButtonBox["AbsolutePointSize",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/AbsolutePointSize.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/AbsolutePointSize.html"],
 " defines the size of a point in pixels:"
}], "Text",ExpressionUUID->"e5a9a238-d846-4417-9703-d9835ada3348"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CellPrint", "[", 
  RowBox[{"ExpressionCell", "[", 
   RowBox[{
    RowBox[{"DynamicModule", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"input", ",", "injectOptions", ",", 
        RowBox[{"data", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"makeList", "[", "\"\<Mary\>\"", "]"}], ",", 
           RowBox[{"makeList", "[", "\"\<John\>\"", "]"}]}], "}"}]}], ",", 
        RowBox[{"sizeFlag", "=", "False"}], ",", 
        RowBox[{"ps", "=", "0.05"}], ",", 
        RowBox[{"aps", "=", "3"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Grid", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Item", "[", 
             RowBox[{
              RowBox[{"Style", "[", 
               
               RowBox[{"\"\<Point Directives\>\"", ",", "\"\<Text\>\"", ",", 
                "Bold", ",", "14", ",", 
                RowBox[{"GrayLevel", "[", ".2", "]"}]}], "]"}], ",", 
              RowBox[{"Alignment", "\[Rule]", "Left"}], ",", 
              RowBox[{"Background", "\[Rule]", 
               RowBox[{"GrayLevel", "[", ".95", "]"}]}]}], "]"}], ",", 
            "SpanFromLeft"}], "}"}], ",", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Item", "[", 
             RowBox[{
              RowBox[{"Dynamic", "[", 
               RowBox[{"ListPlot", "[", 
                RowBox[{"data", ",", 
                 RowBox[{"ImageSize", "\[Rule]", "Medium"}], ",", 
                 RowBox[{"PlotStyle", "\[Rule]", 
                  RowBox[{"Directive", "[", 
                   RowBox[{"If", "[", 
                    RowBox[{"sizeFlag", ",", 
                    RowBox[{"PointSize", "[", "ps", "]"}], ",", 
                    RowBox[{"AbsolutePointSize", "[", "aps", "]"}]}], "]"}], 
                   "]"}]}]}], "]"}], "]"}], ",", 
              RowBox[{"Alignment", "\[Rule]", 
               RowBox[{"{", 
                RowBox[{"Left", ",", "Center"}], "}"}]}]}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Item", "[", 
             RowBox[{
              RowBox[{"TabView", "[", 
               RowBox[{
                RowBox[{"{", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"Style", "[", 
                   RowBox[{"\"\<PointSize\>\"", ",", "Bold", ",", 
                    RowBox[{"GrayLevel", "[", "0.2", "]"}]}], "]"}], "\[Rule]",
                   "\[IndentingNewLine]", 
                  RowBox[{"Grid", "[", 
                   RowBox[{
                    RowBox[{"{", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"\"\<Type\>\"", ",", "SpanFromLeft"}], "}"}], ",",
                     "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"SetterBar", "[", 
                    RowBox[{
                    RowBox[{"Dynamic", "[", "sizeFlag", "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"True", "\[Rule]", "\"\<Scaled\>\""}], ",", 
                    RowBox[{"False", "\[Rule]", "\"\<Absolute\>\""}]}], 
                    "}"}]}], "]"}], ",", "SpanFromLeft"}], "}"}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"PaneSelector", "[", 
                    RowBox[{
                    RowBox[{"{", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"True", "\[Rule]", 
                    RowBox[{"LabeledSlider", "[", 
                    RowBox[{
                    RowBox[{"Dynamic", "[", "ps", "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "0.2"}], "}"}]}], "]"}]}], ",", 
                    "\[IndentingNewLine]", 
                    RowBox[{"False", "\[Rule]", 

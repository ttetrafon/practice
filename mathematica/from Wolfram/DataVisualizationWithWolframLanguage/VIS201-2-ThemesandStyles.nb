Cell[CellGroupData[{

Cell["Modifying Style Types: Priority", "Section",ExpressionUUID->"995c3bb8-6674-4196-8e40-916ed7dea7df"],

Cell["\<\
An individually styled object has the highest priority. The following table \
shows which styles affect each other in order of decreasing priority.\
\>", "Text",ExpressionUUID->"a19f7fa1-f88a-44a0-8bfe-cc4d6afbd984"],

Cell["\<\
The \[OpenCurlyDoubleQuote]x\[CloseCurlyDoubleQuote] indicates which \
attribute each option changes, while the items higher in the table have the \
highest priority.\
\>", "Text",ExpressionUUID->"9952038a-df5b-624f-8626-6a268702a6cb"],


Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "If the FrameTicksStyle is set to Blue while the FrameStyle is \
set to Green, what will be the color of the numbers on the axes of the plot?",
              "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["Green", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The numbers will not be green.", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Green", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell["Blue", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: The numbers on the axes of the plot will be \
blue.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["Blue", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["Black", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The numbers will not be black.", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Black", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell[
                    "Numbers will not be displayed.", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The numbers will still be displayed.", "Text",
                     FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Numbers will not be displayed.", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],

Cell[CellGroupData[{

Cell["Color Schemes", "Subsection",ExpressionUUID->"99698923-3804-474f-a69f-679a3f16925e"],

Cell[TextData[{
 "All named colors can be accessed through the ",
 ButtonBox["Color Schemes",
  BaseStyle->"Hyperlink",
  ButtonData->{
    FrontEnd`FileName[{"SystemFiles", "FrontEnd", "Palettes"}, 
     "ColorSchemes.nb", CharacterEncoding -> "WindowsANSI"], None}],
 " palette, which allows you to insert the code for the color you want to use \
in your notebook."
}], "Text",ExpressionUUID->"fb420931-b1cb-4a1c-8fed-f3d0f053bfef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Color Models", "Subsection",ExpressionUUID->"1e590804-7efa-4624-a075-a6549eb79fc6"],

Cell[TextData[{
 "Wolfram Language also provides a number of color models, such as gray \
level, RGB, HSB and CMYK. The parameters in the color models have been \
normalized so that they run from 0 to 1. ",
 ButtonBox["ColorConvert",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ColorConvert.html?q=\
ColorConvert"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/ColorConvert.html?q=\
ColorConvert"],
 " will convert a color to a different color space:"
}], "Text",ExpressionUUID->"9e4d547a-419e-43bc-8798-244429045eae"],


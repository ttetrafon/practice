Cell[CellGroupData[{
Cell["Themes and Styles", "Subtitle",ExpressionUUID->"abd2714b-c40b-491d-9b98-1f3d249655e3"],

Cell[CellGroupData[{

Cell["Learning Objectives", "Section",ExpressionUUID->"a97f34a4-babe-4547-8f90-f67ece348d5f"],

Cell[CellGroupData[{

Cell["Quickly modify multiple plotting elements", "Subsubsection",ExpressionUUID->"6d4ee551-dcc5-40b5-8ce0-e2596d3afd3e"],

Cell["\<\
There are many ways in Wolfram Language to modify the overall style of a \
graphic with minimal change to the original expression:\
\>", "Text",ExpressionUUID->"584fdcba-9a10-481b-a4ab-caa2b47412ce"],

Cell[TextData[{
 ButtonBox["PlotTheme",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PlotTheme.html?q=\
PlotTheme"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/PlotTheme.html?q=PlotTheme"],
 " and its many subthemes"
}], "Item",ExpressionUUID->"0c9d763c-f1a6-4693-bdbf-9ed98cb14fa5"],

Cell["Options to modify particular visualization sections", "Item",ExpressionUUID->"62a27531-d62a-45cc-a335-1e3aeec7374a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Individual styles", "Subsubsection",ExpressionUUID->"6804e3e9-8536-43c5-915a-efcbda4c17c5"],

Cell["\<\
As you find styling choices that you want to use repeatedly, you can group \
them into a list and use them later.\
\>", "Text",ExpressionUUID->"d9f7e53e-bf74-4015-b3d1-d8d2e762bef8"]
}, Open  ]]
}, Open  ]],


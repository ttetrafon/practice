Cell[CellGroupData[{

Cell["Directives: Face and Edge Styles", "Section",ExpressionUUID->"ba43a8df-5fd7-4c10-83ad-1ae006320cf1"],

Cell[TextData[{
 "For a 2D object, such as a ",
 ButtonBox["Rectangle",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Rectangle.html?q=\
Rectangle"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Rectangle.html?q=Rectangle"],
 ", ",
 ButtonBox["FaceForm",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/FaceForm.html?q=FaceForm"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/FaceForm.html?q=FaceForm"],
 " controls the filling and ",
 ButtonBox["EdgeForm",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/EdgeForm.html?q=EdgeForm"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/EdgeForm.html?q=EdgeForm"],
 " controls the edge. The directives used within them are the same as those \
introduced earlier:"
}], "Text",ExpressionUUID->"42b4d23e-b4bd-4218-b680-fef05fd66541"],


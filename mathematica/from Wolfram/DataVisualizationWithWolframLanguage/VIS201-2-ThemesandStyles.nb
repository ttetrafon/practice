Cell[TextData[{
 "There are many, many other options that let you customize the styles of \
immediate objects, such as ",
 ButtonBox["GridLinesStyle",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/GridLinesStyle.html?q=\
GridLinesStyle"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/GridLinesStyle.html?q=\
GridLinesStyle"],
 " and ",
 ButtonBox["FaceGridsStyle",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/FaceGridsStyle.html?q=\
FaceGridsStyle"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/FaceGridsStyle.html?q=\
FaceGridsStyle"],
 ". These other styles only affect their immediate object:"
}], "Text",ExpressionUUID->"7b41d8a5-cf0d-4e87-a77d-087c3f6c9f52"],


          With[{colorBlender`Private`i$ = colorBlender`Private`i}, 
           InputField[
            Dynamic[
             Part[
             colorBlender`Private`elements$, colorBlender`Private`i$, 1]], 
            Appearance -> "Frameless", FieldSize -> Tiny]], {
          colorBlender`Private`i, colorBlender`Private`n$$, 1, -1}], Spacings -> 
         2], 
        EventHandler[
         Dynamic[
          Graphics[
           colorBlender`Private`sliderBars[colorBlender`Private`elements$], 
           PlotRangePadding -> None, 
           PlotRange -> {{-0.021, 1.02}, {
             0.5, colorBlender`Private`n$$ + 0.5}}, AspectRatio -> 
           0.016514285714285662` + 
            0.10488571428571436` colorBlender`Private`n$$, ImageSize -> 
           400]], {"MouseDown" :> (colorBlender`Private`ln = First[
              Nearest[
               Range[colorBlender`Private`n$$], 
               Last[
                MousePosition["Graphics"]]]]; 
           Part[colorBlender`Private`elements$, colorBlender`Private`ln, 1] = 
            Clip[
              First[
               MousePosition["Graphics"]], {0, 1}]), 
          "MouseDragged" :> (
           Part[colorBlender`Private`elements$, colorBlender`Private`ln, 1] = 
           Clip[
             First[
              MousePosition["Graphics"]], {0, 1}])}], 
        Column[
         Table[
          With[{colorBlender`Private`i$ = colorBlender`Private`i}, 
           Row[{
             ColorSlider[
              Dynamic[
               Part[
               colorBlender`Private`elements$, colorBlender`Private`i$, 2]]], 
             Spacer[10], 
             VerticalSlider[
              Dynamic[
               Part[
               colorBlender`Private`elements$, colorBlender`Private`i$, 3]], {
              0, 1}, ImageSize -> {Automatic, 40}], 
             Spacer[10], 
             InputField[
              Dynamic[
               Part[
               colorBlender`Private`elements$, colorBlender`Private`i$, 3]], 
              Appearance -> "Frameless", FieldSize -> 3], 
             Spacer[10], colorBlender`Private`i$}]], {
          colorBlender`Private`i, colorBlender`Private`n$$, 1, -1}], Spacings -> 
         0]}]], colorBlender`Private`sliderBars[
      Pattern[colorBlender`Private`element, 
       Blank[List]]] := 
    With[{colorBlender`Private`n = Length[colorBlender`Private`element]}, {{
       Gray, 
        Table[
         Line[{{-0.02, colorBlender`Private`i}, {
           1.015, colorBlender`Private`i}}], {
         colorBlender`Private`i, colorBlender`Private`n}]}, 
       Transpose[{
         Map[Directive[
           Part[#, 2], 
           Opacity[
            Part[#, 3]]]& , colorBlender`Private`element], 
         ConstantArray[Thick, colorBlender`Private`n], 
         Table[
          Line[{{
             Part[colorBlender`Private`element, colorBlender`Private`i, 1], 
             colorBlender`Private`i}, {
             Part[colorBlender`Private`element, colorBlender`Private`i, 1], 
             0}}], {colorBlender`Private`i, colorBlender`Private`n}]}], 
       Table[
        Inset[
         Graphics[
          colorBlender`Private`mySlider[], ImageSize -> 14], {
          Part[colorBlender`Private`element, colorBlender`Private`i, 1], 
          colorBlender`Private`i}], {
        colorBlender`Private`i, colorBlender`Private`n}]}], 
    colorBlender`Private`mySlider[] = Graphics[{
       EdgeForm[{
         Thickness[Tiny], 
         GrayLevel[0]}], 
       Polygon[{{0, 0}, {1, 0}, {1, -1.2}, {0.5, -1.5}, {0, -1.2}}, 
        VertexColors -> {
          GrayLevel[1], 
          GrayLevel[1], 
          GrayLevel[0.8], 
          GrayLevel[0.8], 
          GrayLevel[0.8]}]}, ImageSize -> 15, AspectRatio -> 1.5], 
    colorBlender`Private`colorBlend[
      Pattern[colorBlender`Private`elements, 
       Blank[List]]] := Graphics[
      Raster[{Range[1000]/1000}, ColorFunction -> (Blend[
         Map[{
           Part[#, 1], 
           Directive[
            Part[#, 2], 
            Opacity[
             Part[#, 3]]]}& , colorBlender`Private`elements], #]& )], 
      AspectRatio -> 0.3, PlotRangePadding -> None, ImageSize -> 
      385]}]], "Output",
 GeneratedCell->False,ExpressionUUID->"0b113afa-cb48-4771-b97a-c7fcdfd56bae"]

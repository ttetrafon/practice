$CellContext`input$$[
      Pattern[$CellContext`x, 
       Blank[List]]] := 
    With[{$CellContext`aa = ReplaceAll[$CellContext`x, Automatic -> Nothing]}, 
      Defer[
       InputForm[
        PieChart[{$CellContext`malesTooltip, $CellContext`femalesTooltip}, 
         PlotTheme -> $CellContext`aa]]]])]], "Output",
 GeneratedCell->False,ExpressionUUID->"db8b56c7-6876-4381-918c-cef88580480a"]

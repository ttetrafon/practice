Cell[CellGroupData[{

Cell["Custom Interfaces: Button Grid with Pane", "Section",ExpressionUUID->"1e6cf9b2-e6e1-40f5-b69a-a07353b62196"],

Cell["\<\
An ActionMenu with many values can be too long. You can use Pane with a \
column of buttons to have a similar effect:\
\>", "Text",ExpressionUUID->"c1d33b63-966b-4a25-9784-233f545b4c52"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"name", "=", "\"\<John\>\""}], ";"}], "\n", 
 RowBox[{"Dynamic", "[", "name", "]"}]}], "Input",
 CellLabel->"In[72]:=",ExpressionUUID->"1651128f-df07-432e-962b-1ba5498c0e6b"],

Cell[BoxData[
 RowBox[{"nList", "=", 
  RowBox[{"Normal", "@", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"Keys", "@", "females20"}], ",", 
     RowBox[{"Keys", "@", "males20"}]}], "]"}]}]}]], "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"932c477f-eafe-465b-8fe2-8de9cf226fe0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nameList", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", "=", "i"}], "}"}], ",", 
       RowBox[{"Button", "[", 
        RowBox[{"i", ",", 
         RowBox[{"name", "=", 
          RowBox[{"Style", "[", 
           RowBox[{"i", ",", 
            RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}], ",", "24"}], 
           "]"}]}], ",", 
         RowBox[{"Appearance", "\[Rule]", "\"\<Palette\>\""}]}], "]"}]}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "nList"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[78]:=",ExpressionUUID->"a88ac554-cbdf-48f0-98e9-94b052cd4a81"],

Cell[BoxData[
 RowBox[{"paneSelector", "=", 
  RowBox[{"Panel", "[", 
   RowBox[{
    RowBox[{"Pane", "[", 
     RowBox[{
      RowBox[{"Grid", "[", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", "nameList", "}"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"75", ",", "100"}], "}"}], ",", 
      RowBox[{"Scrollbars", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"False", ",", "True"}], "}"}]}]}], "]"}], ",", 
    RowBox[{"FrameMargins", "\[Rule]", "None"}]}], "]"}]}]], "Input",
 CellLabel->"In[76]:=",ExpressionUUID->"84f9b23b-32cf-48c4-ab48-78051a324588"]
}, Open  ]],


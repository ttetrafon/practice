Cell[TextData[{
 "Many charting functions already have interactivity built in. For example, ",
 ButtonBox["Tooltip",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Tooltip.html?q=Tooltip"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Tooltip.html?q=Tooltip"],
 " and ",
 ButtonBox["StatusArea",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/StatusArea.html?q=\
StatusArea"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/StatusArea.html?q=StatusArea"],
 " (bottom-left corner of this window) are included in ",
 ButtonBox["BarChart",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/BarChart.html?q=BarChart"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/BarChart.html?q=BarChart"],
 " and ",
 ButtonBox["PieChart",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PieChart.html?q=PieChart"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/PieChart.html?q=PieChart"],
 ":"
}], "Text",ExpressionUUID->"63541b9c-da6a-4238-8122-521b707c2edb"],


Cell[CellGroupData[{

Cell["Generic Mouse-Click Actions: Buttons", "Section",ExpressionUUID->"f638ed6b-bc22-41e3-b885-be941626907a"],

Cell[TextData[{
 "Any expression can be a ",
 ButtonBox["Button",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Button.html?q=Button"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Button.html?q=Button"],
 ", even a graphic. A button allows you to execute any code with a mouse \
click. It even works as a wrapper within graphics expressions:"
}], "Text",ExpressionUUID->"f3c86d8b-5e4c-46ac-b341-11452dfd027c"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Button", "[", 
     RowBox[{"\"\<Click me.\>\"", ",", " ", 
      RowBox[{"Print", "[", "\"\<I've been clicked.\>\"", "]"}]}], "]"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"Button", "[", 
     RowBox[{
      RowBox[{"RandomImage", "[", "]"}], ",", " ", 
      RowBox[{"Print", "[", "\"\<Image was clicked.\>\"", "]"}]}], "]"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Button", "[", 
       RowBox[{
        RowBox[{"Sin", "[", "x", "]"}], ",", " ", 
        RowBox[{
        "Print", "[", "\"\<Graphics function was clicked.\>\"", "]"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "}"}], "]"}]], "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"36b6c087-aeed-450b-ac84-57bbbc98dde4"],


Cell[CellGroupData[{

Cell["Automatic Actions: Slide Shows", "Section",ExpressionUUID->"32c1ce2f-5b0b-4577-a31a-f6a36c3e1de5"],

Cell[TextData[{
 "The simplest interactivity is that which does not require any input from \
the user. ",
 ButtonBox["ListAnimate",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ListAnimate.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/ListAnimate.html"],
 " creates a slide show from a list of expressions:"
}], "Text",ExpressionUUID->"87362a22-7723-435d-a8a9-5a2137faa87c"],


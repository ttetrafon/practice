Cell[TextData[{
 "Financial data can be looked at in detail in a ",
 ButtonBox["TradingChart",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/TradingChart.html?q=\
TradingChart"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/TradingChart.html?q=\
TradingChart"],
 ", and it can be examined even further using ",
 ButtonBox["InteractiveTradingChart",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/InteractiveTradingChart.\
html?q=InteractiveTradingChart"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/InteractiveTradingChart.html?q=\
InteractiveTradingChart"],
 ":"
}], "Text",ExpressionUUID->"1ad6ef4a-e166-499d-85f0-f5f8af5f776a"],


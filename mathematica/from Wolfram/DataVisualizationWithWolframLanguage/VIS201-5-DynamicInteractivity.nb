Cell[CellGroupData[{

Cell["Modifying Automatic Interactivity", "Section",ExpressionUUID->"5cbc2471-67a8-4bd4-84da-659c9ae6f6fa"],

Cell[TextData[{
 "You can use the ",
 ButtonBox["ChartLabels",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ChartLabels.html?q=\
ChartLabels"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/ChartLabels.html?q=\
ChartLabels"],
 " option with ",
 ButtonBox["Placed",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Placed.html?q=Placed"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Placed.html?q=Placed"],
 " to modify the automatic tooltip action:"
}], "Text",ExpressionUUID->"b3c88bc3-94b8-4378-b9c1-dd7bc104bc22"],

Cell[BoxData[
 RowBox[{"BarChart", "[", 
  RowBox[{"males20", ",", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"Placed", "[", 
     RowBox[{"Automatic", ",", "Tooltip"}], "]"}]}]}], "]"}]], "Input",Express\
ionUUID->"9968d437-d5e9-40df-81d0-738f6eeafd20"],

Cell["\<\
Alternatively, wrapping the data in Tooltip provides a finer-grained way to \
edit the automatic tooltip action:\
\>", "Text",ExpressionUUID->"30544f3d-f7e2-46d3-9818-f015038e6f45"],

Cell[BoxData[
 RowBox[{"PieChart", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Tooltip", "[", 
       RowBox[{"20031", ",", 
        RowBox[{"Column", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Female Names\>\"", ",", "20031"}], "}"}], "]"}]}], 
       "]"}], ",", 
      RowBox[{"Tooltip", "[", 
       RowBox[{"13139", ",", 
        RowBox[{"Column", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Male Names\>\"", ",", "13139"}], "}"}], "]"}]}], 
       "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Tooltip", "[", 
       RowBox[{
        TemplateBox[{"143770075", "\"people\"", "people", "\"People\""},
         "Quantity"], ",", 
        RowBox[{"Column", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Female Population\>\"", ",", 
           TemplateBox[{"143770075", "\"people\"", "people", "\"People\""},
            "Quantity"]}], "}"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Tooltip", "[", 
       RowBox[{
        TemplateBox[{"155113251", "\"people\"", "people", "\"People\""},
         "Quantity"], ",", 
        RowBox[{"Column", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<Male Population\>\"", ",", 
           TemplateBox[{"155113251", "\"people\"", "people", "\"People\""},
            "Quantity"]}], "}"}], "]"}]}], "]"}]}], "}"}]}], "}"}], 
  "]"}]], "Input",ExpressionUUID->"04b635f2-643f-4705-9126-e805326360b1"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell["How is the content of a Tooltip displayed?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell[
                    "Clicking the item with the Tooltip", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The Tooltip is not activated by clicking. ", 
                    "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Clicking the item with the Tooltip", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "Hovering the mouse over the plot that contains an item \
with a Tooltip", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: The Tooltip is only activated when the mouse \
is over specific items in the plot. ", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "Hovering the mouse over the plot that contains an item \
with a Tooltip", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> 
               Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell[
                    "Hovering the mouse pointer over the item with the \
Tooltip", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: The Tooltip is only displayed by hovering the \
mouse over the item with the Tooltip. ", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell[
                    "Hovering the mouse pointer over the item with the \
Tooltip", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell[
                    "The content is always displayed.", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Content displayed by a Tooltip is not always \
displayed.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["The content is always displayed.", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 

Cell[TextData[{
 "The ",
 ButtonBox["DefaultDuration",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/DefaultDuration.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/DefaultDuration.html"],
 " controls the duration of the animation in seconds:"
}], "Text",ExpressionUUID->"800f707d-cad1-ce4e-9cbe-e3faec0e0d16"],

Cell[BoxData[
 RowBox[{"ListAnimate", "[", 
  RowBox[{"data", ",", 
   RowBox[{"DefaultDuration", "\[Rule]", "4"}]}], "]"}]], "Input",ExpressionUU\
ID->"4b2370b1-1a39-e84e-8700-1e018a8e5344"],

Cell[TextData[{
 "To ignore the animation control, lower-level functionality is required. Use \
",
 ButtonBox["Dynamic",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Dynamic.html?q=Dynamic"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Dynamic.html?q=Dynamic"],
 " and ",
 ButtonBox["Clock",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Clock.html?q=Clock"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Clock.html?q=Clock"],
 " to continuously change the element being viewed."
}], "Text",ExpressionUUID->"9f243b45-a48f-4b85-8ae4-77b87362aefc"],

Cell["\<\
For example, it can be seen that combining Dynamic and Clock as below will \
cycle from 1 to 4 in steps of 1 over 10 seconds:\
\>", "Text",ExpressionUUID->"f2d1116d-8a34-3644-a968-447188c02289"],

Cell[BoxData[
 RowBox[{"Dynamic", "[", 
  RowBox[{"Clock", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"Length", "[", "data", "]"}], ",", "1"}], "}"}], ",", "10"}], 
   "]"}], "]"}]], "Input",ExpressionUUID->"64631ae5-c6e6-0549-bb63-\
06b8ae56c838"],

Cell[TextData[{
 "Combining this with the list of plots stored in the ",
 Cell[BoxData[
 "data"], "Input",ExpressionUUID->"21b6489a-06bf-48eb-bfa9-208501a1c9b1"],
 " variable will cycle through the four plots:"
}], "Text",ExpressionUUID->"9dba4864-7d6b-a049-b468-d9add4b19477"],

Cell[BoxData[
 RowBox[{"Dynamic", "[", 
  RowBox[{"data", "[", 
   RowBox[{"[", 
    RowBox[{"Clock", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"Length", "[", "data", "]"}], ",", "1"}], "}"}], ",", "10"}], 
     "]"}], "]"}], "]"}], "]"}]], "Input",ExpressionUUID->"73ed5746-bff6-4c26-\
aab0-a81f151d82a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Automatic Actions: Mousing Over", "Section",ExpressionUUID->"7575646f-1cbc-4a95-a407-8cd6a517102b"],

Cell["\<\
The minimal amount of input from the user involves positioning the mouse. \
Tooltip was used earlier to alter the automatic tooltip values, but it can \
also be added to elements that do not normally have tooltips. The wrapper can \
be used at any level:\
\>", "Text",ExpressionUUID->"376e148c-b75e-4b2e-9410-b52db783a837"],

Cell[BoxData[
 RowBox[{"GraphicsGrid", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"Tooltip", "[", 
           RowBox[{"2", ",", "\"\<boo\>\""}], "]"}], ",", "3", ",", "4"}], 
         "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"PointSize", "[", "Medium", "]"}]}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"ListPlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Tooltip", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}], 
            ",", "\"\<foo\>\""}], "]"}], ",", 
          RowBox[{"Tooltip", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], 
            ",", "\"\<bar\>\""}], "]"}]}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"PointSize", "[", "Medium", "]"}]}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Tooltip", "[", 
       RowBox[{
        RowBox[{"ListPlot", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}], ",", 
          RowBox[{"PlotStyle", "->", 
           RowBox[{"PointSize", "[", "Medium", "]"}]}]}], "]"}], 
        ",", "\"\<boo\>\""}], "]"}]}], "\[IndentingNewLine]", "}"}], "}"}], ",", 
   RowBox[{"ImageSize", "->", "Large"}]}], "]"}]], "Input",ExpressionUUID->\
"821449ec-b4d0-4050-af60-7baf45cce7d3"],

Cell[TextData[{
 ButtonBox["Mouseover",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Mouseover.html?q=\
Mouseover"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/Mouseover.html?q=Mouseover"],
 " changes the expression itself. It works best if the two objects have the \
same size:"
}], "Text",ExpressionUUID->"644c322a-cf44-4b22-a135-a0596bf00e5b"],

Cell[BoxData[
 RowBox[{"Mouseover", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Style", "[", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{"Background", "\[Rule]", "LightPink"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Style", "[", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", "2", "]"}], "]"}], ",", 
     RowBox[{"Background", "\[Rule]", "LightBlue"}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",ExpressionUUID->"b4468434-f9bd-4173-\
becb-9454df637e55"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Default Mouse-Click Actions: PopupWindow", "Section",ExpressionUUID->"0e0a1a23-1abf-48b0-aa77-111bbd2d1bb0"],

Cell["\<\
Revisit the PieChart example. First, add the bar charts from earlier:\
\>", "Text",ExpressionUUID->"b5f510f0-3a23-48a8-b92b-0a5bab71a11b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"bcmale", "=", 
   RowBox[{"BarChart", "[", 
    RowBox[{"males20", ",", " ", 
     RowBox[{"ChartLabels", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{"Automatic", ",", "Below", ",", 
        RowBox[{
         RowBox[{"Rotate", "[", 
          RowBox[{"#", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "]"}], "&"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bcfemale", "=", 
   RowBox[{"BarChart", "[", 
    RowBox[{"females20", ",", " ", 
     RowBox[{"ChartLabels", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{"Automatic", ",", "Below", ",", 
        RowBox[{
         RowBox[{"Rotate", "[", 
          RowBox[{"#", ",", 
           RowBox[{"\[Pi]", "/", "2"}]}], "]"}], "&"}]}], "]"}]}]}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[48]:=",ExpressionUUID->"02928891-8ff0-43b5-934c-35d94015542e"],

Cell[TextData[{
 ButtonBox["PopupWindow",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PopupWindow.html?q=\
PopupWindow"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/PopupWindow.html?q=\
PopupWindow"],
 " is similar to Tooltip, except it opens a separate floating window. \
Wrapping PopupWindow around plot elements overrides any default mouse-click \
actions:"
}], "Text",ExpressionUUID->"e24bc58f-9616-4492-a6ba-d4943a0f4f58"],

Cell[BoxData[
 RowBox[{"PieChart", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PopupWindow", "[", 
        RowBox[{"13139", ",", "bcmale", ",", 
         RowBox[{"WindowTitle", "\[Rule]", "\"\<Top 20 Male Names\>\""}]}], 
        "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PopupWindow", "[", 
        RowBox[{"20031", ",", "bcfemale", ",", 
         RowBox[{"WindowTitle", "\[Rule]", "\"\<Top 20 Female Names\>\""}]}], 
        "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       TemplateBox[{"155113251", "\"people\"", "people", "\"People\""},
        "Quantity"], ",", 
       TemplateBox[{"143770075", "\"people\"", "people", "\"People\""},
        "Quantity"]}], "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<Unique\\nNames\>\"", ",", "\"\<Total\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<Male\>\"", ",", "\"\<Female\>\""}], "}"}]}], "}"}]}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"SectorSpacing", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "2"}], "}"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"b9a745c5-dd80-48d3-b8c3-a9d743666dbc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Default Mouse-Click Actions: Pane", "Section",ExpressionUUID->"ba43a8df-5fd7-4c10-83ad-1ae006320cf1"],

Cell[TextData[{
 ButtonBox["Pane",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Pane.html?q=Pane"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Pane.html?q=Pane"],
 " is useful to control the amount of space that an expression occupies. The \
user input comes in the form of scrollbars and window resizing:"
}], "Text",ExpressionUUID->"c2c038c3-12af-41cc-b52c-2a50a9c94a0a"],

Cell[BoxData[
 RowBox[{"Pane", "[", 
  RowBox[{"data", ",", 
   RowBox[{"ImageSize", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"50", ",", "50"}], "}"}]}], ",", 
   RowBox[{"ImageSizeAction", "\[Rule]", "\"\<Scrollable\>\""}], ",", 
   RowBox[{"Scrollbars", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellLabel->"In[51]:=",ExpressionUUID->"2f691fa9-52cf-45de-b2ad-3f8833ab9264"],

Cell["\<\
Often if an expression does not appear at its expected size, wrapping it in \
Pane causes it to size correctly:\
\>", "Text",ExpressionUUID->"ca1845d8-6156-43ff-9aa8-70164ae71941"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"data", "[", 
     RowBox[{"[", "1", "]"}], "]"}], ",", 
    RowBox[{"data", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]], "Input",
 CellLabel->"In[52]:=",ExpressionUUID->"fc636d15-e210-423c-85ea-a0d9f8fea9db"],

Cell[BoxData[
 RowBox[{"Row", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Pane", "[", 
     RowBox[{"data", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
    RowBox[{"data", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"382a3fb9-7e16-4715-aca9-a31d7ce81894"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Default Mouse-Click Actions: Viewers", "Section",ExpressionUUID->"0c7ffa21-ef5b-47d3-9ae3-3cdbb8b28c9d"],

Cell["\<\
Viewers are similar to slide shows, except they require user input to change \
between views. Some viewers have built-in labels, and some viewers are \
paneled:\
\>", "Text",ExpressionUUID->"7ea6d088-7268-4f04-8be5-47ac45085fc7"],

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Labeled", "[", 
        RowBox[{
         RowBox[{"SlideView", "[", "data", "]"}], ",", "\"\<SlideView\>\"", ",",
          "Top"}], "]"}], ",", 
       RowBox[{"Labeled", "[", 
        RowBox[{
         RowBox[{"FlipView", "[", 
          RowBox[{"data", ",", 

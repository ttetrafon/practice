Cell[TextData[{
 "To get those, we can use the ",
 Cell[BoxData["\"\<LocateElements\>\""], "Input",ExpressionUUID->
  "1f541031-ae0b-4efe-a521-a083dead6972"],
 " option of WebExecute, specifying that we want elements that match a \
certain HTML tag, in this case, <span>:"
}], "Text",ExpressionUUID->"8b8de4d8-9e81-4df7-9387-1898a8c9d6ec"],

Cell[BoxData[
 RowBox[{
  RowBox[{"allSpans", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<span\>\""}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"45111c6b-0f7d-455c-b27d-6eff31423f4d"],

Cell[TextData[{
 "And then get all <span> instances where the value for the ",
 Cell[BoxData["\"\<class\>\""], "Input",ExpressionUUID->
  "009f4c79-cadc-4fd3-99a4-8f3ce2ced93a"],
 " attribute is ",
 Cell[BoxData["\"\<text\>\""], "Input",ExpressionUUID->
  "cf2d213b-4b27-45ff-a8d1-320277e7c369"],
 ":"
}], "Text",ExpressionUUID->"cc67d250-0183-47da-b964-7fc0254421cc"],

Cell[BoxData[
 RowBox[{"allQuotes", "=", 
  RowBox[{"Map", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"StringMatchQ", "[", " ", 
        RowBox[{
         RowBox[{"WebExecute", "[", 
          RowBox[{"session", ",", 
           RowBox[{"\"\<ElementAttribute\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"#", ",", "\"\<class\>\""}], "}"}]}]}], "]"}], 
         ",", "\"\<text\>\""}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"If", " ", "the", " ", 
         RowBox[{"element", "'"}], "s", " ", "class", " ", "is", 
         " ", "\"\<text\>\""}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"WebExecute", "[", 
        RowBox[{"session", ",", 
         RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"get", " ", "its", " ", "text"}], "*)"}], 
       "\[IndentingNewLine]", "Nothing"}], "]"}], "&"}], " ", 
    RowBox[{"(*", 
     RowBox[{"else", ":", " ", 
      RowBox[{"do", " ", "nothing"}]}], "*)"}], "\[IndentingNewLine]", ",", 
    " ", "allSpans"}], "]"}]}]], "Input",ExpressionUUID->"1f1b56e8-4e0c-4a83-\
a3fd-edf8fe0d37cb"],

Cell["\<\
Now we have all the quotes in a list. Let\[CloseCurlyQuote]s get the author \
names, which are located in <small> HTML elements:\
\>", "Text",ExpressionUUID->"fc8de3ec-e785-433a-b0c5-c85c467c91bc"],


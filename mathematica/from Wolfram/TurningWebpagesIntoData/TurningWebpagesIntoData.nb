  "SlideShowHeader",ExpressionUUID->"16823dd0-8e50-4a53-83ca-f261e85bc2bc"],

Cell[CellGroupData[{

Cell["Things You\[CloseCurlyQuote]ll Learn", "Section",ExpressionUUID->"3b4bc144-af34-4a6e-b772-d37d1cf844cf"],

Cell["\[OpenCurlyDoubleQuote]What\[CloseCurlyDoubleQuote] and \
\[OpenCurlyDoubleQuote]Why\[CloseCurlyDoubleQuote] of Turning Webpages into \
Data", "Subsection",ExpressionUUID->"6904e5b9-0201-4d85-a3ad-a1e855130411"],

Cell["Sending HTTP Requests and Getting Text", "Subsection",ExpressionUUID->"43227cba-a2ed-49b8-a2cb-4e29f37a5410"],

Cell["Parsing Structured Responses", "Subsection",ExpressionUUID->"c6e6b60e-0c89-4d26-b8ec-390b8a02abf9"],

Cell["Scaling Up: Async Requests", "Subsection",ExpressionUUID->"ce97ea49-06a7-41b3-8b2a-6cd89ec85f0f"],

Cell["Automating Web Browsers", "Subsection",ExpressionUUID->"1bbb6ace-6430-415f-8b4d-38b0430ddf9e"]
}, Open  ]],


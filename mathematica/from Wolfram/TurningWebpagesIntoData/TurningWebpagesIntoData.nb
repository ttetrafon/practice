Cell[CellGroupData[{

Cell["Return Stats", "Subsubsection",ExpressionUUID->"7339b89b-80ad-474e-aa82-e6cfd86c658a"],

Cell["\<\
Since this page is almost identical to the previous one, we follow the same \
procedure. The only difference is that the table contains fewer elements, so \
our final function that extracts the information from the table is slightly \
modified:\
\>", "Text",ExpressionUUID->"387d30b4-d7ee-462f-ab7a-fa7858f01385"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "start", " ", "the", " ", "session", " ", "and", " ", "open", " ", "the", " ",
     "page"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"session", "=", 
     RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", 
      RowBox[{"\"\<OpenPage\>\"", 
       "->", "\"\<https://www.atptour.com/en/stats/leaderboard?boardType=\
return&timeFrame=52week&surface=all&versusRank=all&formerNo1=false\>\""}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"wait", " ", "for", " ", "page", " ", "to", " ", "load"}], ",", 
     " ", 
     RowBox[{"and", " ", "click", " ", "\"\<Cookies\>\"", " ", "button"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Pause", "[", "3", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"buttonTags", " ", "=", " ", 
     RowBox[{"WebExecute", "[", 
      RowBox[{"session", ",", 
       RowBox[{"\"\<LocateElements\>\"", "->", 
        RowBox[{"\"\<Tag\>\"", "->", "\"\<button\>\""}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cookiesButton", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"WebExecute", "[", 
           RowBox[{"session", ",", 
            RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], 
          "==", "\"\<Accept All Cookies\>\""}], ",", "#", ",", "Nothing"}], 
        "]"}], "&"}], "/@", "buttonTags"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", 
      RowBox[{"\"\<ClickElement\>\"", "->", 
       RowBox[{"First", "[", "cookiesButton", "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"wait", " ", "for", " ", "page", " ", "to", " ", "load"}], ",", 
     " ", 
     RowBox[{"and", " ", "click", " ", "\"\<Load More\>\"", " ", "button"}]}],
     " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Pause", "[", "3", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aTags", "=", 
     RowBox[{"WebExecute", "[", 
      RowBox[{"session", ",", 
       RowBox[{"\"\<LocateElements\>\"", "->", 
        RowBox[{"\"\<Tag\>\"", "->", "\"\<a\>\""}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"loadMoreButton", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"WebExecute", "[", 
           RowBox[{"session", ",", 
            RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], 
          "==", "\"\<Load More\>\""}], ",", "#", ",", "Nothing"}], "]"}], 
       "&"}], "/@", "aTags"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", 
      RowBox[{"\"\<ClickElement\>\"", "->", 
       RowBox[{"First", "[", "loadMoreButton", "]"}]}]}], "]"}], 
    ";"}]}]}]], "Input",ExpressionUUID->"953ea9be-4823-4f6c-90f0-\
8e9e3680739b"],

Cell[BoxData["\[IndentingNewLine]"], "Input",ExpressionUUID->"eec11755-2901-ee42-93b9-39236af18614"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"returntrTags", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<tr\>\""}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"returnStats", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"StringCases", "[", 
      RowBox[{
       RowBox[{"WebExecute", "[", 
        RowBox[{"\"\<ElementText\>\"", "->", "#"}], "]"}], ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", 
         "[", "\"\<(^\\\\d{1,})\\\\n(.*)\\\\n(\\\\d{3}.\\\\d)\\\\s(.*?%)\\\\s(\
.*?%)\\\\s(.*?%)\\\\s(.*?%)\>\"", "]"}], "->", 
        RowBox[{"{", 
         RowBox[{"\"\<$1\>\"", ",", "\"\<$2\>\"", ",", "\"\<$3\>\"", 
          ",", "\"\<$4\>\"", ",", "\"\<$5\>\"", ",", "\"\<$6\>\"", 
          ",", "\"\<$7\>\""}], "}"}]}]}], "]"}], "&"}], "/@", 
    RowBox[{"returntrTags", "[", 
     RowBox[{"[", 
      RowBox[{"2", ";;"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"returnsTab", "=", 
  RowBox[{"ToTabular", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Apply", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"<|", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<Return ranking\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#1", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Name\>\"", "->", "#2"}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Return rating\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#3", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<% 1st serve return points won\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#4", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<% 2nd serve return points won\>\"", " ", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#5", 
            "]"}]}], ",", "\[IndentingNewLine]", " ", 
          RowBox[{"\"\<% return games won\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#6", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<% break points converted\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#7", 
            "]"}]}]}], "|>"}], "&"}], ",", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"Flatten", "[", 
     RowBox[{"returnStats", ",", "1"}], "]"}]}], "]"}]}]}], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"1d293011-bf0d-419b-a7da-07b8e8ee04d2"],


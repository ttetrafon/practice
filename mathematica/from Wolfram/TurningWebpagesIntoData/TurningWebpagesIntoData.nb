         "Return ranking", "Integer64"}, {"Return rating", "Real64"}, {
         "% 1st serve return points won", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {
         "% 2nd serve return points won", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {
         "% return games won", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {
         "% break points converted", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {
         "Under pressure ranking", "Integer64"}, {
         "Under pressure rating", "Real64"}, {"% break points saved", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {
         "% tie breaks won", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {
         "% deciding sets won", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}}, Alignment -> 
        Left], "Backend" -> "Tabular`Backend`WolframKernel", "UUID" -> 
      "Tabular-a7dc259e-f826-45e1-b4db-d4ff0e817ddb", "Form" -> StandardForm, 
      "Interpretable" -> True|>, "TabularSummary", 
     BaseStyle -> (DynamicUpdating -> True)], "Main" -> TableViewBox[
     Tabular[<|
      "RawSchema" -> <|
        "ColumnProperties" -> <|
          "World ranking" -> <|"ElementType" -> "Integer64"|>, 
           "Name" -> <|"ElementType" -> "String"|>, 
           "Country" -> <|
            "ElementType" -> TypeSpecifier["Entity"]["Country", "String"]|>, 
           "Serve ranking" -> <|"ElementType" -> "Integer64"|>, 
           "Serve rating" -> <|"ElementType" -> "Real64"|>, 
           "% 1st serve" -> <|

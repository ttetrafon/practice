Cell[CellGroupData[{

Cell["Exploration of the Data", "Subsubsection",ExpressionUUID->"f8998aeb-4fc9-44d8-849b-d1e8cfabc133"],

Cell["\<\
Once we have the data in Wolfram Language, we can start using any of the \
thousands of built-in functions to get insights. For example, find out which \
country has the most representatives in the ATP Top 100:\
\>", "Text",ExpressionUUID->"7f0228ea-d45c-4f71-9c2c-8862216d2dc8"],

Cell[BoxData[
 RowBox[{"ReverseSort", "[", 
  RowBox[{"GroupBy", "[", 
   RowBox[{"finalDataset", ",", 
    RowBox[{"#Country", " ", "&"}], ",", "Length"}], "]"}], "]"}]], "Input",Ex\
pressionUUID->"9687bd63-6e94-4357-917c-879e3d543865"],

Cell["\<\
As well as world rankings, players are ranked across three other categories: \
serves, returns and performance under pressure. Find the player with the \
biggest discrepancy between world ranking and serve ranking:\
\>", "Text",ExpressionUUID->"61d4f70a-c8a3-452d-8c28-fe1aa9e378ca"],

Cell[BoxData[
 RowBox[{"TakeLargestBy", "[", "\[IndentingNewLine]", "    ", 
  RowBox[{"finalDataset", ",", "\[IndentingNewLine]", "    ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"#", "[", "\"\<World ranking\>\"", "]"}], "-", 
      RowBox[{"#", "[", "\"\<Serve ranking\>\"", "]"}]}], "]"}], "&"}], ",", 
   "\[IndentingNewLine]", "    ", "1"}], "\[IndentingNewLine]", 
  "]"}]], "Input",ExpressionUUID->"f3ff5165-7a3a-46ce-8bb7-bb1dc3431fe6"],

Cell["Find the players who can serve really well but can\[CloseCurlyQuote]t \
return:", "Text",ExpressionUUID->"c8b1e7b1-4680-4682-9453-f634be7422d6"],

Cell[BoxData[
 RowBox[{"TakeLargestBy", "[", "\[IndentingNewLine]", "    ", 
  RowBox[{"finalDataset", ",", "\[IndentingNewLine]", "    ", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"#", "[", "\"\<Serve ranking\>\"", "]"}], "-", 
      RowBox[{"#", "[", "\"\<Return ranking\>\"", "]"}]}], "]"}], "&"}], ",", 
   "\[IndentingNewLine]", "    ", "3"}], "\[IndentingNewLine]", 
  "]"}]], "Input",ExpressionUUID->"c4f6f8e6-3970-4eee-aac2-16783046b9f8"],

Cell[TextData[{
 "Create a ",
 ButtonBox["Manipulate",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Manipulate.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Manipulate.html"],
 " object to explore scatter plots of different factors in the dataset:"
}], "Text",ExpressionUUID->"4f536d09-72ec-4855-8514-0e37b0b10022"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"finaldataset", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"TabularQ", "[", "finalDataset", "]"}], ",", "finalDataset", ",", 
       RowBox[{"Import", "[", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], 
          ",", "\"\<TennisDataset.mx\>\""}], "]"}], "]"}]}], "]"}]}], "}"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "factor1Values", ",", "factor2Values", ",", "playerNames", ",", 
         "correlation"}], "}"}], ",", "\[IndentingNewLine]", "    ", 
       RowBox[{
        RowBox[{"factor1Values", "=", 
         RowBox[{"Normal", "[", 
          RowBox[{"finaldataset", "[", 
           RowBox[{"All", ",", "factor1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"factor2Values", "=", 
         RowBox[{"Normal", "[", 
          RowBox[{"finaldataset", "[", 
           RowBox[{"All", ",", "factor2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"playerNames", "=", 
         RowBox[{"Normal", "[", 
          RowBox[{"finaldataset", "[", 
           RowBox[{"All", ",", "\"\<Name\>\""}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"correlation", "=", 
         RowBox[{"Correlation", "[", 
          RowBox[{"factor1Values", ",", "factor2Values"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"ListPlot", "[", "\[IndentingNewLine]", "      ", 
         RowBox[{
          RowBox[{"MapThread", "[", "\[IndentingNewLine]", "        ", 
           RowBox[{
            RowBox[{
             RowBox[{"Tooltip", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"#1", ",", "#2"}], "}"}], ",", "#3"}], "]"}], " ", 
             "&"}], ",", "\[IndentingNewLine]", "        ", 
            RowBox[{"{", 
             RowBox[{
             "factor1Values", ",", "factor2Values", ",", "playerNames"}], 
             "}"}]}], "\[IndentingNewLine]", "      ", "]"}], ",", 
          "\[IndentingNewLine]", "      ", 
          RowBox[{"AxesLabel", "->", 
           RowBox[{"{", 
            RowBox[{"factor1", ",", "factor2"}], "}"}]}], ",", 
          "\[IndentingNewLine]", "      ", 
          RowBox[{"PlotLabel", "->", "\"\<Scatter Plot\>\""}], ",", 
          "\[IndentingNewLine]", "      ", 
          RowBox[{"ImageSize", "->", "Large"}], ",", "\[IndentingNewLine]", 
          "      ", 
          RowBox[{"PlotMarkers", "->", "\"\<\|01f3be\>\""}]}], 
         "\[IndentingNewLine]", "    ", "]"}]}]}], "\[IndentingNewLine]", 
      "  ", "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"factor1", ",", "\"\<% 1st serve points won\>\""}], "}"}], ",", 
       RowBox[{"ColumnKeys", "[", "finaldataset", "]"}], ",", 
       RowBox[{"ControlType", "->", "PopupMenu"}]}], "}"}], ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"factor2", ",", "\"\<Avg. aces/match\>\""}], "}"}], ",", 
       RowBox[{"ColumnKeys", "[", "finaldataset", "]"}], ",", 
       RowBox[{"ControlType", "->", "PopupMenu"}]}], "}"}], ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"TrackedSymbols", ":>", 
      RowBox[{"{", 
       RowBox[{"factor1", ",", "factor2"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"SynchronousInitialization", "->", "False"}]}], 
    "\[IndentingNewLine]", "]"}]}], "]"}]], "Input",ExpressionUUID->"e412937e-\
d94a-410f-8b2c-193dc72b5162"],


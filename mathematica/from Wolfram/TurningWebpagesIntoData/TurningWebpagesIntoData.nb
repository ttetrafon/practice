Cell[BoxData["\[IndentingNewLine]"], "Input",ExpressionUUID->"45959ae0-1332-074f-a0fc-b20376b5046e"],

Cell["\<\
And use some of the integrated LLM functionality with the headlines:\
\>", "Text",ExpressionUUID->"47c38826-3f0f-490b-b020-afca25c86f2a"],

Cell[BoxData[
 RowBox[{"emojify", "=", 
  RowBox[{"LLMExampleFunction", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<Summarize the news article using emojis\>\"", ",", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<Rare red wind warning issued as Storm Darragh \
approaches\>\"", "->", "\"\<\:26c8\:fe0f\|01f4a8\:2757\>\""}], ",", " ", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<Nationwide fault causes delays across rail network\>\"", 
        "->", "\"\<\|01f1ec\|01f1e7\:274c\|01f682\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"\"\<How citizen scientists are uncovering the secret lives of \
blue whales\>\"", "->", "\"\<\|01f9d1\:200d\|01f52c\|01f9d0\|01f433\>\""}]}], 
      "}"}]}], "}"}], "]"}]}]], "Input",ExpressionUUID->"1bda2be1-923f-4381-\
9829-c38b415d5790"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"emojify", "[", "#", "]"}], "&"}], "/@", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{"bbcArticlesHeadlines", ",", "5"}], "]"}]}]], "Input",ExpressionUUI\
D->"ed6ae4e0-d0d2-41d4-a9e9-188c7d70d596"]
}, Open  ]]
}, Open  ]],

Cell["", "EndOfSlide",ExpressionUUID->"f2bae80d-5f80-43f2-9ce9-5f7aa4aa8a69"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"57ef526d-1fe7-4dd3-85d8-2fa8ef2b6ea6"],

Cell[CellGroupData[{

Cell["Example: Scaling Up with Async Requests", "Subsection",ExpressionUUID->"f4c4336e-b15f-4fd6-903e-d076a9df5d51"],

Cell["\<\
Demonstrating our news example with another site, we can expand it by getting \
the body of the articles and not just the headlines. First, let\
\[CloseCurlyQuote]s get all the hyperlinks from the ESPN\[CloseCurlyQuote]s \
front page:\
\>", "Text",ExpressionUUID->"86fe98e4-0f3e-4cf3-b6df-2cb5bc159f77"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sportHyperlinks", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<https://www.espn.co.uk/\>\"", ",", 
     " ", "\"\<Hyperlinks\>\""}], "]"}]}], ";"}]], "Input",ExpressionUUID->\
"febad0dc-523a-4550-ab1e-d196e51b1466"],

Cell["\<\
Then we can string match those that lead to articles, filtering out unrelated \
links:\
\>", "Text",ExpressionUUID->"98f1c4d7-d179-49b7-a0d7-449c0ebe846c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sportArticleLinks", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"StringCases", "[", 
     RowBox[{"sportHyperlinks", ",", 
      RowBox[{
      "RegularExpression", "[", "\"\<https://www.espn.co.uk/.*/story/.*\>\"", 
       "]"}]}], " ", 
     RowBox[{"(*", 
      RowBox[{"StringExpression", "[", 
       RowBox[{"\"\<https://www.espn.co.uk/\>\"", ",", " ", "___", " ", 
        ",", "\"\</story/\>\"", ",", " ", "___"}], "]"}], "*)"}], " ", "]"}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"2fb6c5ee-9552-4e38-9363-\
a570ecd9c856"],

Cell[BoxData[
 RowBox[{"Length", "[", "sportArticleLinks", "]"}]], "Input",ExpressionUUID->"cce3edb0-47e7-fb48-a41d-47745d6ff620"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sportArticleLinks", " ", "=", " ", 
   RowBox[{"RandomSample", "[", 
    RowBox[{"sportArticleLinks", ",", "30"}], "]"}]}], ";"}]], "Input",Express\
ionUUID->"7ac4a2cf-79f9-bf40-aae7-52a4811a9f58"],

Cell["Prepare an empty list that will hold all the variables:", "Text",ExpressionUUID->"462ec3e9-78db-4e43-9144-b1198a820d0e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sportArticleBodies", "=", 
   RowBox[{"{", "}"}]}], ";"}]], "Input",ExpressionUUID->"279a9be2-eef8-46bd-\
ad7d-eaea7198cdc4"],

Cell[TextData[{
 "Now we have a few dozen articles. If we pass them to Import or URLRead, we \
will need to wait for them to be downloaded sequentially, which could take a \
long time. Wolfram Language is equipped with a lot of parallel computation \
functionality, which can greatly reduce the time needed for a list of \
independent computations. In the case of web fetching, parallel computation \
is often referred to as \[OpenCurlyDoubleQuote]asynchronous\
\[CloseCurlyDoubleQuote], and the corresponding Wolfram Language function we \
can use for asynchronous web fetching is ",
 ButtonBox["URLSubmit",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/URLSubmit.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/URLSubmit.html"],
 ":"
}], "Text",ExpressionUUID->"83b737b1-87ed-4e98-8082-515d693c2ab5"],

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"URLSubmit", "[", 
     RowBox[{"#", ",", 
      RowBox[{"HandlerFunctions", "->", 
       RowBox[{"<|", 
        RowBox[{"\"\<TaskFinished\>\"", "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"AppendTo", "[", 
            RowBox[{"sportArticleBodies", ",", 
             RowBox[{"Cases", "[", 
              RowBox[{
               RowBox[{"ImportString", "[", 
                RowBox[{"#Body", ",", "\"\<XMLObject\>\""}], "]"}], ",", 
               RowBox[{
                RowBox[{"XMLElement", "[", 
                 RowBox[{"\"\<p\>\"", ",", "_", ",", 
                  RowBox[{"{", "content_String", "}"}]}], "]"}], ":>", 
                "content"}], ",", "Infinity"}], "]"}]}], "]"}], "&"}], 
          ")"}]}], "|>"}]}], ",", 
      RowBox[{"HandlerFunctionsKeys", "->", "\"\<Body\>\""}]}], "]"}], "&"}], 
   "/@", "sportArticleLinks"}], "]"}]], "Input",ExpressionUUID->"7e1e360b-\
de60-4b51-9d17-cde0ce015a36"],

Cell["Check how many articles we have collected:", "Text",ExpressionUUID->"8f318e53-e9b5-4926-ad3a-3dd17ca91502"],

Cell[BoxData[
 RowBox[{"Length", "[", "sportArticleBodies", "]"}]], "Input",ExpressionUUID->"2e367791-e84e-4a1d-b232-6a8ab86f3064"],

Cell["\<\
Produce a word cloud again to see at a glance what\[CloseCurlyQuote]s been \
talked about today:\
\>", "Text",ExpressionUUID->"f266badb-efab-49c4-86ce-a4cb74f2f043"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"WordCloud", "[", 
  RowBox[{"StringJoin", "[", 
   RowBox[{"Flatten", "[", "sportArticleBodies", "]"}], "]"}], "]"}]], "Input",\

 CellLabel->"In[9]:=",ExpressionUUID->"40c4e463-b5aa-47d3-8cc5-1676171de95a"],


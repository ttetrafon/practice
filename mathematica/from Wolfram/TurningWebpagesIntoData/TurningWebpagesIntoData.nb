}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"a99cff0a-9334-47d9-a007-66c583b6224e"],

Cell[CellGroupData[{

Cell["Importing Webpages as Text", "Section",ExpressionUUID->"888a2174-0c79-43b9-84e7-b7f51ed0241d"],

Cell[CellGroupData[{

Cell["Aside: robots.txt", "Subsection",
 CellChangeTimes->{{3.9334063384095592`*^9, 
  3.9334063406833477`*^9}},ExpressionUUID->"63950362-638d-42ed-96b5-\
3ecc8c31093d"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{"robots", ".", "txt"}]},
   "ChatCodeInlineTemplate"]], "ChatCode",
  Background->None,ExpressionUUID->"7e2cf12a-12ce-4026-8a21-d2aeb42c22f2"],
 " file is a standard used by websites to communicate with web crawlers about \
which parts of the site should not be accessed. It is typically located in \
the root directory of a website (e.g. ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      RowBox[{"www", ".", "example", ".", "com"}], "/", 
      RowBox[{"robots", ".", "txt"}]}]},
   "ChatCodeInlineTemplate"]], "ChatCode",
  Background->None,ExpressionUUID->"aa8eafc4-7996-4923-924f-f295d2828cb6"],
 "). This file contains directives that specify which user agents (crawlers) \
are allowed or disallowed from accessing certain sections of the site. \
Understanding and respecting the ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{"robots", ".", "txt"}]},
   "ChatCodeInlineTemplate"]], "ChatCode",
  Background->None,ExpressionUUID->"61922833-0d8d-47d9-9710-cd2c9bd5d623"],
 " file is crucial for responsible data extraction, as it helps ensure that \
extractors do not violate the site\[CloseCurlyQuote]s terms of service or \
overload the server by unintentionally crawling restricted areas. Adhering to \
these guidelines fosters responsible data collection practices and supports \
the site\[CloseCurlyQuote]s operational integrity."
}], "Text",ExpressionUUID->"cd595882-8d8a-4b26-b63f-fb3a6e0b8055"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Import", "Subsection",
 CellChangeTimes->{{3.933406651996584*^9, 3.933406653053932*^9}, {
  3.9334079593832664`*^9, 
  3.9334079630789833`*^9}},ExpressionUUID->"3d76b8cc-17d5-4306-9b2e-\
5eb6da5b0e34"],

Cell[TextData[{
 "The most straightforward way of getting the contents of a webpage is to \
send an HTML request to the server that is providing the webpage. Here, we \
will use a website that provides sample webpages specifically for training \
purposes. In this case, we will use their \[OpenCurlyDoubleQuote]e-commerce\
\[CloseCurlyDoubleQuote] subpage, which mimics a web store webpage, and it\
\[CloseCurlyQuote]s already filled in with some mock products. We can pass a \
URL to ",
 ButtonBox["Import",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Import.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Import.html"],
 " and specify ",
 Cell[BoxData["\"\<Text\>\""], "Input",ExpressionUUID->
  "ff4d8ace-0987-4fbf-8528-1f05c2e04b02"],
 " as our desired output. With that, Import can handle the underlying HTTP \
requests and response parsing for us:"
}], "Text",ExpressionUUID->"d791a51e-c2a4-4a6e-be58-0f5ef869c6e4"],

Cell[BoxData[
 RowBox[{"ecommerce", " ", "=", " ", 
  RowBox[{"Import", "[", 
   RowBox[{"\"\<https://webscraper.io/test-sites/e-commerce/allinone/\
computers/laptops\>\"", ",", " ", "\"\<Text\>\""}], "]"}]}]], "Input",Expressi\
onUUID->"6e331007-e4a9-4991-83d5-24faa0ec5737"],

Cell[TextData[{
 "Once we have the string, we can start parsing it, just like any other \
string in Wolfram Language. With strings, the typical way we do that is by \
looking at the structure surrounding the information we are interested in and \
using ",
 ButtonBox["StringExpression",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/StringExpression.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/StringExpression.html"],
 " or ",
 ButtonBox["RegularExpression",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/RegularExpression.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/RegularExpression.html"],
 " to extract it. For example, if we are interested in the product \
descriptions, we can see that they are enclosed in <p class = \
\[OpenCurlyDoubleQuote]description card-text\[CloseCurlyDoubleQuote] > < /p \
>. With that, we can match all the products on the page with StringExpression:"
}], "Text",ExpressionUUID->"11925604-9cc9-43fc-be1f-e33e09e40df9"],

Cell[BoxData[
 RowBox[{"StringCases", "[", 
  RowBox[{"ecommerce", ",", 
   RowBox[{"StringExpression", "[", 
    RowBox[{"\"\<<p class=\\\"description card-text\>\"", "~~", 
     RowBox[{"Shortest", "[", "__", "]"}], "~~", "\"\<</p>\>\""}], "]"}]}], 
  "]"}]], "Input",ExpressionUUID->"347d4251-493d-4d80-a81f-aa5721d7eda3"],

Cell["Or with RegularExpression:", "Text",ExpressionUUID->"055f3e2f-3ab7-49fa-9978-0b39a44a4c06"],

Cell[BoxData[
 RowBox[{"Column", "[", 
  RowBox[{"StringCases", "[", 
   RowBox[{"ecommerce", ",", 
    RowBox[{
     RowBox[{
     "RegularExpression", 
      "[", "\"\<<p class=\\\"description card-text.*description\\\">(.*?)</p>\
\>\"", "]"}], "->", "\"\<$1\>\""}]}], "]"}], "]"}]], "Input",ExpressionUUID->\
"d899cc58-da9d-4f7d-8739-aeadb1ac33f0"],

Cell[TextData[{
 "String matching is a very powerful method of parsing string data, not only \
in web data but in many other data analysis workflows as well. If you are \
interested in learning more about StringExpression and RegularExpression, \
there is an excellent guide page: ",
 ButtonBox["Working with String Patterns",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/tutorial/\
WorkingWithStringPatterns.html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/tutorial/WorkingWithStringPatterns.\
html"],
 "."
}], "Text",ExpressionUUID->"7ed1cd66-ba4a-4c07-9e12-ac51523f0836"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[Cell[BoxData["URLRead"], \
"InlineCode",ExpressionUUID->"ae039be8-9e76-4e89-9245-9a5f0de03f7f"]], \
"Subsection",
 CellChangeTimes->{{3.938857833904188*^9, 3.938857834788581*^9}, 
   3.9388581288717623`*^9},ExpressionUUID->"ff8bbce3-2ee0-4ec1-9ec3-\
e32366ed7c14"],

Cell[TextData[{
 "The more manual way of sending requests is by using ",
 ButtonBox["URLRead",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/URLRead.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/URLRead.html"],
 " directly, which will preserve all the information about the response from \
the server, not just the text. Let\[CloseCurlyQuote]s test it with the same \
e-commerce webpage:"
}], "Text",ExpressionUUID->"94e95abe-d056-4f83-aaff-7a9d411094c6"],

Cell[BoxData[
 RowBox[{"ecommerceurlread", "=", 
  RowBox[{
  "URLRead", 
   "[", "\"\<https://webscraper.io/test-sites/e-commerce/allinone\>\"", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.938857777541279*^9, 3.9388577858178883`*^9}, {
  3.938857884566812*^9, 3.938857903296341*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"6a5adb14-2bff-4d5c-bb43-53f27c4663d3"],

Cell[TextData[{
 "The output is an ",
 ButtonBox["HTTPResponse",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/HTTPResponse.html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/HTTPResponse.html"],
 " object, which contains the text in its ",
 Cell[BoxData["\"\<Body\>\""], "Input",ExpressionUUID->
  "359983a0-2238-4701-a236-0e7b4b80f1b8"],
 " property:"
}], "Text",ExpressionUUID->"a56b0932-7a85-4d3e-8b3f-96261c71a136"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ecommerceurlread", "[", "\"\<Body\>\"", "]"}], ";"}]], "Input",Expr\
essionUUID->"97e6467b-582f-4274-8334-bfc873103171"],

Cell["\<\
This is identical to the text we got by using Import. As well as the body, \
the response normally also contains other information, such as the headers \
and status codes:\
\>", "Text",ExpressionUUID->"722eeab9-9ac6-47af-a243-45adf201c08d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ecommerceurlread", "[", "\"\<Headers\>\"", "]"}], ";"}]], "Input",E\
xpressionUUID->"1810a17f-c2c6-45c3-a7e7-5f13ea2eff82"],

Cell["\<\
This can give you more information about how the server handled your request, \
which can be very useful for debugging and troubleshooting. It can also be \
used for passing custom headers, such as user agents, which is a common \
practice when trying to bypass anti-automated restrictions.\
\>", "Text",ExpressionUUID->"367eba84-ad03-4e2e-811f-ffc6c12f79b9"]
}, Open  ]]
}, Open  ]],

Cell["", "EndOfSlide",ExpressionUUID->"d65d6511-b311-44b3-bcf6-7ff208f35b0a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"45a8cfae-8565-4f4f-9dbc-d0ed874bf296"],

Cell[CellGroupData[{

Cell["Example: Import and String Cleaning", "Subsection",ExpressionUUID->"9fcdedf6-18c9-4ed4-8a74-a7a4b0d82037"],

Cell["\<\
Collecting contact information from different webpages is a common workflow \
in producing mailing lists. Here, we will take some publicly available \
contact numbers from a few big businesses that have offices in the UK. First, \
we\[CloseCurlyQuote]ll collect their contact pages in a list of associations, \
where the key is the company name and the value is the webpage itself:\
\>", "Text",ExpressionUUID->"cd7faa85-c4ad-40a2-8baa-f7ef6d6768da"],

Cell[BoxData[
 RowBox[{
  RowBox[{"contactPages", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"<|", 
      RowBox[{"\"\<Apple\>\"", 
       "->", "\"\<https://www.apple.com/uk/contact/\>\""}], "|>"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{"\"\<Barclays\>\"", 
       "->", "\"\<https://www.barclays.co.uk/ways-to-bank/telephone-banking/\>\
\""}], "|>"}], ",", "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{"\"\<Monzo\>\"", "->", "\"\<https://monzo.com/help/\>\""}], 
      "|>"}], ",", "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{"\"\<Evri\>\"", 
       "->", "\"\<https://www.evri.com/contact-us\>\""}], "|>"}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}]], "Input",ExpressionUUID->"126357a3-\
bd5d-4d69-a1c6-2125ee835dce"],

Cell["\<\
Then we will write a simple function which takes one association, opens the \
webpage (the value) and tries to find a phone number on the page. The regular \
expression below tries to capture common UK number formatting, and it can be \
read as \[OpenCurlyDoubleQuote]4 digits, followed by either a space or a \
dash, followed by 3 digits, followed by either a space or a dash, followed by \
4 digits\[CloseCurlyDoubleQuote]:\
\>", "Text",ExpressionUUID->"af9b72a0-1d28-41b1-8cfd-36a892acc273"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getContactDetails", "[", "asc_Association", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"webpageText", ",", "numbers", ",", "companyName"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"webpageText", "=", 
      RowBox[{"Import", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Values", "[", "asc", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<Text\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"numbers", "=", 
      RowBox[{
       RowBox[{"StringCases", "[", 
        RowBox[{"webpageText", ",", 
         RowBox[{
         "RegularExpression", 
          "[", "\"\<\\\\d{4}[\\\\s-]\\\\d{3}[\\\\s-]\\\\d{4}\>\"", "]"}]}], 
        RowBox[{"(*", 
         RowBox[{"StringExpression", "[", 
          RowBox[{
           RowBox[{"Repeated", "[", 
            RowBox[{"DigitCharacter", ",", 
             RowBox[{"{", "4", "}"}]}], "]"}], ",", 
           RowBox[{"WhitespaceCharacter", "|", "\"\<-\>\""}], ",", 
           RowBox[{"Repeated", "[", 
            RowBox[{"DigitCharacter", ",", 
             RowBox[{"{", "3", "}"}]}], "]"}], ",", 
           RowBox[{"WhitespaceCharacter", "|", "\"\<-\>\""}], ",", 
           RowBox[{"Repeated", "[", 
            RowBox[{"DigitCharacter", ",", 
             RowBox[{"{", "4", "}"}]}], "]"}]}], "]"}], "*)"}], "]"}], "//", 
       "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"companyName", "=", 
      RowBox[{
       RowBox[{"Keys", "[", "asc", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Association", "[", 
      RowBox[{"<|", 
       RowBox[{"companyName", "->", "numbers"}], "|>"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",ExpressionUUID->"2b2162a2-31c3-\
43b0-a059-8581f0ee8a33"],

Cell["Finally, we\[CloseCurlyQuote]ll apply the function to our original \
dataset:", "Text",ExpressionUUID->"b0293974-2d27-4a7b-9c33-3e1cd5ef6f7b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"getContactDetails", "[", "#", "]"}], "&"}], "/@", 
   "contactPages"}], "//", "Dataset"}]], "Input",
 CellChangeTimes->{{3.9337553579684105`*^9, 3.933755363134945*^9}, {
  3.9337554238177376`*^9, 3.933755425052084*^9}, {3.933755554195141*^9, 
  3.933755555397753*^9}},ExpressionUUID->"b05ac900-4e06-493c-b5b0-\
7e107b21ab2f"],

Cell[BoxData[""], "Input",ExpressionUUID->"b82e538b-1263-4263-b852-aa59da4469c8"],

Cell[TextData[{
 "To scale up this workflow, we only need to add more contact pages and pass \
them to our ",
 Cell[BoxData[
 "getContactDetails"], "Input",ExpressionUUID->
  "e71043e5-0555-4810-a45f-4add24eca2f8"],
 " function."
}], "Text",ExpressionUUID->"77ac8748-8cf7-4c86-95ad-f86385156f7a"],

Cell[BoxData["\[IndentingNewLine]"], "Input",ExpressionUUID->"f57dcb7a-ebb8-4be4-95e0-dc78a76b10aa"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"aafd6f72-36db-43d4-bd85-c2f1c4416713"],

Cell[CellGroupData[{

Cell["Parsing Structured Responses", "Section",ExpressionUUID->"5fc8ebaf-a129-441a-8c17-0b6864bd2881"],

Cell[CellGroupData[{

Cell["XML", "Subsection",
 CellChangeTimes->{{3.9392721224728527`*^9, 
  3.939272122594165*^9}},ExpressionUUID->"53896c97-fe4e-42e5-91c6-\
bd1f20810393"],

Cell[TextData[{
 "XML is a markup language commonly used on websites to define their data \
structures. There is some degree of interoperability between HTML and XML, \
which means that you can typically import a webpage as an ",
 ButtonBox["XMLObject",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/XMLObject.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/XMLObject.html"],
 " and make use of Wolfram\[CloseCurlyQuote]s XML parsing tools to navigate \
its structure. However, XML is a stricter standard than HTML, and the HTML in \
lot of modern webpages cannot be perfectly represented as XML. There are \
still places where XML is common and standard."
}], "Text",ExpressionUUID->"447d9370-2d59-4178-b4d7-1123f7ecb882"],

Cell["\<\
One common example of XML in webpages is sitemaps of news websites, which are \
intended to display the current contents of the website in an accessible way \
for automated tools (typically Google web scrapers). Let\[CloseCurlyQuote]s \
import the latest BBC sitemap as an XMLObject:\
\>", "Text",ExpressionUUID->"8568a15d-fb0e-412c-8073-2fbfc8a0d2cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bbcSitemap", "=", 
  RowBox[{"Import", "[", 
   RowBox[{"\"\<https://www.bbc.co.uk/sitemaps/https-sitemap-uk-news-1.xml\>\"\
", ",", "\"\<XMLObject\>\""}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"2265e767-f361-4367-bc14-abdd04d9918d"],

Cell[BoxData[
 TemplateBox[<|"shortenedBoxes" -> TagBox[
     RowBox[{
       RowBox[{"XMLObject", "[", "\"Document\"", "]"}], "[", 
       RowBox[{
         RowBox[{"{", 
           RowBox[{
             RowBox[{"XMLObject", "[", "\"Declaration\"", "]"}], "[", 
             RowBox[{
               RowBox[{"\"Version\"", "\[Rule]", "\"1.0\""}], ",", 
               RowBox[{"\"Encoding\"", "\[Rule]", "\"UTF-8\""}], ",", 
               RowBox[{"\"Standalone\"", "\[Rule]", "\"yes\""}]}], "]"}], 
           "}"}], ",", 
         RowBox[{"XMLElement", "[", 
           RowBox[{"\"urlset\"", ",", 
             RowBox[{"{", 
               TemplateBox[{"1"}, "OutputSizeLimit`Skeleton"], "}"}], ",", 
             RowBox[{"{", 
               RowBox[{
                 RowBox[{"XMLElement", "[", 
                   RowBox[{"\"url\"", ",", 
                    RowBox[{"{", "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"XMLElement", "[", 
                    RowBox[{"\"loc\"", ",", 
                    RowBox[{"{", "}"}], ",", 
                    
                    RowBox[{"{", 
                    "\"https://www.bbc.co.uk/sport/football/articles/\
cddnjev4e5eo\"", "}"}]}], "]"}], ",", 
                    RowBox[{"XMLElement", "[", 
                    RowBox[{"\"lastmod\"", ",", 
                    RowBox[{"{", "}"}], ",", 
                    RowBox[{"{", "\"2026-03-11T10:26:44Z\"", "}"}]}], "]"}], 
                    ",", 
                    RowBox[{"XMLElement", "[", 
                    TemplateBox[{"1"}, "OutputSizeLimit`Skeleton"], "]"}]}], 
                    "}"}]}], "]"}], ",", 
                 TemplateBox[{"972"}, "OutputSizeLimit`Skeleton"], ",", 
                 RowBox[{"XMLElement", "[", 
                   TemplateBox[{"1"}, "OutputSizeLimit`Skeleton"], "]"}]}], 
               "}"}]}], "]"}], ",", 
         RowBox[{"{", "}"}]}], "]"}], Short[#, 8]& ], "line" -> 3, 
   "sessionID" -> 33513211559291375946, "byteCount" -> 2785736, "size" -> 8, 
   "stored" -> False, "expr" -> Missing["NotStored"], "wrap" -> 
   OutputSizeLimit`Defer, "version" -> 1|>,
  "OutputSizeLimitTemplate"]], "Output",
 CellLabel->"Out[3]=",ExpressionUUID->"6328464f-ab25-174b-ae18-2fafee8d023e"]
}, Open  ]],

Cell["\<\
Now we can use pattern matching to extract the information that we are \
interested in. By inspecting the XML structure above, we can see that \
hyperlinks to the actual news articles are contained in the following \
structure:\
\>", "Text",ExpressionUUID->"13a10133-67d0-470a-94d7-a417262e4d30"],

Cell[BoxData[
 RowBox[{
  RowBox[{"bbcArticlesLinks", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"bbcSitemap", ",", 
     RowBox[{
      RowBox[{"XMLElement", "[", 
       RowBox[{"\"\<loc\>\"", ",", "_", ",", 
        RowBox[{"{", "url_", "}"}]}], "]"}], ":>", "url"}], ",", "Infinity"}],
     "]"}]}], ";"}]], "Input",ExpressionUUID->"62fa3ec3-eac1-48fc-8ae7-\
273488648bf5"],

Cell["And headlines are in this structure:", "Text",ExpressionUUID->"01032131-ac3a-490c-8cba-83161a38b871"],

Cell[BoxData[
 RowBox[{
  RowBox[{"bbcArticlesHeadlines", "=", 
   RowBox[{"Cases", "[", 
    RowBox[{"bbcSitemap", ",", 
     RowBox[{
      RowBox[{"XMLElement", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"___", ",", "\"\<title\>\""}], "}"}], ",", "_", ",", 
        RowBox[{"{", "headline_", "}"}]}], "]"}], ":>", "headline"}], " ", ",",
      "Infinity"}], "]"}]}], ";"}]], "Input",ExpressionUUID->"83e2db46-7200-\
427e-a41c-ac00129cc8b2"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s put everything together in a ",
 ButtonBox["Dataset",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Dataset.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Dataset.html"],
 " structure:"
}], "Text",ExpressionUUID->"13d9bee2-8d22-4a6a-9cc5-4e76f0c59cb7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"minLength", "=", 
   RowBox[{"Min", "[", 
    RowBox[{
     RowBox[{"Length", "[", "bbcArticlesHeadlines", "]"}], ",", 
     RowBox[{"Length", "[", "bbcArticlesLinks", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dataset", "[", "\[IndentingNewLine]", "  ", 
  RowBox[{
   RowBox[{
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Headline\>\"", "->", "#1"}], ",", 
      RowBox[{"\"\<URL\>\"", "->", "#2"}]}], "|>"}], " ", "&"}], " ", "@@@", 
   " ", "\[IndentingNewLine]", "    ", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Take", "[", 
       RowBox[{"bbcArticlesHeadlines", ",", "minLength"}], "]"}], ",", 
      RowBox[{"Take", "[", 
       RowBox[{"bbcArticlesLinks", ",", "minLength"}], "]"}]}], "}"}], 
    "]"}]}], "\[IndentingNewLine]", "]"}]}], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"af35a6a4-6f01-4bf7-a962-92cea82764b9"],

Cell[BoxData[
 TagBox[
  TagBox[
   DynamicModuleBox[{TypeSystem`NestedGrid`PackagePrivate`$state$$ = <|
    "InitialData" -> {<|
       "Headline" -> 
        "Newcastle analysis: Fearless Lewis Hall epitomises effort against \
Barcelona", "URL" -> 
        "https://www.bbc.co.uk/sport/football/articles/cddnjev4e5eo"|>, <|
       "Headline" -> 
        "Tottenham news: Spurs boosted by return of Djed Spence and Radu \
Dragusin", "URL" -> 
        "https://www.bbc.co.uk/sport/football/articles/cz6ev1zldzgo"|>, <|

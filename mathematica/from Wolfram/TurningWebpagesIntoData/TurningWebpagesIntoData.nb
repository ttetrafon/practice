Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"9ade1b55-91b6-4405-95de-f8bef4178e47"],

Cell[CellGroupData[{

Cell["Example: Headless Browsers, JavaScript Injections", "Subsection",ExpressionUUID->"0f81a4a5-da06-4ef7-9c4c-49bfe9e9e310"],

Cell[TextData[{
 "As extensive as WebExecute is, there will eventually be some things that we \
would want to do that are not readily available. This is where the ",
 Cell[BoxData[
 "\"\<JavascriptExecute\>\""], "Input",ExpressionUUID->
  "a480a670-30b0-4a8e-9b88-9527ffd8d4fb"],
 " option comes in\[LongDash]it allows us to execute an arbitrary piece of \
JavaScript code in the browser that we are controlling. In practice, that \
opens up basically any web browser functionality. "
}], "Text",ExpressionUUID->"f831001a-63e8-4717-a9b5-7a45c78b4447"],

Cell["\<\
In this example, we will see how we can load dynamic elements by scrolling to \
the bottom of the page to load more. Start our web session as usual:\
\>", "Text",ExpressionUUID->"f56229bb-0a81-49d2-9d1f-57dab8280931"],

Cell[BoxData[
 RowBox[{
  RowBox[{"session", "=", 
   RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}], ";"}]], "Input",\
ExpressionUUID->"179905fe-03e4-42d7-b4fb-c279c76e72bc"],

Cell["\<\
Navigate to the resource repository. If you open this page separately, you \
will see that by default it loads only a few rows\[CloseCurlyQuote] elements. \
When the user scrolls down to the bottom of the page, some more are loaded. \
If we are controlling the browser manually, we will keep scrolling to the \
bottom of the page until all elements are loaded. But how can we do that \
programmatically?\
\>", "Text",ExpressionUUID->"3cdafda4-46ba-4682-9f60-eca1fce8d060"],

Cell[BoxData[
 RowBox[{"WebExecute", "[", 
  RowBox[{"session", ",", 
   RowBox[{"\"\<OpenPage\>\"", 
    "->", "\"\<https://resources.wolframcloud.com/ExampleRepository/\>\""}]}],
   "]"}]], "Input",
 CellChangeTimes->{{3.9326268584798775`*^9, 
  3.932626873343296*^9}},ExpressionUUID->"7c58bb23-ecf9-4661-b37b-\
47c961a03ad4"],

Cell["\<\
Since there is no \[OpenCurlyDoubleQuote]keep scrolling down\
\[CloseCurlyDoubleQuote] functionality baked into WebExecute, we can write a \
simple JavaScript loop to do what we need. Here, we are getting the height of \
the webpage before scrolling down to the bottom. If the new height of the \
page is larger than the one previously, this indicates that more things are \
loaded, so we repeat. We only stop when the height doesn\[CloseCurlyQuote]t \
change after the scroll:\
\>", "Text",ExpressionUUID->"776f5171-8cd8-4b49-9d11-0121695efabd"],

Cell[BoxData[
 RowBox[{"WebExecute", "[", 
  RowBox[{"session", ",", 
   RowBox[{"\"\<JavascriptExecute\>\"", 
    "->", "\"\<let lastScrollHeight = 0;\n\n// Create a hidden container to \
store links\nlet archiveDiv = document.createElement(\\\"div\\\");\n\
archiveDiv.id = \\\"archived-links\\\";\narchiveDiv.style.display = \
\\\"none\\\";\ndocument.body.appendChild(archiveDiv);\n\nconst \
scrollAndCollect = () => {\n    window.scrollTo(0, \
document.body.scrollHeight);\n\n    setTimeout(() => {\n        // Collect \
current visible links\n        const links = \
document.querySelectorAll(\\\"a[href]\\\");\n        links.forEach(link => {\n\
            if (!archiveDiv.innerHTML.includes(link.href)) {\n                \
const clonedLink = link.cloneNode(true);\n                \
archiveDiv.appendChild(clonedLink);\n                \
archiveDiv.appendChild(document.createElement(\\\"br\\\"));\n            }\n  \
      });\n\n        // Check if we need to scroll more\n        if \
(document.body.scrollHeight > lastScrollHeight) {\n            \
lastScrollHeight = document.body.scrollHeight;\n            \
scrollAndCollect();\n        }\n        // else: done\n    }, 1000); // wait \
1 second after scroll\n};\n\nscrollAndCollect();\>\""}]}], "]"}]], "Input",Exp\
ressionUUID->"58e99546-c98c-4ec6-accd-b1be3dbc3994"],

Cell[BoxData[
 RowBox[{
  RowBox[{"archivedLinks", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<CSSSelector\>\"", "->", "\"\<#archived-links\>\""}]}]}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"5ea8e692-2cec-435a-89de-\
8e5012d75f12"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"allHyperlinks", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", "\"\<PageHyperlinks\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Length", "[", "allHyperlinks", "]"}]}], "Input",ExpressionUUID->\
"ebc9a5f3-87e7-4dd4-90e6-bda1ae5f38a1"],

Cell["And clean them up as usual:", "Text",ExpressionUUID->"e6f64e92-e488-45c1-94b3-2dc2e72530a1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"allResourceLinks", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"allHyperlinks", ",", 
     RowBox[{
     "StringContainsQ", 
      "[", "\"\<https://resources.wolframcloud.com/ExampleRepository/\
resources/\>\"", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Length", "[", "allResourceLinks", "]"}]}], "Input",ExpressionUUID->\
"ab1405b3-db63-418d-a166-8722c330def5"],

Cell["Noticing this is significantly smaller than what we see.", "Text",ExpressionUUID->"9fc27935-e2aa-4f9b-ba03-3559567bc396"],

Cell[BoxData[
 RowBox[{"DeleteObject", "[", "session", "]"}]], "Input",ExpressionUUID->"fc775340-17d3-4186-91c0-56de52b07c52"],

Cell[CellGroupData[{

Cell["Different approach", "Subsubsection",ExpressionUUID->"ff654bb7-83c6-49b1-977f-fb1044eb83cf"],

Cell["\<\
We can go to each category page to get the links without handling the webpage \
structure uncertainties.\
\>", "Text",ExpressionUUID->"828a7053-37d8-46b7-8b9b-65646b4790b3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"this", " ", "will", " ", "take", " ", "a", " ", "while"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"categories", "=", 
     RowBox[{"{", 
      RowBox[{"\"\<astronomy\>\"", ",", "\"\<audio-processing\>\"", 
       ",", "\"\<calculus\>\"", ",", "\"\<cellular-automata\>\"", 
       ",", "\"\<chemistry\>\"", ",", "\"\<complex-systems\>\"", 
       ",", "\"\<computer-science\>\"", ",", "\"\<computer-vision\>\"", 
       ",", "\"\<control-systems\>\"", ",", "\"\<creative-arts\>\"", 
       ",", "\"\<data-science\>\"", ",", "\"\<engineering\>\"", 
       ",", "\"\<finance-economics\>\"", ",", "\"\<finite-element-method\>\"",
        ",", "\"\<food-nutrition\>\"", ",", "\"\<geography\>\"", 
       ",", "\"\<geometry\>\"", ",", "\"\<graphs-networks\>\"", 
       ",", "\"\<image-processing\>\"", ",", "\"\<life-sciences\>\"", 
       ",", "\"\<machine-learning\>\"", ",", "\"\<mathematics\>\"", 
       ",", "\"\<optimization\>\"", ",", "\"\<physics\>\"", 
       ",", "\"\<probability-statistics\>\"", 
       ",", "\"\<puzzles-and-recreation\>\"", 
       ",", "\"\<quantum-computation\>\"", ",", "\"\<signal-processing\>\"", 
       ",", "\"\<social-sciences\>\"", ",", "\"\<system-modeling\>\"", 
       ",", "\"\<tabular-processing\>\"", 
       ",", "\"\<text-language-processing\>\"", 
       ",", "\"\<time-related-computation\>\"", 
       ",", "\"\<video-processing\>\"", 
       ",", "\"\<visualization-graphics\>\""}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"session2", "=", 
     RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"allLinks", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{"cat", ",", 
          RowBox[{
           RowBox[{"WebExecute", "[", 
            RowBox[{"session2", ",", 
             RowBox[{"\"\<OpenPage\>\"", "->", 
              
              RowBox[{"\"\<https://resources.wolframcloud.com/\
ExampleRepository/category/\>\"", "<>", "cat"}]}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Pause", "[", "3", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"WebExecute", "[", 
            RowBox[{"session2", ",", "\"\<PageHyperlinks\>\""}], "]"}]}]}], 
         "]"}], ",", "categories"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"exampleLinks", "=", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"DeleteDuplicates", "[", "allLinks", "]"}], ",", 
       RowBox[{
        RowBox[{"StringContainsQ", "[", 
         RowBox[{"#", ",", "\"\</resources/\>\""}], "]"}], "&"}]}], "]"}]}], 
    ";"}]}]}]], "Input",ExpressionUUID->"6f2daad3-7166-45ea-afce-\
4d63d6a3706e"],

Cell[BoxData[
 RowBox[{"RandomSample", "[", 
  RowBox[{"exampleLinks", ",", "5"}], "]"}]], "Input",ExpressionUUID->\
"c6624220-184d-4a0c-9b1b-525b6ac40877"],

Cell["\<\
Write a small function to extract the authors of all the contributed examples:\
\>", "Text",ExpressionUUID->"d88bf351-77f4-4506-9501-58badf73b7fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GetExampleContributors", "[", 
   RowBox[{"allExamples_List", ",", "session_WebSessionObject"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"page", ",", 
      RowBox[{"allContributors", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"WebExecute", "[", 
         RowBox[{"session", ",", 
          RowBox[{"\"\<OpenPage\>\"", "->", "link"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"page", "=", 
         RowBox[{"WebExecute", "[", 
          RowBox[{"session", ",", 
           RowBox[{"\"\<LocateElements\>\"", "->", " ", 
            
            RowBox[{"\"\<CSSSelector\>\"", 
             "->", "\"\<body > main > div.wrap > div > \
ul.source-metadata.publisher-info > li > span\>\""}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"allContributors", ",", " ", 
          RowBox[{"WebExecute", "[", 
           RowBox[{"session", ",", " ", 
            RowBox[{"\"\<ElementText\>\"", "->", "page"}]}], "]"}]}], "]"}], 
        ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"link", ",", "allExamples"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "allContributors"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9326332331532955`*^9, 3.93263325171611*^9}, {
   3.932633361333576*^9, 3.932633378227421*^9}, {3.932633414399954*^9, 
   3.9326334451631966`*^9}, {3.9326337816904984`*^9, 3.932633791936943*^9}, {
   3.9326338986053543`*^9, 3.93263393604932*^9}, {3.932634017963785*^9, 
   3.9326340651329517`*^9}, {3.9326341023466263`*^9, 3.932634103107786*^9}, {
   3.9326341888797894`*^9, 3.932634194801567*^9}, {3.933326924306757*^9, 
   3.9333269384344482`*^9}, {3.9333269895324535`*^9, 
   3.9333269944645348`*^9}, {3.940323976639296*^9, 3.94032402177977*^9}, {
   3.940324080431899*^9, 3.940324081733564*^9}, {3.940324118113669*^9, 
   3.9403241837245827`*^9}, {3.940324300541664*^9, 3.94032430121609*^9}, {
   3.940324736756309*^9, 3.9403247787215023`*^9}, {3.94032488872677*^9, 
   3.940324889926198*^9}, {3.9403251361896067`*^9, 3.94032513859515*^9}, 
   3.940325255934894*^9},
 CellLabel->"In[6]:=",ExpressionUUID->"cbb41fa4-7dab-4d75-87fe-a1d269e23836"],

Cell["\<\
Collect all the authors in a variable and clean up the web session:\
\>", "Text",ExpressionUUID->"4dd83c63-85fa-42e2-af73-09e7e52caaa0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"this", " ", "will", " ", "take", " ", "a", " ", "while"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"allAuthors", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{"GetExampleContributors", "[", 
      RowBox[{"exampleLinks", ",", "session2"}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"6b3718aa-05a0-4f32-a034-c9e62891331f"],

Cell["Clean up the authors and tally them:", "Text",ExpressionUUID->"b08e3975-7cc0-4647-8c5a-206dc0b28148"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cleanedupAuthors", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"StringReplace", "[", 
      RowBox[{
       RowBox[{"ToString", "[", "#", "]"}], ",", 
       RowBox[{"\"\< Null\>\"", "->", "\"\<\>\""}]}], "]"}], "&"}], "/@", 
    "allAuthors"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Length", "[", "cleanedupAuthors", "]"}]}], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"545c501e-bad8-42fc-af08-4df69e0cdb19"],

Cell[BoxData["378"], "Output",
 CellLabel->"Out[11]=",ExpressionUUID->"552421b4-8df0-4cab-b6fe-d70d5b341239"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ReverseSortBy", "[", 
  RowBox[{
   RowBox[{"Tally", "[", "cleanedupAuthors", "]"}], ",", "Last"}], 
  "]"}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"ed5abb78-e17b-472e-9153-c41c21f437f6"],


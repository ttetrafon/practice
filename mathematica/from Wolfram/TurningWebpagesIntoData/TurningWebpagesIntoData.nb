Cell[CellGroupData[{

Cell["Under Pressure Stats", "Subsubsection",ExpressionUUID->"3428944a-0ab4-47aa-aa57-53bf4116de57"],

Cell["\<\
This is the same type of webpage as before, so copy/paste the procedure:\
\>", "Text",ExpressionUUID->"d3d69ffd-c449-4692-accd-321080a8ece6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "start", " ", "the", " ", "session", " ", "and", " ", "open", " ", "the", " ",
     "page"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"session", "=", 
     RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", 
      RowBox[{"\"\<OpenPage\>\"", 
       "->", "\"\<https://www.atptour.com/en/stats/leaderboard?boardType=\
pressure&timeFrame=52week&surface=all&versusRank=all&formerNo1=false\>\""}]}],
      "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"wait", " ", "for", " ", "page", " ", "to", " ", "load"}], ",", 
     " ", 
     RowBox[{"and", " ", "click", " ", "\"\<Cookies\>\"", " ", "button"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Pause", "[", "3", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"buttonTags", " ", "=", " ", 
     RowBox[{"WebExecute", "[", 
      RowBox[{"session", ",", 
       RowBox[{"\"\<LocateElements\>\"", "->", 
        RowBox[{"\"\<Tag\>\"", "->", "\"\<button\>\""}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cookiesButton", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"WebExecute", "[", 
           RowBox[{"session", ",", 
            RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], 
          "==", "\"\<Accept All Cookies\>\""}], ",", "#", ",", "Nothing"}], 
        "]"}], "&"}], "/@", "buttonTags"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", 
      RowBox[{"\"\<ClickElement\>\"", "->", 
       RowBox[{"First", "[", "cookiesButton", "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"wait", " ", "for", " ", "page", " ", "to", " ", "load"}], ",", 
     " ", 
     RowBox[{"and", " ", "click", " ", "\"\<Load More\>\"", " ", "button"}]}],
     " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Pause", "[", "3", "]"}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aTags", "=", 
     RowBox[{"WebExecute", "[", 
      RowBox[{"session", ",", 
       RowBox[{"\"\<LocateElements\>\"", "->", 
        RowBox[{"\"\<Tag\>\"", "->", "\"\<a\>\""}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"loadMoreButton", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"WebExecute", "[", 
           RowBox[{"session", ",", 
            RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], 
          "==", "\"\<Load More\>\""}], ",", "#", ",", "Nothing"}], "]"}], 
       "&"}], "/@", "aTags"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"WebExecute", "[", 
     RowBox[{"session", ",", 
      RowBox[{"\"\<ClickElement\>\"", "->", 
       RowBox[{"First", "[", "loadMoreButton", "]"}]}]}], "]"}], 
    ";"}]}]}]], "Input",ExpressionUUID->"681c8baf-fb04-4152-a7b8-\
bd0538b89147"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Get", " ", "data", " ", "and", " ", "format", " ", "data"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"pressuretrTags", "=", 
     RowBox[{"WebExecute", "[", 
      RowBox[{"session", ",", 
       RowBox[{"\"\<LocateElements\>\"", "->", 
        RowBox[{"\"\<Tag\>\"", "->", "\"\<tr\>\""}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pressureStats", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"StringCases", "[", 
        RowBox[{
         RowBox[{"WebExecute", "[", 
          RowBox[{"\"\<ElementText\>\"", "->", "#"}], "]"}], ",", 
         RowBox[{
          RowBox[{
          "RegularExpression", 
           "[", "\"\<(^\\\\d{1,})\\\\n(.*)\\\\n(\\\\d{3}.\\\\d)\\\\s(.*?%)\\\\\
s(.*?%)\\\\s(.*?%)\\\\s(.*?%)\>\"", "]"}], "->", 
          RowBox[{"{", 
           
           RowBox[{"\"\<$1\>\"", ",", "\"\<$2\>\"", ",", "\"\<$3\>\"", 
            ",", "\"\<$4\>\"", ",", "\"\<$5\>\"", ",", "\"\<$6\>\"", 
            ",", "\"\<$7\>\""}], "}"}]}]}], "]"}], "&"}], "/@", 
      RowBox[{"pressuretrTags", "[", 
       RowBox[{"[", 
        RowBox[{"2", ";;"}], "]"}], "]"}]}]}], ";", 
    RowBox[{"pressureTab", "=", 
     RowBox[{"ToTabular", "[", 
      RowBox[{"Dataset", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Apply", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"<|", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"\"\<Under pressure ranking\>\"", "->", 
               RowBox[{
                RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", 
                "#1", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<Name\>\"", "->", "#2"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"\"\<Under pressure rating\>\"", "->", 
               RowBox[{
                RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", 
                "#3", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<% break points converted\>\"", "->", 
               RowBox[{
                RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", 
                "#4", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<% break points saved\>\"", " ", "->", 
               RowBox[{
                RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", 
                "#5", "]"}]}], ",", " ", "\[IndentingNewLine]", 
              RowBox[{"\"\<% tie breaks won\>\"", "->", 
               RowBox[{
                RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", 
                "#6", "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<% deciding sets won\>\"", "->", 
               RowBox[{
                RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", 
                "#7", "]"}]}]}], "\[IndentingNewLine]", "|>"}], "&"}], ",", 
           "#"}], "]"}], "&"}], "/@", 
        RowBox[{"Flatten", "[", 
         RowBox[{"pressureStats", ",", "1"}], "]"}]}], "]"}], 
      "]"}]}]}]}]}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"c4df6f45-8457-487b-8662-ead61e909f98"],


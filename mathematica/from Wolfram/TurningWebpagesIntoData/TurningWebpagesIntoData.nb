Cell[CellGroupData[{

Cell["Putting Everything Together", "Subsubsection",ExpressionUUID->"5e0a123e-7b34-4194-9ad9-f5c69061010f"],

Cell["\<\
Once we have all the information we want from the different webpages, we can \
put it together in a single dataset:\
\>", "Text",ExpressionUUID->"3624edda-8d38-4472-831b-5eb4a86d4cb4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"JoinAcrossAll", "[", 
    RowBox[{"list_", ",", "key_"}], "]"}], ":=", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"JoinAcross", "[", 
       RowBox[{"#1", ",", "#2", ",", "key"}], "]"}], "&"}], ",", "list"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"JoinAcrossAll", "[", 
    RowBox[{"list_", ",", "key_", ",", "joinspec_"}], "]"}], ":=", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"JoinAcross", "[", 
       RowBox[{"#1", ",", "#2", ",", "key", ",", "joinspec"}], "]"}], "&"}], ",",
      "list"}], "]"}]}], ";"}]}], "Input",ExpressionUUID->"81682829-1a6d-4b64-\
9a60-9628277ef4ca"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"finalDataset", "=", 
  RowBox[{"JoinAcrossAll", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "rankingsTab", ",", "servesTab", ",", "returnsTab", ",", "pressureTab"}],
      "}"}], ",", "\"\<Name\>\"", ",", "\"\<Left\>\""}], "]"}]}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"b688cf3c-0faf-480f-aa14-cdd3bb4f982d"],

Cell[BoxData[
 TemplateBox[<|
  "Summary" -> 
   TemplateBox[<|
     "RowCount" -> 100, "ColumnCount" -> 22, "ColumnTypes" -> 
      Grid[{{"World ranking", "Integer64"}, {"Name", "String"}, {"Country", 
          TypeSpecifier["Entity"]["Country", "String"]}, {
         "Serve ranking", "Integer64"}, {"Serve rating", "Real64"}, {
         "% 1st serve", 
          TypeSpecifier["Quantity"]["Real64", "Percent"]}, {

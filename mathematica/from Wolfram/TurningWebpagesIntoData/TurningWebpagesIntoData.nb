Cell[BoxData[
 RowBox[{
  RowBox[{"allAuthors", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<small\>\""}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"0f042660-7a20-4594-8fb9-53c1630e4688"],

Cell["Put everything together in an association:", "Text",ExpressionUUID->"dd03ac35-a725-4fb4-86cf-e471ec29d56b"],

Cell[BoxData[
 RowBox[{"quotesThread", "=", 
  RowBox[{"AssociationThread", "[", 
   RowBox[{"allQuotes", ",", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"WebExecute", "[", 
        RowBox[{"\"\<ElementText\>\"", "->", "#"}], "]"}], "&"}], ",", 
      "allAuthors"}], "]"}]}], "]"}]}]], "Input",ExpressionUUID->"e0a379fa-\
f88e-47d3-b0a6-65f7fff0ac20"],

Cell["And get a random quote from our list:", "Text",ExpressionUUID->"ea655607-4900-4d2f-affa-f10a9b780663"],

Cell[BoxData[
 RowBox[{"quoteOfTheDay", "=", "\[IndentingNewLine]", 
  RowBox[{"With", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", " ", "=", " ", 
      RowBox[{"Once", "[", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"Length", "[", "quotesThread", "]"}]}], "}"}], "]"}], 
       "]"}]}], "}"}], ",", 
    RowBox[{"Framed", "[", 
     RowBox[{"StringJoin", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Keys", "[", "quotesThread", "]"}], "[", 
        RowBox[{"[", "n", "]"}], "]"}], ",", "\"\<\\n\[LongDash] \>\"", ",", 
       RowBox[{"quotesThread", "[", 
        RowBox[{"[", "n", "]"}], "]"}]}], "]"}], "]"}]}], "]"}]}]], "Input",Ex\
pressionUUID->"08511e45-0ef9-45d0-a71e-2188c023df95"],

Cell[TextData[{
 "When you are done with your session, remember to delete it with ",
 ButtonBox["DeleteObject",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/DeleteObject"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/DeleteObject"],
 " to avoid having unused processes running in the background (especially \
easy to forget if you\[CloseCurlyQuote]re running the browser headlessly):"
}], "Text",ExpressionUUID->"4fe1b421-6b74-4e46-ac19-84748c91ddd7"],

Cell[BoxData[
 RowBox[{"DeleteObject", "[", "session", "]"}]], "Input",
 CellChangeTimes->{{3.939187949430722*^9, 3.93918795260828*^9}, {
  3.939271102472528*^9, 
  3.9392711033725033`*^9}},ExpressionUUID->"eca5df2c-ef39-4fcd-9b11-\
561d06100c10"]
}, Open  ]]
}, Open  ]],

Cell["", "EndOfSlide",ExpressionUUID->"c84b7b10-9246-4c29-95a0-341c7f187373"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"94ca47be-0a39-4d87-bd48-e1cc3e852226"],

Cell[CellGroupData[{

Cell["Example: Headless Browsers and String Cleaning", "Subsection",ExpressionUUID->"dab3e47b-4fe4-467f-80f0-a88c0c9f8f71"],

Cell["\<\
Sometimes, we want to transform the data we find online into a different \
format. In this example, we will take some tabular data from a Wikipedia page \
and present it as an interactive map. Specifically, we are interested in the \
blood type distribution in European countries. \
\>", "Text",ExpressionUUID->"badfeb99-14fc-4ea6-ad1b-d24a85edad22"],

Cell[CellGroupData[{

Cell["Starting Up a Browser Session", "Subsubsection",ExpressionUUID->"2b7f588e-e250-4b99-864c-5db269a76b87"],

Cell[TextData[{
 "Start up our headless browser with ",
 Cell[BoxData[
  RowBox[{"Visible", "->", "False"}]], "Input",ExpressionUUID->
  "5cc0fe87-dfb9-4bfa-9787-48c91c74cdcc"],
 ", navigate to the relevant wiki page and extract the element with tag \
<table>:"
}], "Text",ExpressionUUID->"37e386bb-add8-4e3c-a6e2-d77bba1ae5d1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ses", "=", 
   RowBox[{"StartWebSession", "[", 
    RowBox[{"\"\<Chrome\>\"", ",", 
     RowBox[{"Visible", "->", "False"}]}], "]"}]}], ";"}]], "Input",Expression\
UUID->"4f715812-84a4-4088-8984-e913c7386b61"],

Cell[BoxData[
 RowBox[{
  RowBox[{"WebExecute", "[", 
   RowBox[{"ses", ",", 
    RowBox[{"\"\<OpenPage\>\"", 
     "->", "\"\<https://en.wikipedia.org/wiki/Blood_type_distribution_by_\
country\>\""}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.9338266024381084`*^9, 3.9338266267171974`*^9}, 
   3.9338398934939613`*^9},ExpressionUUID->"1e876bb2-f88c-4f8c-8d00-\
0cb3c19a1ed3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"table", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"ses", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<table\>\""}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"6de4cf72-c66f-496b-8f51-2fb0a97ebb31"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Extracting the Relevant Elements (in This Case: The Second <table>)\
\>", "Subsubsection",ExpressionUUID->"ee6d8cb1-8a4f-484d-8977-3d536c886275"],

Cell["\<\
Get the text of the second table (for this specific webpage, there is an \
empty element with the <table> tag that gets added to our list):\
\>", "Text",ExpressionUUID->"0eea3c24-4608-4c38-9dcc-3917d745152e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rawTable", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"ses", ",", 
     RowBox[{"\"\<ElementText\>\"", "->", 
      RowBox[{"table", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}]}], ";"}]], "Input",Expression\
UUID->"b46fcc01-1ebf-43d9-91f8-aa5341ec5843"]
}, Open  ]],

Cell[CellGroupData[{

Cell["String Cleaning", "Subsubsection",ExpressionUUID->"d475eaf4-0cef-4f34-ace7-4397323e47be"],

Cell["\<\
Now, we do some data cleaning that is specific to the webpage. We are mixing \
StringExpression and RegularExpression instances to extract the country names \
from the table:\
\>", "Text",ExpressionUUID->"452d1349-0108-4805-8074-a4f06e79ecfd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"countryList", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"StringTrim", "[", "#", "]"}], "&"}], "/@", 
    "\[IndentingNewLine]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"StringReplace", "[", 
        RowBox[{"#", ",", 
         RowBox[{
          RowBox[{"\"\<[\>\"", "~~", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"DigitCharacter", ".."}], ")"}], "|", 
            RowBox[{"(", 
             RowBox[{"LetterCharacter", ".."}], ")"}], 
            "|", "\"\<citation needed\>\""}], "~~", "\"\<]\>\""}], 
          "->", "\"\<\>\""}]}], "]"}], "&"}], "/@", 
      RowBox[{"StringCases", "[", 
       RowBox[{"rawTable", ",", 
        RowBox[{
         RowBox[{
         "RegularExpression", 
          "[", "\"\<(.*)\\\\s(\\\\d{1,}.*,\\\\d{3})\\\\s(.*)\>\"", "]"}], 
         "->", "\"\<$1\>\""}]}], "]"}]}], ")"}]}]}], ";"}]], "Input",Expressio\
nUUID->"754186f9-f986-45f1-b7d3-a0be1e1fdf8a"],

Cell[TextData[{
 "Then we take out the information related to a specific blood type, in this \
case A",
 Cell[BoxData[
  FormBox["+", TraditionalForm]],ExpressionUUID->
  "b44bcad3-c840-4ec3-b0aa-adb4fa387829"],
 " and A",
 Cell[BoxData[
  FormBox["-", TraditionalForm]],ExpressionUUID->
  "170a6770-51a8-4b37-a636-ba2a54f3c272"],
 ", and we store it in a list:"
}], "Text",ExpressionUUID->"82dc5db7-9a95-421e-ab4d-ab7983fa06de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aPlus", "=", 
   RowBox[{"StringDelete", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringSplit", "[", 
       RowBox[{
        RowBox[{"StringCases", "[", 
         RowBox[{"rawTable", ",", 
          RowBox[{
           RowBox[{
           "RegularExpression", 
            "[", "\"\<(.*)\\\\s(\\\\d{1,}.*,\\\\d{3})\\\\s(.*)\>\"", "]"}], 
           "->", "\"\<$3\>\""}]}], "]"}], ",", "\"\< \>\""}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", "\"\<%\>\""}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"39fce2dd-57dc-4436-ac80-a299981b1732"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aMinus", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"StringReplace", "[", 
      RowBox[{"#", ",", 
       RowBox[{"\"\<n/a\>\"", "->", "\"\<NA\>\""}]}], "]"}], "&"}], "/@", 
    RowBox[{"StringDelete", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"StringSplit", "[", 
        RowBox[{
         RowBox[{"StringCases", "[", 
          RowBox[{"rawTable", ",", 
           RowBox[{
            RowBox[{
            "RegularExpression", 
             "[", "\"\<(.*)\\\\s(\\\\d{1,}.*,\\\\d{3})\\\\s(.*)\>\"", "]"}], 
            "->", "\"\<$3\>\""}]}], "]"}], ",", "\"\< \>\""}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "6"}], "]"}], "]"}], ",", "\"\<%\>\""}], 
     "]"}]}]}], ";"}]], "Input",ExpressionUUID->"3543a36c-c582-4d90-961c-\
885223c0ef3b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"a", " ", "=", " ", 
    RowBox[{"aPlus", " ", "+", " ", "aMinus"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"a", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"ToExpression", "[", "#", "]"}], "&"}], "/@", "aPlus"}], 
      ")"}], "+", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"ToExpression", "[", "#", "]"}], "&"}], "/@", "aMinus"}], 
      ")"}]}]}], ";"}]}]], "Input",ExpressionUUID->"83c5b493-3629-499b-a6c7-\
93e9514f285a"],

Cell["\<\
Then we create an association thread which associates the proportion of \
people with A blood type to the country name:\
\>", "Text",ExpressionUUID->"01671a82-95cf-4990-8625-9b7b4668999d"],

Cell[BoxData[
 RowBox[{"assoc", "=", 
  RowBox[{"AssociationThread", "[", 
   RowBox[{"countryList", ",", "a"}], "]"}]}]], "Input",ExpressionUUID->\
"ced22b03-bbaa-466a-a920-dbdc969f810a"],

Cell["\<\
Finally, we take the names of the European countries and interpret them as \
entities:\
\>", "Text",ExpressionUUID->"da558560-a1f3-4818-af05-537365fa77c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"europeCountriesNames", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Name\>\"", "]"}], "&"}], "/@", 
    RowBox[{"=[", "europe countries", "]"}]}]}], ";"}]], "Input",ExpressionUUI\
D->"8a6a7778-0c79-40de-91e6-47895466975c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"europeCountriesEntities", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Interpreter", "[", "\"\<Country\>\"", "]"}], "[", "#", "]"}], 
     "&"}], "/@", 
    RowBox[{"Intersection", "[", 
     RowBox[{
      RowBox[{"Keys", "[", "assoc", "]"}], ",", "europeCountriesNames"}], 
     "]"}]}]}], ";"}]], "Input",ExpressionUUID->"ee6ebc52-6de4-4df7-9ba6-\
0a08cac3285e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aBloodType", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"assoc", "[", "#", "]"}], "&"}], "/@", 
    RowBox[{"Intersection", "[", 
     RowBox[{
      RowBox[{"Keys", "[", "assoc", "]"}], ",", "europeCountriesNames"}], 
     "]"}]}]}], ";"}]], "Input",ExpressionUUID->"89fea3e0-de34-4f3e-8dd3-\
4313df882d18"],

Cell["This gives us the final association:", "Text",ExpressionUUID->"582edf9f-1bcc-44bc-9cd0-bad807061c3a"],

Cell[BoxData[
 RowBox[{"geoData", "=", 
  RowBox[{"AssociationThread", "[", 
   RowBox[{"europeCountriesEntities", ",", "aBloodType"}], "]"}]}]], "Input",E\
xpressionUUID->"1a6bd0b8-87a1-4b65-9be5-375a169a29c2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Final Plot", "Subsubsection",ExpressionUUID->"3b59a2b0-aaf7-4bc0-ac01-0cf4346436e0"],

Cell[TextData[{
 "Then we can pass our final association to ",
 ButtonBox["GeoHistogram",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/GeoHistogram"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/GeoHistogram"],
 " to produce a map:"
}], "Text",ExpressionUUID->"df64e618-a173-4926-91c2-6a2daa5dfb23"],

Cell[BoxData[
 RowBox[{"GeoHistogram", "[", 
  RowBox[{"geoData", ",", "\"\<Country\>\"", ",", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"BarLegend", "[", "Automatic", "]"}], ",", "Below"}], "]"}], ",", 
      RowBox[{"Placed", "[", 
       RowBox[{"\"\<Proportion of people with A blood type\>\"", ",", "Top"}],
        "]"}]}], "}"}]}], ",", 
   RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}], ",", 
   RowBox[{"GeoRange", "->", 
    RowBox[{"=[", "europe", "]"}]}], ",", 
   RowBox[{"ImageSize", "->", "Full"}], ",", 
   RowBox[{"Frame", "->", "True"}]}], "]"}]], "Input",ExpressionUUID->\
"b3a04556-e79b-4b7a-83a6-8d3d1e26bcae"],

Cell[BoxData[
 RowBox[{"DeleteObject", "[", "ses", "]"}]], "Input",ExpressionUUID->"7092d2d6-8e90-4ed7-bde2-3f127e55f58a"],

Cell[BoxData["\[IndentingNewLine]"], "Input",ExpressionUUID->"64231d42-a324-cc4a-bfb8-add6798ccfff"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"5c63cdbb-791e-4549-a69d-224b1feeb7cb"],

Cell[CellGroupData[{

Cell["Example: Headless Browsers, Manipulating Webpages", "Subsection",ExpressionUUID->"6acc1d8b-373b-4034-a9e9-6ba23cd5168c"],

Cell["\<\
In many cases, the data that we are interested in exists in different places, \
making unified analysis difficult. In this example, we will look at the \
Association of Tennis Professionals (ATP), which provides a lot of data about \
the tennis players on tour. This data, however, is split between different \
pages (at least four). If we want to do any meaningful analysis, we need to \
visit each webpage, collect the data and finally put it in a single dataset. \
\
\>", "Text",ExpressionUUID->"d13a2419-ae58-4b7b-aca2-f89de7673ed2"],

Cell[CellGroupData[{

Cell["Serve Stats", "Subsubsection",ExpressionUUID->"374c6737-8d1f-4337-b4a7-0ce5b13c3c1d"],

Cell["\<\
We\[CloseCurlyQuote]ll start with the statistics related to serves. Open up a \
web browser and navigate to the serve stats webpage:\
\>", "Text",ExpressionUUID->"a818cac4-6d14-491f-be33-f8b803c1a7af"],

Cell[BoxData[
 RowBox[{
  RowBox[{"session", "=", 
   RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.9388586599849253`*^9, 3.9388586606813726`*^9}, {
   3.938858714077423*^9, 3.938858720649507*^9}, {3.9388587526260653`*^9, 
   3.938858761306519*^9}, {3.939184603830926*^9, 3.9391846043988743`*^9}, 
   3.940495139281698*^9},ExpressionUUID->"a8e864e5-4e77-45ae-9f3e-\
d96eadd80265"],

Cell[BoxData[
 RowBox[{
  RowBox[{"WebExecute", "[", 
   RowBox[{"session", ",", 
    RowBox[{"\"\<OpenPage\>\"", 
     "->", "\"\<https://www.atptour.com/en/stats/leaderboard?boardType=serve&\
timeFrame=52week&surface=all&versusRank=all&formerNo1=false\>\""}]}], "]"}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9388599043058558`*^9, 3.9388599178832827`*^9}, {
   3.939184626337028*^9, 3.9391846278094883`*^9}, 3.9391857539951897`*^9, 
   3.939269566208493*^9, 3.940392535571006*^9, 
   3.940495141275996*^9},ExpressionUUID->"ae328197-5c2b-464a-ab69-\
36adf72d6b6e"],

Cell["\<\
We see our first challenge: when we open the webpage, we see the cookies \
banner first, which is preventing us from further actions. Since we don\
\[CloseCurlyQuote]t want to do this manually, we can use the methods in \
WebExecute to achieve that, but first we need to locate the button. By \
inspecting the webpage, we see that the cookies button is located in a \
<button> tag, so get those first:\
\>", "Text",ExpressionUUID->"1f4079ee-ec63-4378-8b50-2e566a01124c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"buttonTags", " ", "=", " ", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<button\>\""}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"fa203843-7bc5-974a-aa6a-e721e0477ea4"],

Cell["\<\
There are a lot of <button> elements on a webpage, and we only need one of \
them. For each <button> element, we check if its text is equal to \
\[OpenCurlyDoubleQuote]Accept All Cookies\[CloseCurlyDoubleQuote], and if it\
\[CloseCurlyQuote]s not, we discard it, which should leave us with only the \
<button> element that we care about:\
\>", "Text",ExpressionUUID->"c2bf2533-eac8-9746-97a9-a7f5b1c1a4ab"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cookiesButton", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"WebExecute", "[", 
         RowBox[{"session", ",", 
          RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], 
        "==", "\"\<Accept All Cookies\>\""}], ",", "#", ",", "Nothing"}], 
      "]"}], "&"}], "/@", "buttonTags"}]}], ";"}]], "Input",ExpressionUUID->\
"eec91b78-705f-904a-bb75-c50bbf1df93c"],

Cell[TextData[{
 "Then we can use the ",
 Cell[BoxData["\"\<ClickElement\>\""], "Input",ExpressionUUID->
  "30a2c833-d391-c442-a2ed-5e5949ef9a30"],
 " method of WebExecute to click the button:"
}], "Text",ExpressionUUID->"a441aca8-762d-46ff-a0b8-06504c9a547a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"WebExecute", "[", 
   RowBox[{"session", ",", 
    RowBox[{"\"\<ClickElement\>\"", "->", 
     RowBox[{"First", "[", "cookiesButton", "]"}]}]}], "]"}], ";"}]], "Input",\
ExpressionUUID->"b149aeb7-5690-6342-b2e5-4d3ae63c9f9c"],

Cell["\<\
Our second challenge is: we see only the first 50 players. To see all, we \
need to click a button labeled \[OpenCurlyDoubleQuote]Load More\
\[CloseCurlyDoubleQuote] at the bottom of the page. This time, the \
\[OpenCurlyDoubleQuote]Load More\[CloseCurlyDoubleQuote] button is located in \
an <a> tag. We handle this in a similar way as the cookies button.\
\>", "Text",ExpressionUUID->"3edcb300-93dd-3047-a4a7-63976f4c0cc3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aTags", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<a\>\""}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"loadMoreButton", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"WebExecute", "[", 
         RowBox[{"session", ",", 
          RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], 
        "==", "\"\<Load More\>\""}], ",", "#", ",", "Nothing"}], "]"}], "&"}],
     "/@", "aTags"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"WebExecute", "[", 
   RowBox[{"session", ",", 
    RowBox[{"\"\<ClickElement\>\"", "->", 
     RowBox[{"First", "[", "loadMoreButton", "]"}]}]}], "]"}], 
  ";"}]}], "Input",ExpressionUUID->"0b2be63c-0dc6-4432-a9e3-e3fb054ae31c"],

Cell["\<\
Once all the players are loaded, we can extract the information that we care \
about. In this case, each row in the table is in a <tr> element, so we get \
that:\
\>", "Text",ExpressionUUID->"f39859c1-f827-42c3-94b9-4d02e496a0d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"servetrTags", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<tr\>\""}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"75f30cc3-97a0-44bc-9615-23562f85e475"],

Cell["And we clean it up with a RegularExpression:", "Text",ExpressionUUID->"551bacc2-86b8-4cf4-a1d8-da7152fa22bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"serveStats", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"StringCases", "[", 
      RowBox[{
       RowBox[{"WebExecute", "[", 
        RowBox[{"\"\<ElementText\>\"", "->", "#"}], "]"}], ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", 
         "[", "\"\<(^\\\\d{1,})\\\\n(.*)\\\\n(\\\\d{3}.\\\\d)\\\\s(.*?%)\\\\s(\
.*?%)\\\\s(.*?%)\\\\s(.*?%)\\\\s(\\\\d{1,}.\\\\d{1})\\\\s(\\\\d{1,}.\\\\d{1})\
\>\"", "]"}], "->", 
        RowBox[{"{", 
         RowBox[{"\"\<$1\>\"", ",", "\"\<$2\>\"", ",", "\"\<$3\>\"", 
          ",", "\"\<$4\>\"", ",", "\"\<$5\>\"", ",", "\"\<$6\>\"", 
          ",", "\"\<$7\>\"", ",", "\"\<$8\>\"", ",", "\"\<$9\>\""}], 
         "}"}]}]}], "]"}], "&"}], "/@", 
    RowBox[{"servetrTags", "[", 
     RowBox[{"[", 
      RowBox[{"2", ";;"}], "]"}], "]"}]}]}], ";"}]], "Input",ExpressionUUID->\
"951ecbf2-a82a-430f-abfc-55bb7dcfe698"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"servesTab", "=", 
  RowBox[{"ToTabular", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Apply", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"<|", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<Serve ranking\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#1", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Name\>\"", "->", "#2"}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Serve rating\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#3", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<% 1st serve\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#4", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<% 1st serve points won\>\"", " ", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#5", 
            "]"}]}], ",", "\[IndentingNewLine]", " ", 
          RowBox[{"\"\<% 2nd serve points won\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#6", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<% Service games won\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Percent\>\"", "]"}], "[", "#7", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Avg. aces/match\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#8", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Avg. double faults/match\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#9", 
            "]"}]}]}], "|>"}], "&"}], ",", "#"}], "]"}], 
     "\[IndentingNewLine]", "&"}], "/@", 
    RowBox[{"Flatten", "[", 
     RowBox[{"serveStats", ",", "1"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[51]:=",ExpressionUUID->"55bfe10c-34ee-4c2b-8454-cf8b46c1dcba"],


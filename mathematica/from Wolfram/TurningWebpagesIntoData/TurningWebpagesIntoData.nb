Cell[BoxData[
 RowBox[{"DeleteObject", "[", "session", "]"}]], "Input",
 CellChangeTimes->{{3.940393121590994*^9, 
  3.940393124508651*^9}},ExpressionUUID->"92c96f88-7677-4307-ba60-\
7d67a41675cc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rankings", "Subsubsection",
 CellChangeTimes->{{3.940488698197403*^9, 3.940488699475506*^9}, {
  3.940494856226166*^9, 
  3.9404948565005207`*^9}},ExpressionUUID->"294eeae4-b09f-48fd-a2f5-\
f2f417463ade"],

Cell["\<\
The final page we care about is slightly different. First, all the players \
are listed automatically, so there is no need to look for a \
\[OpenCurlyDoubleQuote]Load More\[CloseCurlyDoubleQuote] button to click. We \
open up our browser and navigate to the webpage:\
\>", "Text",ExpressionUUID->"621e27b8-cb66-4d52-888b-8bea51b3d511"],

Cell[BoxData[
 RowBox[{
  RowBox[{"session", "=", 
   RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.9388586599849253`*^9, 3.9388586606813726`*^9}, {
   3.938858714077423*^9, 3.938858720649507*^9}, {3.9388587526260653`*^9, 
   3.938858761306519*^9}, {3.939184603830926*^9, 3.9391846043988743`*^9}, 
   3.940495271952402*^9},ExpressionUUID->"fa93bfdd-ab0f-4654-a852-\
6a6abd540d17"],

Cell[BoxData[
 RowBox[{
  RowBox[{"WebExecute", "[", 
   RowBox[{"session", ",", 
    RowBox[{"\"\<OpenPage\>\"", 
     "->", "\"\<https://www.atptour.com/en/rankings/singles\>\""}]}], "]"}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9388599043058558`*^9, 3.9388599178832827`*^9}, {
   3.939184626337028*^9, 3.9391846278094883`*^9}, 3.9391857539951897`*^9, 
   3.939269566208493*^9, 3.940392535571006*^9, 3.9404877093604097`*^9, 
   3.9404952735644913`*^9},ExpressionUUID->"e39b245d-dbdf-45fb-9edf-\
ab7bc3c03f2a"],

Cell[CellGroupData[{

Cell["Getting the Countries", "Subsubsubsection",ExpressionUUID->"c333844b-b66f-4148-a7f8-11603cc28a7d"],

Cell["\<\
There are two things that we are interested in on this webpage: the players\
\[CloseCurlyQuote] rankings and their countries. Since getting the countries \
is a bit more complicated, let\[CloseCurlyQuote]s start with that. All of the \
little flags beside the player\[CloseCurlyQuote]s image are located in <use> \
elements, which we can leverage:\
\>", "Text",ExpressionUUID->"681703b1-0492-417a-93f2-9c8b8c457db2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"flags", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<use\>\""}]}]}], "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"18cb449b-d9e1-4e82-b39a-bbf3e50a0ff0"],

Cell[TextData[{
 "Each use element has a \[OpenCurlyDoubleQuote]href\[CloseCurlyDoubleQuote] \
attribute leading to the flag itself, looking something like ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"<", 
    RowBox[{"use", " ", "href"}]}], "=", 
   RowBox[{"\"\</assets/atptour/assets/flags.svg#flag-ita\>\"", ">"}]}]], 
  "InlineCode",ExpressionUUID->"bd5f8e11-6edc-4df4-8406-d62aea4553d0"],
 ". We can exploit the consistent structure with regular expressions to get \
everything after ",
 Cell[BoxData["\"\<flag-\>\""], "InlineCode",ExpressionUUID->
  "abb9635e-8930-4bb1-8e71-bd7d2facbd45"],
 ", which is essentially a three-letter code for the country (e.g. \
\[OpenCurlyDoubleQuote]ita\[CloseCurlyDoubleQuote]). "
}], "Text",ExpressionUUID->"1f0b46eb-3314-44b8-9683-4e305aa6a0cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"countryCodes", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"StringCases", "[", 
      RowBox[{
       RowBox[{"RegularExpression", "[", "\"\<.*#flag-(.*)\>\"", "]"}], 
       ":>", "\"\<$1\>\""}], "]"}], "[", 
     RowBox[{
      RowBox[{
       RowBox[{"WebExecute", "[", 
        RowBox[{"session", ",", 
         RowBox[{"\"\<ElementAttribute\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"#", ",", "\"\<href\>\""}], "}"}]}]}], "]"}], "&"}], "/@", 
      "flags"}], "]"}], "]"}]}], ";"}]], "Input",ExpressionUUID->"42404090-\
3bd9-4a0c-bee7-dc02b5f15a7c"],

Cell[TextData[{
 "Now we have a list of three-letter country codes that we need to convert to \
actual country entities. The built-in ",
 ButtonBox["Interpreter",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Interpreter.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/Interpreter.html"],
 " function can do a lot of the heavy lifting even with three-letter inputs. \
We can test:"
}], "Text",ExpressionUUID->"3db09e39-26cd-48ea-ad19-a9ce8f3615f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Interpreter", "[", "\"\<Country\>\"", "]"}], "[", "\"\<ita\>\"", 
  "]"}]], "Input",ExpressionUUID->"593edc0b-dd10-43b5-aed4-ef90064a35e7"],

Cell["However, in some cases, it might fail:", "Text",ExpressionUUID->"256359fc-e829-413f-8048-0249ccc2ded6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Interpreter", "[", "\"\<Country\>\"", "]"}], "[", "\"\<cro\>\"", 
  "]"}]], "Input",ExpressionUUID->"0a36ac67-cf32-4adb-99dc-28e7454247bf"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s create a helper function that will take our \
countryCodes and return country entities. In it, we want to try interpreting \
the country code with ",
 ButtonBox["Interpreter",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Interpreter.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/Interpreter.html"],
 "; if that fails, we want to use a more flexible tool like an LLM:"
}], "Text",ExpressionUUID->"ab9429d1-d225-4e29-9f4f-116d15098317"],

Cell[BoxData[
 RowBox[{
  RowBox[{"interpretCountry", "[", "code_String", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "wolframInterpretation", ",", "llmInterpretation", ",", "country"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"wolframInterpretation", "=", 
      RowBox[{
       RowBox[{"Interpreter", "[", "\"\<Country\>\"", "]"}], "[", "code", 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"llmInterpretation", "=", 
      RowBox[{
      "LLMFunction", 
       "[", "\"\<Which country is `1`. Respond only with the country name\>\"",
        "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"country", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"FailureQ", "[", "wolframInterpretation", "]"}], ",", 
        RowBox[{
         RowBox[{"Interpreter", "[", "\"\<Country\>\"", "]"}], "[", 
         RowBox[{"llmInterpretation", "[", "code", "]"}], "]"}], ",", 
        "wolframInterpretation"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"FailureQ", "[", "country", "]"}], ",", "Missing", ",", 
       "country"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",Expres\
sionUUID->"d8dde767-f243-4e2f-9510-c4c68b0b8a38"],

Cell["\<\
We can now map our new helper function to our country codes to get a list of \
countries:\
\>", "Text",ExpressionUUID->"3a1d6333-0ff9-426e-84a9-71f0bbd8455b"],

Cell[BoxData[
 RowBox[{"countries", "=", 
  RowBox[{"Map", "[", 
   RowBox[{"interpretCountry", ",", "countryCodes"}], "]"}]}]], "Input",Expres\
sionUUID->"b7a9a389-196c-4204-bf7f-bfb0bfa792c2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Getting the Rankings", "Subsubsubsection",ExpressionUUID->"a439a2bf-f4bc-4aa0-aa97-31ac9a3e63a7"],

Cell["Get all <a> elements:", "Text",ExpressionUUID->"94270d37-d9ec-4489-a0cd-6499b1a08dfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"anchors", "=", 
   RowBox[{"WebExecute", "[", 
    RowBox[{"session", ",", 
     RowBox[{"\"\<LocateElements\>\"", "->", 
      RowBox[{"\"\<Tag\>\"", "->", "\"\<a\>\""}]}]}], "]"}]}], ";"}]], "Input",\
ExpressionUUID->"d4968041-1cd5-46ab-aead-82522f2662f8"],

Cell["\<\
Check if there is a player contained in each <a> element. <a> elements \
containing players have a \[OpenCurlyDoubleQuote]href\[CloseCurlyDoubleQuote] \
attribute, which we can represent as a string expression. We check if each \
element in \[OpenCurlyDoubleQuote]anchors\[CloseCurlyDoubleQuote] matches \
that expression, and we discard it if it does not:\
\>", "Text",ExpressionUUID->"9a95411d-8b8f-414a-8d66-1760e78beaa6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"this", " ", "will", " ", "take", " ", "a", " ", "bit"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"playerAnchors", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"StringContainsQ", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"WebExecute", "[", "\[IndentingNewLine]", 
            RowBox[{"session", ",", 
             RowBox[{"\"\<ElementAttribute\>\"", "->", 
              RowBox[{"{", 
               RowBox[{"#", ",", "\"\<href\>\""}], "}"}]}]}], "]"}], ",", 
           
           RowBox[{"\"\<https://www.atptour.com/en/players/\>\"", "~~", "___",
             "~~", "\"\<overview\>\""}]}], "]"}], ",", "#", ",", "Nothing"}], 
        "]"}], "&"}], "/@", "anchors"}], "//", "Quiet"}]}], ";"}]}]], "Input",\
ExpressionUUID->"6a617ac7-82f5-431f-9f82-2a6939668c70"],

Cell["\<\
Now that we have the anchors that contain players, we can extract their text:\
\
\>", "Text",ExpressionUUID->"14c8cae5-9e4c-47ab-850a-cd0c144dea24"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rankings", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"WebExecute", "[", 
       RowBox[{"session", ",", 
        RowBox[{"\"\<ElementText\>\"", "->", "#"}]}], "]"}], "&"}], "/@", 
     "playerAnchors"}], "/.", 
    RowBox[{"\"\<\>\"", "->", "Nothing"}]}]}], ";"}]], "Input",ExpressionUUID->\
"805e4b26-59e1-4349-a535-6ba9736e90b0"],

Cell["\<\
Since the player names are already ordered by the way they appear on the \
webpage, we don\[CloseCurlyQuote]t need to extract their rankings; we can \
simply append Range[100] to the first 100 names:\
\>", "Text",ExpressionUUID->"7bc86a2a-adf0-4103-ad13-c5a716a7ca2b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rankingsTab", "=", 
  RowBox[{"ToTabular", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Apply", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"<|", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<World ranking\>\"", "->", 
           RowBox[{
            RowBox[{"Interpreter", "[", "\"\<Number\>\"", "]"}], "[", "#1", 
            "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Name\>\"", "->", "#2"}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<Country\>\"", "->", "#3"}]}], "\[IndentingNewLine]", 
         "|>"}], "&"}], ",", "#"}], "]"}], "&"}], "/@", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Range", "[", "100", "]"}], ",", 
       RowBox[{"rankings", "[", 
        RowBox[{"[", 
         RowBox[{";;", "100"}], "]"}], "]"}], ",", 
       RowBox[{"countries", "[", 
        RowBox[{"[", 
         RowBox[{";;", "100"}], "]"}], "]"}]}], "}"}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"7cadff83-6b5a-437b-9f9a-a9cc86152329"],


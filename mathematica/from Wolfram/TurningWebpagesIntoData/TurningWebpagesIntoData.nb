Cell[TextData[{
 "Use ",
 ButtonBox["TextCases",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/TextCases.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/TextCases.html"],
 " with the ",
 Cell[BoxData["\"\<Country\>\""], "Input",ExpressionUUID->
  "d9bef426-96ee-44ab-9033-1f1dc81548de"],
 " argument to see which countries were mentioned today:"
}], "Text",ExpressionUUID->"195cb1df-3493-4190-95d2-6299fab80763"],

Cell[BoxData[
 RowBox[{"mentionedCountries", "=", 
  RowBox[{"Flatten", "[", 
   RowBox[{"TextCases", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", "sportArticleBodies", "]"}], ",", " ", 
     RowBox[{"\"\<Country\>\"", "->", "\"\<Interpretation\>\""}]}], "]"}], 
   "]"}]}]], "Input",ExpressionUUID->"8385ba6c-d612-4b7e-ba37-4edb50aedb2e"],

Cell["Sort by the frequency of mentions:", "Text",ExpressionUUID->"901e1be2-9f73-4c02-9cde-3dfed4098b4b"],

Cell[BoxData[
 RowBox[{"countryFrequencies", "=", 
  RowBox[{"ReverseSort", "[", 
   RowBox[{"Counts", "[", "mentionedCountries", "]"}], "]"}]}]], "Input",Expre\
ssionUUID->"fadc3640-b3a8-41a8-8fe2-7733bdd686a3"],

Cell["Word cloud of the countries:", "Text",ExpressionUUID->"72877cb1-0b68-4d65-ac06-8ab173b00b29"],

Cell[BoxData[
 RowBox[{"WordCloud", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#", "[", "\"\<Name\>\"", "]"}], "&"}], "/@", 
    "mentionedCountries"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<United States\>\"", "->", "\"\<US\>\""}], ",", 
     RowBox[{"\"\<United Kingdom\>\"", "->", "\"\<UK\>\""}]}], "}"}]}], 
  "]"}]], "Input",ExpressionUUID->"55d74f6a-133e-4b4d-b433-d2bb5cd52b10"],

Cell[TextData[{
 "A ",
 ButtonBox["GeoBubbleChart",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/GeoBubbleChart.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/GeoBubbleChart.html"],
 " from the frequencies:"
}], "Text",ExpressionUUID->"5728e123-7822-49dc-93cc-43a661decd25"],

Cell[BoxData[
 RowBox[{"GeoBubbleChart", "[", 
  RowBox[{"Counts", "[", "mentionedCountries", "]"}], "]"}]], "Input",Expressi\
onUUID->"acbe3ce1-760c-4bfd-a558-a47bfddcac01"],

Cell["Generate word cloud for top 3 countries:", "Text",ExpressionUUID->"0e89ad10-6304-124a-b785-d0f6383af01c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GenClouds", "[", "articles_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"top3", ",", "unwantedwords", ",", "wordclouds"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"top3", "=", 
      RowBox[{"Keys", "[", 
       RowBox[{"countryFrequencies", "[", 
        RowBox[{"[", 
         RowBox[{";;", "3"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"unwantedwords", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<said\>\"", "->", "\"\<\>\""}], ",", 
        RowBox[{"\"\<says\>\"", "->", "\"\<\>\""}], ",", 
        RowBox[{"\"\<$\>\"", "->", "\"\<\>\""}], ",", 
        RowBox[{"\"\<\[Sterling]\>\"", "->", "\"\<\>\""}], ",", 
        RowBox[{"\"\<%\>\"", "->", "\"\<\>\""}], ",", 
        RowBox[{"\"\<\[CloseCurlyQuote]s\>\"", "->", "\"\<\>\""}], ",", " ", 
        RowBox[{
         RowBox[{"RegularExpression", "[", "\"\<\\\\d{1,}\>\"", "]"}], 
         "->", "\"\<\>\""}]}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"wordclouds", "=", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"WordCloud", "[", 
         RowBox[{
          RowBox[{"DeleteStopwords", "[", 
           RowBox[{"StringJoin", "[", 
            RowBox[{"StringReplace", "[", 
             RowBox[{
              RowBox[{"Map", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"Function", "[", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"ContainsAny", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Interpreter", "[", "\"\<Country\>\"", "]"}], "[", 
                    RowBox[{"TextCases", "[", 
                    RowBox[{"#", ",", "\"\<Country\>\""}], "]"}], "]"}], ",", 
                    
                    RowBox[{"{", "country", "}"}]}], "]"}], ",", "#", ",", 
                   "Nothing"}], "]"}], "]"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"StringRiffle", "[", "#", "]"}], "&"}], "/@", 
                 "articles"}]}], "]"}], ",", "unwantedwords"}], "]"}], "]"}], 
           "]"}], ",", 
          RowBox[{"ColorNegate", "[", 
           RowBox[{"Binarize", "[", 
            RowBox[{
             RowBox[{"country", "[", "\"\<Shape\>\"", "]"}], ",", ".95"}], 
            "]"}], "]"}], ",", 
          RowBox[{"ImageSize", "->", "Large"}]}], "]"}], 
        "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"country", ",", "top3"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Column", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"top3", ",", "wordclouds"}], "}"}], "]"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",ExpressionUUID->"dca1b28d-0f82-\
4532-abb3-2e205d53d105"],

Cell[BoxData[
 RowBox[{"GenClouds", "[", "sportArticleBodies", "]"}]], "Input",ExpressionUUID->"d03ce58e-8aa3-4c13-8cba-3d5d7efc0946"],

Cell["Use the article bodies to create a semantic search index:", "Text",ExpressionUUID->"72d78910-7aec-497f-85fa-0428aebd3a6f"],

Cell[BoxData[
 RowBox[{"ssind", "=", 
  RowBox[{"CreateSemanticSearchIndex", "[", 
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", "sportArticleBodies", "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"StringTrim", "[", "#", "]"}], "=!=", "\"\<\>\""}], "&"}]}], 
    "]"}], "]"}]}]], "Input",ExpressionUUID->"8d896558-6b7f-429d-8751-\
6675440ef5c7"],

Cell["\<\
Use the created semantic search index as a dynamic prompt for your LLM \
interactions:\
\>", "Text",ExpressionUUID->"51bd52a5-828b-4943-b9c4-be497488c6ca"],

Cell[BoxData[
 RowBox[{"LLMSynthesize", "[", 
  RowBox[{"\"\<why has England been in the news recently?\>\"", ",", 
   RowBox[{"LLMEvaluator", "->", 
    RowBox[{"<|", 
     RowBox[{"\"\<Prompts\>\"", "->", 
      RowBox[{"LLMPromptGenerator", "[", "ssind", "]"}]}], "|>"}]}]}], 
  "]"}]], "Input",ExpressionUUID->"89e3e925-93b3-49d4-856e-bceefa565d26"]
}, Open  ]],

Cell["", "EndOfSlide",ExpressionUUID->"6ef7b85c-24d0-4eb9-b5f7-dec61bf8f2db"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "SlideShowNavigationBar",
 CellTags->
  "SlideShowHeader",ExpressionUUID->"d9ca66f5-f0f5-44e9-bd74-8342803832c3"],

Cell[CellGroupData[{

Cell["Automated Browsers, Parsing HTML", "Section",ExpressionUUID->"95be77d3-3044-4f7a-b1d8-bd869d96ca06"],

Cell["\<\
Importing the text from webpages with Import or URLRead is often enough for \
simple, static webpages. However, as you start visiting more complex, dynamic \
webpages, you will find that the information you are looking for might not be \
contained in the server response, even though you see it when you open the \
webpage in a web browser. There are multiple reasons why this might happen, \
but typically the server responds differently based on who or what is \
requesting the information. In many cases, websites load content dynamically \
with JavaScript scripts, which can only run on web browsers, so an HTML \
request for the content is unlikely to give you the full webpage. \
\>", "Text",ExpressionUUID->"97f438cb-5f4d-4f1a-8e62-2e42497c7003"],

Cell["\<\
If the website only serves the information you need when it is requested by a \
web browser, the solution is to use an automated web browser. Wolfram \
Language has built-in functionality to start and manage web browser sessions \
programmatically. \
\>", "Text",ExpressionUUID->"948d7b17-0c72-4b4c-937a-40c75a568baa"],

Cell[CellGroupData[{

Cell["Starting a Web Session", "Subsection",ExpressionUUID->"3a79dfd8-6256-49ad-8b7d-522ddaa81429"],

Cell["\<\
The first thing we need to do is start a web session. We will want to store \
that web session in a variable, since it is an object that we will be passing \
around every time we want to interact with it. We can start a web session in \
the following way:\
\>", "Text",
 CellChangeTimes->{{3.938858679792396*^9, 3.93885871183622*^9}, 
   3.939184688972885*^9},ExpressionUUID->"53335b5d-2c16-4ade-824b-\
3dff24f1fb53"],

Cell[BoxData[
 RowBox[{"session", "=", 
  RowBox[{"StartWebSession", "[", "\"\<Chrome\>\"", "]"}]}]], "Input",
 CellChangeTimes->{{3.9388586599849253`*^9, 3.9388586606813726`*^9}, {
  3.938858714077423*^9, 3.938858720649507*^9}, {3.9388587526260653`*^9, 
  3.938858761306519*^9}, {3.939184603830926*^9, 
  3.9391846043988743`*^9}},ExpressionUUID->"77c22555-af07-4ec1-b6b2-\
9b162b435d44"],

Cell[TextData[{
 "Normally, these web browser sessions are run purely programmatically, \
without opening a graphical window for the browser (i.e. headlessly), but \
during development you might want to have a visual window so you can see what \
is happening. When you are satisfied that your web browser actions are being \
followed correctly, you can add the ",
 Cell[BoxData[
  RowBox[{"Visible", "->", "False"}]], "Input",ExpressionUUID->
  "b4b137f0-fd98-4b61-bb5e-2cabe67c718e"],
 " option to ",
 Cell[BoxData[
 "StartWebSession"], "Input",ExpressionUUID->
  "c99c773e-a5ba-4fab-ae6b-73e3e546f019"],
 ", which will hide the browser window. "
}], "Text",ExpressionUUID->"18ca2379-6fa7-4366-a082-44efda7d5771"]
}, Open  ]],

Cell[CellGroupData[{

Cell["WebExecute", "Subsection",ExpressionUUID->"55ae3b78-4b03-49e7-9671-120d068cd4ef"],

Cell[TextData[{
 "With the session now open and its object stored in a variable, we can start \
interacting with it programmatically. The main function we are going to be \
using is ",
 ButtonBox["WebExecute",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/WebExecute.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/WebExecute.html"],
 ", which takes the web session as the first argument and an operation to be \
performed on that session as the second argument. For example, if we want to \
go to a specific webpage in our session, we can do it with:"
}], "Text",ExpressionUUID->"16a923b3-8324-4d3c-90f1-912080909eb2"],

Cell[BoxData[
 RowBox[{"WebExecute", "[", 
  RowBox[{"session", ",", 
   RowBox[{"\"\<OpenPage\>\"", "->", "\"\<http://www.example.com\>\""}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9388599043058558`*^9, 3.9388599178832827`*^9}, {
   3.939184626337028*^9, 3.9391846278094883`*^9}, 3.9391857539951897`*^9, 
   3.939269566208493*^9},ExpressionUUID->"41fa6e23-6467-410d-867b-\
40e547cc27d8"],

Cell["\<\
There is a wide range of actions that WebExecute can take. Here, we will \
focus on locating and extracting elements. On a basic level, all webpages are \
a combination of HTML, CSS and script files. We can use the structure of each \
of those to locate the elements that we are interested in. Let\
\[CloseCurlyQuote]s start by looking at how to grab HTML elements that we are \
interested in with WebExecute:\
\>", "Text",ExpressionUUID->"dbaf19ae-3281-4fc3-a35d-8a67d9e08e66"],

Cell[BoxData[
 RowBox[{"h1element", "=", 
  RowBox[{"WebExecute", "[", 
   RowBox[{"session", ",", 
    RowBox[{"\"\<LocateElements\>\"", "->", 
     RowBox[{"\"\<Tag\>\"", "->", "\"\<h1\>\""}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.939269587643852*^9, 
  3.9392696121527777`*^9}},ExpressionUUID->"c265280e-9ed2-412c-9235-\
0aaedb54f3ea"],

Cell[TextData[{
 "All elements located with ",
 Cell[BoxData[
 "\"\<LocateElements\>\""], "Input",ExpressionUUID->
  "ce83bed2-9294-4bc4-94a2-ab98236526a5"],
 " are ",
 ButtonBox["WebElementObject",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/WebElementObject"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/WebElementObject"],
 " instances. To extract the text contained in them, we can pass them to the ",
 Cell[BoxData[
 "\"\<ElementText\>\""], "Input",ExpressionUUID->
  "164c7c82-74db-44b1-89ad-8f7b07039bdd"],
 " option:"
}], "Text",ExpressionUUID->"ef9fb55d-059f-4b4d-880b-3a9d7bb2b2fc"],

Cell[BoxData[
 RowBox[{"WebExecute", "[", 
  RowBox[{"session", ",", 
   RowBox[{"\"\<ElementText\>\"", "->", "h1element"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.939269616268108*^9, 
  3.9392696343906717`*^9}},ExpressionUUID->"76ab6df4-4df5-4bec-a1c6-\
525b14f5fc98"],

Cell["\<\
 Let\[CloseCurlyQuote]s navigate to a website with a slightly more \
complicated structure:\
\>", "Text",ExpressionUUID->"52dfe722-4d23-4d7a-8541-66ae6c37cc00"],

Cell[BoxData[
 RowBox[{"WebExecute", "[", 
  RowBox[{"session", ",", 
   RowBox[{"\"\<OpenPage\>\"", "->", "\"\<http://quotes.toscrape.com\>\""}]}],
   "]"}]], "Input",ExpressionUUID->"cdc608f5-7e59-4ab4-9ae1-afd72686eb85"],

Cell["\<\
The easiest way to get an idea of the structure of the website, and therefore \
of the location of the elements you are interested in, is to use the web \
inspector option in your browser, which allows you to point at different \
parts of the current webpage you are on and inspect their underlying HTML \
structure. The current page we are on contains quotes located in <span> \
elements.\
\>", "Text",ExpressionUUID->"c388c097-8cc4-4fda-806d-044764277901"],


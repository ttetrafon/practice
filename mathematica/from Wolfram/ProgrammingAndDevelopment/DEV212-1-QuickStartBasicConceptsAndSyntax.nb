Cell[CellGroupData[{

Cell["Suppress output", "Subsubsection",ExpressionUUID->"7f5936cc-caa5-405b-90d2-aea28441ed11"],

Cell["\<\
Adding a semicolon at the end of an input suppresses the output:\
\>", "Text",ExpressionUUID->"82e880fe-7f07-4a61-8fdb-ea0a521c1435"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"myList", " ", "=", " ", 
    RowBox[{"RandomInteger", "[", 
     RowBox[{"10", ",", 
      RowBox[{"{", 
       RowBox[{"100", ",", "2"}], "}"}]}], "]"}]}], ";"}]}]], "Input",Expressi\
onUUID->"01fd8864-c345-489f-9def-4c29fa584234"],

Cell[TextData[{
 "The semicolon is actually infix for ",
 ButtonBox["CompoundExpression",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/CompoundExpression.html"],
     None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/CompoundExpression.html"],
 ":"
}], "Text",ExpressionUUID->"63a1f6ec-1261-47e0-a89d-9783c7c40d57"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"a", "=", "1"}], ";", 
   RowBox[{"b", "=", "2"}], ";", 
   RowBox[{"c", "=", "3"}], ";"}]}]], "Input",
 CellLabel->"In[42]:=",ExpressionUUID->"2a2c7cb9-a326-4800-aacd-e3b691bbb3fb"],

Cell["\<\
If you end your input with a semicolon, it is as if you are giving a sequence \
of operations with an \"empty\" one at the end. \
\>", "Text",ExpressionUUID->"a508acf5-5e73-4f62-b919-121d3017eaa7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Shortcuts and Menu Items", "Subsection",ExpressionUUID->"7b116f5f-082b-4816-8d17-99210d4aef29"],

Cell["\<\
The following keyboard shortcuts can be useful while working in notebooks:\
\>", "Text",ExpressionUUID->"58e8a624-b409-49c4-a255-1806b56d90c5"],

Cell[TextData[{
 Cell["Ctrl", "KeyEvent",ExpressionUUID->
  "3522895c-fe06-4b6b-98ba-73ba46a94598"],
 "+",
 Cell["L", "KeyEvent",ExpressionUUID->
  "480d3d35-d4ff-455e-9c20-7cfd395bb186"],
 ": Copy input from above"
}], "Item",ExpressionUUID->"f0198b7d-2463-4d1f-86be-083de774d0c0"],

Cell[TextData[{
 Cell["Shift", "KeyEvent",ExpressionUUID->
  "3085fae4-51fe-4e35-94ca-f8a03d83894e"],
 "+",
 Cell["Ctrl", "KeyEvent",ExpressionUUID->
  "8e40f72b-9f5e-4560-89e3-cd0048882cf7"],
 "+",
 Cell["L", "KeyEvent",ExpressionUUID->
  "443edb61-6d32-465a-adae-79172244a123"],
 ": Copy output from above"
}], "Item",ExpressionUUID->"2ca3fba6-24d1-4854-a7c2-6d569bfd65f8"],

Cell[TextData[{
 Cell["Cmd", "KeyEvent",ExpressionUUID->
  "6c2a3105-f611-4729-bcee-76dfbcb39b26"],
 "+",
 Cell["Shift", "KeyEvent",ExpressionUUID->
  "48626917-1091-4f96-9d5f-ea70d3b69463"],
 "+",
 Cell["K", "KeyEvent",ExpressionUUID->
  "aa168788-a8bb-4743-88df-61230cc7de38"],
 " (or ",
 Cell["Ctrl", "KeyEvent",ExpressionUUID->
  "1b3e60f1-14c3-420b-bbab-9b047fe24ccf"],
 "+",
 Cell["Shift", "KeyEvent",ExpressionUUID->
  "da855bbe-4dcf-4ccd-840f-7574a0f01687"],
 "+",
 Cell["K", "KeyEvent",ExpressionUUID->
  "b70b95ae-63c7-47a9-b9a2-004b71c17e88"],
 ") after typing in a function name: Brings up a list of function templates"
}], "Item",ExpressionUUID->"70dba104-6e44-4e0c-a8d8-98c99212d55a"],

Cell[TextData[{
 Cell["Ctrl", "KeyEvent",ExpressionUUID->
  "d7f669d9-95a9-409d-9253-c561c0d63463"],
 "+",
 Cell["Shift", "KeyEvent",ExpressionUUID->
  "b0eb8708-cfb8-4c63-8aa2-3258b3af80c1"],
 "+",
 Cell["'", "KeyEvent",ExpressionUUID->
  "eae0a693-00b1-4b39-9193-f2b056432dfd"],
 ": Un/Iconize selection"
}], "Item",ExpressionUUID->"b04ba0a9-3a45-4fb2-a1d8-7b0c2a4e3b0c"],

Cell["\<\
You can evaluate all the cells in a notebook at once from the menu using \
Evaluation \[FilledRightTriangle] Evaluate Notebook.\
\>", "Text",ExpressionUUID->"6c9b5313-af3a-436b-98c2-ef08c9af7327"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Which of the following pairs contain equivalent expressions?", 
             "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["f[a,b] and a~f~b", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While these two expressions are indeed \
equivalent, they are not the only equivalent expressions in this list.", 
                    "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f[a,b] and a~f~b", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell["f[x] and x//f", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While these two expressions are indeed \
equivalent, they are not the only equivalent expressions in this list.", 
                    "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f[x] and x//f", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["f@x and f[x]", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While these two expressions are indeed \
equivalent, they are not the only equivalent expressions in this list.", 
                    "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f@x and f[x]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell["f@x and x//f", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While these two expressions are indeed \
equivalent, they are not the only equivalent expressions in this list.", 
                    "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f@x and x//f", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 5 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 5, {
                    TextCell[
                    "All of the above", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Every pair represents two equivalent \
expressions by using combinations of standard, prefix, postfix and infix \
input forms.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["All of the above", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{1005., {21.959640502929688`, 29.192062377929688`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"68b505c8-fc7e-43fa-bac2-\
8350a4ceb738"]], "Text",
 CellTags->"CYU",ExpressionUUID->"41b59f98-eab8-4a5a-bc55-3615d3bd1d16"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symbolic Expressions", "Section",ExpressionUUID->"014960ab-0616-4314-91d8-4096ec437904"],

Cell["\<\
Everything in Wolfram Language is a symbolic expression. Sometimes \
expressions look similar; sometimes they look very different.\
\>", "Text",
 CellID->1679675790,ExpressionUUID->"8da60578-3e73-4151-8018-6f8bf8136be9"],

Cell["A prototypical example of a Wolfram Language expression is:", "Text",
 CellID->1633805668,ExpressionUUID->"901d2120-fa5d-43fa-ba74-d813f4a454d3"],

Cell[BoxData[
 StyleBox[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y", ",", "z", ",", "..."}], "]"}],
  FontSize->24,
  FontWeight->"Regular"]], "Program",
 TextAlignment->Center,
 FontColor->GrayLevel[
  0],ExpressionUUID->"a3cf2f77-6e74-41fe-b56d-2c66e946cadf"],

Cell[CellGroupData[{

Cell["Structure of an Expression", "Subsection",ExpressionUUID->"dd832228-cc65-4405-b14f-9b2311476134"],

Cell["Most expressions look similar:", "Text",ExpressionUUID->"871aee61-7205-483c-98d1-2a6714800405"],

Cell["They begin with a word that starts with a capital letter.", "Item",
 CellID->1022088571,ExpressionUUID->"90c920b3-bbd2-4825-9ff3-90c863ed2e96"],

Cell["They have square brackets.", "Item",
 CellID->520920444,ExpressionUUID->"8bd368b2-6188-4976-9a93-25ca2fae2e0b"],

Cell["\<\
Elements enclosed in the square brackets are separated from one another using \
commas.\
\>", "Item",
 CellID->1966557136,ExpressionUUID->"41e70eb9-3689-437f-853d-6c9bda85de2e"],

Cell[CellGroupData[{

Cell["Sometimes there are no elements within the square brackets.", "Item",
 CellID->4973775,ExpressionUUID->"69b3fa42-7431-4b4c-865b-8e89c8f41519"],

Cell[BoxData[
 RowBox[{"StringJoin", "[", 
  RowBox[{"\"\<Hello\>\"", ",", "\"\<World\>\""}], "]"}]], "Input",ExpressionU\
UID->"c76bfbae-97d0-411d-bf03-6a3b326bd82e"],

Cell[BoxData[
 RowBox[{"Classify", "[", 
  RowBox[{"\"\<Language\>\"", ",", "\"\<the house is blue\>\""}], 
  "]"}]], "Input",ExpressionUUID->"55ce1079-bc29-4bcd-a798-70134c4a39d5"],

Cell[BoxData[
 RowBox[{"ConstantArray", "[", 
  RowBox[{"c", ",", "10"}], "]"}]], "Input",ExpressionUUID->"4015f327-e9cb-\
4f62-95ab-724e76e78ab6"],

Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{"{", 
   RowBox[{"Red", ",", 
    RowBox[{"Disk", "[", "]"}], ",", "Green", ",", 
    RowBox[{"Rectangle", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "2"}], "}"}]}], "]"}], ",", "Blue", ",", 
    RowBox[{"Disk", "[", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}], "]"}]}], "}"}], "]"}]], "Input",Expressi\
onUUID->"75dbf06e-bfa5-4bb2-a81b-4ee8c9f2f24f"],

Cell[BoxData[
 RowBox[{"DateString", "[", "]"}]], "Input",ExpressionUUID->"29d95ced-bda0-429c-b498-0b8996c603ff"]
}, Open  ]],

Cell["\<\
You will also run into expressions that look nothing like the template shown: \
\>", "Text",
 CellID->1769371758,ExpressionUUID->"757569c1-13c5-41bc-9586-2da158e75d03"],

Cell[BoxData[
 RowBox[{"a", "+", "b"}]], "Input",ExpressionUUID->"2f0466dd-e0f5-48ab-a4e0-cef1662b59b9"],

Cell[BoxData[
 RowBox[{"a", "+", 
  RowBox[{"b", "^", "2"}], "+", 
  RowBox[{"Sin", "[", 
   RowBox[{"3", "*", 
    RowBox[{"c", "^", "3"}]}], "]"}]}]], "Input",ExpressionUUID->"94284a66-\
02d0-4724-ae49-45ad482c4728"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", ",", "y", ",", "z"}], "}"}]], "Input",ExpressionUUID->\
"767be930-8a40-4916-ae54-a11811fb53b9"],


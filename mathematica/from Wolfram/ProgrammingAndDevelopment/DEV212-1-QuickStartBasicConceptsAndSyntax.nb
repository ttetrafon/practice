Cell["Symbolic Expressions", "Subsection",ExpressionUUID->"91f427e2-993c-46ba-8064-9e3fdbe5c729"],

Cell["Structure of an expression", "Item",ExpressionUUID->"36a294a4-43e6-42c9-98fc-c9b58c4396b7"],

Cell["Meaning of an expression", "Item",ExpressionUUID->"f9e21e9f-95f3-4402-a303-2b9db8e88711"],

Cell["Components of an expression", "Item",ExpressionUUID->"f542cc45-7eea-4c19-aa63-f1bdd183eb33"],


Cell[TextData[{
 "The notion of a function is considerably more general in Wolfram Language \
than in either traditional mathematics or computer science. For example, ",
 StyleBox["f[anything]", "Input"],
 " is considered a function, whether it evaluates to something definite or \
remains in symbolic form."
}], "Text",ExpressionUUID->"bc1727c9-4911-4329-8e77-977d2dbfcb21"],

Cell[CellGroupData[{

Cell["Wolfram Function Repository", "Subsection",ExpressionUUID->"d24879ad-e30f-45cd-8317-b61a0562a0a3"],

Cell[TextData[{
 "In the case that you cannot find a function that does ",
 StyleBox["exactly",
  FontSlant->"Italic"],
 " what you want, you should take a quick look at the ",
 ButtonBox["Wolfram Function Repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/FunctionRepository"], None},
  ButtonNote->"https://resources.wolframcloud.com/FunctionRepository"],
 ". Many useful functions that are perhaps a little too specific for general \
inclusion in Wolfram Language find their home here, contributed both by \
Wolfram employees and enthusiasts and vetted by a dedicated team."
}], "Text",ExpressionUUID->"525c2889-4f5c-4ec4-84a5-8c0f43abc8d2"],

Cell["\<\
Repository functions span many different topic areas. Here are a few of these \
functions:\
\>", "Text",ExpressionUUID->"0eb2ff39-50ff-47c4-9579-5db957607c9f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ResourceFunction", "[", "\"\<ColorToHex\>\"", "]"}], "[", "Pink", 
  "]"}]], "Input",
 CellLabel->
  "In[337]:=",ExpressionUUID->"43ec90dc-66a2-46a1-af4f-94785fabd867"],

Cell[BoxData["\<\"#ff8080\"\>"], "Output",
 CellLabel->
  "Out[337]=",ExpressionUUID->"ad73d778-989c-4a90-82cf-84802c9bec69"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ResourceFunction", "[", "\"\<XKCDConvert\>\"", "]"}], "[", 
  RowBox[{"BarChart", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"10", ",", "1"}], "}"}], ",", 
    RowBox[{"ChartLabels", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<XKCD\>\"", ",", "\"\<Others\>\""}], "}"}]}], ",", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", "SequenceIcon", 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Sequence", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["2", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["552", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     Sequence[
     PlotLabel -> "Popularity of questions on MMA.SE", 
      Ticks -> {None, {{1, "Min"}, {10, "Max"}}}],
     SelectWithContents->True,
     Selectable->False]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[338]:=",ExpressionUUID->"1830fd38-7bfa-4b1f-bbb8-cd4c0c7cc2b2"],


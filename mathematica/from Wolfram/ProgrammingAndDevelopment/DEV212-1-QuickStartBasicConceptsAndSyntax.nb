Cell[CellGroupData[{

Cell["Accessing a Part of an Expression", "Subsection",ExpressionUUID->"4eee2ba5-f579-423e-b3f1-8348c340bab4"],

Cell["\<\
Now that you have visualized expressions built out of many parts, you can \
think of working with these parts individually or in combination.\
\>", "Text",ExpressionUUID->"b11b3069-fdd8-43a6-a044-4ecb4da29fa9"],

Cell[TextData[{
 "You can use ",
 ButtonBox["Part",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Part.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Part.html"],
 " to extract any part of an expression:"
}], "Text",ExpressionUUID->"2dee7ea2-daad-467d-a0d2-a76e514630e7"],


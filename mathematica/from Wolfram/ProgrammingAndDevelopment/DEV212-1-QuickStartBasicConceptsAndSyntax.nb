          Column[{
            TextCell[
            "At which level in the expression Sqrt[b^2-4a c] will you find \
2?", "Text"], 
            DynamicModule[{$CellContext`qState = None}, 
             RadioButtonBar[
              Dynamic[$CellContext`qState], {1 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 1, {
                    TextCell["0", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 

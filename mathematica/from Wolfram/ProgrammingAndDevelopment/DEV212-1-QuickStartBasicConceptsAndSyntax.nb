Cell[TextData[{
 "Some of these functions see enough usage that they are eventually \
integrated into the language itself (e.g. ",
 ButtonBox["PositionLargest",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PositionLargest.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/PositionLargest.html"],
 " and ",
 ButtonBox["PositionSmallest",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PositionSmallest.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/PositionSmallest.html"],
 "). If you come up with a function that you think other people might find \
useful, you can easily submit your own right from your Mathematica \
installation (File \[FilledRightTriangle] New \[FilledRightTriangle] \
Repository Item \[FilledRightTriangle] Function Repository Item)."
}], "Text",ExpressionUUID->"9bb000a5-53bd-429f-8d74-6004fa23e2a7"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Which of the following could be a correctly formatted built-in \
function?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["someFunction()", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Built-in functions always start with capital \
letters and use square brackets.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["someFunction()", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell["SomeFunction()", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Built-in functions do use capital letters for \
each word or abbreviation but always use square brackets rather than \
parentheses.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["SomeFunction()", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell[
                    "SomeFunction[]", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Built-in functions always start each word or \
abbreviation with capital letters and use square brackets.", "Text", 
                    FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["SomeFunction[]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell["someFunction[]", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Built-in functions do use square brackets, \
but they must always start with capital letters.", "Text", FontColor -> 
                    RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["someFunction[]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{1005., {21.959640502929688`, 29.192062377929688`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"741b4fc9-9e24-45d8-99ff-\
2f889cbd5b50"]], "Text",
 CellTags->"CYU",ExpressionUUID->"b22b0470-144d-4b37-96ba-2bf39fe86920"]
}, Open  ]]
}, Open  ]],


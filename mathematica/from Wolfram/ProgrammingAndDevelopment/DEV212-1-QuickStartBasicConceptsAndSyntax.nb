Cell[CellGroupData[{

Cell["Special notations for functions", "Subsubsection",ExpressionUUID->"939b60cb-8c5c-49c2-a586-d77d6e9bbd8a"],

Cell["\<\
Wolfram Language offers a few short forms for function applications:\
\>", "Text",ExpressionUUID->"7c44e771-3a36-48ed-88a3-a706009306be"],

Cell[CellGroupData[{

Cell["Standard function application", "Item",ExpressionUUID->"85b8c837-faa7-404a-98d8-eb9dc3e96399"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"Reverse", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}], 
   "]"}]}]], "Input",ExpressionUUID->"d392ae2e-bf0e-4bfb-a177-fb835e9369a3"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"Join", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"3", ",", "4"}], "}"}]}], "]"}]}]], "Input",ExpressionUUID->\
"e243b5a0-b321-42d4-baae-4e1cf4ad55db"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Prefix function application", "Item",ExpressionUUID->"a1c5103e-c575-4a2e-9f91-130730ea6584"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"Reverse", "@", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}]}]}]], "Input",\
ExpressionUUID->"58103ebd-cb74-4a2f-a7d4-8c0dcdcae649"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Postfix function application", "Item",ExpressionUUID->"9adf9074-f299-49b7-814a-3110a5afc853"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}], " ", "//", 
   "Reverse"}]}]], "Input",ExpressionUUID->"f52e8d4b-9b25-41f7-b17f-\
adc0a884d46e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Infix function application", "Item",ExpressionUUID->"0c9463e4-9f35-4151-b033-0b5978cc0a7a"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], "~", "Join", "~", 
   RowBox[{"{", 
    RowBox[{"3", ",", "4"}], "}"}]}]}]], "Input",ExpressionUUID->"4023a457-\
ebe2-46eb-b781-536ee992c9dc"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comment", "Subsubsection",ExpressionUUID->"c60a8eb5-4eca-4f85-97a1-8550c912cf7e"],

Cell["Comments can be included in your code as follows:", "Text",ExpressionUUID->"0f989a3a-ec7d-45ac-8a34-f6efec770c3c"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"Ignore", " ", "this"}], "*)"}]], "Input",ExpressionUUID->"2885b4ab-\
b4dc-4d67-bfbf-55eeba5c6934"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Iconize", "Subsubsection",ExpressionUUID->"009f56e0-a76c-4411-83cd-52d774bd15d3"],

Cell[TextData[{
 "You can apply ",
 ButtonBox["Iconize",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Iconize.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Iconize.html"],
 " to any part of an input that is too large or not sufficiently relevant. \
The iconized expression is an exact stand-in for the original input:"
}], "Text",ExpressionUUID->"27c1a996-d41d-4bf0-81e0-8d5fcdc46ee8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Iconize", "[", 
  RowBox[{
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "500"}], "]"}], ",", 
   "\"\<Random List\>\""}], "]"}]], "Input",
 CellLabel->
  "In[528]:=",ExpressionUUID->"cc3c599d-6094-4ec0-b883-37b7d934a70d"],


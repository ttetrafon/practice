Cell[CellGroupData[{
Cell["Quick Start: Basic Concepts and Syntax", "Subtitle",ExpressionUUID->"9e7017e3-e14a-4986-b5fb-0882acf596d5"],

Cell[CellGroupData[{

Cell["Learning Objectives", "Section",ExpressionUUID->"89d4c0e4-6fcb-4079-b339-af08a5753e10"],

Cell[CellGroupData[{

Cell["The Basics", "Subsection",ExpressionUUID->"c50548b3-d4d9-499f-bf75-ebb3b636220d"],

Cell["Two main parts of the Wolfram System: front end and kernel", "Item",ExpressionUUID->"935adc74-e381-4e23-bcb5-346da743d0c4"],

Cell["Data's round trip and session history", "Item",ExpressionUUID->"09981d8c-f45d-46ca-89b0-dc924a9e6d44"],

Cell["The notebook as a structured computable document", "Item",ExpressionUUID->"dbc1f50f-e61b-46e0-9e10-e8d0769ea81a"],

Cell["Using built-in functions", "Item",ExpressionUUID->"3b42fc5b-261b-4d68-b3e0-221ff915858f"],

Cell["Finding help from the documentation", "Item",ExpressionUUID->"f4467535-86a8-44c6-8856-6dd0ba1ea12f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Coding in Notebooks", "Subsection",ExpressionUUID->"74abfd4d-39d0-4db9-9ead-d49ff0d672b9"],

Cell["Helpful features of the notebook interface", "Item",ExpressionUUID->"9e0117ff-e7b7-4544-933a-f6e92b12f77e"],

Cell["Input assistance ", "Item",ExpressionUUID->"80844bcc-d04f-407d-bcad-753dd6ef559b"],

Cell["Wolfram Language syntax ", "Item",ExpressionUUID->"07ce7d59-263b-4b89-8bd2-3e367eaddde3"],


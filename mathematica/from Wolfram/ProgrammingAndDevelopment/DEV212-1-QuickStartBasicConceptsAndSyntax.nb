Cell["\<\
While you can manually iconize some expression by using the function, it is \
more common to highlight some portion of an input and choose \"Un/Iconize \
Selection\" from the context menu:\
\>", "Text",ExpressionUUID->"94e5c3f1-4178-460b-8ebb-1f0beb751cf1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Sin", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", "SequenceIcon", 
       GridBox[{{
          RowBox[{
            TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["Sequence", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["7", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            
            TagBox["904", "IconizedItem"]}]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    Sequence[
    Axes -> {True, True}, AxesOrigin -> {0, 0}, Frame -> True, 
     FrameLabel -> {$CellContext`x, 
       Sin[$CellContext`x]}, GridLines -> Automatic, GridLinesStyle -> 
     Directive[Gray, Dashed, 
       Opacity[0.4]], ColorFunction -> "DarkRainbow"],
    SelectWithContents->True,
    Selectable->False]}], "]"}]], "Input",
 CellLabel->
  "In[537]:=",ExpressionUUID->"88cce75c-8c51-4392-aaf8-58d04a8330a4"],


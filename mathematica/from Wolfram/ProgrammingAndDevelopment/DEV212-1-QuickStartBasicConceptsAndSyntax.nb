Cell[CellGroupData[{

Cell["\<\
Triple-clicking establishes useful structured selections in code. Try \
triple-clicking at various positions below.\
\>", "Item",ExpressionUUID->"485b4525-1a21-41cd-9a35-8445d7df832a"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"TabView", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Framed", "[", 
      RowBox[{"Plot3D", "[", 
       RowBox[{
        RowBox[{"n", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"x", " ", "y"}], "]"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "0", ",", " ", 
          RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "0", ",", 
          RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "6", ",", "1"}], "}"}]}], "]"}], 
   "]"}]}]], "Input",ExpressionUUID->"0982223c-b965-44a8-8c21-29f0e98f33f6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wolfram Language Syntax", "Subsection",ExpressionUUID->"c0207bc2-e7ed-4908-9754-9f537b940ecc"],

Cell[CellGroupData[{

Cell["The usual suspects", "Subsubsection",ExpressionUUID->"05110349-63f1-4370-9ffd-f3830439f13c"],

Cell["\<\
Some of the more familiar components of the rich syntax of Wolfram Language:\
\>", "Text",ExpressionUUID->"a5c80766-5e3c-4802-a0fb-92b7895a6a5b"],

Cell[CellGroupData[{

Cell["Strings ", "Item",ExpressionUUID->"87e46ebb-1ec7-441c-92a1-c21783203499"],

Cell[BoxData[
 RowBox[{"\t", "\"\<Hello\>\""}]], "Input",ExpressionUUID->"140e94e0-af7a-40b4-9cd4-dff3d603e13e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Integers and real numbers ", "Item",ExpressionUUID->"be9a7846-ab04-44b7-8b21-1f9a109c39fa"],

Cell[BoxData[
 RowBox[{"\t", "1"}]], "Input",ExpressionUUID->"67751531-6120-4272-8719-3d5153044775"],

Cell[BoxData[
 RowBox[{"\t", "1.23"}]], "Input",ExpressionUUID->"ffb0df80-f80a-4cc6-9cb1-d284dd385af1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Operators", "Item",ExpressionUUID->"c054eafb-1df3-49a7-bf13-c608381a826c"],

Cell[BoxData[
 RowBox[{"\t", "+"}]], "Input",ExpressionUUID->"3375538b-fc67-4ba0-8eb3-124ad47f2608"],

Cell[BoxData[
 RowBox[{"\t", ">"}]], "Input",ExpressionUUID->"35aca0e7-5283-4d5a-ad93-8b41a40b049d"],

Cell[BoxData[
 RowBox[{"\t", "&&"}]], "Input",ExpressionUUID->"6b846c78-03d6-42c3-83a6-922a8432f0a4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Symbols: defined or undefined (Wolfram Language is fully symbolic, so \
\"undefined variables\" can always just stand for themselves)\
\>", "Item",ExpressionUUID->"de3cb4bd-c8fc-497c-b881-a472f2eaef8c"],

Cell[BoxData[
 RowBox[{"\t", "Pi"}]], "Input",ExpressionUUID->"ad7a669d-89c7-43ac-933f-5835751b5556"],

Cell[BoxData[
 RowBox[{"\t", "x"}]], "Input",ExpressionUUID->"5124c780-732f-495c-b766-88ade736baa1"],

Cell[BoxData[
 RowBox[{"\t", "\[Alpha]"}]], "Input",ExpressionUUID->"0338829a-bd41-4078-82d7-69e148e3d5d7"]
}, Open  ]],

Cell["\<\
Wolfram Language symbols are the ultimate atoms of symbolic data. Every \
symbol has a unique name, exists in a certain Wolfram Language context or \
namespace and can have a variety of types of values and attributes.\
\>", "Text",ExpressionUUID->"92bd5665-1b41-4b7b-97ff-1c4eb25a7d2a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Brackets", "Subsubsection",ExpressionUUID->"b6a83b85-fc06-4380-9c16-bf8159f97a97"],

Cell["\<\
Four kinds of brackets are used in Wolfram Language, each serving a different \
purpose:\
\>", "Text",
 CellID->1661028570,ExpressionUUID->"654c3a38-f1a0-4ffa-a5fa-f1385622f6f1"],

Cell[CellGroupData[{

Cell["Square brackets for functions", "Item",
 CellID->1767248637,ExpressionUUID->"2712fea5-3678-4240-be1b-667fbfd8cfff"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"RandomInteger", "[", "]"}]}]], "Input",ExpressionUUID->"b3b725fc-\
55aa-44f3-9e39-12d572916072"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Curly braces for lists", "Item",
 CellID->1630194176,ExpressionUUID->"da83ac30-220a-469a-8a24-684bb02c5526"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}]}]], "Input",Ex\
pressionUUID->"11c84291-5111-4e00-9bf1-0849a40815c2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Double square brackets for indexing", "Item",
 CellID->332669832,ExpressionUUID->"655983d4-09c0-4d13-b5f0-ca88a62fed82"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{
    RowBox[{"myList", "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}]}], ";"}], 
   " ", "\[IndentingNewLine]", "\t", 
   RowBox[{"myList", "[", 
    RowBox[{"[", "3", "]"}], "]"}]}]}]], "Input",ExpressionUUID->"d21a2ab9-\
b4b4-4f60-9948-268851154fe1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Parentheses for grouping operations", "Item",
 CellID->783853971,ExpressionUUID->"b70d33c0-dd70-444c-97b0-977cc76f7647"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"a", "+", "b"}], ")"}], "/", "c"}]}]], "Input",ExpressionUUID->\
"8a03c1e6-98c2-4f1f-98ae-f2bb524e80ae"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Precedence of operators", "Subsubsection",ExpressionUUID->"739f3815-7cc4-4347-920f-c5cc3a33946e"],

Cell["\<\
The usual rules of algebra apply for precedence of operators: \
\>", "Text",ExpressionUUID->"fb50048d-dc93-4026-8fbc-d12eaa5d5a13"],

Cell[TextData[{
 "exponentiation > ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", GridBox[{
      {"multiplication"},
      {"division"}
     }]}], TraditionalForm]],ExpressionUUID->
  "a4bdc0c1-6786-410f-8fc7-6d75926a2a07"],
 " > ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", GridBox[{
      {"addition"},
      {"subtraction"}
     }]}], TraditionalForm]],ExpressionUUID->
  "53ae1054-e3fd-4f3a-8999-523872059fcc"],
 " > negation"
}], "Item",ExpressionUUID->"584fe28e-d328-4473-92db-0c36eaaec83f"],

Cell["All operators (e.g. \[CircleTimes]) have a precedence assigned to \
them", "Item",ExpressionUUID->"45e1cf6c-0e73-45d2-8f15-db089d25d969"],

Cell[CellGroupData[{

Cell["\<\
Parentheses should be used for explicitly grouping terms (never curly braces \
or square brackets)\
\>", "Item",ExpressionUUID->"5a40c863-2867-4143-a4c9-4e0ab733a556"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"2", "+", 

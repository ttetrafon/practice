Cell[CellGroupData[{

Cell["Front End and Kernel ", "Section",ExpressionUUID->"a09c7e10-8000-4a70-9c3d-a20102c3367b"],

Cell["Two main parts of the Wolfram System are:", "Text",ExpressionUUID->"8796fe71-ed35-46ff-9567-6c437bb4844c"],

Cell["Wolfram Language kernel (performs computations)", "Item",ExpressionUUID->"bd069e5f-a2c2-46bc-9290-4037f7891600"],

Cell["\<\
The Wolfram System front end (handles interactions with the user)\
\>", "Item",ExpressionUUID->"8cb3a95f-c45f-4421-baf4-5aa1d0223863"],

Cell["\<\
The most common way to work on the Wolfram System (desktop and cloud) is to \
use the interactive Wolfram Notebook (part of the front end).\
\>", "Text",ExpressionUUID->"15a6b7f6-5760-4661-be02-dea1ff90aaa5"],

Cell[CellGroupData[{

Cell["Your Data's Round Trip", "Subsection",ExpressionUUID->"6e4c05c2-d718-4b47-ba7e-25c266a89664"],

Cell["\<\
The following outlines the interaction between the front end and the kernel \
during a computation:\
\>", "Text",ExpressionUUID->"da286e6e-ad7e-4a04-b179-2ef5a4aea2be"],

Cell[TextData[{
 "When you enter a Wolfram Language input into a notebook and press ",
 Cell["Shift", "KeyEvent",ExpressionUUID->
  "d53eae8a-b507-4a63-817c-288e1958b6ba"],
 "+",
 Cell["Enter", "KeyEvent",ExpressionUUID->
  "d247df36-d9f5-4cc4-9490-627c39571339"],
 ", the front end parses your input into a ",
 ButtonBox["FullForm",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/FullForm.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/FullForm.html"],
 " expression and passes it to the kernel."
}], "Item",ExpressionUUID->"9a9f3e7c-dd89-4b7a-966b-fcb43fa63097"],

Cell["\<\
The kernel evaluates the expression and returns the result to the front end \
as a FullForm expression.\
\>", "Item",ExpressionUUID->"7e7eb9c1-0156-42df-b731-9cbfd889c7ba"],

Cell[CellGroupData[{

Cell["\<\
The front end renders the result in an appropriate manner in your notebook, \
and subsequently an output cell is generated.\
\>", "Item",ExpressionUUID->"bc25c7f5-1e65-49d8-a161-d682db5c144e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"2", "+", "2"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"c625ccd5-73a8-41bf-814e-81a5070c318b"],

Cell[BoxData["4"], "Output",
 CellLabel->"Out[12]=",ExpressionUUID->"ae21befa-0024-4b1b-af32-07cafe64dbf6"]
}, Open  ]]
}, Open  ]],

Cell["\<\
The kernel may be run either on the same computer as the front end or on \
another computer connected via a network. Sometimes, the kernel is not even \
started until you actually do some computation with Wolfram Language.\
\>", "Text",ExpressionUUID->"2d4a95ce-a3ff-4157-8d69-0b9b494724fa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wolfram System Session History", "Subsection",ExpressionUUID->"ccc70f6c-2d63-4f82-bd84-fdf2d554e68b"],

Cell[TextData[{
 "Each input and output cell is indexed by a number ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ee1bd3c2-e82b-402b-9e77-44e07865c2fe"],
 ", (seen in the labels ",
 StyleBox["In[n]",
  FontSlant->"Italic"],
 " or ",
 StyleBox["Out[n]",
  FontSlant->"Italic"],
 " to the left of the cells). The number ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "da9f09a0-7df2-4024-9ee5-08c2ec9611bd"],
 " refers to the sequence of the evaluation in the current session."
}], "Text",ExpressionUUID->"3ee4b1ae-b3f1-451d-a52c-274808a983f0"],

Cell[TextData[{
 "Previously evaluated inputs and their corresponding outputs are stored \
symbolically in a sequence of ",
 ButtonBox["In",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/In.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/In.html"],
 " and ",
 ButtonBox["Out",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Out.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Out.html"],
 " objects."
}], "Text",ExpressionUUID->"4f13656f-8cc7-4ae9-a015-56a25baa2f00"],

Cell[TextData[{
 StyleBox["In[n]", "Input"],
 " causes the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f34f0af9-edfb-49f5-9a4e-7091e42a5725"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Null]", "th"], TraditionalForm]],ExpressionUUID->
  "23fd2036-154d-4f11-89b6-350e86415936"],
 " input line to be reevaluated."
}], "Item",ExpressionUUID->"51b3acf9-0093-49f1-be59-406db77d79ab"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Out[n]", "Input"],
 " returns the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "5b341776-65d6-4aab-b11d-09ba66fab0aa"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Null]", "th"], TraditionalForm]],ExpressionUUID->
  "f6bbc121-54d3-478e-9b63-621df02ed67e"],
 " output expression."
}], "Item",ExpressionUUID->"3d6dcb47-a90a-43d1-a6b3-0876392c1757"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"3", "+", "4"}]], "Input",
 CellLabel->
  "In[259]:=",ExpressionUUID->"f28181a4-802b-4a69-9913-98a3e2d42384"],

Cell[BoxData["7"], "Output",
 CellLabel->
  "Out[259]=",ExpressionUUID->"d47e3524-fd94-4373-9511-a6288366345b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"In", "[", "12", "]"}]], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"2f174244-516f-4e54-a2f6-5bf7035f108f"],

Cell[BoxData["4"], "Output",
 CellLabel->"Out[15]=",ExpressionUUID->"962a35e1-2d6b-426c-954d-0e6b89c1dba4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Out", "[", "12", "]"}]], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"ba6fb3c6-ac9d-4b7b-bf6e-eb107cd839d3"],

Cell[BoxData["4"], "Output",
 CellLabel->"Out[16]=",ExpressionUUID->"6ef48584-1bbf-4f17-a34b-a4021d9c8651"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 " The last result generated can also be accessed using ",
 Cell[BoxData[
 "%"], "Input",ExpressionUUID->"9462444a-fe5f-44cf-8255-697eb08e1fd2"],
 ":"
}], "Text",ExpressionUUID->"ad39983e-1d36-491d-ae27-ee2e9d0a9a83"],

Cell[TextData[{
 " ",
 Cell[BoxData[
 "%%"], "Input",ExpressionUUID->"20cf5ed5-3ed6-4965-b891-eef99aa8aba6"],
 " gives the second-to-last result.\t"
}], "Item",ExpressionUUID->"b20853bd-0e17-442e-ae57-b4f7f8bdb30a"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{"%%", "..."}], "%"}]], "Input",ExpressionUUID->
  "7f973643-72cf-451d-a563-b604ea5f2fc8"],
 " (",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "501eb925-29de-4b52-a961-bf2779ede5eb"],
 " times) gives the ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "624a024e-3433-4654-9169-b3ee12baf9e0"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Null]", "th"], TraditionalForm]],ExpressionUUID->
  "0a6c6c10-913a-4982-be84-53ac9bc0e6e7"],
 " previous result."
}], "Item",ExpressionUUID->"d847506f-0533-432d-8276-8860d0957681"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"%", "n"}]], "Input",ExpressionUUID->
  "82750d81-a98d-46f5-af0d-f7cc15b5a262"],
 " gives the result from ",
 StyleBox["Out[n]", "Input"],
 StyleBox[".", "Text"]
}], "Item",ExpressionUUID->"3f30a675-255d-4836-bdae-e43fe9e508ee"],

Cell[BoxData[{
 RowBox[{"5", "^", "2"}], "\[IndentingNewLine]", 
 RowBox[{"%", "+", "25"}], "\[IndentingNewLine]", 
 RowBox[{"%%", "+", "225"}], "\[IndentingNewLine]", 
 RowBox[{"%%", "+", "1000"}]}], "Input",ExpressionUUID->"ec6e633d-81b3-484a-\
b135-2dda460306b7"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Notebook", "Section",ExpressionUUID->"0639d916-aa89-4e2c-bae1-7d5b3755f314"],

Cell["Wolfram Notebooks provide:", "Text",ExpressionUUID->"184e6e5b-464c-4165-87c2-97135ba2601e"],

Cell["A complete high-level programmatic interface", "Item",ExpressionUUID->"104710bc-3ade-48da-aaae-0469447554ca"],

Cell["An environment to build arbitrary dynamic interfaces", "Item",ExpressionUUID->"f8964e4d-e99c-42ab-bb5d-2bab25b202c6"],

Cell["\<\
Familiar word-processing metaphors to create full, typeset, publishable \
documents\
\>", "Item",ExpressionUUID->"0bb2b02a-2ea3-4872-9920-4e54a65c38cd"],

Cell[CellGroupData[{

Cell["Cells", "Subsection",ExpressionUUID->"48b1471d-d72a-4301-b893-f647d955e5b6"],

Cell["A notebook is a structured document:", "Text",ExpressionUUID->"40cb1dea-ca08-4b98-94d6-2c0017751e25"],

Cell["\<\
The structure is delineated by the \"cell.\" A notebook consists of a \
hierarchical collection of cells.\
\>", "Item",ExpressionUUID->"89905515-1cdb-49a0-b2c3-71da98c2efa0"],

Cell[CellGroupData[{

Cell["Cells typically have distinct brackets on the right.", "Item",ExpressionUUID->"f2a070f3-0732-4dd4-ac9b-26be3fb80f0f"],


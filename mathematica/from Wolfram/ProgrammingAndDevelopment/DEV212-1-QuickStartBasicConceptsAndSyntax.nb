Cell[CellGroupData[{

Cell["Composite expressions", "Subsubsection",ExpressionUUID->"34ac269f-5696-4d15-9eaa-f765cd2855f8"],

Cell["\<\
Atomic expressions can be combined to build up composite expressions. You can \
also nest composite expressions to build progressively more complicated \
expressions.\
\>", "Text",ExpressionUUID->"ccdc7556-74b4-4304-88ae-62538b884f3a"],

Cell["\<\
Here is a composite expression built up from multiple atomic elements:\
\>", "Text",ExpressionUUID->"62c90824-5a3a-450e-a142-649c9fccaaf7"],

Cell[BoxData[
 StyleBox[
  RowBox[{"Times", "[", 
   RowBox[{
    RowBox[{"Rational", "[", 
     RowBox[{"1", ",", "2"}], "]"}], ",", 
    RowBox[{"Power", "[", 
     RowBox[{"a", ",", 
      RowBox[{"-", "1"}]}], "]"}], ",", 
    RowBox[{"Plus", "[", 
     RowBox[{
      RowBox[{"Times", "[", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "b"}], "]"}], ",", 
      RowBox[{"Power", "[", 
       RowBox[{
        RowBox[{"Plus", "[", 
         RowBox[{
          RowBox[{"Power", "[", 
           RowBox[{"b", ",", "2"}], "]"}], ",", 
          RowBox[{"Times", "[", 
           RowBox[{
            RowBox[{"-", "4"}], ",", "a", ",", "c"}], "]"}]}], "]"}], ",", 
        RowBox[{"Rational", "[", 
         RowBox[{"1", ",", "2"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
  ShowSpecialCharacters->False,
  ShowStringCharacters->True,
  NumberMarks->True]], "Input",ExpressionUUID->"20b67af2-f87f-4bf6-a931-\
6443e3abb7f9"],


Cell[CellGroupData[{

Cell["Inserting, editing and selecting cells", "Subsubsection",ExpressionUUID->"154cab8a-aa42-4517-b718-5e31db3e8bc1"],

Cell[TextData[{
 "The ",
 StyleBox["cell insertion bar",
  FontSlant->"Italic"],
 " is a solid gray line with a small black cursor running horizontally across \
the notebook that appears when you click within the blank section of a \
notebook or between cells. The cell insertion bar is the place where new \
cells will be created."
}], "Text",ExpressionUUID->"7899c4be-5297-4406-a939-10fbec652dbd"],

Cell[TextData[{
 "The ",
 StyleBox["cursor",
  FontSlant->"Italic"],
 " is a vertical bar that appears when hovering over a cell. Clicking there \
allows creation, modification or deletion of content."
}], "Text",ExpressionUUID->"53c9b8d6-dd1e-4883-8969-6de8260cbe14"],

Cell[TextData[{
 "The ",
 StyleBox["cell selector",
  FontSlant->"Italic"],
 " is a left arrow \[LeftArrowBar] that appears when hovering over the cell \
brackets. Clicking there allows selection of whole cells for copying, \
cutting, deleting or setting properties."
}], "Text",ExpressionUUID->"e2e483b7-dff4-4e05-87a8-a282eec9b49c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Cell styles", "Subsubsection",ExpressionUUID->"b3a0847d-d73c-438b-830a-c0016b99ee02"],

Cell["\<\
A cell may contain narrative text, code, math, images or some combination. \
The type of content is dictated by the style of the cell:\
\>", "Text",ExpressionUUID->"c86e8854-4c40-4548-b1ba-c2f62a27ec94"],

Cell["\<\
The default style of a cell is \"Input\", meaning Wolfram Language input.\
\>", "Item",ExpressionUUID->"7a640adc-c750-4d01-a5d8-ba3eb22dbcc3"],

Cell["\<\
You can select the style from the \"+\" icon on the cell insertion bar or \
from the menu Format \[FilledRightTriangle] Style.\
\>", "Item",ExpressionUUID->"9c8966dd-e9e7-4012-865f-38344e2c31d6"],

Cell[TextData[{
 "You can use shortcut keys to set the style: ",
 Cell["Alt", "KeyEvent",ExpressionUUID->
  "03f40d57-7da7-4e54-9e46-811c714d15da"],
 Cell["7", "KeyEvent",ExpressionUUID->
  "970bac43-4edb-4abe-bf27-edbb7583bf95"],
 " or ",
 Cell["Cmd", "KeyEvent",ExpressionUUID->
  "aba8c807-b5e8-40a1-865c-32cdda5fe53a"],
 Cell["7", "KeyEvent",ExpressionUUID->
  "9692f620-c662-4094-9cd0-599367d85a7f"],
 " for Text, ",
 Cell["Alt", "KeyEvent",ExpressionUUID->
  "1c093184-8957-45ed-bc2e-a8c6ffca9cfa"],
 Cell["4", "KeyEvent",ExpressionUUID->
  "d351fafe-12d7-4313-b36b-42f6f659505b"],
 " or ",
 Cell["Cmd", "KeyEvent",ExpressionUUID->
  "71a0eb38-d41d-4d62-826a-fd9bcdfa31d5"],
 Cell["4", "KeyEvent",ExpressionUUID->
  "940ce77b-b169-463a-a263-09df97554433"],
 " for Section, ",
 Cell["Alt", "KeyEvent",ExpressionUUID->
  "ee5c4964-9cff-4f33-9758-20957614f3c3"],
 Cell["5", "KeyEvent",ExpressionUUID->
  "2544f9a3-627c-49c3-98cb-0a13b81be9d8"],
 " or ",
 Cell["Cmd", "KeyEvent",ExpressionUUID->
  "b8629fb6-a51d-41a9-858a-c259795e4e14"],
 Cell["5", "KeyEvent",ExpressionUUID->
  "63182f67-7694-44ca-bdee-df002735a273"],
 " and so on. "
}], "Item",ExpressionUUID->"80f0c420-d9a1-46c4-8e21-ee0225ff14d5"],

Cell["\<\
You can change the style of an existing cell by selecting the cell bracket \
and then selecting the new style from the Format menu or using shortcut keys.\
\
\>", "Item",ExpressionUUID->"ddd17c4b-44bf-45f2-928b-4de27ddf33a7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Notebooks Are Computable", "Subsection",ExpressionUUID->"58180588-1801-41f4-adbf-d4bf0dc6a905"],

Cell[TextData[{
 "In Wolfram Language's unified symbolic architecture, every Wolfram Language \
notebook you see is represented as a symbolic expression that can be ",
 ButtonBox["manipulated and controlled programmatically",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/tutorial/\
ManipulatingNotebooksOverview.html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/tutorial/\
ManipulatingNotebooksOverview.html"],
 " using Wolfram Language:"
}], "Text",ExpressionUUID->"51292299-dd00-4248-a077-0be92b3241f0"],

Cell[TextData[{
 "The notebook document is represented as a ",
 ButtonBox["Notebook",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Notebook.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Notebook.html"],
 " expression by the front end."
}], "Item",ExpressionUUID->"e32abe47-786c-49a3-aa9c-c4bba27d0e66"],

Cell["\<\
It is written to the storage device as an expression. It can be, and \
sometimes is, read as data! (Take a peek with TextEdit or Notepad.)\
\>", "Item",ExpressionUUID->"3fc56980-70a9-4392-ac52-fa573bf70338"],

Cell["\<\
There are special comments included that allow the front end to handle the \
file efficiently. Therefore, it is best to edit the file only with the \
Wolfram System front end.\
\>", "Item",ExpressionUUID->"26d93bea-a392-49bb-a861-07cbb0bf6683"],

Cell["Notebooks can be created programmatically:", "Text",ExpressionUUID->"bb50e10d-ff32-4bb2-ac8f-fe132714030d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NotebookPut", "[", 
  RowBox[{"Notebook", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cell", "[", 
      RowBox[{"\"\<Section heading\>\"", ",", "\"\<Section\>\""}], "]"}], ",", 
     RowBox[{"Cell", "[", 
      RowBox[{"\"\<Some text.\>\"", ",", "\"\<Text\>\""}], "]"}], ",", 
     RowBox[{"Cell", "[", 
      RowBox[{"\"\<More text.\>\"", ",", "\"\<Text\>\""}], "]"}]}], "}"}], 
   "]"}], "]"}]], "Input",ExpressionUUID->"c1de993e-2e6f-427c-b249-\
1940a70f93c4"],

Cell[BoxData[
 TemplateBox[{"3170d86b-54b4-495a-aed6-3de290b1cf7e", "\"Untitled-1\""},
  "NotebookObjectUUIDUnsaved"]], "Output",
 CellLabel->"Out[18]=",ExpressionUUID->"0041029f-ea70-48dc-9b44-3cf2d4ea72b6"]
}, Open  ]],

Cell[TextData[{
 "The raw expression corresponding to a notebook can be read in from the ",
 ButtonBox["NotebookObject",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/NotebookObject.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/NotebookObject.html"],
 ":"
}], "Text",ExpressionUUID->"30957986-dea8-4490-8f08-53cdf12553c0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NotebookGet", "[", "%", "]"}]], "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"826ee00c-f372-469e-8e88-a9706447bdc5"],

Cell[BoxData[
 RowBox[{"Notebook", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Cell", "[", 
     RowBox[{"CellGroupData", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Cell", "[", 
          RowBox[{"\<\"head\"\>", ",", "\<\"Section\"\>"}], "]"}], ",", 
         RowBox[{"Cell", "[", 
          RowBox[{"\<\"text\"\>", ",", "\<\"Text\"\>"}], "]"}]}], "}"}], ",", 
       "Open"}], "]"}], "]"}], "}"}], ",", 
   RowBox[{"WindowSize", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"808", ",", "755"}], "}"}]}], ",", 
   RowBox[{"WindowMargins", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"316", ",", "Automatic"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "50"}], "}"}]}], "}"}]}], ",", 
   RowBox[{
   "FrontEndVersion", 
    "\[Rule]", "\<\"12.3 for Mac OS X x86 (64-bit) (May 11, 2021)\"\>"}], ",", 
   RowBox[{"StyleDefinitions", "\[Rule]", "\<\"Default.nb\"\>"}]}], 
  "]"}]], "Output",
 CellLabel->"Out[19]=",ExpressionUUID->"3825a5ca-5c6e-4260-9212-aedf49d91263"]
}, Open  ]],

Cell["\<\
It is possible to extract the contents from a notebook with code:\
\>", "Text",ExpressionUUID->"9335c09b-cdf7-4a3b-81c9-7961213cbe6d"],

Cell[BoxData[
 RowBox[{"NotebookImport", "[", 
  RowBox[{
   RowBox[{"EvaluationNotebook", "[", "]"}], ",", "\"\<Section\>\""}], 
  "]"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"135c3187-ff83-45cc-91f7-7bc5585076c3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Built-in Functions", "Section",ExpressionUUID->"03de0655-149c-42ee-b2c4-d2a3725fae27"],

Cell["There are 6400+ built-in functions in Wolfram Language:", "Text",ExpressionUUID->"2b78b4bd-f94f-450c-9a4c-0ca2b4b5d431"],

Cell["\<\
All built-in functions use square brackets to accept their arguments and have \
names that start with Capital letters.\
\>", "Item",ExpressionUUID->"6a987152-0938-426a-9ffb-59b5a782b4f2"],

Cell[CellGroupData[{

Cell["\<\
The names of built\[Hyphen]in functions are complete English words or\
\[LongDash]in some cases\[LongDash]standard mathematical abbreviations. \
American spelling is used.\
\>", "Item",ExpressionUUID->"46eb8389-7b81-4ff5-8dcb-4fc0e03881bb"],

Cell[BoxData[
 RowBox[{"Range", "[", "10", "]"}]], "Input",ExpressionUUID->"201eb18b-aa28-4f12-844e-f213a6231a55"],

Cell[BoxData[
 RowBox[{"RandomInteger", "[", "10", "]"}]], "Input",ExpressionUUID->"5006cff8-1777-4830-8c0d-8bf02c96a45d"],

Cell[BoxData[
 RowBox[{"RandomWord", "[", "]"}]], "Input",ExpressionUUID->"38b0417a-af7b-4fb6-b3f3-ee42b276d107"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Functions whose names end with ",
 Cell[BoxData[
 "Q"], "Input",ExpressionUUID->"9197c5c6-99cc-4551-8c22-c1d296c30ae5"],
 " usually \"ask a question,\" and evaluate to either ",
 ButtonBox["True",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/True.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/True.html"],
 " or ",
 ButtonBox["False",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/False.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/False.html"],
 "."
}], "Item",ExpressionUUID->"404a17aa-7165-4d6c-9b42-327a67269592"],

Cell[BoxData[
 RowBox[{"EvenQ", "[", "4", "]"}]], "Input",ExpressionUUID->"e9c14b10-d559-4a7f-b003-2f0f981239a4"],

Cell[BoxData[
 RowBox[{"PrimeQ", "[", "37", "]"}]], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"85538cfb-f5ae-42b5-8878-dd5af00f6797"]
}, Open  ]],


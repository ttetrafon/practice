    URL["https://reference.wolfram.com/language/ref/DownValues.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/DownValues.html"],
 ":"
}], "Text",ExpressionUUID->"1ed6d426-5309-40fa-bcf8-ae6e66f6263d"],


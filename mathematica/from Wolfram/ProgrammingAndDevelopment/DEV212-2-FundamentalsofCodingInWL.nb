Cell[CellGroupData[{

Cell["Assignments", "Section",ExpressionUUID->"f8e2ca42-c017-48c2-a4e6-bee3b873ec45"],

Cell[TextData[{
 "Values can be assigned to symbols using ",
 ButtonBox["Set",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Set.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Set.html"],
 " and ",
 ButtonBox["SetDelayed",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/SetDelayed.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/SetDelayed.html"],
 ". Assignments establish rules to replace the left-hand side (LHS) of an \
assignment with the right-hand side (RHS)."
}], "Text",ExpressionUUID->"7bd0dc41-33b0-4e31-85e3-f0aa346e3c24"],

Cell[CellGroupData[{

Cell["Immediate Assignment", "Subsection",ExpressionUUID->"bdf7fb56-666f-4383-92a8-14bbab7f9f0b"],

Cell["These are rules of the form:", "Text",ExpressionUUID->"b001da05-0ec7-41c4-aae9-d20018ad8f99"],

Cell[BoxData[
 RowBox[{"LHS", "=", "RHS"}]], "Program",
 CellMargins->{{120, 60}, {8, 8}},
 TextAlignment->Center,
 FontSize->24,
 FontColor->GrayLevel[0],
 CellID->2058756739,ExpressionUUID->"be826b13-3a25-4e77-8ab4-ba2f81a23846"],

Cell["\<\
The RHS is evaluated and the result is assigned to be the value of the LHS \
right away:\
\>", "Text",ExpressionUUID->"316a7bac-23d8-46f0-a471-d5de42f3976c"],

Cell[BoxData[
 RowBox[{"a", "=", "3"}]], "Input",ExpressionUUID->"f497e4b7-0407-4661-b254-24346a90b615"],

Cell[BoxData[
 RowBox[{"b", "=", 
  RowBox[{"a", "^", "2"}]}]], "Input",ExpressionUUID->"f7ff70f2-6ac5-4d2e-80eb-d172f4e5fa2f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Delayed Assignment", "Subsection",ExpressionUUID->"5ab2dce2-9886-4afe-9f19-99f09030e444"],

Cell["These are rules of the form:", "Text",ExpressionUUID->"63f937b6-518b-4dcd-b94a-04d7e151b3fc"],

Cell[BoxData[
 RowBox[{"LHS", ":=", "RHS"}]], "Program",
 CellMargins->{{120, 60}, {8, 8}},
 TextAlignment->Center,
 FontSize->24,
 FontColor->GrayLevel[0],
 CellID->395781206,ExpressionUUID->"be26e7e8-8fb5-4fd4-9927-9ec1a45f2136"],

Cell["\<\
The RHS is maintained in an unevaluated form. Whenever LHS appears in an \
expression, it is replaced by RHS, evaluated anew each time:\
\>", "Text",ExpressionUUID->"18e7a1ee-f6d2-4cc1-8f31-ec6120bd776e"],

Cell[BoxData[
 RowBox[{"c", ":=", " ", 
  RowBox[{"a", "^", "2"}]}]], "Input",ExpressionUUID->"494e09ac-d627-4abe-b1b8-894db969491e"],

Cell[BoxData["c"], "Input",ExpressionUUID->"4f07ba02-fdc9-4796-ba39-cb0e945c4b37"],

Cell[BoxData[
 RowBox[{
  RowBox[{"a", "=", "2"}], ";"}]], "Input",ExpressionUUID->"884949f1-4f1c-4a7a-b420-c12b46d15b83"],

Cell[BoxData["b"], "Input",ExpressionUUID->"59ed0628-c1af-4abd-9262-dcf5f0c35b43"],

Cell[BoxData["c"], "Input",ExpressionUUID->"17aaf0c4-e01d-4cbe-a76e-7e8c4b8f5d5a"],

Cell[BoxData[
 RowBox[{"?", "b"}]], "Input",ExpressionUUID->"0500f3c3-898e-4494-b69a-e55ffc7a50f1"],

Cell[BoxData[
 RowBox[{"?", "c"}]], "Input",ExpressionUUID->"69dd9902-1bdf-49fd-8478-bbddd9a9689a"]
}, Open  ]],


Cell[CellGroupData[{

Cell["DownValues", "Subsection",ExpressionUUID->"c3454322-954b-4cae-8ba5-a9abefbd4e16"],

Cell["\<\
DownValues is defined when a symbol does not have a meaning by itself, but \
acquires one when one goes \"downward\" in the internal structure, i.e. when \
the symbol name is combined with the proper arguments.\
\>", "Text",ExpressionUUID->"aa574f53-0d3f-4330-9543-a999c25e16c6"],

Cell["\<\
DownValues is created when functions are defined either with Set or \
SetDelayed:\
\>", "Text",ExpressionUUID->"f68dbff5-a280-4a48-907b-32698ce300d2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"f1", ",", "x"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f1", "[", "x_", "]"}], ":=", 
  RowBox[{"x", "^", "2"}]}], "\[IndentingNewLine]", 

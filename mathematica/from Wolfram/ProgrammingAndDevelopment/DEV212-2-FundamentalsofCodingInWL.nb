Cell[CellGroupData[{

Cell["Optional Arguments and Options", "Section",ExpressionUUID->"c7157de8-653c-4615-aebe-70cabd7f31d1"],

Cell["\<\
Wolfram Language provides two basic methods for dealing with optional \
arguments.\
\>", "Text",ExpressionUUID->"aa989934-3e26-41c3-a721-c8a4252d768b"],

Cell[CellGroupData[{

Cell["Optional Arguments", "Subsection",ExpressionUUID->"cce55444-354a-45c8-8926-44402724c76b"],

Cell["\<\
The first method is to have the meaning of each argument determined by its \
position and then to allow one to drop arguments, replacing them by default \
values:\
\>", "Text",ExpressionUUID->"56364773-b261-4cec-888b-563e5a8c3158"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "shout", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"shout", "[", "msg_String", "]"}], ":=", " ", 
  RowBox[{"Style", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ToUpperCase", "[", "msg", "]"}], "<>", "\"\<!!!\>\""}], ",", 
    "42"}], "]"}]}]}], "Input",
 CellLabel->"In[82]:=",ExpressionUUID->"405072ed-0c99-45ef-ba70-679162145cfb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"shout", "[", "\"\<hello\>\"", "]"}]], "Input",
 CellLabel->"In[84]:=",ExpressionUUID->"c91471d3-716b-4574-b776-668aec0e3397"],

Cell[BoxData[
 StyleBox["\<\"HELLO!!!\"\>",
  StripOnInput->False,
  FontSize->42]], "Output",
 CellLabel->"Out[84]=",ExpressionUUID->"0d983008-6ed6-47fc-a303-30acc02b2408"]
}, Open  ]],

Cell["Provide a default value for the argument:", "Text",ExpressionUUID->"2c7e9d7f-bd36-4532-b3a7-530c5a8c09d8"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "shout", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"shout", "[", 
   RowBox[{"msg_String", ":", "\"\<Yabba-dabba-doo\>\""}], "]"}], ":=", " ", 
  RowBox[{"Style", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ToUpperCase", "[", "msg", "]"}], "<>", "\"\<!!!\>\""}], ",", 
    "42"}], "]"}]}]}], "Input",
 CellLabel->"In[85]:=",ExpressionUUID->"f9ec445c-87c3-45db-87a6-144a8cf7546b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"shout", "[", "]"}]], "Input",
 CellLabel->"In[87]:=",ExpressionUUID->"6a11864f-e9ff-4cbd-bb1d-87d52a42404b"],

Cell[BoxData[
 StyleBox["\<\"YABBA-DABBA-DOO!!!\"\>",
  StripOnInput->False,
  FontSize->42]], "Output",
 CellLabel->"Out[87]=",ExpressionUUID->"71bc57b6-3154-4279-9cf2-2f534f433af1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Options", "Subsection",ExpressionUUID->"208a2c1b-050d-456d-8d8a-9b70ca3ef4ed"],

Cell["\<\
The second method that can be used for dealing with optional arguments is to \
give explicit names to the optional arguments and then to allow their values \
to be given using transformation rules. This is particularly convenient for \
functions with a large number of optional parameters.\
\>", "Text",ExpressionUUID->"e19b1ad0-e110-47e3-bc96-38d5ecd7a8f3"],

Cell[TextData[{
 "You can define ",
 ButtonBox["Options",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Options.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Options.html"],
 " for your function:"
}], "Text",ExpressionUUID->"47087be4-dd83-4a14-bbac-386b9cf37c19"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "shout", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Options", "[", "shout", "]"}], "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"color", "->", "Black"}], ",", 
    RowBox[{"loud", "->", "False"}]}], "}"}]}]}], "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"29436f40-383d-44db-afda-028523845fa6"],


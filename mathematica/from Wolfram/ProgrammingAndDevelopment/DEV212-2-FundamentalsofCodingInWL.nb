Cell[CellGroupData[{

Cell["Function Definitions", "Section",ExpressionUUID->"454ca5c2-867d-45f5-a24a-238209c11c3f"],

Cell["\<\
The notion of a function is considerably more general in Wolfram Language \
than in either traditional mathematics or computer science. \
\>", "Text",ExpressionUUID->"825d5583-44e3-43bb-ae79-6f3b055fc6e4"],

Cell["For example:", "Text",ExpressionUUID->"9991a93d-e48f-43bb-ae09-aa826e594a1b"],

Cell[BoxData[
 RowBox[{"f", "[", "anything", "]"}]], "Program",
 CellMargins->{{120, 60}, {8, 8}},
 TextAlignment->Center,
 FontSize->24,
 FontColor->GrayLevel[0],
 CellID->95517003,ExpressionUUID->"71a60ad9-abf1-41fc-9699-5a59ca56e7ca"],

Cell["\<\
is considered a function, whether it evaluates to something definite or \
remains in symbolic form.\
\>", "Text",ExpressionUUID->"96cab594-5a57-4694-baf0-ba447c12eb6d"],

Cell["\<\
A lot can be done already with the functions that are built into Wolfram \
Language. But sometimes you need to define your own functions, and Wolfram \
Language has a very flexible way of doing this.\
\>", "Text",ExpressionUUID->"33bb9cfc-3608-4680-97ed-bc3c58cc9c7d"],

Cell["Functions are usually defined as:", "Text",ExpressionUUID->"8729d7f1-b731-4212-bb51-f224a13e4207"],

Cell[BoxData[
 RowBox[{"LHS", ":=", "RHS"}]], "Program",
 CellMargins->{{120, 60}, {8, 8}},
 TextAlignment->Center,
 FontSize->24,
 FontColor->GrayLevel[0],
 CellID->2052769531,ExpressionUUID->"e1b69114-147c-4bab-9acd-5080bfe13465"],

Cell["\<\
LHS is typically the name of the function, along with pattern(s) for the \
input(s) it expects. RHS defines the rule describing how to use the input \
arguments to the function in computing the result to be returned by the \
function.\
\>", "Text",ExpressionUUID->"1e944544-9836-4984-b056-8bdf6c3f168c"],

Cell[TextData[{
 "A single ",
 ButtonBox["Blank",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Blank.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Blank.html"],
 " (_) with a single underscore character represents a pattern that can stand \
for any Wolfram Language expression. A pattern can be given a name by \
preceding the blank with characters representing the name."
}], "Text",ExpressionUUID->"e3d67ebe-eb03-4e64-9a39-d334f9652b15"],

Cell[CellGroupData[{

Cell["Example 1", "Subsection",ExpressionUUID->"3a4822f6-b8dc-48d7-a492-ee46434ca1a5"],

Cell["\<\
Define a function that will double the input and add 20 to it:\
\>", "CodeText",ExpressionUUID->"31ed00ed-49f0-43ff-98c2-713583b6399a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"2", " ", "x"}], " ", "+", " ", "20"}]}]], "Input",ExpressionUUID->\
"68b5566d-73be-4162-b4f7-a7576b59ea49"],

Cell["Use the function to obtain the result for an input of 21:", "CodeText",ExpressionUUID->"1752d30d-f545-48b4-b990-d62e229ffc6c"],

Cell[BoxData[
 RowBox[{"fun", "[", "21", "]"}]], "Input",ExpressionUUID->"245d43e9-cb45-43a0-9541-f3cf1bd35cf0"],

Cell[TextData[{
 "Use the function to obtain the result for an input of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["x", "2"], "+", "y"}], TraditionalForm]],ExpressionUUID->
  "9b7bbab0-a85b-4601-be64-7596d96dcbdc"],
 ":"
}], "CodeText",ExpressionUUID->"ca7d7030-1bf4-465f-b459-4600018ab94e"],

Cell[BoxData[
 RowBox[{"fun", "[", 
  RowBox[{
   RowBox[{"x", "^", "2"}], "+", "y"}], "]"}]], "Input",ExpressionUUID->\
"d65b5baf-b271-45e0-a4fe-d4eca7e0db8d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Example 2", "Subsection",ExpressionUUID->"c77ca36a-f915-4661-8a0c-2c1dd796819c"],

Cell["\<\
Define a function that accepts two inputs and adds the square of the first \
input to three times the second input:\
\>", "CodeText",ExpressionUUID->"ff78ab23-85ac-431e-bece-cc7aa6d1c5e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun2", "[", 
   RowBox[{"x_", ",", "z_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"x", "^", "2"}], "+", 
   RowBox[{"3", "z"}]}]}]], "Input",ExpressionUUID->"34395a9a-87fe-4d59-a6ca-\
369c0ce9b951"],

Cell["Try the function on two inputs:", "CodeText",ExpressionUUID->"88b40229-8348-462a-b4ef-77f3aca213a4"],

Cell[BoxData[
 RowBox[{"fun2", "[", 
  RowBox[{"2", ",", "3"}], "]"}]], "Input",ExpressionUUID->"4501b81d-15a0-\
48f3-be3e-28e66db5f00b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Example 3", "Subsection",ExpressionUUID->"4d370021-eb5d-4e44-8586-1138cd1b05a2"],

Cell["\<\
Define a function that accepts a piece of text and a color scheme, then \
identifies the language of the text and visualizes the total number of \
speakers per country using the specified color scheme:\
\>", "CodeText",ExpressionUUID->"c846250d-e968-4f06-b0ce-c954346a3c7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"languageCountry", "[", 
   RowBox[{"phrase_", ",", "colorScheme_"}], "]"}], ":=", 
  RowBox[{"GeoRegionValuePlot", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"LanguageIdentify", "[", "phrase", "]"}], "[", 
     "\"\<Speakers\>\"", "]"}], ",", 
    RowBox[{"ColorFunction", "\[Rule]", "colorScheme"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[558]:=",ExpressionUUID->"515c6e25-9e07-43fb-9c8c-63637694899f"],

Cell["Try the function on different inputs:", "CodeText",ExpressionUUID->"72726b8f-2d25-4957-a09c-61d026a88631"],

Cell[BoxData[
 RowBox[{
  RowBox[{"languageCountry", "[", 
   RowBox[{
   "\"\<vengo de la tierra de las mariposas amarillas\>\"", ",", 
    "\"\<CandyColors\>\""}], "]"}], " ", 
  RowBox[{"(*", "Spanish", "*)"}]}]], "Input",
 CellLabel->
  "In[559]:=",ExpressionUUID->"c757fa25-c220-422a-b00f-a3c3afa808f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"languageCountry", "[", 
   RowBox[{
   "\"\<\:0431\:0443\:0434\:0438\:043d\:043e\:043a \:0441\:0438\:043d\:0456\
\:0439\>\"", ",", "\"\<DarkRainbow\>\""}], "]"}], " ", 
  RowBox[{"(*", "Ukrainian", "*)"}]}]], "Input",ExpressionUUID->"9f445a65-\
b734-4a30-bcc2-3bf909fab764"],

Cell[BoxData[
 RowBox[{
  RowBox[{"languageCountry", "[", 
   RowBox[{
   "\"\<\:0c07\:0c26\:0c4d\:0c26\:0c30\:0c41 \:0c35\:0c3f\:0c2a\:0c4d\:0c32\
\:0c35 \:0c35\:0c40\:0c30\:0c41\:0c32\:0c41\>\"", ",", "\"\<RustTones\>\""}], 
   "]"}], " ", 
  RowBox[{"(*", "Telugu", "*)"}]}]], "Input",
 CellLabel->
  "In[561]:=",ExpressionUUID->"ef4d6312-93ea-4fa1-b778-fd00898fb394"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Why Use SetDelayed?", "Section",ExpressionUUID->"81e4ed37-f23e-4ca9-97bd-ad707559dd3f"],

Cell["\<\
When defining your own function, you likely do not want either the LHS or RHS \
to be evaluated at the time of definition, but rather the definition to be \
recorded during assignment and only evaluated whenever the function is \
invoked. SetDelayed is a convenient choice when defining such functions.\
\>", "Text",ExpressionUUID->"5f50100d-0683-48c8-ae8f-60a707999dbc"],

Cell["\<\
Define a function that generates a randomly colored polygon with a random \
number of sides:\
\>", "CodeText",ExpressionUUID->"ec79353a-c1c0-48ee-9026-fff657df1f3e"],

Cell[BoxData[
 RowBox[{"randomPolygon", ":=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"RandomColor", "[", "]"}], ",", 
     RowBox[{"RegularPolygon", "[", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{"{", 
        RowBox[{"3", ",", "20"}], "}"}], "]"}], "]"}]}], "}"}], 
   "]"}]}]], "Input",ExpressionUUID->"e1a2c2d7-8a40-4adc-adf0-06329dded2df"],

Cell["Try creating a random polygon:", "CodeText",ExpressionUUID->"3f15cedf-b0e9-4487-afc9-e5b986aba9e9"],

Cell[BoxData["randomPolygon"], "Input",ExpressionUUID->"aaebb276-85c4-4a1b-bc2e-2567f8401866"],

Cell["\<\
Note that every time this symbol is evaluated, you get a new random color and \
a new random number of sides.\
\>", "Text",ExpressionUUID->"8b89f11a-dae3-4f56-b6e3-c403edaf2ff7"],

Cell[BoxData["randomPolygon"], "Input",ExpressionUUID->"122286d8-b5ab-4f57-823f-9da3e8eee607"],

Cell["\<\
If SetDelayed had not been used for defining the function, it would not \
behave as expected.\
\>", "Text",ExpressionUUID->"611bfd87-f591-45a6-b075-e7be79ab812d"],

Cell["\<\
Define a version using Set instead of SetDelayed, making no other changes:\
\>", "CodeText",ExpressionUUID->"0fa2e5cc-2363-4032-88e2-b08c47095710"],

Cell[BoxData[
 RowBox[{"notQuiteRandomPolygon", "=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"RandomColor", "[", "]"}], ",", 
     RowBox[{"RegularPolygon", "[", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{"{", 
        RowBox[{"3", ",", "20"}], "}"}], "]"}], "]"}]}], "}"}], 
   "]"}]}]], "Input",ExpressionUUID->"5539008e-edb2-4345-9cc5-55cd3cc20d10"],

Cell["\<\
Note that the definition already has an output, unlike the version defined \
with SetDelayed.\
\>", "Text",ExpressionUUID->"e96e0426-77dc-44a3-bf92-7670abb39328"],

Cell["Try evaluating this new symbol repeatedly:", "CodeText",ExpressionUUID->"7335808c-7e25-4820-a4f2-dac9936fae75"],

Cell[BoxData["notQuiteRandomPolygon"], "Input",ExpressionUUID->"0923a8d6-1474-4fab-ad13-d8e0e62e7381"],

Cell["\<\
No matter how many times you evaluate this symbol, it will always have the \
same color and the same number of sides.\
\>", "Text",ExpressionUUID->"c96f590c-98c8-4a83-be46-932c144e1d39"],

Cell["\<\
Notice the fundamental difference between the two definitions, brought about \
entirely by the use of SetDelayed vs. Set:\
\>", "CodeText",ExpressionUUID->"65ac3a33-b4f3-43ba-a518-5c6c7149d0dc"],

Cell[BoxData[
 RowBox[{"?", "randomPolygon"}]], "Input",
 CellLabel->
  "In[573]:=",ExpressionUUID->"5757da0c-349c-4629-a4b3-b95e10371227"],

Cell[BoxData[
 RowBox[{"?", "notQuiteRandomPolygon"}]], "Input",
 CellLabel->
  "In[574]:=",ExpressionUUID->"869ec7eb-36ed-4178-8622-a17105d5db19"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Which of the following definitions of randMat will always give \
you a new random matrix whenever randMat appears in a calculation?", "Text"], 
            
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell[
                    "randMat = RandomReal[{0, 1}, {10, 10}]", "Text", 
                    FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Using Set (=) means that the right-hand side \
of this definition will be evaluated immediately and then used forevermore.", 
                    "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "randMat = RandomReal[{0, 1}, {10, 10}]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "randMat := RandomReal[{0, 1}, {10, 10}]", "Text", 
                    FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Using SetDelayed (:=) ensures that the \
right-hand side of this definition will be evaluated anew each time randMat \
is called in an evaluation.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell[
                    "randMat := RandomReal[{0, 1}, {10, 10}]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell[
                    "randMat \[Rule] RandomReal[{0, 1}, {10, 10}]", "Text", 
                    FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While definitions do use rules, you cannot \
define a symbol with Rule (\[Rule]).", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "randMat \[Rule] RandomReal[{0, 1}, {10, 10}]", "Text"]}],
                   BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell[
                    "randMat \[RuleDelayed] RandomReal[{0, 1}, {10, 10}]", 
                    "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While (many) definitions do use RuleDelayed (\
\[RuleDelayed]) to store their right-hand sides, you cannot define a symbol \
directly via RuleDelayed.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "randMat \[RuleDelayed] RandomReal[{0, 1}, {10, 10}]", 
                    "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]]}, 
              Appearance -> "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{859., {21.959640502929688`, 29.192062377929688`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"b29d0875-8659-46ed-a314-\
88ffa0e6364b"]], "Text",
 CellTags->"CYU",ExpressionUUID->"31abb015-1848-4157-84f1-9725a2b68601"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Transformation Rules", "Section",ExpressionUUID->"b37ac5b5-5454-4231-a0da-7b435203c48d"],

Cell["\<\
Definitions discussed so far are nothing but a set of rewrite rules that are \
invoked automatically whenever the LHS of the definition matches an \
expression you are working with.\
\>", "Text",ExpressionUUID->"bf4543e5-2e3c-4de0-a0fa-812345bb8db0"],

Cell["\<\
Assignments can be thought of as special cases of transformation rules. Each \
assignment specifies a transformation rule to be applied whenever an \
expression of the appropriate form occurs. Transformation rules can be used \
in a more general way.\
\>", "Text",ExpressionUUID->"483a1215-5af6-469c-9c9c-68757dbd0121"],

Cell["\<\
Transformation rules can also be applied explicitly to compute the value of \
an expression after changing some of its component elements.\
\>", "Text",ExpressionUUID->"eb33dbdd-fda5-4cec-ba90-85608a9c7cec"],

Cell[CellGroupData[{

Cell["ReplaceAll with a Rule", "Subsection",ExpressionUUID->"db37aab7-3f5b-41b9-90cf-c1e59e4d7e05"],

Cell[TextData[{
 ButtonBox["ReplaceAll",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/ReplaceAll.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/ReplaceAll.html"],
 " transforms an expression according to a replacement rule of the form"
}], "Text",ExpressionUUID->"9bb2e1b2-7d4a-41ef-b312-a8df06601cb4"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{"LHS", "\[Rule]", "RHS"}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"54978bcb-fa2c-4d3b-b2c8-8c1ae6d4cba5"]], \
"Program",ExpressionUUID->"f5ae7694-609c-4d72-89bf-9daeba3f3177"],

Cell["by replacing all occurrences of LHS with RHS:", "Text",ExpressionUUID->"edbf69c5-8dff-4cce-844d-e76372cc98c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"a", " ", 
    RowBox[{"x", "^", "2"}]}], "+", 
   RowBox[{"b", " ", "x"}], "+", "c"}], " ", "/.", 
  RowBox[{"x", "\[Rule]", "2"}]}]], "Input",ExpressionUUID->"40d35325-dfc6-\
4aa7-b8e2-e07510fb9635"],

Cell[BoxData[
 RowBox[{"y", "=", 
  RowBox[{
   RowBox[{"a", " ", 
    RowBox[{"x", "^", "2"}]}], "+", 
   RowBox[{"b", " ", "x"}], "+", "c"}]}]], "Input",ExpressionUUID->"757cfd5e-\
fe9a-4737-a587-badbec6ddf61"],

Cell[BoxData[
 RowBox[{"y", "/.", 
  RowBox[{"x", "\[Rule]", "42"}]}]], "Input",ExpressionUUID->"dd07cc16-ef3b-\
4d0c-b2da-66ea28bdc7be"],

Cell[BoxData[
 RowBox[{"y", " "}]], "Input",ExpressionUUID->"1d7ed357-ec9d-41b8-8163-f048ae037493"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rule versus RuleDelayed", "Subsection",ExpressionUUID->"6bed9e5c-f200-4ba7-a370-428f8fef07a5"],

Cell["\<\
Rules are a very general construct in Wolfram Language that allow \
transformation of arbitrary symbolic expressions.\
\>", "Text",ExpressionUUID->"e04303e1-b359-4de5-bce8-cc6a9834383a"],

Cell[TextData[{
 "The RHS of a ",
 ButtonBox["Rule",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Rule.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Rule.html"],
 StyleBox[ButtonBox[" ",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Rule"],
  FontWeight->"Bold"],
 "(\[Rule]) is evaluated immediately when it is created. However, the RHS of ",
 ButtonBox["RuleDelayed",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/RuleDelayed.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/RuleDelayed.html"],
 StyleBox[ButtonBox[" ",
  BaseStyle->"Link",
  ButtonData->"paclet:/ref/RuleDelayed"],
  FontWeight->"Bold"],
 "(\[RuleDelayed]) is evaluated only when the rule is used. This is precisely \
the same distinction as is seen in Set (=) vs. SetDelayed (:=)."
}], "Text",
 CellTags->
  "RuleDelayed",ExpressionUUID->"dd0c55a6-462a-454a-8a66-ccba76211fe6"],

Cell["\<\
For example, when working with random numbers, you may want to use the same \
number repeatedly (Rule):\
\>", "Text",ExpressionUUID->"bfeff485-d70a-4c77-828d-9325ebeb7dfa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"x", ",", "x", ",", "x", ",", "x"}], "}"}], "/.", 
  RowBox[{"x", "\[Rule]", 
   RowBox[{"RandomReal", "[", "]"}]}]}]], "Input",
 CellLabel->"In[81]:=",ExpressionUUID->"12f5b694-063b-4667-aa33-d01e7c5e6774"],

Cell[TextData[{
 "Or you may want a different random number every time you replace ",
 Cell[BoxData[
 "x"], "Input",ExpressionUUID->"b7fbb24b-6873-4148-8007-83207c2c1f25"],
 " (RuleDelayed):"
}], "Text",ExpressionUUID->"eb90f6a0-e1aa-4212-bdd1-9e304db029b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"x", ",", "x", ",", "x", ",", "x"}], "}"}], "/.", 
  RowBox[{"x", "\[RuleDelayed]", 
   RowBox[{"RandomReal", "[", "]"}]}]}]], "Input",
 CellLabel->"In[82]:=",ExpressionUUID->"2e252faf-2869-4a64-869b-ef145e33c313"],

Cell[TextData[{
 "This tutorial talks more about ",
 ButtonBox["Applying Transformation Rules",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/tutorial/\
TransformationRulesAndDefinitions.html#18035"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/tutorial/\
TransformationRulesAndDefinitions.html#18035"],
 ". "
}], "Text",ExpressionUUID->"e4b72958-6022-4a1b-9426-0a66d3819262"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rules Use Patterns", "Section",ExpressionUUID->"9bf49de2-906f-451d-b59c-f77f97431301"],

Cell["\<\
Rules can be extremely powerful when used with patterns. The typical syntax \
for such a rule is:\
\>", "Text",ExpressionUUID->"92ca5fed-a934-48f3-af88-e46f13bda4ae"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{
      StyleBox["pattern", "Input"], "\[Rule]", 
      StyleBox["replacement", "Input"]}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], TraditionalForm]],
 CellTags->{
  "201853155754.163213", "201853155756.869136", "20185315581.187373", 
   "20185315586.811606"},ExpressionUUID->"9e9bb496-cce2-4328-8d7b-\
f95c7ab1923f"]], "Program",ExpressionUUID->"8aec171d-df2e-4dc6-9293-\
92be521e9ebb"],

Cell[TextData[{
 "This describes the transformation of an expression whose elements match the \
",
 StyleBox["pattern", "Input"],
 " on the LHS and should thus be replaced by the ",
 StyleBox["replacement", "Input"],
 " expression on the RHS. "
}], "Text",ExpressionUUID->"b0550d31-882b-4031-9b98-d9d990a5fafa"],

Cell[CellGroupData[{

Cell["Specific Replacements", "Subsection",ExpressionUUID->"55760412-9efe-435a-8ea8-b32686bd84d1"],

Cell[TextData[{
 "The following looks for the specific pattern ",
 Cell[BoxData[
  RowBox[{"a", "^", "2"}]], "Input",ExpressionUUID->
  "487d2046-a427-4e68-b58b-75acd9c3167d"],
 " and replaces it with the expression ",
 Cell[BoxData[
 "100"], "Input",ExpressionUUID->"9daa6eb9-a2ba-43a3-a885-3208f6002c18"],
 ":"
}], "Text",ExpressionUUID->"e7532cf8-0729-4912-a3be-8019b269ec29"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"a", "^", "2"}], ",", 
    RowBox[{"a", "^", "3"}], ",", 
    RowBox[{"b", "^", "2"}], ",", 
    RowBox[{"b", "^", "3"}], ",", 
    RowBox[{"c", "^", "2"}], ",", 
    RowBox[{"c", "^", "3"}]}], " ", "}"}], "/.", 
  RowBox[{
   RowBox[{"a", "^", "2"}], "\[Rule]", "100"}]}]], "Input",ExpressionUUID->\
"ac9130f7-eb16-454d-973d-7532fb26c9ef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Replacements", "Subsection",ExpressionUUID->"293383ca-ed09-4870-b94f-45bbf36bcb4d"],

Cell["\<\
Pattern objects can be used to find matches in expressions for a more general \
pattern. The following matches all the squares but not the cubes:\
\>", "Text",ExpressionUUID->"f86b1055-2cff-45c0-be9d-788467157cf5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"a", "^", "2"}], ",", 
    RowBox[{"a", "^", "3"}], ",", 
    RowBox[{"b", "^", "2"}], ",", 
    RowBox[{"b", "^", "3"}], ",", 
    RowBox[{"c", "^", "2"}], ",", 
    RowBox[{"c", "^", "3"}]}], " ", "}"}], "/.", 
  RowBox[{
   RowBox[{"_", "^", "2"}], "\[Rule]", "100"}]}]], "Input",ExpressionUUID->\
"fb1c5a16-7fdd-4179-b566-1edb3a8cfd34"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pattern Objects", "Section",ExpressionUUID->"c61f8f09-edf6-4299-8f6c-4c510502c881"],

Cell["\<\
An important component of good programming in Wolfram Language is the \
effective use of pattern matching. Patterns are defined as a class of \
expressions containing pattern objects that can represent sets of possible \
expressions.\
\>", "Text",ExpressionUUID->"e4ebe2d1-d4d9-4245-9190-d7f9fb19df75"],

Cell[CellGroupData[{

Cell["The Blanks", "Subsection",ExpressionUUID->"bc901dc6-2b0b-421b-8df2-14b3e0e83f36"],

Cell[TextData[{
 "A pattern object may consist of blanks: a single Blank (_) with a single \
underscore character, a ",
 ButtonBox["BlankSequence",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/BlankSequence.html"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/BlankSequence.html"],
 " (__) with two underscores or a ",
 ButtonBox["BlankNullSequence",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/BlankNullSequence.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/BlankNullSequence.html"],
 " (___) with three underscores."
}], "Text",ExpressionUUID->"7606cc61-a718-4c8b-b4e0-1a82f07a6159"],

Cell[CellGroupData[{

Cell["Just one thing", "Subsubsection",ExpressionUUID->"ff35ac27-16af-424b-862d-e884064410d6"],

Cell[TextData[{
 "The Blank (_) pattern object can stand for any Wolfram Language expression. \
",
 ButtonBox["Cases",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Cases.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Cases.html"],
 " can be used to find matches for a pattern:"
}], "Text",ExpressionUUID->"3edaa942-b943-4646-83fb-8ca52aa91df2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"1", ",", 
    RowBox[{"f", "[", "]"}], ",", 
    RowBox[{"f", "[", "a", "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"a", ",", "b"}], "]"}], ",", 
    RowBox[{"g", "[", 
     RowBox[{"e1", ",", "e2"}], "]"}]}], "}"}], "/.", 
  RowBox[{
   RowBox[{"f", "[", "_", "]"}], "->", " ", "\"\<Match\>\""}]}]], "Input",
 CellLabel->"In[46]:=",ExpressionUUID->"dc37f312-d4ff-4658-8604-d25ba4a7de5b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   RowBox[{"f", "[", "]"}], ",", "\<\"Match\"\>", ",", 
   RowBox[{"f", "[", 
    RowBox[{"a", ",", "b"}], "]"}], ",", 
   RowBox[{"g", "[", 
    RowBox[{"e1", ",", "e2"}], "]"}]}], "}"}]], "Output",
 CellLabel->"Out[46]=",ExpressionUUID->"6c22bf65-fa4e-4a43-b37f-472f16ef1a4b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["One or more things", "Subsubsection",ExpressionUUID->"7347b08c-58ac-4226-8ec4-6cd88e3ab67c"],

Cell["\<\
A BlankSequence (__) pattern object can stand for any sequence of one or more \
Wolfram Language expressions:\
\>", "Text",ExpressionUUID->"cdd07102-a932-4e72-b75f-cd789876ebaf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"1", ",", 
    RowBox[{"f", "[", "]"}], ",", 
    RowBox[{"f", "[", "a", "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"a", ",", "b"}], "]"}], ",", 
    RowBox[{"g", "[", 
     RowBox[{"e1", ",", "e2"}], "]"}]}], "}"}], "/.", 
  RowBox[{
   RowBox[{"f", "[", "__", "]"}], "->", " ", "\"\<Match\>\""}]}]], "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"707d5e9f-3c89-430e-95bc-233778705477"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   RowBox[{"f", "[", "]"}], ",", "\<\"Match\"\>", ",", "\<\"Match\"\>", ",", 
   RowBox[{"g", "[", 
    RowBox[{"e1", ",", "e2"}], "]"}]}], "}"}]], "Output",
 CellLabel->"Out[47]=",ExpressionUUID->"630368ed-ee6e-408a-84f7-47cf614762dd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Zero or more things", "Subsubsection",ExpressionUUID->"41136f2b-53f0-4f1f-91f7-9e562d3bfe1e"],

Cell["\<\
A BlankNullSequence (___) pattern object can stand for any sequence of zero \
or more Wolfram Language expressions:\
\>", "Text",ExpressionUUID->"93232153-f23b-4f75-84ee-a8c8a4e7a274"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"1", ",", 
    RowBox[{"f", "[", "]"}], ",", 
    RowBox[{"f", "[", "a", "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"a", ",", "b"}], "]"}], ",", 
    RowBox[{"g", "[", 
     RowBox[{"e1", ",", "e2"}], "]"}]}], "}"}], "/.", 
  RowBox[{
   RowBox[{"f", "[", "___", "]"}], "->", " ", "\"\<Match\>\""}]}]], "Input",
 CellLabel->"In[48]:=",ExpressionUUID->"94bd6968-2798-45c9-adf6-5f2ed0620caf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1", ",", "\<\"Match\"\>", ",", "\<\"Match\"\>", ",", "\<\"Match\"\>", ",", 
   
   RowBox[{"g", "[", 
    RowBox[{"e1", ",", "e2"}], "]"}]}], "}"}]], "Output",
 CellLabel->"Out[48]=",ExpressionUUID->"72b05c17-4deb-49fb-8314-85d68f58e092"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Named Patterns", "Subsection",ExpressionUUID->"4eca5639-ca19-4a75-a4d5-0fb713a0f5b2"],

Cell[TextData[{
 "A label can be added to the start of the pattern object to name the pattern \
(",
 StyleBox["name_", "Input"],
 ", or ",
 StyleBox["name__", "Input"],
 ", or ",
 StyleBox["name___", "Input"],
 "), so that the candidate expression that matches the pattern can be used \
later while being referred to by ",
 StyleBox["name", "Input"],
 ":"
}], "Text",ExpressionUUID->"83709223-2169-465b-8db0-e5bc4cf53c4a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"1", ",", "12", ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"2", ",", "3"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}], "}"}], "/.", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x_", ",", "y_"}], "}"}], "\[RuleDelayed]", 
   RowBox[{"x", "+", 
    RowBox[{"y", "^", "2"}]}]}]}]], "Input",ExpressionUUID->"ec26c6b5-3354-\
4681-86ef-fbbb2fd57f5d"],

Cell["\<\
Note that it is better to use RuleDelayed when using named patterns for \
further computation for the same reason it is better to use SetDelayed when \
defining a function that transforms some variables\[LongDash]you want the \
automatic scoping provided by the delayed versions.\
\>", "Text",ExpressionUUID->"8b7cf651-64ef-4514-9090-91d92808eb3a"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{$CellContext`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], 
           "CYUButtonActive"]], ($CellContext`cyuOpen$$ = 
         Not[$CellContext`cyuOpen$$])& , Appearance -> None, Evaluator -> 
         Automatic, Method -> "Preemptive"]}}, 
      If[$CellContext`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Given the following input, which elements of the list will be \
\"caught\" by the replacement rule? {f[x, y, z], f[x], f[y], f[{x, y}], f[]} \
/. f[x_] \[Rule] hello", "Text"], 
            DynamicModule[{$CellContext`qState = None}, 
             RadioButtonBar[
              Dynamic[$CellContext`qState], {1 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 1, {
                    TextCell["f[x]", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While f[x] will be caught by the rule, it is \
not the only element that it will catch. Note that the x in the rule is not \
the same as the x that appears in the list\[LongDash]it is just a temporary \
name for the Blank pattern.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f[x]", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 2, {
                    TextCell["f[x] and f[y]", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While these two expressions will be caught by \
the rule, there is one more that will be caught. Remember that Blank (_) \
means \"one Wolfram Language expression.\"", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f[x] and f[y]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 3, {
                    TextCell[
                    "f[x], f[y] and f[{x, y}]", "Text", FontColor -> 
                    RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Blank (_) means \"one Wolfram Language \
expression,\" and x, y and {x, y} are all examples of \"one Wolfram Language \
expression.\" The List may throw you off, but \"a list\" is still just one \
Wolfram Language expression regardless of how many elements it has or its \
depth.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["f[x], f[y] and f[{x, y}]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 4, {
                    TextCell[
                    "f[x], f[y] and f[]", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: f[] will not be caught because Blank (_) \
means \"one Wolfram Language expression,\" but there is nothing inside this \
f. f[x] and f[y] will indeed be caught, however.", "Text", FontColor -> 
                    RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["f[x], f[y] and f[]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 5 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 5, {
                    TextCell[
                    "Every element will be caught by the rule.", "Text", 
                    FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Some expressions will be caught, but more \
than one will not be. Remember that Blank (_) means \"one Wolfram Language \
expression\" and move forward from there.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "Every element will be caught by the rule.", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{852., {21.959640502929688`, 29.192062377929688`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"36893957-1689-4b99-b27d-\
6745eb8a98d2"]], "Text",
 CellTags->"CYU",ExpressionUUID->"0ac9a5bc-810f-440b-be3b-9d62bf8b90b8"]
}, Open  ]],


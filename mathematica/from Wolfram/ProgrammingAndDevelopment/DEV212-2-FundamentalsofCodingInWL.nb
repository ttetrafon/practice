Cell[TextData[{
 "Wolfram Language has numerous predicate functions to test expressions, \
their names typically ending in ",
 Cell[BoxData[
 "Q"], "Input",ExpressionUUID->"09f90098-2294-425a-91c5-27f3fa8a65d3"],
 ". For example: ",
 ButtonBox["IntegerQ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/IntegerQ.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/IntegerQ.html"],
 ", ",
 ButtonBox["StringQ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/StringQ.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/StringQ.html"],
 ", ",
 ButtonBox["PossibleZeroQ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/PossibleZeroQ.html"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/PossibleZeroQ.html"],
 " and more to be found at ",
 ButtonBox["Testing Expressions",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/guide/TestingExpressions.\
html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/guide/TestingExpressions.html"],
 "."
}], "Text",ExpressionUUID->"bb232498-74a6-4adb-bb88-b1691f4681ed"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Expressions tested with condition(s)", "Subsubsection",ExpressionUUID->"13897537-b8e2-47a4-80df-754baa175eb4"],

Cell["\<\
Patterns can also include a condition that must be tested and satisfied in \
order for an expression to be declared a match.\
\>", "Text",ExpressionUUID->"e3727cd3-c3fe-4113-abbf-e80a027562c0"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"pattern", "/;", "condition", " "}], "TI"]], "Input",
  ExpressionUUID->"d1eed668-e8ed-4d55-b54c-6c6f2ae04409"],
 " "
}], "Program",
 TextAlignment->Center,
 CellTags->{
  "_?", "PatternTest"},ExpressionUUID->"d5317a08-fea3-48ff-adfd-3d4b62b54d0d"],

Cell["\<\
The condition often needs a named pattern that it can work with:\
\>", "Text",ExpressionUUID->"fdfab9f6-d398-43e0-95a0-c6ae845dd367"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"4.18", ",", 
   RowBox[{"x_", "/;", 
    RowBox[{"x", ">", "4"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[116]:=",ExpressionUUID->"0c865cbf-f402-4d89-bf6e-d402e4ecdab9"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"4.0", ",", 
   RowBox[{"x_", "/;", 
    RowBox[{"x", ">", "4"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[117]:=",ExpressionUUID->"a5bcf575-2522-4a42-94cf-6672792a4d05"],

Cell["\<\
Here is an example of finding the square roots of only the positive integers \
in a list:\
\>", "Text",ExpressionUUID->"500c876b-aa53-4aa5-97c9-207cb1c3fef0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"4", ",", 
    RowBox[{"-", "2"}], ",", "3.14", ",", "9", ",", 
    RowBox[{"-", "25"}], ",", "16"}], "}"}], "/.", 
  RowBox[{
   RowBox[{"x_", "/;", 
    RowBox[{
     RowBox[{"x", ">", "0"}], "&&", 
     RowBox[{"IntegerQ", "[", "x", "]"}]}]}], "\[RuleDelayed]", 
   RowBox[{"Sqrt", "[", "x", "]"}]}]}]], "Input",ExpressionUUID->"f400312c-\
fca3-48d2-92ac-4ce871d39ae7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Testing Patterns", "Subsection",ExpressionUUID->"b0cbe1d9-32f5-4771-b8e4-bf120d2c1b39"],

Cell[TextData[{
 ButtonBox["MatchQ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/MatchQ.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/MatchQ.html"],
 " can be used to check what classes of expressions match a pattern and as a \
tool to assist in learning how pattern matching works in Wolfram Language:"
}], "Text",ExpressionUUID->"e5b00522-ac64-4d8d-b09e-78f62184a872"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"\"\<Red\>\"", ",", "_"}], "]"}]], "Input",ExpressionUUID->\
"968ae3fd-1f76-4f3f-aacc-faab1c6e2c65"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"Red", ",", "_"}], "]"}]], "Input",ExpressionUUID->"566b6ffb-5d79-\
4ad1-b4ca-260571ca1390"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"\"\<Red\>\"", ",", 
   RowBox[{"RGBColor", "[", 
    RowBox[{"_", ",", "_", ",", "_"}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"09590536-6a18-4b5a-92f9-9eaaba4bb7f8"],

Cell[BoxData[
 RowBox[{"MatchQ", "[", 
  RowBox[{"Red", ",", 
   RowBox[{"RGBColor", "[", 
    RowBox[{"_", ",", "_", ",", "_"}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"f0641524-16fb-41bd-98ee-9d8f347da30b"],

Cell[BoxData[
 RowBox[{"Head", "[", "\"\<Red\>\"", "]"}]], "Input",ExpressionUUID->"a40125ce-37b9-423b-8200-7838853096ee"],

Cell[BoxData[
 RowBox[{"Head", "[", "Red", "]"}]], "Input",ExpressionUUID->"8b34f86f-0ff1-4f62-a089-4209db79711d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Using Restricted Patterns for Function Inputs", "Section",ExpressionUUID->"177eace2-cc58-487a-b58e-333ad33f3e06"],

Cell["\<\
While Wolfram Language allows for completely arbitrary inputs to functions, \
this can (of course) result in errors.\
\>", "Text",ExpressionUUID->"dd080594-cd58-40e0-bf89-b2fc03292897"],

Cell["\<\
Consider a function that creates a polygon with user-defined (rather than \
random) parameters:\
\>", "CodeText",ExpressionUUID->"f1529106-3e04-40d4-be43-0611a5c1285c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"definedPolygon", "[", 
   RowBox[{"sides_", ",", "color_"}], "]"}], ":=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{"color", ",", 
     RowBox[{"RegularPolygon", "[", "sides", "]"}]}], "}"}], "]"}]}]], "Input",\

 CellLabel->
  "In[575]:=",ExpressionUUID->"f4c2dce6-cac8-4d9f-b9b5-fc2ba8148ee8"],

Cell["Try this function on some reasonable inputs:", "CodeText",ExpressionUUID->"7b45c4fe-be98-4515-b777-d89a3fee077f"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"8", ",", "Red"}], "]"}]], "Input",
 CellLabel->
  "In[576]:=",ExpressionUUID->"3f550e95-54de-4182-88e4-7bca4ab78cd9"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"3", ",", "Purple"}], "]"}]], "Input",
 CellLabel->
  "In[577]:=",ExpressionUUID->"e98f3f5b-5974-46bd-a413-ccbfaf6aa2af"],

Cell[TextData[{
 "These inputs work without issue. However, it should be clear that the user \
could provide inputs that would ",
 StyleBox["not",
  FontSlant->"Italic"],
 " work so nicely."
}], "Text",ExpressionUUID->"44df72b8-71e5-48be-9c24-4afe1bef37fc"],

Cell["Try a complex number of sides:", "CodeText",ExpressionUUID->"76b6a03b-c7fd-464d-a1d4-792b7bc4a463"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{
   RowBox[{"2", "+", "\[ImaginaryI]"}], ",", "Red"}], "]"}]], "Input",
 CellLabel->
  "In[582]:=",ExpressionUUID->"43885206-a02e-4ac8-a853-a69f7dee87ae"],

Cell["\<\
Try a color that does not have a pre-defined Wolfram Language symbol \
associated to it:\
\>", "CodeText",ExpressionUUID->"0411fa1e-b629-4b49-a325-d78ef6483ea1"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"7", ",", "Fuchsia"}], "]"}]], "Input",
 CellLabel->
  "In[583]:=",ExpressionUUID->"f5e5350a-c28a-4e94-9a18-c70bea96405b"],

Cell["\<\
These sorts of errors are inevitable with the sorts of definitions you have \
seen so far, but can be easily avoided by restricting the sorts of patterns \
accepted by the function.\
\>", "Text",ExpressionUUID->"21dd13f5-1fc2-4e00-b3a6-56ec9c536586"],

Cell[TextData[{
 "Clear the definition for the ",
 Cell[BoxData[
 "definedPolygon"], "Input",ExpressionUUID->
  "b545c398-e15b-489d-87b0-41ee51b88a7c"],
 " so that the old unrestricted patterns are no longer recognized:"
}], "CodeText",ExpressionUUID->"965554fd-ca7a-4473-9ada-0a296c1d85df"],

Cell[BoxData[
 RowBox[{"Clear", "[", "definedPolygon", "]"}]], "Input",
 CellLabel->
  "In[601]:=",ExpressionUUID->"a92f6a2b-6370-4865-9744-bda9008d3f00"],

Cell[TextData[{
 "Redefine ",
 StyleBox["definedPolygon", "Input"],
 " so that it only accepts an integer number of sides and colors that are \
internally represented with ",
 ButtonBox["RGBColor",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/RGBColor.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/RGBColor.html"],
 ":"
}], "CodeText",ExpressionUUID->"9aff4659-e570-42c1-8827-12156e2c4c35"],

Cell[BoxData[
 RowBox[{
  RowBox[{"definedPolygon", "[", 
   RowBox[{"sides_Integer", ",", "color_RGBColor"}], "]"}], ":=", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", 
    RowBox[{"color", ",", 
     RowBox[{"RegularPolygon", "[", "sides", "]"}]}], "}"}], "]"}]}]], "Input",\

 CellLabel->
  "In[602]:=",ExpressionUUID->"77461fc8-cc46-46e6-b515-55a3e17138b3"],

Cell["Try the previously troublesome inputs:", "CodeText",ExpressionUUID->"f5925cc6-13db-4aad-8a61-d46d936403bd"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{
   RowBox[{"2", "+", "\[ImaginaryI]"}], ",", "Red"}], "]"}]], "Input",
 CellLabel->
  "In[586]:=",ExpressionUUID->"ed8bf9c2-329e-4931-b0ab-b38de1982a12"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"7", ",", "Fuchsia"}], "]"}]], "Input",
 CellLabel->
  "In[587]:=",ExpressionUUID->"d83aa43e-d4c7-45b1-8dfb-938fdd0e098f"],

Cell[TextData[{
 "The function now refuses to evaluate at all because the input ",
 StyleBox["no longer matches the pattern",
  FontWeight->"Bold"],
 " used in its definition."
}], "Text",ExpressionUUID->"d114ae1b-c460-482d-a6b6-137039aa2d9c"],

Cell["\<\
Of course, the function still works without issue when provided appropriate \
(i.e. pattern-matching) inputs:\
\>", "CodeText",ExpressionUUID->"1218a66b-ab7a-403f-ae60-f3cea683101b"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"9", ",", "Pink"}], "]"}]], "Input",
 CellLabel->
  "In[588]:=",ExpressionUUID->"bee75c4e-6ac4-4808-b224-ddb02877d223"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"17", ",", 
   RowBox[{"RGBColor", "[", 
    RowBox[{"0", ",", ".4", ",", ".7"}], "]"}]}], "]"}]], "Input",
 CellLabel->
  "In[590]:=",ExpressionUUID->"0ddeec52-3b6d-4a73-8a0c-fc30f33576f2"],

Cell["Add catch-all definitions that account for \"bad\" inputs:", "CodeText",ExpressionUUID->"14ca3638-6004-4ff3-b59b-b2b2c46dd7f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"definedPolygon", "[", 
   RowBox[{"sides___", ",", "color___"}], "]"}], ":=", " ", 
  "\"\<The specified number of sides is not an integer and/or the specified \
color is not valid.\>\""}]], "Input",
 CellLabel->
  "In[603]:=",ExpressionUUID->"eb53e3b7-d6af-4170-aefe-db040a36e9f2"],

Cell["Test on bad inputs:", "CodeText",ExpressionUUID->"c5150684-1add-4ea2-a867-c9bbfaad1bc2"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{"3", ",", "Mahogany"}], "]"}]], "Input",
 CellLabel->
  "In[606]:=",ExpressionUUID->"c0afbc26-b465-4455-bf0a-77d2eef68fe5"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{
   RowBox[{"2", "\[Pi]"}], ",", "Green"}], "]"}]], "Input",
 CellLabel->
  "In[607]:=",ExpressionUUID->"1f040d21-7bae-4dde-b8bd-6624acc0e8ab"],

Cell[BoxData[
 RowBox[{"definedPolygon", "[", 
  RowBox[{
   RowBox[{"2", "\[Pi]"}], ",", "Aubergine"}], "]"}]], "Input",
 CellLabel->
  "In[608]:=",ExpressionUUID->"d47b1764-c7dd-4b83-a02c-d7072eaed836"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Function Overloading", "Section",ExpressionUUID->"2fdd5311-20da-4642-977d-101bb348d943"],

Cell[CellGroupData[{

Cell["Ordering of Definitions", "Subsection",ExpressionUUID->"b171092b-009d-403d-8774-65034cc3c5a6"],

Cell["\<\
For custom functions with multiple definitions, Wolfram Language will always \
check the special definitions before the general definitions.\
\>", "Text",ExpressionUUID->"ffd4b758-eb39-4079-9138-6c5ca5f52fd4"],

Cell["Here is a function for computing the factorial of a number:", "Text",ExpressionUUID->"cdd09ac1-b189-491e-820f-f2f39301bd1c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "fact", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fact", "[", "n_", "]"}], ":=", 
  RowBox[{"n", " ", 
   RowBox[{"fact", "[", 
    RowBox[{"n", "-", "1"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fact", "[", "0", "]"}], ":=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fact", "[", "1", "]"}], ":=", "1"}]}], "Input",
 CellLabel->
  "In[216]:=",ExpressionUUID->"0a3c0809-aa00-4760-928a-59dffdcf5b72"],

Cell["Check the order in which the definitions are stored:", "Text",ExpressionUUID->"021b0a8a-dd54-4ca8-b7e8-ab39bb8e4774"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "fact"}]], "Input",
 CellLabel->
  "In[220]:=",ExpressionUUID->"da8c6466-f6e7-490d-9415-695ae7b1a299"],


 RowBox[{"square", "/:", 
  RowBox[{"area", "[", 
   RowBox[{"square", "[", "length_", "]"}], "]"}], ":=", 
  RowBox[{"length", "^", "2"}]}], "\[IndentingNewLine]", 
 RowBox[{"square", "/:", 
  RowBox[{"perimeter", "[", 
   RowBox[{"square", "[", "length_", "]"}], "]"}], ":=", 
  RowBox[{"4", "*", "length"}]}], "\[IndentingNewLine]", 
 RowBox[{"square", "/:", 
  RowBox[{"lengthOfDiagonal", "[", 
   RowBox[{"square", "[", "length_", "]"}], "]"}], ":=", 
  RowBox[{"length", "*", 
   RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], "Input",
 CellLabel->
  "In[112]:=",ExpressionUUID->"2b62fc9c-31c3-4fe0-88be-0d237b694691"],


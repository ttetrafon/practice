Cell["\<\
OwnValues is unique, whereas\[LongDash]as you have seen above\[LongDash]a \
symbol can have many different values associated with it by means of \
DownValues.\
\>", "Text",ExpressionUUID->"61889b08-266f-4ddf-a0b7-fd2fb2d66975"],

Cell[TextData[{
 StyleBox["Note:",
  FontWeight->"Bold"],
 "\n1. Assigning OwnValues to a symbol with DownValues is a bad idea.\n2. \
Assigning DownValues to a symbol that already has OwnValues will not work."
}], "Text",ExpressionUUID->"d687929e-ca66-4615-8302-f0321c6573d3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["UpValues", "Subsection",ExpressionUUID->"11d918a2-135a-42aa-8bcb-b4331bb9ba3d"],

Cell[TextData[{
 "Similar to DownValues, ",
 ButtonBox["UpValues",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/UpValues.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/UpValues.html"],
 " is defined when a symbol does not have a meaning by itself, but acquires \
one when one goes \"",
 "upward",
 "\" in the internal structure, i.e. the symbol name is provided ",
 StyleBox["as",
  FontSlant->"Italic"],
 " an argument to a specific head:"
}], "Text",ExpressionUUID->"d0b34c8a-e955-4535-a959-4dc4908d7844"],


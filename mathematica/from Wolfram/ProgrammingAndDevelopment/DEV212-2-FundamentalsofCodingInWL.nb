Cell[CellGroupData[{

Cell["OwnValues, DownValues and UpValues", "Section",ExpressionUUID->"a45d50a3-a445-49f2-997e-93c050fd64f5"],

Cell["\<\
Wolfram Language effectively stores all definitions you give as lists of \
transformation rules.\
\>", "Text",ExpressionUUID->"4ae6be68-3773-4a1d-98a9-406ffd7615ed"],

Cell[TextData[{

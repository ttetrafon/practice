    URL["https://reference.wolfram.com/language/ref/Head.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Head.html"],
 ":"
}], "Text",ExpressionUUID->"77bb69da-799e-4e37-89ab-31f4a35b09ee"],


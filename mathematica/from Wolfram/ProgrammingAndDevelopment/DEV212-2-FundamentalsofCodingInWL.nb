Cell[TextData[{
 "A good rule of thumb is that a definition for ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"g", "[", "x", "]"}], "]"}]], "Input",ExpressionUUID->
  "cac1d5ee-dffb-4404-ad40-e247e71474a5"],
 " should be created as an upvalue for ",
 Cell[BoxData[
 "g"], "Input",ExpressionUUID->"b78560b1-0888-4b79-a80d-ae5b60613416"],
 " in cases where the function ",
 Cell[BoxData[
 "f"], "Input",ExpressionUUID->"eaabce5a-23c7-447a-8894-b46bb3c5f0c7"],
 " is more common than ",
 Cell[BoxData[
 "g"], "Input",ExpressionUUID->"857c64b6-85fe-44fa-a90a-10ba87ed6488"],
 ". "
}], "Text",ExpressionUUID->"b0c88746-2329-451e-8a6f-63e22a0f5d40"],

Cell[CellGroupData[{

Cell["Why use UpValues?", "Subsubsection",ExpressionUUID->"4b547ef7-0d37-4bf8-b610-7a72fafe6c12"],

Cell["\<\
It is generally better to define upvalues for symbols that will occur as \
special arguments for a built-in function rather than modify the definition \
of a built-in function to accommodate the special argument:\

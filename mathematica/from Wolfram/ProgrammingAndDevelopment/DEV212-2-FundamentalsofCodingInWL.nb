Cell[CellGroupData[{

Cell["Try Pure Functions", "Subsection",ExpressionUUID->"7cb1ffc1-ed8b-4b7a-8733-8277d3870dec"],

Cell["\<\
As mentioned above, pure functions tend to be faster than their named \
counterparts.\
\>", "Text",ExpressionUUID->"998470c1-b3c9-49c8-9169-ea5f868be7fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pts", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1000", ",", 
     RowBox[{"10", "^", "5"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[247]:=",ExpressionUUID->"c5eeaf61-9cac-4afa-b8c8-80040a14885f"],

Cell["\<\
Try a named function that adds 1 to the input and squares the result:\
\>", "Text",ExpressionUUID->"b0057e43-24d3-4f33-90b6-dc3ddf573cd5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mySquareAdder", "[", "n_", "]"}], ":=", 

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{$CellContext`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], 
           "CYUButtonActive"]], ($CellContext`cyuOpen$$ = 
         Not[$CellContext`cyuOpen$$])& , Appearance -> None, Evaluator -> 
         Automatic, Method -> "Preemptive"]}}, 
      If[$CellContext`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "In the pattern a_b?c, explain what a, b and c indicate, \
respectively.", "Text"], 
            DynamicModule[{$CellContext`qState = None}, 
             RadioButtonBar[
              Dynamic[$CellContext`qState], {1 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 1, {
                    TextCell[
                    "a is a temporary name for the Blank object that can be \
use to refer back to it on the right-hand side, b is a restriction on the \
Head of the Blank object, and c is a predicate test that will be applied to \
the Blank object.", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell["Correct", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell[
                    "a is a temporary name for the Blank object that can be \
use to refer back to it on the right-hand side, b is a restriction on the \
Head of the Blank object, and c is a predicate test that will be applied to \
the Blank object.", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> 
               Dynamic[
                 Column[
                  If[$CellContext`qState === 2, {
                    TextCell[
                    "a is a restriction on the Head of the Blank object, b is \
a temporary name for the Blank object that can be used to refer back to it on \
the right-hand side, and c is a predicate test that will be applied to the \
Blank object.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: c is correct, but a and b are not.", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "a is a restriction on the Head of the Blank object, b is \
a temporary name for the Blank object that can be used to refer back to it on \
the right-hand side, and c is a predicate test that will be applied to the \
Blank object.", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> 
               Dynamic[
                 Column[
                  If[$CellContext`qState === 3, {
                    TextCell[
                    "a is a predicate test that will be applied to the Blank \
object, b is a temporary name for the Blank object that can be used to refer \
back to it on the right-hand side, and c is a restriction on the Head of the \
Blank object.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: These have been mixed up. Think about \

Cell[TextData[{
 "As revealed, Wolfram Language will check for the special cases of ",
 Cell[BoxData[
  RowBox[{"fact", "[", "0", "]"}]], "Input",ExpressionUUID->
  "898612cf-a9d3-4e4f-b930-aa74c764e4c7"],
 " and ",
 Cell[BoxData[
  RowBox[{"fact", "[", "1", "]"}]], "Input",ExpressionUUID->
  "2e8134d1-2736-4dcc-bada-231d0d313e13"],
 " before the more general definition for ",
 Cell[BoxData[
  RowBox[{"fact", "[", "n_", "]"}]], "Input",ExpressionUUID->
  "afd30a55-c399-47fb-bf27-971caed2b772"],
 ":"
}], "Text",ExpressionUUID->"10fb6f9b-07b1-422c-b8e7-3dead744a0b6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"fact", "[", "0", "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"fact", "[", "0", "]"}], " ", "is", " ", "used"}], " ", 
   "*)"}]}]], "Input",ExpressionUUID->"e62091de-d199-437f-9afe-041c7e8cb4d0"],

Cell[BoxData["1"], "Output",ExpressionUUID->"1b550486-3b29-4650-9a84-92dcb69bbc7b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"fact", "[", "5", "]"}], " ", 
  RowBox[{"(*", " ", 

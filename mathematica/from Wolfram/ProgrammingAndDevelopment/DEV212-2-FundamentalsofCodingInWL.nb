Cell[CellGroupData[{

Cell["Expressions tested with a predicate", "Subsubsection",ExpressionUUID->"ec560e57-2514-44e3-b25b-a12e4cb6a76c"],

Cell[TextData[{
 "The end of Blank can also be modified to test the pattern against a \
predicate function. The following recognizes patterns for which the ",
 StyleBox["test", "Input"],
 " evaluates to ",
 StyleBox["True", "Input"],
 ":"
}], "Text",
 CellTags->{
  "_?", "PatternTest"},ExpressionUUID->"454b0b14-844e-4cd0-a4d7-a777152574e9"],

Cell[TextData[{
 " ",

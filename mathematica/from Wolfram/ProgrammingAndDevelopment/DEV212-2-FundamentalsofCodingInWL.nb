   StyleBox["pattern", "TI"], "?", 
   StyleBox["test", "TI"]}]], "Input",ExpressionUUID->
  "00fa1a9d-8b99-48be-ab70-3056cc43c346"],
 " "
}], "Program",
 TextAlignment->Center,
 CellTags->{
  "_?", "PatternTest"},ExpressionUUID->"addddafd-7a10-42e7-8893-9fa01b85c173"],


Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Which of the following is a reason to use UpValues?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell[
                    "UpValues is safer than modifying the definitions of \
built-in Protected functions.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: This is true, but there are more reasons to \
use UpValues.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "UpValues is safer than modifying the definitions of \
built-in Protected functions.", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "UpValues associates properties more readily with their \
appropriate symbols.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: This is true, but there are more reasons to \
use UpValues.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "UpValues associates properties more readily with their \
appropriate symbols.", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]],
                3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell[
                    "UpValues is more efficient than adding novel definitions \
to built-in Protected functions.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: This is true, but there are more reasons to \
use UpValues.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "UpValues is more efficient than adding novel definitions \
to built-in Protected functions.", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell[
                    "UpValues for a symbol follows naturally from the \
\"standard\" DownValues definitions.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: This is true, but there more are reasons to \
use UpValues.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "UpValues for a symbol follows naturally from the \
\"standard\" DownValues definitions.", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 5 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 5, {
                    TextCell[
                    "All of the above", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: All of the above are good reasons to use \
UpValues.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["All of the above", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 

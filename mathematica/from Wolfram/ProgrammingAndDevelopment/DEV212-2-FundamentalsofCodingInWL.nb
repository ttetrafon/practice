Cell["Use Block or With", "Subsection",ExpressionUUID->"3034e1d7-64cc-4112-99d9-bd5517d8a728"],

Cell[TextData[{
 ButtonBox["Block",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Block.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Block.html"],
 ", ",
 ButtonBox["With",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/With.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/With.html"],
 " and ",
 ButtonBox["Module",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Module.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Module.html"],
 " are all localization constructs. Block and Module are interchangeable most \
of the time, but Block can be faster, and in some cases With (effectively \
Block with the variables in a read-only state) is faster still:"
}], "Text",ExpressionUUID->"03fa8de0-0287-4d4f-bfdc-ad3e75eb2c1e"],


    URL["https://reference.wolfram.com/language/ref/MessageName.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/MessageName.html"],
 "). The tag is used to provide a name for the message."
}], "Text",ExpressionUUID->"01c7795e-060a-4554-a305-f94c9ccd4fc6"],


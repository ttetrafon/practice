Cell[BoxData["\<\"Global`\"\>"], "Output",
 CellLabel->"Out[12]=",ExpressionUUID->"d411f8d4-ee55-4f89-95bd-5d0473d4d6d7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"x", "=", "10"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"20449c2b-e9a0-4f1b-80d4-83537c6dc04f"],

Cell[BoxData["10"], "Output",
 CellLabel->"Out[13]=",ExpressionUUID->"18e05674-77cd-4f26-a38e-844ba2d0a887"]
}, Open  ]],


Cell["\<\
The Context function gives the context in which a symbol appears:\
\>", "Text",ExpressionUUID->"ab1da58e-d730-4a1f-aa9b-88d9decd79d7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Context", "[", "Plus", "]"}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"f13d2bef-4a5e-4b3f-9b2c-4db939639beb"],

Cell[BoxData["\<\"System`\"\>"], "Output",
 CellLabel->"Out[22]=",ExpressionUUID->"d854cc69-daa1-46db-8174-2400a4a337a8"]
}, Open  ]],

Cell["\<\
Functions defined in a specific context are not available for use outside the \
context right away.\
\>", "Text",ExpressionUUID->"f8052cfb-5c27-4864-99ba-c781fb7f9a7f"],

Cell["You can use the function within the open context:", "Text",ExpressionUUID->"4e93ee3a-536f-4f10-a3c4-4b18016a4616"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Begin", "[", "\"\<Demo`\>\"", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"cube", "::", "usage"}], "=", 
   "\"\<This function takes an integer and cubes it\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"cube", "[", "x_Integer", "]"}], ":=", 
    RowBox[{"x", "^", "3"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"cube", "[", "4", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"End", " ", "[", "]"}], ";"}]}], "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"7e30897a-9032-4c44-9fe9-54d49ffbc62d"],

Cell[BoxData["64"], "Output",
 CellLabel->"Out[53]=",ExpressionUUID->"e36a798a-0827-4516-93e2-d4f39990b776"]
}, Open  ]],

Cell["\<\
You can also call a function outside its context using the absolute context \
path:\
\>", "Text",ExpressionUUID->"68fbbf2d-789c-41bc-9499-783be6c996a9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Demo`cube", "[", "4", "]"}]], "Input",
 CellLabel->"In[56]:=",ExpressionUUID->"7d730f27-ee0d-4edd-b996-92cda26277ed"],

Cell[BoxData["64"], "Output",
 CellLabel->"Out[56]=",ExpressionUUID->"53b35d6e-71f3-4cb0-ab07-f7ed69bfbabe"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Context Path", "Subsection",ExpressionUUID->"ca28bee3-7ad3-45aa-8982-e8c08c2d3ab3"],

Cell["\<\
One of the easiest methods of accessing a function from another context is to \
add the context to the context path:\
\>", "Text",ExpressionUUID->"51a0b1d4-a162-4b42-b034-b84ab30269ad"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AppendTo", "[", 
  RowBox[{"$ContextPath", ",", "\"\<Demo`\>\""}], "]"}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"7da26ebb-9a9e-4c29-ac1f-629e96412a13"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"DocumentationSearch`\"\>", ",", "\<\"ResourceLocator`\"\>", 
   ",", "\<\"URLUtilities`\"\>", ",", "\<\"PacletManager`\"\>", 
   ",", "\<\"System`\"\>", ",", "\<\"Global`\"\>", ",", "\<\"Demo`\"\>"}], 
  "}"}]], "Output",
 CellLabel->"Out[37]=",ExpressionUUID->"f9d24213-1f38-4754-b956-079bbcdb0ced"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cube", "[", "10", "]"}]], "Input",
 CellLabel->"In[58]:=",ExpressionUUID->"4113dc8a-8e43-47bf-9b8b-7713b9db7711"],

Cell[BoxData["1000"], "Output",
 CellLabel->"Out[58]=",ExpressionUUID->"a5d9c193-10bd-425b-a542-8c5fd2cf93cf"]
}, Open  ]],

Cell["\<\
The context path is the list of locations (in order) that Wolfram Language \
will look through for the definitions of functions. The current list can be \
accessed using the global variable. Be aware that if a definition for a \
function exists in more than one context, then the order of the context path \
matters:\
\>", "Text",ExpressionUUID->"b896eb0a-2304-4f9c-b8d4-30c58f6e7c46"],

Cell[CellGroupData[{

Cell[BoxData["$ContextPath"], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"03cc4a6f-d48a-4ca8-9986-c6e246fabcd7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"DocumentationSearch`\"\>", ",", "\<\"ResourceLocator`\"\>", 
   ",", "\<\"URLUtilities`\"\>", ",", "\<\"PacletManager`\"\>", 
   ",", "\<\"System`\"\>", ",", "\<\"Global`\"\>"}], "}"}]], "Output",
 CellLabel->"Out[7]=",ExpressionUUID->"5d7c1693-e5e2-4dbc-8be3-0b072a1936fa"]
}, Open  ]],

Cell["\<\
Once a package is loaded, it is automatically added to the end of the context \
path, allowing a user to use the functions from that context without having \
to use an absolute context path.\
\>", "Text",ExpressionUUID->"c0c96b75-34e6-4326-a76d-cb2ab9b9dbc0"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Usage Messages", "Section",ExpressionUUID->"25a802f3-b423-48ba-81ab-36c1db35b0ab"],

Cell[CellGroupData[{

Cell["Provide Information", "Subsection",ExpressionUUID->"2b6e9446-852c-4b51-9b47-7a6449beaa36"],

Cell[TextData[{
 "All built-in functions have usage messages, which can be found when you use \
the ",
 ButtonBox["Information",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Information.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/Information.html"],
 " function:"
}], "Text",ExpressionUUID->"ac31410c-735b-4e45-b338-ada6998e8d12"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "Plus"}]], "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"2b6457eb-650d-4c61-bb0a-4cca80ea40de"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox["\<\" Symbol\"\>", "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox[
           PaneBox[
            TooltipBox[
             ButtonBox[

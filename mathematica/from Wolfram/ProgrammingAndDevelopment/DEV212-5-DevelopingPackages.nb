Cell[BoxData[
 RowBox[{"Context", "[", "x", "]"}]], "Input",
 CellLabel->"In[14]:=",ExpressionUUID->"5001860e-f86e-4657-ae5e-0981edc9318f"],

Cell[BoxData["\<\"Global`\"\>"], "Output",
 CellLabel->"Out[14]=",ExpressionUUID->"af609af8-5f58-45ba-abbf-8bf0f021134c"]
}, Open  ]],

Cell[TextData[{
 "To start a new context, the function ",
 ButtonBox["Begin",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Begin.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Begin.html"],
 " is required, along with the name of the context you wish to start."
}], "Text",ExpressionUUID->"378b306a-f256-4360-8c50-773b58b075f7"],

Cell[TextData[{
 "To end the context, ",
 ButtonBox["End",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/End.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/End.html"],
 " is used. This will automatically end the last context that was started:"
}], "Text",ExpressionUUID->"db19eca1-d1a4-4d33-b8f2-4abfb3d3c5dd"],

Cell[CellGroupData[{

Cell[BoxData["$Context"], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"41cfd469-156e-458a-b5e8-f1754c3853bb"],

Cell[BoxData["\<\"Global`\"\>"], "Output",
 CellLabel->"Out[15]=",ExpressionUUID->"f2b64fda-3e8a-4b1c-b3cc-88f595e0b956"]
}, Open  ]],


Notebook[{

Cell[CellGroupData[{
Cell["Developing Packages", "Subtitle",ExpressionUUID->"ac1537b3-4a7a-4210-adcc-dd5cb537e26b"],

Cell[CellGroupData[{

Cell["Learning Objectives", "Section",ExpressionUUID->"ca56afa9-3dc9-49d7-9641-f45d0b039c01"],

Cell[CellGroupData[{

Cell["Developing Packages ", "Subsection",ExpressionUUID->"39de91ef-4e18-4ef6-925b-5d428a5cf6c1"],

Cell["Understand the differences between packages and notebooks", "Item",ExpressionUUID->"193542d5-eceb-4d12-ae25-fab366b58a60"],

Cell["Learn to load packages", "Item",ExpressionUUID->"aa32d549-e8e8-4a9e-a499-e1017d205858"],

Cell["Utilize contexts and namespaces to localize symbols", "Item",ExpressionUUID->"ddd2104c-1aa4-41dc-bf53-6e5c3604f522"],

Cell["Write usage messages for functions included in a package", "Item",ExpressionUUID->"39622492-b9c5-4319-a68b-ea33e7a97339"],

Cell["Create a package using the correct sequence of commands", "Item",ExpressionUUID->"db960618-0b0a-4a65-a57d-b4e4d733a722"],

Cell["\<\
Organize the components of your package with the correct folder structure\
\>", "Item",ExpressionUUID->"ba907a79-cd9b-4b7a-93bc-fa317fba77db"],

Cell["Set up autoloading for packages and other definitions", "Item",ExpressionUUID->"200902aa-cf58-4814-bd6e-515605b0b477"],

Cell["Compare and contrast packages and paclets", "Item",ExpressionUUID->"afcd113d-fbac-4c39-9762-9f994cb8401d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Packages versus Notebooks", "Section",ExpressionUUID->"b131ebdf-5cc2-4acd-99a4-07c8fea73d94"],

Cell[CellGroupData[{

Cell["Notebooks (.nb)", "Subsection",ExpressionUUID->"5b9765c1-9653-43ed-b34d-433466714450"],

Cell["Some advantages of using notebooks are:", "Text",ExpressionUUID->"57ed0d40-f292-41c9-a656-e0b8c7c15beb"],

Cell["Ease of use", "Item",ExpressionUUID->"510d7dc8-f0e7-497f-bdd0-572100346826"],

Cell["Support for powerful graphics and interactivity", "Item",ExpressionUUID->"f5653a90-acd4-4a5c-8888-e26019056ec7"],

Cell["Ease of editing", "Item",ExpressionUUID->"dd89a849-93d2-42ec-a1b7-3e62b0250896"],

Cell["However, notebooks can be difficult to distribute.", "Text",ExpressionUUID->"0f02d7a3-8eaf-4ce9-8b73-51525f2e98a2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Packages (.m or .wl)", "Subsection",ExpressionUUID->"b6b4cfe5-da65-4c09-b71a-f4f42c36dec3"],

Cell["\<\
Packages provide a way to bundle together new functions. They make them: \
\>", "Text",ExpressionUUID->"e777479d-3e32-4b4f-b759-73967427654e"],

Cell["Convenient to distribute", "Item",ExpressionUUID->"42f63c84-6f26-48ec-af49-89b7f5e6d79e"],

Cell["Easy to load", "Item",ExpressionUUID->"38c00bdd-2137-4944-b2c2-545ff2139c0d"],

Cell["Possible to abstract the implementation from the user", "Item",ExpressionUUID->"3725df8a-2894-4a84-94d9-2486565547f2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Loading a Package", "Section",ExpressionUUID->"9ac6829a-23f6-4d3d-9411-117dd7bab1f3"],

Cell["\<\
Wolfram Language is an extensible system, allowing for users to add in more \
functionality. Packages can be used to put together a collection of new \
Wolfram Language function definitions that can be \"taught\" to Wolfram \
Language. \
\>", "Text",ExpressionUUID->"aedc6907-1e3c-4615-a9f5-da83c462173e"],

Cell["\<\
Packages can vary in size from a handful of functions to several hundred. No \
matter their size, they can be accessed in the same way.\
\>", "Text",ExpressionUUID->"9d761b2b-2432-40fa-aa01-6139cff541bf"],

Cell[TextData[{
 "You can explicitly tell Wolfram Language to read in a package at any point \
using ",
 ButtonBox["Get",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Get.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Get.html"],
 ":"
}], "Text",ExpressionUUID->"dcff4453-ffd3-4a0e-a817-7ccb0afe55a6"],

Cell[BoxData[
 RowBox[{"Get", "[", "\"\<package file path\>\"", "]"}]], "Input",ExpressionUU\
ID->"9cfd0c09-d175-4914-a91f-c34cc7fc6da8"],

Cell["Or:", "Text",ExpressionUUID->"aa094f70-5825-4ed4-85ca-94dd293371e5"],

Cell[BoxData[
 RowBox[{"<<", "PackageNameHere`"}]], "Input",ExpressionUUID->"fe23a6f5-395a-4bfd-bbba-9837bc156ff9"],

Cell["This reads in a sample package:", "Text",ExpressionUUID->"288aeb4d-65e5-4f36-869f-a51748ebb683"],

Cell[BoxData[
 RowBox[{"<<", "ExampleData/Collatz.m"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"15e8ecc1-b046-47d7-8c3b-6953e2cb74e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Collatz", "[", "4", "]"}]], "Input",
 CellLabel->"In[14]:=",ExpressionUUID->"559fc2e1-d938-4e90-ae86-b4bd583cb971"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"4", ",", "2", ",", "1"}], "}"}]], "Output",
 CellLabel->"Out[14]=",ExpressionUUID->"e396b239-929a-4239-b6e1-55294ed2cb02"]
}, Open  ]],

Cell[TextData[{
 "You can also set it up so that a particular package is read in only if it \
is needed, using ",
 ButtonBox["Needs",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Needs.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Needs.html"],
 ":"
}], "Text",ExpressionUUID->"9ae2ad6b-db79-43a9-8e2a-a590662f2002"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<DatabaseLink`\>\"", "]"}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"b1f27841-73c6-4baa-9d0b-a20cd191fb25"],

Cell[TextData[{
 "The default location to look for packages is the current working directory \
(found using the function ",
 ButtonBox["Directory",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Directory.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Directory.html"],
 "):"
}], "Text",ExpressionUUID->"643fdda6-b75d-413b-93ff-2686ca964a35"],

Cell[BoxData[
 RowBox[{"Directory", "[", "]"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"d5d568b2-78e9-4de0-a8e4-21ca76196981"],

Cell["\<\
You can get a list of the contexts corresponding to all packages that have \
been loaded in your current Wolfram System session:\
\>", "Text",ExpressionUUID->"59b5cde2-ee9d-4874-be3c-8ef03c1cbcc5"],

Cell[BoxData["$Packages"], "Input",
 CellLabel->
  "In[277]:=",ExpressionUUID->"ab4dbb9f-8b77-43cf-8f33-30e03ad5d9bc"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Suppose that you have loaded a package called CoolPackage that \
includes a function coolFunction. Which of the following is the best way to \
call this function from the open or Global context?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell[
                    "coolFunction", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Once a \"parent\" package has been loaded, it \
is added to the context path and you no longer need to specify it when \
calling any of its functions.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["coolFunction", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "CoolPackage`coolFunction", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While this will work, you do not need to \
specify the package name once the package has been loaded. This is because \
loading a package adds it to the context path.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["CoolPackage`coolFunction", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell[
                    "You cannot call the function from outside of its \
context.", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: You can call a function from outside of the \
context of its \"parent\" package.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "You cannot call the function from outside of its \
context.", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]]}, 
              Appearance -> "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{1005., {22.574980042874813`, 29.807401917874813`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"5f8fbe71-9b57-4738-9b2b-\
679ce089f8ec"]], "Text",
 CellTags->"CYU",ExpressionUUID->"4b18c5f0-7172-4715-9996-79a247a909c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Namespaces", "Section",ExpressionUUID->"1a552e90-63ca-4434-87a8-abdbd663af2b"],

Cell[CellGroupData[{

Cell["Context", "Subsection",ExpressionUUID->"ad6e9f7e-3c07-4d35-bcea-2d93b57fac1e"],

Cell[TextData[{
 ButtonBox["Context",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Context.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Context.html"],
 " allows definitions of functions to be separated into appropriate \
groupings, each with a unique identifier."
}], "Text",ExpressionUUID->"ccb0ac1d-da9d-4008-ac1d-30d028ccdb98"],

Cell["The current context can be found using:", "Text",ExpressionUUID->"ad7a0000-77fb-4239-8a54-6cee322f1211"],


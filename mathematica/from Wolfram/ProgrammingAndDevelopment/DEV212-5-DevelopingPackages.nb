Cell[TextData[{
 ButtonBox["Messages",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Messages.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Messages.html"],
 " gives a list of the messages associated with a function:"
}], "Text",ExpressionUUID->"4eb626da-4fe1-4824-a7d2-3d48df7e7bcc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Messages", "[", "f", "]"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"860959df-7842-4d93-be34-abfbf8dcf368"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"HoldPattern", "[", 
     StyleBox[
      RowBox[{"f", "::", "argx"}], "MessageName"], "]"}], 
    "\[RuleDelayed]", "\<\"`1` called with `2` arguments; 1 argument is \
expected.\"\>"}], ",", 
   RowBox[{
    RowBox[{"HoldPattern", "[", 
     StyleBox[
      RowBox[{"f", "::", "len"}], "MessageName"], "]"}], 
    "\[RuleDelayed]", "\<\"Argument `1` is too large; limiting to 80\"\>"}], 
   ",", 
   RowBox[{
    RowBox[{"HoldPattern", "[", 
     StyleBox[
      RowBox[{"f", "::", "usage"}], "MessageName"], "]"}], 
    "\[RuleDelayed]", "\<\"f[n] prints n asterisks\"\>"}]}], "}"}]], "Output",\

 CellLabel->"Out[13]=",ExpressionUUID->"4067537a-fb8b-46df-9f2d-c0a283a8348d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Making the Symbol or Function Available for Use", "Subsection",ExpressionUUID->"1d26d599-7494-44ee-b8ac-82328bba77cd"],

Cell[TextData[{
 "Including the usage message ",
 StyleBox["outside",
  FontSlant->"Italic"],
 " the Private context in a package allows the function to be explicitly \
accessed in the context of the packages. Functions defined within the private \
context without a usage message outside the private context are not available \
for use outside the package."
}], "Text",ExpressionUUID->"b8ea0c14-2c78-4e46-819b-754ff9f434e2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Syntax Coloring and Other Advisories", "Section",ExpressionUUID->"c5f0339f-18bc-4bba-b93e-656a01dc6656"],

Cell[TextData[{
 ButtonBox["SyntaxInformation",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/SyntaxInformation.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/SyntaxInformation.html"],
 " is a function that defines what pattern of arguments is acceptable. This \
is so that any other pattern of arguments will result in the front end \
display alerting the user they have provided too many or too few arguments:"
}], "Text",ExpressionUUID->"6abefea9-38e4-4868-91f7-d32ea0b78b7c"],

Cell[BoxData[
 RowBox[{"ClearAll", "[", "f", "]"}]], "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"a3843e0f-2dda-4844-ae56-eabdae25f338"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SyntaxInformation", "[", "f", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<ArgumentsPattern\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"_", ",", "_"}], "}"}]}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[20]:=",
 CellID->1608,ExpressionUUID->"f06dcac3-067d-4e67-a212-d3e06b1291ea"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", "]"}], ",", 
    RowBox[{"f", "[", "x", "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y", ",", "z", ",", "w"}], "]"}]}], "}"}], 
  ";"}]], "Input",
 CellLabel->"In[64]:=",
 CellID->12654,ExpressionUUID->"b4758d7c-7e65-4b18-bb10-14af68f865e9"],

Cell["SyntaxInformation is also usable with options:", "Text",ExpressionUUID->"32d12a31-e801-483b-94be-b423d91f7e5f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SyntaxInformation", "[", "f", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"\"\<ArgumentsPattern\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"_", ",", "_", ",", 
       RowBox[{"OptionsPattern", "[", "]"}]}], "}"}]}], "}"}]}], 
  ";"}]], "Input",
 CellLabel->"In[21]:=",
 CellID->24604,ExpressionUUID->"9265de02-abbc-47c3-9d7b-3b6b162bbe47"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y", ",", 
    RowBox[{"aab", "->", "2"}], ",", 
    RowBox[{"aaa", "->", "3"}], ",", 
    RowBox[{"bba", "->", "4"}]}], "]"}], ";"}]], "Input",
 CellID->22225,ExpressionUUID->"52881867-fd28-4f40-810c-752350ca423e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Editing a Package", "Section",ExpressionUUID->"7fed8d0b-6371-4494-a36b-38be4a0631dc"],

Cell["\<\
You can create and edit a package file using the package editor in \
Mathematica (File \[FilledRightTriangle] New \[FilledRightTriangle] \
Package/Script \[FilledRightTriangle] Wolfram Language Package).\
\>", "Text",ExpressionUUID->"6274dc40-95d4-445b-ae8c-b093fe3cee19"],

Cell[TextData[{
 "The syntax for creating a new package is simple, using the ",
 ButtonBox["BeginPackage",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/BeginPackage.html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/BeginPackage.html"],
 " function, the name of the package and a backtick:"
}], "Text",ExpressionUUID->"f50825a9-de71-47c0-aaa4-f8fd036a8c0c"],

Cell[BoxData[
 RowBox[{"BeginPackage", "[", "\"\<NewPackage`\>\"", "]"}]], "Input",Expressio\
nUUID->"daa29aa5-c1b9-4dc1-9ab8-9de6a8f7d7b4"],

Cell["\<\
Your package may have dependencies on other packages; these should also be \
included in the definition. It can be done within the BeginPackage function \
at the beginning or can be included using the Needs function within the \
package:\
\>", "Text",ExpressionUUID->"b582ffc7-a510-40f1-982f-650af4adfb04"],

Cell[BoxData[
 RowBox[{"BeginPackage", "[", 
  RowBox[{"\"\<NewPackage`\>\"", ",", 
   RowBox[{"{", "\"\<OldPackage`\>\"", "}"}]}], "]"}]], "Input",ExpressionUUID\
->"3833fb00-12b7-4227-8ea7-89feb0432abc"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<OldPackage`\>\"", "]"}]], "Input",ExpressionUUID->"fb5c756d-6e4f-4373-b4d1-bc699f39261a"],

Cell["\<\
You can start and end a context within a package using Begin and End.\
\>", "Text",ExpressionUUID->"317cb1db-e5c4-4783-8f71-b9df4e371fe2"],

Cell[TextData[{
 "Use the ",
 ButtonBox["EndPackage",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/EndPackage.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/EndPackage.html"],
 " function to end the definition of a package:"
}], "Text",ExpressionUUID->"7e91d7b4-2c32-438a-ba38-886b8a0a96ee"],

Cell[BoxData[
 RowBox[{"EndPackage", "[", "]"}]], "Input",ExpressionUUID->"7f1c823d-7996-49bb-9c89-6c66e43a3fa8"],

Cell["\<\
There is a standard sequence of Wolfram Language commands that is typically \
used to set up the contexts in a package:\
\>", "Text",ExpressionUUID->"205a5342-d7af-4bb8-9208-456707305e0c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<BeginPackage[\\\"Package`\\\"]\>\"", ",", "\"\<Input\>\""}], 
        "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<set Package` to be the current context,and put only System` on \
the context search path\>\"", ",", "\"\<Text\>\""}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<f::usage=\\\"text\\\",\[Ellipsis]\>\"", ",", "\"\<Input\>\""}], 
        "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<introduce the objects intended for export (and no others)\>\"", 
         ",", "\"\<Text\>\""}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<Begin[\\\"`Private`\\\"]\>\"", ",", "\"\<Input\>\""}], 
        "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<set the current context to Package`Private`\>\"", ",", 
         "\"\<Text\>\""}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<f[args]=value,\[Ellipsis]\>\"", ",", "\"\<Input\>\""}], 
        "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<give the main body of definitions in the package\>\"", ",", 
         "\"\<Text\>\""}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<End[]\>\"", ",", "\"\<Input\>\""}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<revert to the previous context (here Package`)\>\"", ",", 
         "\"\<Text\>\""}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<EndPackage[]\>\"", ",", "\"\<Input\>\""}], "]"}], ",", 
       RowBox[{"Style", "[", 
        RowBox[{
        "\"\<end the package,prepending the Package` to the context search \
path\>\"", ",", "\"\<Text\>\""}], "]"}]}], "}"}]}], "\[IndentingNewLine]", 
    "}"}], ",", 
   RowBox[{"Alignment", "\[Rule]", "Left"}]}], "]"}]], "Input",ExpressionUUID->\
"c3e227e9-e73a-4c86-a0bb-072739704673"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"BeginPackage[\\\"Package`\\\"]\"\>", "Input",
      StripOnInput->False], 
     StyleBox["\<\"set Package` to be the current context,and put only \
System` on the context search path\"\>", "Text",
      StripOnInput->False]},
    {
     StyleBox["\<\"f::usage=\\\"text\\\",\[Ellipsis]\"\>", "Input",
      StripOnInput->False], 
     StyleBox["\<\"introduce the objects intended for export (and no \
others)\"\>", "Text",
      StripOnInput->False]},
    {
     StyleBox["\<\"Begin[\\\"`Private`\\\"]\"\>", "Input",
      StripOnInput->False], 
     StyleBox["\<\"set the current context to Package`Private`\"\>", "Text",
      StripOnInput->False]},
    {
     StyleBox["\<\"f[args]=value,\[Ellipsis]\"\>", "Input",
      StripOnInput->False], 
     StyleBox["\<\"give the main body of definitions in the package\"\>", 
      "Text",
      StripOnInput->False]},
    {
     StyleBox["\<\"End[]\"\>", "Input",
      StripOnInput->False], 
     StyleBox["\<\"revert to the previous context (here Package`)\"\>", "Text",
      StripOnInput->False]},
    {
     StyleBox["\<\"EndPackage[]\"\>", "Input",
      StripOnInput->False], 
     StyleBox["\<\"end the package, prepending the Package` to the context \
search path\"\>", "Text",
      StripOnInput->False]}
   },
   AutoDelete->False,
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Output",
 CellLabel->"Out[18]=",ExpressionUUID->"e6090a55-e31e-4678-b52f-87d5a8afcaa3"]
}, {2}]],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Where should you place usage messages for functions defined \
within a package?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell[
                    "Before the BeginPackage command", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: This one is no trick: BeginPackage should be \
the very first command of any package file.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Before the BeginPackage command", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell[
                    "After the BeginPackage command but before the package's \
private context", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Placing a usage message here \"primes\" the \
system to know about functions that will be defined inside a private context. \
This happens because giving a symbol a usage message outside of a private \
context lets the system know that this is a symbol that exists.", "Text", 
                    FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell[
                    "After the BeginPackage command but before the package's \
private context", "Text"]}], BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> 
               Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell[
                    "Inside the package's private context", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Placing a usage message inside the private \
context means that\[LongDash]in the global context\[LongDash]the system will \
not be aware of the symbol at all. This happens because everything relating \
to the symbol occurs in a context that the system cannot see.", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "Inside the package's private context", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{1005., {22.574980042874813`, 29.807401917874813`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"a93ef0c5-b664-4560-a432-\
2bd374608f62"]], "Text",
 CellTags->"CYU",ExpressionUUID->"72528456-ac14-4cda-a6f9-2e0c0157693b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Package Folder Structure", "Section",ExpressionUUID->"2d3d9fa4-ffb1-4a37-a444-fc3426dde5cd"],

Cell["\<\
Mathematica has the ability to handle stylesheets for document-wide \
formatting and palettes as additional tool windows. To start with, some \
Wolfram-defined ones are included; you may, however, wish to create your own. \
Once this is done, they need to be placed in the appropriate folder for them \
to be picked up by Mathematica.\
\>", "Text",ExpressionUUID->"69cbf971-b038-44ee-ba83-14951c546687"],

Cell["\<\
The base directory for all resources can be found using the global variable. \
Then navigate into the Applications folder:\
\>", "Text",ExpressionUUID->"f660c893-b98a-4cd9-a3bb-036d2b81517a"],

Cell[BoxData["$UserBaseDirectory"], "Input",
 CellLabel->"",ExpressionUUID->"44a3bde1-539c-4151-b38e-ede358f6352b"],

Cell["\<\
The structure of this folder and any packages should be as follows:\
\>", "Text",ExpressionUUID->"7ea742f4-5148-40c2-80a2-ce777bf27a2f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TreeForm", "[", 
  RowBox[{"\"\<Applications\>\"", " ", "[", " ", 
   RowBox[{
    RowBox[{"\"\<myPackage\>\"", " ", "[", 
     RowBox[{
      RowBox[{"\"\<Kernel\>\"", "[", " ", "\"\<Init.m\>\"", "]"}], ",", 
      RowBox[{"\"\<FrontEnd\>\"", " ", "[", 
       RowBox[{"\"\<Palettes\>\"", ",", " ", "\"\<Stylesheets\>\""}], "]"}], 
      " ", ",", "\"\<ReadMe\>\""}], "]"}], ",", 
    RowBox[{"\"\<givenPackage\>\"", " ", "[", 
     RowBox[{
      RowBox[{"\"\<Kernel\>\"", "[", " ", "\"\<Init.m\>\"", "]"}], ",", 
      RowBox[{"\"\<FrontEnd\>\"", " ", "[", 
       RowBox[{"\"\<Palettes\>\"", ",", " ", "\"\<Stylesheets\>\""}], "]"}], 
      " ", ",", "\"\<ReadMe\>\""}], "]"}]}], " ", "]"}], " ", "]"}]], "Input",\
ExpressionUUID->"5ca92730-5583-4e88-becc-6fee4c5532a5"],


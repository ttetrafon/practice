Cell[TextData[{
 "All .nb files in Palettes and Stylesheets appear on appropriate menus, and \
the stylesheet will be on the path for StyleDefinitions",
 Cell[BoxData[
  StyleBox["\[RightArrow]",
   FontWeight->Bold]],ExpressionUUID->
  "493b29e8-e039-4472-aac4-c4f138b13b4e"],
 "\"stylesheets.nb\" once the package folder has been placed in the correct \
directory (a restart of Mathematica may be needed)."
}], "Text",ExpressionUUID->"549c7480-2a88-467c-b8d1-164226fdf2a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Autoloading", "Section",ExpressionUUID->"d3727a2a-e720-42af-b58c-2550656711d6"],

Cell[TextData[{
 "It is possible to get Mathematica to automatically start with packages \
loaded, variables initialized or data already imported. This can be done \
through the use of the ",
 ButtonBox["InitializationValue",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/InitializationValue.html"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/InitializationValue.html"],
 " function and the ",
 ButtonBox["$Initialization",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/$Initialization.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/$Initialization.html"],
 " global variable."
}], "Text",ExpressionUUID->"e8addddb-e7c7-4b20-94b6-4a9529e14f4f"],

Cell["By default, $Initialization is empty:", "Text",ExpressionUUID->"689e1110-adf8-4cf5-b376-2ad36b7b64bb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"InitializationValue", "[", "$Initialization", "]"}]], "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"18d3f6c7-d4c9-49c2-8451-28c4b2b55c9b"],

Cell[BoxData[
 RowBox[{"{", "}"}]], "Output",
 CellLabel->"Out[65]=",ExpressionUUID->"7b4a66f0-f548-4ecb-b9c1-c93f50d69352"]
}, Open  ]],

Cell["Now set up a package to autoload:", "Text",ExpressionUUID->"382a761e-212d-48a1-8282-9d5845f78ae5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"InitializationValue", "[", "$Initialization", "]"}], "=", 
  RowBox[{"Hold", "[", 
   RowBox[{"Get", "[", "\"\<ComputerArithmetic`\>\"", "]"}], "]"}]}]], "Input",\

 CellLabel->"In[66]:=",ExpressionUUID->"79a1d53b-2b2e-4b14-9804-02be635c7ec6"],

Cell[BoxData[
 RowBox[{"Hold", "[", 
  RowBox[{"<<", "\<\"ComputerArithmetic`\"\>"}], "]"}]], "Output",
 CellLabel->"Out[66]=",ExpressionUUID->"89f023e6-3b15-43c3-ae41-b29261d30cf2"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Ulp", "[", "1000.", "]"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"65bd63c7-899a-41ac-ad5c-8a67402f7dbc"],

Cell[BoxData["1.1368683772161603`*^-13"], "Output",
 CellLabel->"Out[7]=",ExpressionUUID->"7c3defbc-2fab-47d4-adb0-149b3b189e2c"]
}, Open  ]],

Cell["Or set a variable to contain some data:", "Text",ExpressionUUID->"8e83832d-7f57-4e95-a780-d101b38bc0f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"xNew", ",", "yNew", ",", "zNew"}], "}"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"84709546-91a2-4645-94a4-4ef72584a450"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"10", ",", "20", ",", "30"}], "}"}]], "Output",
 CellLabel->"Out[7]=",ExpressionUUID->"404bdcaa-5b78-49eb-a145-bbd50dc6b477"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"InitializationValue", "[", "$Initialization", "]"}], "=", 
  RowBox[{"Hold", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"xNew", "=", "10"}], ",", 
     RowBox[{"yNew", "=", "20"}], ",", 
     RowBox[{"zNew", "=", "30"}]}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"3a0a7dba-cea8-4818-a83e-f17d282bb715"],

Cell[BoxData[
 RowBox[{"Hold", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"xNew", "=", "10"}], ",", 
    RowBox[{"yNew", "=", "20"}], ",", 
    RowBox[{"zNew", "=", "30"}]}], "}"}], "]"}]], "Output",
 CellLabel->"Out[10]=",ExpressionUUID->"62cfe833-7f4b-4843-ab7f-1295fc5bc6ff"]
}, Open  ]],

Cell[TextData[{
 "To stop this behavior, just use the ",
 ButtonBox["Remove",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Remove.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Remove.html"],
 " function:"
}], "Text",ExpressionUUID->"b6249d18-d7be-4431-bb29-0e9c206c6442"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Remove", "[", 
   RowBox[{"InitializationValue", "[", "$Initialization", "]"}], "]"}], 
  ";"}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"f53ed611-6949-4604-9af1-274aa4177a4c"],

Cell[BoxData[
 RowBox[{"InitializationValue", "[", "$Initialization", "]"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"2ea6ce85-e218-4329-ae6f-3e8f248cb333"],

Cell[TextData[StyleBox["WARNING : This cannot be used with any code that \
generates dialog boxes or requires user input (e.g. login). ",
 FontColor->RGBColor[1, 0, 0]]], "Text",ExpressionUUID->"c6b37d2a-eebe-4746-\
b045-c5ad8fa6cf5d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Package versus Paclet", "Section",ExpressionUUID->"e9ef8308-867d-4d7a-93b2-76035c1456dd"],

Cell[CellGroupData[{

Cell["Package File", "Subsection",ExpressionUUID->"26f3a793-30b4-4527-9c71-ece978ee9512"],

Cell["A package file is:", "Text",ExpressionUUID->"3e63d5b3-4854-4e44-b75f-008ede15fffc"],

Cell["A simple .m or .wl file", "Item",ExpressionUUID->"e6211508-2a9c-4359-8475-4193445d8f62"],

Cell["\<\
Easily installed using Get (so package need not be explicitly installed)\
\>", "Item",ExpressionUUID->"5a407c7e-baeb-4a71-b049-6b3d342ae45c"],

Cell["\<\
Simple and straightforward to use, but can become cumbersome if packed with \
too many functions\
\>", "Item",ExpressionUUID->"c2389d3b-9dcd-4ca9-b087-911dc83d5dfb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Paclet", "Subsection",ExpressionUUID->"a7046528-b6ad-45de-b053-1481c3ab74e9"],

Cell["\<\
A \"paclet\" in Wolfram Language is more like what is called a \"package\" in \
other programming languages. \
\>", "Text",ExpressionUUID->"9e8a2075-23ab-4bac-baf9-2df5eb673a57"],

Cell["A paclet:", "Text",ExpressionUUID->"ab4ad237-8a6e-4579-a8ba-a6abf8a0245a"],

Cell[TextData[{
 "Is an archive bundling together packages (i.e. .wl or .m files) containing ",
 StyleBox["new functions, stylesheets, palettes, documentation notebooks or \
data files",
  CellDingbat->Cell[
    BoxData[
     TooltipBox[
      Cell["tgayley      ", "TentativeID"], "2020-01-16"]], 
    "TentativeWrapper"]],
 " all in a single .paclet file along with metadata"
}], "Item",ExpressionUUID->"599cff91-cce8-4aa4-86db-1982596a4f22"],

Cell["\<\
Makes it easy to install multiple resources at once (user does not need to \
know the details about the individual package files or load/install them one \
by one)\
\>", "Item",ExpressionUUID->"a382c354-e97d-4af0-91fe-0fc974092dd3"],

Cell["Allows for automatic updates ", "Item",ExpressionUUID->"c13c76eb-6869-4d88-b7a7-53b16a6b989d"],

Cell["Is the \"Wolfram\" way to implement packages and distribute", "Item",ExpressionUUID->"600ffe83-ef9c-4dbe-8ebe-dcbfa4a3143c"],

Cell["\<\
Many built-in Wolfram Language functions and data resources are implemented \
and maintained using paclets:\
\>", "Text",ExpressionUUID->"663102a6-a7d7-4392-926b-285407e6efa0"],

Cell[CellGroupData[{


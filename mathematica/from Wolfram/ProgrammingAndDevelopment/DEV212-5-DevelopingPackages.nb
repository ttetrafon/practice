Cell[TextData[{
 "On the off chance that the functionality you need is not already in Wolfram \
Language, make sure to check the paclet repository (as well as the ",
 ButtonBox["Wolfram Function Repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/FunctionRepository"], None},
  ButtonNote->"https://resources.wolframcloud.com/FunctionRepository"],
 "!)."
}], "Text",ExpressionUUID->"faec7b97-a768-499a-8c83-f01d4d80b4a7"],


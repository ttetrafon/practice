Cell[CellGroupData[{

Cell[BoxData["$Context"], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"7c590816-57bf-4e6f-a768-2362db8ae65f"],

Cell[BoxData["\<\"Global`\"\>"], "Output",
 CellLabel->"Out[21]=",ExpressionUUID->"1f2fcf2d-0895-4900-9cd6-3594179fcac5"]

  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Evaluate.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Evaluate.html"],
 ":"
}], "Text",ExpressionUUID->"4bc9b710-2ad1-4b6f-abbc-4c6bfba77122"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"f", "[", 

Cell["Each element in the expression is evaluated in turn:", "Text",ExpressionUUID->"feba7663-ad7b-4660-94d8-e7590a1c8e6a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"x", ",", "y", ",", "z"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "=", "3"}], ";"}]}], "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"fe7a4235-01b5-4b00-a8fb-5c4168c17af4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Trace", "[", 
  RowBox[{
   RowBox[{"Plus", "[", 
    RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
   RowBox[{"TraceOriginal", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"19c9a9f5-3876-43cb-a836-0571130b8ac3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{"x", "+", "y", "+", "z"}],
    HoldForm], ",", 
   RowBox[{"{", 
    TagBox["Plus",
     HoldForm], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox["x",
      HoldForm], ",", 
     TagBox["1",
      HoldForm]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox["y",
      HoldForm], ",", 
     TagBox["2",
      HoldForm]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox["z",
      HoldForm], ",", 
     TagBox["3",
      HoldForm]}], "}"}], ",", 
   TagBox[
    RowBox[{"1", "+", "2", "+", "3"}],
    HoldForm], ",", 
   TagBox["6",
    HoldForm]}], "}"}]], "Output",
 CellLabel->"Out[28]=",ExpressionUUID->"146aa53b-6601-45b5-bac2-c9c452305dd8"]
}, Open  ]]
}, Open  ]]

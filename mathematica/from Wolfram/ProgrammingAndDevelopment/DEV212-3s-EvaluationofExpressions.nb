Cell[CellGroupData[{

Cell["Example", "Subsection",ExpressionUUID->"71d475b0-6888-4204-a642-2a976aa6c03d"],

Cell[TextData[{
 "Consider computing the sine of ",
 StyleBox["10.0", "Input"],
 ":"
}], "Text",ExpressionUUID->"81b87c55-cca7-4df0-9001-26c2b39fd09d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Sin", "[", "10.0", "]"}]], "Input",
 CellLabel->"In[14]:=",ExpressionUUID->"a208049d-aad3-45fe-b4de-b1dc3d161a68"],

Cell[BoxData[
 RowBox[{"-", "0.5440211108893698`"}]], "Output",
 CellLabel->"Out[14]=",ExpressionUUID->"f3c8a742-e3bd-4bba-893a-ae7fbe1dfe1d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Trace", "[", 
  RowBox[{
   RowBox[{"Sin", "[", "10.0", "]"}], ",", 
   RowBox[{"TraceOriginal", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"39791022-a7c5-4c47-ad9f-85416bcfead3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[

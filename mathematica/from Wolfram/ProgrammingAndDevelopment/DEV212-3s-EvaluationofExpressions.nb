Cell[CellGroupData[{

Cell["Principles of Evaluation", "Section",ExpressionUUID->"b0870a91-fe87-486c-a947-d9a5074740b5"],

Cell["\<\
Wolfram Language is at its core a pattern-matching term-rewriting system. How \
is it that terms are actually rewritten in the process of evaluation?\
\>", "Text",ExpressionUUID->"d2b0708a-f6f8-4bea-8a06-78af7612bd85"],

Cell[CellGroupData[{

Cell["Evaluation", "Subsection",ExpressionUUID->"ca11d93d-be15-47d2-8254-bae17eee12fb"],

Cell["\<\
Whenever you enter an expression, Wolfram Language evaluates the expression \
and then returns the result. \
\>", "Text",ExpressionUUID->"eb4b1986-d903-4698-9c3e-3f5c5cb2ae56"],

Cell["\<\
All operations in Wolfram Language can also be viewed in a uniform way as \
examples of evaluation:\
\>", "Text",ExpressionUUID->"00439705-9a1f-4375-9b2e-255a28151191"],

Cell["\<\
Computation 5+6\[LongRightArrow]11
Simplification x-3x+1\[LongRightArrow]1-2x
Execution x=5\[LongRightArrow]5\
\>", "Program",ExpressionUUID->"efd2254e-17d9-4cca-9362-3c65c950244d"],

Cell[BoxData[
 RowBox[{"5", "+", "6"}]], "Input",ExpressionUUID->"5015ee31-4b20-4500-848b-807ba6e09a98"],

Cell[BoxData[
 RowBox[{"x", "-", 
  RowBox[{"3", "x"}], "+", "1"}]], "Input",ExpressionUUID->"17fefcd9-c512-4127-8b86-2668490c9d8a"],

Cell[BoxData[
 RowBox[{"x", "=", "2"}]], "Input",ExpressionUUID->"826168d7-621d-4f23-9f90-7c09c1f61998"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"c", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"a", "+", "b"}], ")"}], "^", "2"}]}]}], "Input",ExpressionUUID->\
"b19a51fa-f152-4efb-b914-676b36bc2210"],

Cell["\<\
Wolfram Language is an infinite evaluation system. This means that whenever \
you enter an expression, Wolfram Language will repeatedly apply definitions \
to transform the expression until no more definitions apply.\
\>", "Text",ExpressionUUID->"e87a2d83-fccf-441b-b028-81fb0bdb6a55"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tracing an Evaluation", "Subsection",ExpressionUUID->"fe63f8db-b732-40ce-9228-1bff05cc77d7"],

Cell["\<\
When you are trying to understand what the Wolfram System is doing, it can be \
worthwhile to check intermediate steps in the evaluation process. \
\>", "Text",ExpressionUUID->"94b2fd40-9490-4177-b303-60fdb77ca932"],

Cell[TextData[{
 ButtonBox["Trace",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Trace.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Trace.html"],
 " can be used to generate a list of all expressions used in a particular \
evaluation process:"
}], "Text",ExpressionUUID->"ad5d956c-5ac1-417e-a903-43113c166a07"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Trace", "[", 
  RowBox[{"5", "+", "6"}], "]"}]], "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"2f51c7cd-56b6-4608-bced-25875412d544"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{"5", "+", "6"}],
    HoldForm], ",", 
   TagBox["11",
    HoldForm]}], "}"}]], "Output",
 CellLabel->"Out[63]=",ExpressionUUID->"f8f12dc3-3413-47a8-97a8-7396cc8741d2"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Trace", "[", 
  RowBox[{
   RowBox[{"5", "^", "3"}], "+", 
   RowBox[{"6", "^", "2"}], "+", "1"}], " ", "]"}]], "Input",
 CellLabel->"In[64]:=",ExpressionUUID->"bd1f6a25-f46f-4cd5-8444-79dea1ebe079"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     TagBox[
      SuperscriptBox["5", "3"],
      HoldForm], ",", 
     TagBox["125",
      HoldForm]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox[
      SuperscriptBox["6", "2"],
      HoldForm], ",", 
     TagBox["36",
      HoldForm]}], "}"}], ",", 
   TagBox[
    RowBox[{"125", "+", "36", "+", "1"}],
    HoldForm], ",", 
   TagBox["162",
    HoldForm]}], "}"}]], "Output",
 CellLabel->"Out[64]=",ExpressionUUID->"a3578d29-b6e7-48c5-bac2-5f6e3a96bcf7"]
}, Open  ]],

Cell[TextData[{
 "By setting the option ",
 ButtonBox["TraceOriginal",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/TraceOriginal.html"], 
    None},
  ButtonNote->"https://reference.wolfram.com/language/ref/TraceOriginal.html"],
 " to ",
 Cell[BoxData[
 "True"], "Input",ExpressionUUID->"fffa6e57-ca20-4e07-8308-493c4180c805"],
 ", you can get Trace also to look at expressions before function arguments \
have been evaluated:"
}], "Text",ExpressionUUID->"f68d45e0-0311-4fa4-9988-92055ec78614"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Trace", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"5", "^", "3"}], "+", 
    RowBox[{"6", "^", "2"}], "+", "1"}], " ", ",", 
   RowBox[{"TraceOriginal", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"b417d49a-3234-4c8d-8ea1-aaa685f8330b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{
     SuperscriptBox["5", "3"], "+", 
     SuperscriptBox["6", "2"], "+", "1"}],
    HoldForm], ",", 
   RowBox[{"{", 
    TagBox["Plus",
     HoldForm], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox[
      SuperscriptBox["5", "3"],
      HoldForm], ",", 
     RowBox[{"{", 
      TagBox["Power",
       HoldForm], "}"}], ",", 
     RowBox[{"{", 
      TagBox["5",
       HoldForm], "}"}], ",", 
     RowBox[{"{", 
      TagBox["3",
       HoldForm], "}"}], ",", 
     TagBox[
      SuperscriptBox["5", "3"],
      HoldForm], ",", 
     TagBox["125",
      HoldForm]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox[
      SuperscriptBox["6", "2"],
      HoldForm], ",", 
     RowBox[{"{", 
      TagBox["Power",
       HoldForm], "}"}], ",", 
     RowBox[{"{", 
      TagBox["6",
       HoldForm], "}"}], ",", 
     RowBox[{"{", 
      TagBox["2",
       HoldForm], "}"}], ",", 
     TagBox[
      SuperscriptBox["6", "2"],
      HoldForm], ",", 
     TagBox["36",
      HoldForm]}], "}"}], ",", 
   RowBox[{"{", 
    TagBox["1",
     HoldForm], "}"}], ",", 
   TagBox[
    RowBox[{"125", "+", "36", "+", "1"}],
    HoldForm], ",", 
   TagBox["162",
    HoldForm]}], "}"}]], "Output",
 CellLabel->"Out[65]=",ExpressionUUID->"b1788951-fd43-423b-8c1e-e0310858c7ec"]
}, Open  ]]
}, Open  ]]
}, Open  ]],


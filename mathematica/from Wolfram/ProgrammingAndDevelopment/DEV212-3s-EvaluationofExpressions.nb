}, Open  ]],

Cell["\<\
Apply transformations associated with the attributes Orderless, Listable and \
Flat.\
\>", "ItemNumbered",ExpressionUUID->"15ffe5df-cc24-4b61-918c-07416077fbec"],

Cell["Apply any definitions that you have given.", "ItemNumbered",
 FontWeight->"Bold",ExpressionUUID->"8ceeaeac-a59e-40d7-92f4-028158843f69"],


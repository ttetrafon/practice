      HoldForm], ",", 
     TagBox["Sin",
      HoldForm]}], "}"}], ",", 
   RowBox[{"{", 
    TagBox["10.`",
     HoldForm], "}"}], ",", 
   TagBox[
    RowBox[{"Sin", "[", "10.`", "]"}],
    HoldForm], ",", 
   TagBox[
    RowBox[{"-", "0.5440211108893699`"}],
    HoldForm]}], "}"}]], "Output",
 CellLabel->"Out[23]=",ExpressionUUID->"08b541b0-9695-4f16-a7e2-29963e26bd6e"]

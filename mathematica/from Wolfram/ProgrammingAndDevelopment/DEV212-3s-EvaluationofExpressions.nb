Cell[CellGroupData[{

Cell["Nonstandard Evaluation", "Subsection",ExpressionUUID->"5e02b41b-3a48-4e05-b961-af32dcfd406b"],

Cell[TextData[{
 StyleBox[ButtonBox["HoldFirst",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/HoldFirst.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/HoldFirst.html"],
  FontWeight->"Plain"],
 StyleBox[" specifies that the first argument to a function is to be \
maintained in an unevaluated form:",
  FontWeight->"Plain"]
}], "Text",ExpressionUUID->"69d76042-b02b-49d0-9734-9e13a713996b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"x", ",", "y", ",", "z"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "=", "3"}], ";"}]}], "Input",
 CellLabel->
  "In[118]:=",ExpressionUUID->"2ad91bd9-fa0e-4c13-8712-30e0d5536e4f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "f", "]"}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", 
  RowBox[{
   RowBox[{"x", "^", "2"}], ",", 
   RowBox[{"y", "^", "2"}], ",", 
   RowBox[{"z", "^", "2"}]}], "]"}]}], "Input",
 CellLabel->
  "In[122]:=",ExpressionUUID->"69d6e51c-1055-43db-b76a-813ffdaccb4d"],

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{"1", ",", "4", ",", "9"}], "]"}]], "Output",
 CellLabel->
  "Out[123]=",ExpressionUUID->"55630da7-abec-4a9e-81d8-8829424c6b4a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "f", "]"}], "\[IndentingNewLine]", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldFirst"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", 
  RowBox[{
   RowBox[{"x", "^", "2"}], ",", 
   RowBox[{"y", "^", "2"}], ",", 

 RowBox[{
  RowBox[{"a", "=", 
   RowBox[{"{", 
    RowBox[{"10", ",", "20", ",", "30", ",", "40", ",", "50"}], "}"}]}], 
  ";"}]], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"46d3b8a6-94a4-4299-bb44-88e2b0e7a7a2"],


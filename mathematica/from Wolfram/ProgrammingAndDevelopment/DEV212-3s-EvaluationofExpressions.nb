   RowBox[{"{", 
    RowBox[{"HoldAll", ",", "Protected", ",", "ReadProtected"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"HoldAll", ",", "Protected"}], "}"}]}], "}"}]], "Output",
 CellLabel->"Out[29]=",ExpressionUUID->"8f7cb291-b40c-4722-9a80-0b7958f0a53a"]
}, Open  ]],

Cell["Instead, the options expression needs to be evaluated first:", "Text",ExpressionUUID->"f09c7a95-32e7-4c00-96f0-cb11ef01b88b"],


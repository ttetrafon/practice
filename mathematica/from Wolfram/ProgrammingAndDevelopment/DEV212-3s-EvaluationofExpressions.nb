    HoldForm], ",", 
   RowBox[{"{", 
    RowBox[{
     TagBox[
      RowBox[{"funs", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}],
      HoldForm], ",", 
     RowBox[{"{", 
      TagBox["Part",
       HoldForm], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       TagBox["funs",
        HoldForm], ",", 
       TagBox[
        RowBox[{"{", 
         RowBox[{"Sin", ",", "Cos", ",", "Tan"}], "}"}],
        HoldForm]}], "}"}], ",", 
     RowBox[{"{", 
      TagBox["1",
       HoldForm], "}"}], ",", 
     TagBox[
      RowBox[{
       RowBox[{"{", 

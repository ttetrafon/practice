}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Example 3: Inject Pre-constructed Options ", "Subsection",ExpressionUUID->"92b7aa47-bee1-4a7a-b772-0dfb40c32ef6"],

Cell["\<\
The following attempt to insert options does not work for functions with the \
HoldAll attribute:\
\>", "Text",ExpressionUUID->"7f284d1e-efaa-413b-9db4-f3fab223562f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"plotOptions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"PlotPoints", "\[Rule]", "10"}], ",", 
     RowBox[{"MaxRecursion", "\[Rule]", "2"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Red"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"x", "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", "plotOptions"}], 
  "]"}]}], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"52e04d69-d636-4ff0-a00a-0a48189ee13a"],

Cell[BoxData[
 TemplateBox[{
  "Plot", "nonopt", 
   "\"Options expected (instead of \\!\\(\\*RowBox[{\\\"plotOptions\\\"}]\\)) \
beyond position \\!\\(\\*RowBox[{\\\"2\\\"}]\\) in \
\\!\\(\\*RowBox[{\\\"Plot\\\", \\\"[\\\", RowBox[{SuperscriptBox[\\\"x\\\", \
\\\"2\\\"], \\\",\\\", RowBox[{\\\"{\\\", RowBox[{\\\"x\\\", \\\",\\\", \\\"0\
\\\", \\\",\\\", \\\"10\\\"}], \\\"}\\\"}], \\\",\\\", \\\"plotOptions\\\"}], \
\\\"]\\\"}]\\). An option must be a rule or a list of rules.\"", 2, 28, 58, 
   30139584320229834644, "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellLabel->
  "During evaluation of \
In[27]:=",ExpressionUUID->"cfd298ae-afe0-4452-9041-d2baaaad2f5b"],

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   SuperscriptBox["x", "2"], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", "plotOptions"}], 
  "]"}]], "Output",
 CellLabel->"Out[28]=",ExpressionUUID->"a64f74ca-4fb3-4440-b883-125b86f8e77e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nintegrateOptions", "=", 
   RowBox[{"{", " ", 
    RowBox[{
     RowBox[{"Exclusions", "\[Rule]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{
          SuperscriptBox["x", "2"], "+", "y"}], "]"}], "\[Equal]", "0"}], 
       ")"}]}], ",", 
     RowBox[{"WorkingPrecision", "\[Rule]", "10"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   FractionBox["1", 
    SqrtBox[
     RowBox[{"Sin", "[", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", "y"}], "]"}]]], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", " ", "nintegrateOptions"}], 
  "]"}]}], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"aa3f1fa3-6603-4ef3-a2df-381c10181550"],


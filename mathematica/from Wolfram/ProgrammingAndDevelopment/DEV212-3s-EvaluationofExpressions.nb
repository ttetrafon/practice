 CellLabel->"Out[88]=",ExpressionUUID->"a151e98b-5017-4b5d-8ec0-94635c756f41"]
}, Open  ]],

Cell["\<\
If function arguments are restricted (e.g. by head), functions with the \
Orderless attribute will try to match the restrictions by reordering their \
arguments:\
\>", "Text",ExpressionUUID->"5019289c-aa12-43c3-b94f-03e2ef23daa2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"magnifyImage", ",", "Orderless"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"magnifyImage", "[", 
   RowBox[{"img_Image", ",", "fact_Integer"}], "]"}], ":=", 
  RowBox[{"Magnify", "[", 
   RowBox[{"img", ",", "fact"}], "]"}]}]}], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"bd935640-5529-4bef-8bdd-57c8a273a606"],


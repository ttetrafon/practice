Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Pick an attribute for f that would make the following relation \
true: f[f[1, 2], 3, f[f[4, f[5]]], 6, f[7]] == f[1, 2, 3, 4, 5, 6, 7]", 
             "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["Listable", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Listable allows a function to automatically \
thread over lists, which is not what is demonstrated above.", "Text", 
                    FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Listable", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell["Flat", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Flat allows all nested instances of a function \
to \"disappear,\" as seen above.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["Flat", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["Orderless", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Orderless sorts the inputs but cannot make \
the function itself \"disappear.\"", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Orderless", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell["HoldAll", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: HoldAll prevents arguments from being \
evaluated but cannot make a function \"disappear.\"", "Text", FontColor -> 
                    RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["HoldAll", "Text"]}], BaselinePosition -> {1, 1},
                   Spacings -> 0]]}, Appearance -> "Vertical", 
              BaselinePosition -> Automatic], DynamicModuleValues :> {}]}], 
          FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],

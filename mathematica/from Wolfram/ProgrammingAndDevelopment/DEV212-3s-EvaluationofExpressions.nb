    HoldForm]}], "}"}]], "Output",
 CellLabel->"Out[67]=",ExpressionUUID->"08ada8aa-392a-41d0-a4c8-363f45cc6618"]
}, Open  ]],

Cell["Now, consider the following list and evaluation:", "Text",ExpressionUUID->"6168f119-cf0a-45e8-b544-4209e665758a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"funs", "=", 
   RowBox[{"{", 
    RowBox[{"Sin", ",", "Cos", ",", "Tan"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"funs", "[", 
    RowBox[{"[", "1", "]"}], "]"}], "[", "10.0", "]"}], " "}]}], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"a839760d-2d79-4bee-bfff-e0e4d4b7cb21"],

Cell[BoxData[
 RowBox[{"-", "0.5440211108893699`"}]], "Output",
 CellLabel->"Out[22]=",ExpressionUUID->"508e102d-0fd5-457b-9dcd-8213e755a66e"]
}, Open  ]],

Cell[TextData[{
 "This produces the same result, because ",
 StyleBox["funs[[1]]", "Input"],
 " gets evaluated to ",
 StyleBox["Sin", "Input"],
 " first:"
}], "Text",ExpressionUUID->"527281c5-9d01-43c6-aa05-8a5bd2051cd9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Trace", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"funs", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "[", "10.0", "]"}], " ", ",", 
   RowBox[{"TraceOriginal", "\[Rule]", "True"}]}], "]"}]], "Input",
 CellLabel->"In[23]:=",ExpressionUUID->"e4f4898c-32d5-4909-9627-6124f51879dd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{
     RowBox[{"funs", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 

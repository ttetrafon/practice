Cell["Instead you can try ReplaceAll with a pattern:", "Text",ExpressionUUID->"74e60847-1ae3-4861-83fd-be0e67fe7b72"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fnList2", "=", 
  RowBox[{
   RowBox[{"Range", "[", "5", "]"}], "/.", 
   RowBox[{"(", 
    RowBox[{"x_Integer", "\[RuleDelayed]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"a", "[", 
         RowBox[{"[", "x", "]"}], "]"}], "*", 
        RowBox[{"Sin", "[", "#", "]"}]}], "&"}], ")"}]}], ")"}]}]}]], "Input",\

 CellLabel->"In[29]:=",ExpressionUUID->"a4d52fc9-c5f5-4420-8aeb-50650bbb4370"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"a", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], " ", 
     RowBox[{"Sin", "[", "#1", "]"}]}], "&"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], " ", 
     RowBox[{"Sin", "[", "#1", "]"}]}], "&"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], " ", 
     RowBox[{"Sin", "[", "#1", "]"}]}], "&"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], " ", 
     RowBox[{"Sin", "[", "#1", "]"}]}], "&"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], " ", 
     RowBox[{"Sin", "[", "#1", "]"}]}], "&"}]}], "}"}]], "Output",
 CellLabel->"Out[29]=",ExpressionUUID->"ab165432-888e-48c8-8fb3-0ecd5085bf0c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"fnList2", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "[", "10.0", "]"}]], "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"6b0866c0-4158-4a41-a959-d8b17e09be0d"],

Cell[BoxData[
 RowBox[{"-", "5.440211108893697`"}]], "Output",

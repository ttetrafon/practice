Cell[CellGroupData[{

Cell["\<\
Example 5: Styling for a List of Expressions inside *Plot Functions\
\>", "Subsection",ExpressionUUID->"dfd98314-82c8-4a8a-b6ca-6fabe1d7e363"],

Cell["\<\
Plot functions apply styling uniformly unless an explicit list structure is \
provided.\
\>", "Text",ExpressionUUID->"5a9b8277-446b-469b-afc3-f60d850ac9a9"],

Cell[TextData[{
 "The ",
 ButtonBox["List",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/List.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/List.html"],
 " structure is not visible to ",
 ButtonBox["Plot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Plot.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Plot.html"],
 " and ",
 ButtonBox["RegionPlot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/RegionPlot.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/RegionPlot.html"],
 ":"
}], "Text",ExpressionUUID->"ed4cb51e-2f62-4181-b980-ad152dc326da"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"x", "^", "i"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", "\"\<Expressions\>\""}]}], 
  "]"}]], "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"e19f26c4-90f8-4984-b1ca-1d8f15fa33bf"],


Cell[CellGroupData[{

Cell["Listable", "Subsection",ExpressionUUID->"a1320632-3fac-4427-8d87-96c77c2b34be"],

Cell["\<\
A function with the Listable attribute automatically threads over lists that \
appear as its arguments:\
\>", "Text",ExpressionUUID->"4cd2d170-58f5-487f-a458-fb1747a9931e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "f", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "Listable"}], "]"}]}], "Input",
 CellLabel->
  "In[125]:=",ExpressionUUID->"e4b5ee0e-80e9-4ca0-ab87-fb7057bbe2ec"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "}"}], "]"}]], "Input",
 CellLabel->
  "In[146]:=",ExpressionUUID->"759eac3d-a416-43ed-b516-55914e16bdf8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"f", "[", "a", "]"}], ",", 
   RowBox[{"f", "[", "b", "]"}], ",", 
   RowBox[{"f", "[", "c", "]"}], ",", 
   RowBox[{"f", "[", "d", "]"}]}], "}"}]], "Output",
 CellLabel->
  "Out[146]=",ExpressionUUID->"a395a63c-83f5-49d8-8e83-07d8d0e1653b"]
}, Open  ]],

Cell["Many built-in functions have the Listable attribute:", "Text",ExpressionUUID->"4efc2792-51cc-48c8-b3c3-0f85025bff22"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Sin", "[", 
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "c"}], "}"}], "]"}]], "Input",
 CellLabel->
  "In[128]:=",ExpressionUUID->"dcf050c0-48fc-4009-a3e4-7fa884b6072c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Sin", "[", "a", "]"}], ",", 
   RowBox[{"Sin", "[", "b", "]"}], ",", 
   RowBox[{"Sin", "[", "c", "]"}]}], "}"}]], "Output",
 CellLabel->
  "Out[128]=",ExpressionUUID->"799724a1-244b-4ff9-976b-0a263c42c5db"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Attributes", "[", "Sin", "]"}]], "Input",
 CellLabel->
  "In[148]:=",ExpressionUUID->"0b141f2e-41fc-41a8-8a42-a5ea6be51d92"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"Listable", ",", "NumericFunction", ",", "Protected"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[148]=",ExpressionUUID->"94ed8a8d-471e-4022-bcf3-af72c24707ee"]
}, Open  ]],

Cell["Over a two-dimensional list:", "Text",ExpressionUUID->"8fc67c7d-f011-482c-9dff-0580bb7c0cdc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"p", ",", "q", ",", "r"}], "}"}]}], "}"}], "]"}]], "Input",
 CellLabel->
  "In[150]:=",ExpressionUUID->"9301e9c1-6a0f-4b45-928d-97e00480ad4a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "a", "]"}], ",", 
     RowBox[{"f", "[", "b", "]"}], ",", 
     RowBox[{"f", "[", "c", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "p", "]"}], ",", 
     RowBox[{"f", "[", "q", "]"}], ",", 
     RowBox[{"f", "[", "r", "]"}]}], "}"}]}], "}"}]], "Output",
 CellLabel->

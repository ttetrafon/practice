Cell[CellGroupData[{

Cell["Overriding Hold* Attributes", "Section",ExpressionUUID->"044241ad-4b00-4c13-a123-bb4232c7e2a3"],

Cell["\<\
Sometimes you need to force evaluation of arguments in functions with Hold* \
attributes:\
\>", "Text",ExpressionUUID->"86a69747-62bd-410a-bc0b-44de079fe6ad"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"f", ",", "x"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldAll"}], "]"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"839f8f60-f9f5-417d-8757-3ab9c811c7d6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", "x", "]"}]}], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"9b39c17f-1204-4210-b3de-8c787c599802"],

Cell[BoxData[
 RowBox[{"f", "[", "x", "]"}]], "Output",
 CellLabel->"Out[4]=",ExpressionUUID->"e619c37c-667e-46f1-ba69-87b402c807ed"]
}, Open  ]],

Cell[TextData[{
 "Method 1: You can force the evaluation using ",

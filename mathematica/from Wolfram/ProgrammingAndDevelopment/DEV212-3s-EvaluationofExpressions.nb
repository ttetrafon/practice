Cell[BoxData[
 RowBox[{"f", "[", "10", "]"}]], "Output",
 CellLabel->"Out[8]=",ExpressionUUID->"dda556d4-e6be-4804-893b-6d409d2b37de"]
}, Open  ]],

Cell["Method 4: You can use ReplaceAll with an injector pattern:", "Text",ExpressionUUID->"5b7dc996-14ba-4b83-be04-471da8db89ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"10", "/.", 
  RowBox[{"num_", ":>", 
   RowBox[{"f", "[", "num", "]"}]}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"75c9ec61-d975-472a-9310-925ba9eea35c"],

Cell[BoxData[
 RowBox[{"f", "[", "10", "]"}]], "Output",
 CellLabel->"Out[9]=",ExpressionUUID->"51eddccf-0690-4992-be50-73f05d142ab9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Example 1: Build a Pure Function from an Existing Expression", \
"Subsection",ExpressionUUID->"c28ebfd3-456d-484e-9f19-2fe42ae6d67d"],

Cell["\<\
The following approach for defining a pure function does not work:\
\>", "Text",ExpressionUUID->"b4df3560-f9c9-4377-b10c-e044a76f77b9"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "expr"}], "]"}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"249d0d21-5861-427c-be0f-0c533c2f0f81"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"expr", "=", 
  RowBox[{
   RowBox[{"x", "^", "2"}], "+", 
   RowBox[{"2", " ", "x"}], "+", "1"}]}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"38a5af69-6205-4e99-99de-81032daa383b"],

Cell[BoxData[
 RowBox[{"1", "+", 
  RowBox[{"2", " ", "x"}], "+", 
  SuperscriptBox["x", "2"]}]], "Output",
 CellLabel->"Out[12]=",ExpressionUUID->"71b88eeb-8dc5-4ede-9253-2b5389285473"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Function", "[", 
   RowBox[{
    RowBox[{"{", "x", "}"}], ",", "expr"}], "]"}], "[", "5", "]"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"72ff5587-a5a1-4cc4-a1d3-959f5a5c3433"],

Cell[BoxData[
 RowBox[{"1", "+", 
  RowBox[{"2", " ", "x"}], "+", 
  SuperscriptBox["x", "2"]}]], "Output",
 CellLabel->"Out[13]=",ExpressionUUID->"8b62d3a5-6c45-4a02-b208-4de5d6c4d809"]
}, Open  ]],


  RowBox[{"ClearAll", "[", "f", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"f", ",", "HoldAll"}], "]"}], ";"}]}], "Input",
 CellLabel->"In[71]:=",ExpressionUUID->"79370abf-3e16-4807-aff2-7f9613dde2d0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 

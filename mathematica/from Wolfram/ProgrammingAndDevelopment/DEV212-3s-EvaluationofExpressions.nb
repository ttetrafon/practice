Cell[CellGroupData[{

Cell["Example 4: Symbolic Evaluations inside *Plot Functions", "Subsection",ExpressionUUID->"fabd617b-a59f-4d92-b064-00540312b976"],

Cell["\<\
Various plot functions evaluate the function after substituting iterator \
values. So you may run into the following issues:\
\>", "Text",ExpressionUUID->"b4be848b-52d3-40b5-ae17-d7b59457108d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", "x"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"9241afe8-b992-400e-8ab7-188cb703f939"],

Cell[BoxData[
 TemplateBox[{
  "General", "ivar", 
   "\"\\!\\(\\*RowBox[{\\\"0.0002042857142857143`\\\"}]\\) is not a valid \
variable.\"", 2, 30, 59, 30139584320229834644, "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellLabel->
  "During evaluation of \
In[30]:=",ExpressionUUID->"e0f6431e-605a-4f21-90bf-ffebe863e119"],


Cell[TextData[{
 "With can be thought of as a generalization of the ReplaceAll ( /. ) \
operator. It takes every occurrence of the symbol ",
 Cell[BoxData[
 "c"], "Input",ExpressionUUID->"1864d852-fc51-4933-b733-5d77a71b7e47"],
 " in the body and replaces it with the value ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"299792458", 
     RowBox[{
      "\"m\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", "\"s\""}], 
     "meters per second", 
     FractionBox["\"Meters\"", "\"Seconds\""]},
    "Quantity"], TraditionalForm]],ExpressionUUID->
  "b81bbb7c-0ec0-4ab6-bc8a-48cf02aedfc5"],
 "."
}], "Text",ExpressionUUID->"55fe012b-58fd-401a-a7f5-75f94f300b74"],

Cell["\<\
With does not generate any new symbols. It does all the replacements before \
the body evaluates, and by that time no \"constant symbols\" are present; all \
of them have been replaced explicitly with their values.\
\>", "Text",ExpressionUUID->"bd9e9996-8b33-411f-ab1c-5ae47dd977f3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Need for Local Values of Global Names", "Section",ExpressionUUID->"f99c797c-ceba-4a5f-87c6-f7359bac730d"],

Cell[CellGroupData[{

Cell["Block: Localizing Values", "Subsection",ExpressionUUID->"d08e5d1f-a6ae-42c5-8d0e-095acde7499b"],

Cell[TextData[{
 ButtonBox["Block",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Block.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Block.html"],
 " uses a different method of scoping called dynamic scoping. In dynamic \
scoping, an entirely new symbol with a new name is not created. ",
 StyleBox["Only the value of the global symbol is localized and temporarily \
changed",
  Background->RGBColor[1, 1, 0]],
 ", and once the localizing body of code is executed, the global value is \
restored. So you could say that its effects are a little less local than \
those of lexical scoping constructs."
}], "Text",ExpressionUUID->"3da76eab-6990-4e5d-aea6-e29d60d804b0"],

Cell[TextData[{
 "One example of using Block is to temporarily change the value of program \
variables like ",
 ButtonBox["$RecursionLimit",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/$RecursionLimit.html"], 
    None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/$RecursionLimit.html"],
 ". This is typically used for temporarily resetting the value of the \
recursion limit, in case a deeply recursive computation gets you into trouble:"
}], "Text",ExpressionUUID->"a7271ea4-32c7-48f2-8a43-2f09dfdb91c4"],

Cell[BoxData["$RecursionLimit"], "Input",
 CellLabel->
  "In[304]:=",ExpressionUUID->"f2421fd2-a2d2-43ad-a5bc-75fb49f0f72a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Clear", "[", "a", "]"}], ";", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"$RecursionLimit", "=", "20"}], "}"}], ",", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{"a", "=", " ", 
       RowBox[{"a", "+", "1"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "200"}], "}"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[305]:=",ExpressionUUID->"4cc89a80-04c3-4d69-a11a-d4818809cae4"],

Cell[TextData[{
 "Internally, Block is the mechanism that localizes iterators for built-in \
functions like Table, Do, Sum and ",
 ButtonBox["Product",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Product.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Product.html"],
 ". "
}], "Text",ExpressionUUID->"63037335-f24f-48d3-a05d-2b587dad7bc3"]
}, Open  ]],


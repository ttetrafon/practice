Cell[CellGroupData[{

Cell["Which one should you use?", "Subsubsection",ExpressionUUID->"42c09593-4bd9-4df1-a370-57e41614ad79"],

Cell["\<\
If all you need is a local constant or a local value for a global variable, \
With or Block may be faster than Module:\
\>", "Text",ExpressionUUID->"c1a5151f-1651-4663-b008-8c1e7d56b943"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", "=", "2."}], "}"}], ",", 
    RowBox[{"1", "/", "x"}]}], "]"}], "//", "RepeatedTiming"}]], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"b0456ca1-4cd1-4717-aedd-5195657a5472"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.7949962615966797`*^-6", ",", "0.5`"}], "}"}]], "Output",
 CellLabel->"Out[31]=",ExpressionUUID->"ca50682c-4723-459c-9594-a8e0392bbf6c"]
}, Open  ]],


 RowBox[{"{", 
  RowBox[{"HoldAll", ",", "Protected"}], "}"}]], "Output",
 CellLabel->
  "Out[225]=",ExpressionUUID->"ad96c434-8cbf-4ad2-aeca-4ab100df891b"]
}, Open  ]],

Cell["\<\
The iterator in the second argument is not evaluated and thus can be scoped:\
\>", "Text",ExpressionUUID->"d2cc5457-f06b-41ce-9e0e-2787d00fbc8a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"i", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"i", "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{"i", ",", "1", ",", "5"}], "}"}]}], "]"}]}], "Input",
 CellLabel->
  "In[226]:=",ExpressionUUID->"9634604e-2651-48a0-9d76-c1d255051928"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "9", ",", "16", ",", "25"}], "}"}]], "Output",
 CellLabel->
  "Out[227]=",ExpressionUUID->"fec914f3-ae8b-4deb-9273-2e4531559f7d"]
}, Open  ]],

Cell["If you allow the evaluation of the first argument:", "Text",ExpressionUUID->"e7a36bd0-22af-4c6e-baaf-553b571dd52e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAttributes", "[", 
   RowBox[{"Table", ",", "HoldAll"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"Table", ",", "HoldRest"}], "]"}], ";"}]}], "Input",
 CellLabel->
  "In[232]:=",ExpressionUUID->"02350c07-bd9a-4c9f-8954-c111b9570b0f"],


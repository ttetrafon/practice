Cell[CellGroupData[{

Cell["The Need for Local Variables", "Section",ExpressionUUID->"d34e4ae8-180b-40e3-83a9-e36444f8c6bb"],

Cell[TextData[{
 "The default scope for symbols is ",
 StyleBox["global",
  FontSlant->"Italic"],
 ". Every time you use a name like ",
 StyleBox["x", "Input"],
 ", Wolfram Language normally assumes that you are referring to the same \
object. "
}], "Text",ExpressionUUID->"c3533628-8823-47bb-ae12-c4d3b6672689"],

Cell[TextData[{
 "Sometimes you want to use the name ",
 StyleBox["x", "Input"],
 " to refer to two quite different variables in two different pieces of code. \
In this case, you need the ",
 StyleBox["x", "Input"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "in each program to be treated as a local variable."
}], "Text",ExpressionUUID->"7a31298c-effd-4785-aa2f-c08607331961"],

Cell[CellGroupData[{

Cell["Module: Localizing Names", "Subsection",ExpressionUUID->"8b6dd1af-1362-481c-a620-7643da6abbd1"],

Cell[TextData[{
 ButtonBox["Module",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Module.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Module.html"],
 " uses what is known as lexical scoping. This means the name of the symbol \
is localized to keep it from clashing with any other variable of the same \
name in the global context. This is done by changing the name to have a \
unique value inside the Module. "
}], "Text",ExpressionUUID->"afeacd04-dac7-45ca-91d2-d7f6c12215d9"],

Cell["\<\
Define two variables in the global context. Specify two variables of the same \
name to also be local to a module:\
\>", "Text",ExpressionUUID->"1d74ef02-54be-4485-8c00-1a65669afd79"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"r", ",", "s"}], "}"}], "=", 
   RowBox[{"{", 
    RowBox[{"100", ",", "200"}], "}"}]}], ";"}]], "Input",
 CellLabel->
  "In[295]:=",ExpressionUUID->"e0445a2c-fd09-4f7b-8d5d-68505375e55a"],

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"r", ",", "s"}], "}"}], ",", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"{", 
      RowBox[{"r", ",", "s"}], "}"}], "]"}], ";", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", "s"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], ";", 
    RowBox[{"{", 
     RowBox[{"r", ",", "s"}], "}"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[296]:=",ExpressionUUID->"931a5024-e82e-4860-b839-af2be537e1a4"],

Cell["The global definitions have not changed:", "Text",ExpressionUUID->"6fecc809-158b-4e43-a50e-59bc13a1016c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"r", ",", "s"}], "}"}]], "Input",
 CellLabel->
  "In[297]:=",ExpressionUUID->"4cfd02bd-23a3-4608-a835-7d3e253874c9"],

Cell[TextData[{
 "Evaluating the module multiple times reveals that the names for ",
 Cell[BoxData[
 "r"], "Input",ExpressionUUID->"efc624e5-14c3-47c3-b201-28c1c1ddb021"],
 " and ",
 Cell[BoxData[
 "s"], "Input",ExpressionUUID->"8dd2fcf6-5326-4ac7-8ef5-159fcff7166e"],
 " are changed each time the Module is evaluated, avoiding the problem of an \
incorrect value getting into the calculations. Symbols used in a Module are \
deleted when the module calculations are complete. "
}], "Text",ExpressionUUID->"c0309855-d9cf-4759-ba55-6a619b611a7d"],

Cell["A typical use of Module would be in defining a function. ", "Text",ExpressionUUID->"89e6d755-e216-4826-bfe6-4b7706a618dd"],

Cell[TextData[{
 "Here is an example of a function to find the greatest common divisor (GCD) \
of two integers using the Euclidean algorithm, which uses the ",
 StyleBox["local variables",
  Background->RGBColor[1, 1, 0]],
 " ",
 Cell[BoxData[
 "m"], "Input",ExpressionUUID->"8f51a330-7f6a-4043-82ff-6f5737c2cb4d"],
 " and ",
 Cell[BoxData[
 "n"], "Input",ExpressionUUID->"aebd89ef-54b5-411a-88ed-d72dffa5c733"],
 ":"
}], "Text",ExpressionUUID->"f061859e-6132-4170-ab48-db64b9a1a06c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"gcd", "[", 
   RowBox[{"m0_", ",", "n0_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", "=", "m0"}], ",", 
      RowBox[{"n", "=", "n0"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"n", "\[NotEqual]", "0"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"m", ",", "n"}], "}"}], "=", 
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"Mod", "[", 
           RowBox[{"m", ",", "n"}], "]"}]}], "}"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", "m"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",\

 CellLabel->
  "In[298]:=",ExpressionUUID->"1e8624de-26d4-4c98-925c-cc47f4246c2d"],

Cell[BoxData[
 RowBox[{"gcd", "[", 
  RowBox[{"270", ",", "192"}], "]"}]], "Input",
 CellLabel->
  "In[299]:=",ExpressionUUID->"f161780c-d684-4546-81c8-dc1e2910fabf"],

Cell[TextData[{
 "Note that ",
 Cell[BoxData[
 "m"], "Input",ExpressionUUID->"b4764226-b597-423d-8cc1-cf697a61354a"],
 " and ",
 Cell[BoxData[
 "n"], "Input",ExpressionUUID->"5fac9d28-c765-4e66-ab79-8ac83c2c3eeb"],
 " have no values in the \"Global`\" context:"
}], "Text",ExpressionUUID->"20fc2254-3d37-476f-9ff5-84e8e5bc223f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"m", ",", "n"}], "}"}]], "Input",
 CellLabel->
  "In[300]:=",ExpressionUUID->"7606b2e1-3485-4514-bb7a-569c3b4dda73"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Need for Local Constants", "Section",ExpressionUUID->"1f2e4cd3-ed42-4bac-b6db-4d2ec76ecd8e"],

Cell[CellGroupData[{

Cell["With: Localizing Constants", "Subsection",ExpressionUUID->"456119dc-9e9e-41b7-ad4c-72199d5efba3"],

Cell[TextData[{
 "If all that is needed is local constants, i.e. ",
 StyleBox["variables whose values never change within the body of the local \
code",
  Background->RGBColor[1, 1, 0]],
 ", it is better to use ",
 ButtonBox["With",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/With.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/With.html"],
 ", another lexical scoping construct. Values are assigned to the local \
constants as they are declared in the list that immediately follows the \
function head. "
}], "Text",ExpressionUUID->"c27eb394-bdeb-49fc-870c-58537d9a8289"],

Cell[TextData[{
 "Define a global value for ",
 Cell[BoxData[
 "c"], "Input",ExpressionUUID->"6d9dd73a-5122-403e-84f0-14a467ae92a0"],
 ":"
}], "Text",ExpressionUUID->"770f02a5-64b0-409f-aa5d-91ee40cf2a87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"c", "=", "42"}], ";"}]], "Input",
 CellLabel->
  "In[166]:=",ExpressionUUID->"46664fe4-7a6d-45e2-bf0a-2987f20e8f96"],

Cell[TextData[{
 "In a simple function, redefine ",
 Cell[BoxData[
 "c"], "Input",ExpressionUUID->"a781bf15-964a-4b0b-9205-d3bd1b1748c8"],
 " to hold a constant value only for the scope of the function:"
}], "Text",ExpressionUUID->"5cae6815-09ee-43f8-93f4-4a19188ffb69"],

Cell[BoxData[
 RowBox[{
  RowBox[{"e", "[", "m_", "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c", "=", 
      TemplateBox[{"299792458", 
        RowBox[{
         "\"m\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", 
          "\"s\""}], "meters per second", 
        FractionBox["\"Meters\"", "\"Seconds\""]},
       "Quantity"]}], "}"}], ",", 
    RowBox[{"m", " ", 
     RowBox[{"c", "^", "2"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[171]:=",ExpressionUUID->"ef158182-35bd-4614-ab3e-57d6bbbe15f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"e", "[", "1", "]"}]], "Input",
 CellLabel->
  "In[172]:=",ExpressionUUID->"3f84b1b1-e2ee-4c0f-9419-7d1b2bfb70ee"],

Cell[BoxData[
 TemplateBox[{"89875517873681764", 
   RowBox[{
     SuperscriptBox["\"m\"", "2"], "\[NegativeMediumSpace]", "\"/\"", 
     "\[InvisibleSpace]", 
     SuperscriptBox["\"s\"", "2"]}], "meters squared per second squared", 
   FractionBox[
    SuperscriptBox["\"Meters\"", "2"], 
    SuperscriptBox["\"Seconds\"", "2"]]},
  "Quantity"]], "Output",
 CellLabel->
  "Out[172]=",ExpressionUUID->"43d976cb-ba81-4bd5-8e47-b9eb71ae32fb"]
}, Open  ]],


                  If[WolframUTools`Private`qState === 2, {
                    TextCell["Block", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Block is best used for temporarily replacing \
the value of some extant symbol\[LongDash]this applies to $MaxPrecision. \
After the cell is done evaluating, $MaxPrecision will return to its prior \
value.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["Block", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["With", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: With is good for setting local constants but \
should not be used to modify the value of extant global constants. Functions \
that implicitly rely upon $MaxPrecision will not check this newly named \
constant when performing computations.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["With", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]]}, Appearance -> "Vertical", 

Cell[CellGroupData[{

Cell["Constructs That Provide Automatic Scoping", "Section",ExpressionUUID->"4e106f8c-c2cd-479e-ad21-7d54b9a3b3ac"],

Cell["\<\
The flexibility of Wolfram Language's symbolic architecture is reflected in \
its rich collection of carefully defined constructs for localization and \
modularization. Multiple forms of scoping allow for more elegant, readable \
and efficient programs.\
\>", "Text",ExpressionUUID->"4b0c3c44-7196-4413-b985-e19805c7f1d9"],

Cell[CellGroupData[{

Cell["Automatic Name Scoping", "Subsection",
 CellID->34103915,ExpressionUUID->"7c4038cc-d893-433d-8b4a-456eb2dc3a0f"],

Cell[TextData[{
 "The Wolfram Language function Function makes it possible to create a pure \
function with automatically scoped formal variables. (The shorthand form of \
Function uses ",
 ButtonBox["Slot",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Slot.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Slot.html"],
 " (",
 StyleBox["#", "Input"],
 "), which obviates the need for variable scoping at all.)"
}], "Text",
 CellID->215987777,ExpressionUUID->"74b60b8d-c1fd-486e-a3ea-02b725a9e023"],

Cell[TextData[{
 ButtonBox["RuleDelayed",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/RuleDelayed.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/RuleDelayed.html"],
 " (",
 StyleBox["\[RuleDelayed]", "Input"],
 ") and SetDelayed (",
 StyleBox[":=", "Input"],
 ") make it possible to use named pattern variables that are automatically \
scoped."
}], "Text",
 CellID->361364205,ExpressionUUID->"82698b23-cec6-409f-8e67-ff3fb5e66033"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Automatic Value Scoping", "Subsection",
 CellID->61991050,ExpressionUUID->"3a86cc5e-6055-4d13-8f26-7a672171f11e"],

Cell["\<\
Iterator variables are automatically scoped in functions like Table:\
\>", "Text",
 CellID->184149195,ExpressionUUID->"85d9d086-ddda-4c52-bedc-e53b9eeffc8d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"i", "=", "\"\<Hello\>\""}], ";", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"i", "+", "1"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "5"}], "}"}]}], "]"}], ",", "i"}], "}"}]}]], "Input",\

 CellLabel->
  "In[156]:=",ExpressionUUID->"eee9a336-c81e-4336-92bf-500266169df3"],

Cell[TextData[{
 "The scoping within the Table expression is indicated by the color of the \
iterator ",
 Cell[BoxData[
 "i"], "Input",ExpressionUUID->"3dc93793-494c-4859-a951-f45eab8b8de7"],
 "."
}], "Text",ExpressionUUID->"63c53b12-ae05-4c5b-b6eb-5523e05c5b26"],

Cell[TextData[{
 "Some other functions that provide automatic scoping are ",
 ButtonBox["Do",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Do.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Do.html"],
 ", ",
 ButtonBox["Sum",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Sum.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Sum.html"],
 ", Plot, ",
 ButtonBox["Plot3D",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Plot3D.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Plot3D.html"],
 " and ",
 ButtonBox["NDSolve",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/NDSolve.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/NDSolve.html"],
 ". You will notice the same coloring in automatically scoped variables used \
within these functions."
}], "Text",ExpressionUUID->"c323e459-61e8-4ff5-901e-598aa3c50a90"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Attributes for Automatic Scoping", "Subsection",ExpressionUUID->"cae4baa0-9850-4ba2-b420-b4aabee9f10e"],

Cell["\<\
Various built-in functions heavily rely on Hold* attributes for effective \
evaluation.\
\>", "Text",ExpressionUUID->"f3aab185-b0f5-418e-a462-0921ee781662"],

Cell[CellGroupData[{

Cell["SetDelayed without its HoldAll attribute works like Set", \
"Subsubsection",ExpressionUUID->"28509937-ad74-4e2b-bc10-c03370e8a415"],

Cell[TextData[{
 "Use delayed assignment for ",
 Cell[BoxData[
 "f"], "Input",ExpressionUUID->"6b9b2648-0322-4703-a408-6313cf3e6c60"],
 ":"
}], "Text",ExpressionUUID->"a72e295f-3733-44b8-ac02-a21887a4dfcf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "f", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"f", ":=", 
  RowBox[{"x", "^", "2"}]}]}], "Input",
 CellLabel->
  "In[243]:=",ExpressionUUID->"60461d4c-95de-47c6-aee0-46deb042140c"],

Cell[TextData[{
 ButtonBox["SetDelayed",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/SetDelayed.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/SetDelayed.html"],
 " behaves as expected:"
}], "Text",ExpressionUUID->"d0ff0f52-62e9-4b08-9f3e-ff75c2a49b4c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "2"}], 
  ";"}], "\[IndentingNewLine]", "f", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "3"}], ";"}], "\[IndentingNewLine]", "f"}], "Input",
 CellLabel->
  "In[246]:=",ExpressionUUID->"13e04ca6-d300-4dd6-8ed6-32dd9a446a50"],

Cell[BoxData["4"], "Output",
 CellLabel->
  "Out[247]=",ExpressionUUID->"dd43e9cf-9699-44bc-ba49-28b3f02bf46d"],

Cell[BoxData["9"], "Output",
 CellLabel->
  "Out[249]=",ExpressionUUID->"beb7a4b0-0002-40e1-ae07-c838e12f682a"]
}, Open  ]],


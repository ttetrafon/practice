Notebook[{

Cell[CellGroupData[{
Cell["Supplement: Working with Data", "Subtitle",ExpressionUUID->"6216d3e6-e4ad-41ed-b314-02204666a68a"],

Cell[CellGroupData[{

Cell["Learning Objectives", "Section",ExpressionUUID->"dbea5887-3b33-4dc2-9fcb-f0376e5ee8ad"],

Cell[CellGroupData[{

Cell["Working with Multiple Data Files", "Subsection",ExpressionUUID->"52ff05c7-a1a1-4319-82aa-cb06b604602c"],

Cell["Learn to merge multiple files containing interrelated data", "Item",ExpressionUUID->"6ac6d8a1-d37a-428f-9d91-4ea55987ba51"],

Cell["Query complex datasets with simple commands", "Item",ExpressionUUID->"a6ce294f-bdf0-438d-bc9a-8c951e41c89f"],

Cell["\<\
Create rich data visualizations and interfaces in a few lines of code\
\>", "Item",ExpressionUUID->"fb96184e-105a-44bc-9fd9-420aa5b4484e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Merging Multiple CSV Files", "Section",ExpressionUUID->"7dba0038-dc67-49e3-a196-e64ce43b829f"],

Cell["It is quite simple to merge multiple files, e.g. CSVs.", "Text",ExpressionUUID->"6b6a7d90-2374-4d08-8f5a-8fc020eb3172"],

Cell["Get the path to the folder containing the data:", "CodeText",ExpressionUUID->"f52d7797-8ebf-40ac-96c8-93f3aa71e67b"],

Cell[BoxData[
 RowBox[{"folder", "=", 
  RowBox[{"FileNameJoin", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<data\>\""}], "}"}], 
   "]"}]}]], "Input",
 CellLabel->"In[93]:=",ExpressionUUID->"0ea6d4ad-6e02-463b-b0c4-79a31f84c25c"],

Cell["\<\
Get the file names that start with \"2021-\" and end with \".csv\" from this \
folder:\
\>", "CodeText",ExpressionUUID->"59a51fd2-d1b0-4b8d-b5f7-f1eff2b77ef2"],

Cell[BoxData[
 RowBox[{"names", "=", 
  RowBox[{"FileNameTake", "/@", 
   RowBox[{"FileNames", "[", 
    RowBox[{"\"\<2021-*.csv\>\"", ",", "folder"}], "]"}]}]}]], "Input",
 CellLabel->"In[94]:=",ExpressionUUID->"11409f76-b17b-4df8-965f-84c6c23d2573"],

Cell["\<\
Before moving on, it is a good idea to examine one of these files in order to \
understand its structure.\
\>", "Text",ExpressionUUID->"bb11d3ea-0ee9-4006-92e1-d1dd8fe9ff5b"],

Cell["Import a random CSV from the list:", "CodeText",ExpressionUUID->"ea48b461-ce46-4640-81ef-eb1fef6844a5"],

Cell[BoxData[
 RowBox[{"Import", "[", 
  RowBox[{"FileNameJoin", "[", 
   RowBox[{"{", 
    RowBox[{"folder", ",", 
     RowBox[{"RandomChoice", "[", "names", "]"}]}], "}"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[111]:=",ExpressionUUID->"c0d0db1c-3782-4621-b334-6ce816757186"],

Cell["\<\
It looks like this file has three columns described by a header row.\
\>", "Text",ExpressionUUID->"653a5503-fc75-428a-ba41-04ba37dfdffe"],

Cell["Check that this is the case for all of the files:", "CodeText",ExpressionUUID->"8cba955a-1d9d-4739-8a39-ba35c543c04b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"First", "@", 
     RowBox[{"Import", "[", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"folder", ",", "#"}], "}"}], "]"}], "]"}]}], "&"}], "/@", 
   "names"}], "//", "Union"}]], "Input",
 CellLabel->
  "In[114]:=",ExpressionUUID->"69557ad8-4a4b-47f0-bc0a-6cd17acd2a06"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"\<\"from\"\>", ",", "\<\"to\"\>", ",", "\<\"amount\"\>"}], "}"}], 
  "}"}]], "Output",
 CellLabel->
  "Out[114]=",ExpressionUUID->"2fec85e2-8449-4002-802a-7e1b9b6c0fcd"]
}, Open  ]],

Cell["\<\
The next thing to notice is that the amounts given are written using periods \
for the thousands separators and commas for the decimal \
separators\[LongDash]this will need to be addressed.\
\>", "Text",ExpressionUUID->"de117acb-7f64-49d9-9411-caeec3b05c09"],

Cell["\<\
There are many ways to proceed. One such way is to write a function that will \
take any given file name and return a list of associations where the headers \
point to the values, which will also have been reformatted to match the \
number formatting used in Wolfram Language.\
\>", "Text",ExpressionUUID->"edac9349-fa2f-48d7-b8b3-3f7344953d35"],

Cell["Write such a function:", "CodeText",ExpressionUUID->"5e0be779-6421-4452-a2b4-07bdbf0c2fc2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataReshaper", "[", "fileName_String", "]"}], ":=", 
  RowBox[{"MapAt", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToExpression", "@", 
      RowBox[{"StringReplace", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<.\>\"", "->", "\"\<\>\""}], ",", 
          RowBox[{"\"\<,\>\"", "->", "\"\<.\>\""}]}], "}"}]}], "]"}]}], "&"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{"With", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"csvData", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"folder", ",", "fileName"}], "}"}], "]"}], "]"}]}], "}"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"AssociationThread", "[", 
         RowBox[{
          RowBox[{"First", "@", "csvData"}], "->", "#"}], "]"}], "&"}], "/@", 
       
       RowBox[{"Rest", "@", "csvData"}]}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"All", ",", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[131]:=",ExpressionUUID->"58f41b1c-50b3-4b29-a160-438c8ff0f168"],

Cell["Test it:", "CodeText",ExpressionUUID->"f1de415b-8a3d-4d98-a36a-ae1d0f3a5f55"],

Cell[BoxData[
 RowBox[{"dataReshaper", "[", 
  RowBox[{"names", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[132]:=",ExpressionUUID->"1495a814-6b55-4908-ac4c-4b69bc6b7b1f"],

Cell[TextData[{
 "There is one more thing that this function could do that would be useful: \
namely, each of the files corresponds to a different date, but that \
information currently exists ",
 StyleBox["only",
  FontSlant->"Italic"],
 " in the file name and not in the data itself."
}], "Text",ExpressionUUID->"c11ee8b7-1f73-4c57-b0ef-2b892c2bac89"],

Cell[TextData[{
 "Update ",
 StyleBox["dataReshaper", "Input"],
 " to convert the file name to a date object and include it with each data \
point:"
}], "CodeText",ExpressionUUID->"dbe2cd85-f4d3-4e79-8095-6740ea6b5efc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dataReshaperDated", "[", "fileName_String", "]"}], ":=", 
  RowBox[{"MapAt", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ToExpression", "@", 
      RowBox[{"StringReplace", "[", 
       RowBox[{"#", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<.\>\"", "->", "\"\<\>\""}], ",", 
          RowBox[{"\"\<,\>\"", "->", "\"\<.\>\""}]}], "}"}]}], "]"}]}], "&"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{"With", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"csvData", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"folder", ",", "fileName"}], "}"}], "]"}], "]"}]}], "}"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Append", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"AssociationThread", "[", 
           RowBox[{
            RowBox[{"First", "@", "csvData"}], "->", "#"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<date\>\"", "->", 
           RowBox[{"DateObject", "[", 
            RowBox[{"FileBaseName", "@", "fileName"}], "]"}]}]}], "]"}], 
        "&"}], "\[IndentingNewLine]", "/@", 
       RowBox[{"Rest", "@", "csvData"}]}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"All", ",", "3"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[133]:=",ExpressionUUID->"4de0a581-03a0-4b54-9116-73fed9990d74"],

Cell["Test:", "CodeText",ExpressionUUID->"454d8ddc-9279-4a1d-999a-4f1de9007fdb"],

Cell[BoxData[
 RowBox[{"dataReshaperDated", "[", 
  RowBox[{"names", "[", 
   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[134]:=",ExpressionUUID->"0da67d26-1697-471f-822c-36c2b657a3c3"],

Cell["\<\
Everything is now in good shape and the data from all of the CSVs can be \
safely merged.\
\>", "Text",ExpressionUUID->"f9a5f1ba-307b-4bf9-9391-0d17e7d71666"],

Cell[TextData[{
 "Map ",
 Cell[BoxData[
 "dataReshaperDated"], "Input",ExpressionUUID->
  "4b0d5c1d-563e-4528-a5a5-344c60b21a4b"],
 " across all of the file names, then apply ",
 ButtonBox["Flatten",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Flatten.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Flatten.html"],
 " to the result to create one list of associations:"
}], "CodeText",ExpressionUUID->"f9afee6a-7db7-4212-b58b-6ecf6202babd"],

Cell[BoxData[
 RowBox[{"transactions", "=", 
  RowBox[{"Flatten", "[", 
   RowBox[{"dataReshaperDated", "/@", "names"}], "]"}]}]], "Input",
 CellLabel->
  "In[296]:=",ExpressionUUID->"076225a8-79cf-4cea-9ddf-dcab55412904"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Merging All Data", "Section",ExpressionUUID->"1d9f636f-913b-4315-a565-1ae21642ead2"],

Cell["\<\
With all of the transactions merged together, you can do a few basic things.\
\>", "Text",ExpressionUUID->"e38d34dc-27e6-4bbb-913e-5144b40db8c4"],

Cell["See who initiated the most outgoing transfers:", "CodeText",ExpressionUUID->"d625e988-242c-497a-944a-ed5a65a6e4d3"],

Cell[BoxData[
 RowBox[{"ReverseSort", "@", 
  RowBox[{"Counts", "@", 
   RowBox[{"transactions", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "\"\<from\>\""}], "]"}], "]"}]}]}]], "Input",
 CellLabel->
  "In[148]:=",ExpressionUUID->"8a777cb3-88b8-4801-ae5c-995b2c01dd8d"],

Cell["Compute the total amount transferred by date:", "CodeText",ExpressionUUID->"2b8ea784-300c-4719-8c78-054388b10bf8"],

Cell[BoxData[
 RowBox[{"DateListPlot", "[", 
  RowBox[{"Total", "/@", 
   RowBox[{
    RowBox[{"GroupBy", "[", 
     RowBox[{"transactions", ",", 
      RowBox[{"#date", "&"}]}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "All", ",", "\"\<amount\>\""}], "]"}], "]"}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[153]:=",ExpressionUUID->"c65498b7-bf15-4722-8441-b17abaff0c7b"],

Cell["Create a graph structure of who transferred money to whom:", "CodeText",ExpressionUUID->"731a3260-8f5c-4874-af2f-9ad7e02fb3be"],

Cell[BoxData[
 RowBox[{"Graph", "[", 
  RowBox[{"Rule", "@@@", 
   RowBox[{"Values", "@", 
    RowBox[{"transactions", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<from\>\"", ",", "\"\<to\>\""}], "}"}]}], "]"}], 
     "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[157]:=",ExpressionUUID->"04c0aaa0-c61c-480f-ba3d-68c29007f586"],

Cell["\<\
This is rather neat! However, there is another CSV in the data folder that \
has not yet been used.\
\>", "Text",ExpressionUUID->"d4843e38-eeff-44b1-b535-c331b8fbf3a8"],

Cell["Find this file:", "CodeText",ExpressionUUID->"7b5974b5-f20e-4cac-bb2f-ae104197aa38"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Complement", "[", 
  RowBox[{
   RowBox[{"FileNameTake", "/@", 
    RowBox[{"FileNames", "[", 
     RowBox[{"\"\<*.csv\>\"", ",", "folder"}], "]"}]}], ",", "names"}], 
  "]"}]], "Input",
 CellLabel->
  "In[163]:=",ExpressionUUID->"8fdbcb7a-8c99-42a0-920b-8728e8902b0f"],

Cell[BoxData[
 RowBox[{"{", "\<\"persons.csv\"\>", "}"}]], "Output",
 CellLabel->
  "Out[163]=",ExpressionUUID->"ec5abd65-0e40-44b1-a9ad-d8e956f1ed0d"]
}, Open  ]],

Cell["Check what is in this CSV:", "CodeText",ExpressionUUID->"77cde1bf-f526-45cf-bca4-b908b8166fbd"],

Cell[BoxData[
 RowBox[{"Import", "[", 
  RowBox[{"FileNameJoin", "[", 
   RowBox[{"{", 
    RowBox[{"folder", ",", " ", "\"\<persons.csv\>\""}], "}"}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[164]:=",ExpressionUUID->"81d19f2e-e853-486c-bd21-26e91b610b9d"],

Cell["\<\
This file contains information about the people represented by the integers \
in the \"from\" and \"to\" fields of the transaction CSVs. You can now \
combine the full list of transactions with the information from this file to \
get a more detailed picture of the data.\
\>", "Text",ExpressionUUID->"52399757-cfdb-4be3-9b04-1ef24cb488e1"],

Cell["\<\
Before doing this combining, you should reshape this nested list as a list of \
associations using the base code that was used on the prior CSVs:\
\>", "Text",ExpressionUUID->"8afc3e21-d6ce-4d02-a4d4-624a3b7197f1"],

Cell[BoxData[
 RowBox[{"personData", "=", 
  RowBox[{"With", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"csvData", "=", 
      RowBox[{"Import", "[", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"folder", ",", "\"\<persons.csv\>\""}], "}"}], "]"}], 
       "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"AssociationThread", "[", 
       RowBox[{
        RowBox[{"First", "@", "csvData"}], "->", "#"}], "]"}], "&"}], "/@", 
     RowBox[{"Rest", "@", "csvData"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[297]:=",ExpressionUUID->"b0e49ca4-9995-4570-943e-b5eac6f1cae0"],

Cell["\<\
This will let you associate each transaction with the relevant parties. It \
would be nice to add extra fields that specify each person's incoming and \
outgoing transactions, now that you know who's who.\
\>", "Text",ExpressionUUID->"85846a3c-2b67-4038-8292-84c11566020c"],

Cell["\<\
Write a function that will get the transactions associated with (\"to\" or \
\"from\") a particular ID number:\
\>", "CodeText",ExpressionUUID->"f3ced27c-f563-4dd7-a51a-48c6375dcb75"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getTransactions", "[", 
   RowBox[{"id_", ",", "key_"}], "]"}], ":=", 
  RowBox[{"Select", "[", 
   RowBox[{"transactions", ",", 
    RowBox[{
     RowBox[{"id", "\[Equal]", 
      RowBox[{"#", "[", "key", "]"}]}], "&"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[298]:=",ExpressionUUID->"0ab0fabf-1019-4add-a413-385aa2ff817d"],

Cell["Test:", "CodeText",ExpressionUUID->"cdc68cf6-5743-4e01-9f30-489afa440612"],

Cell[BoxData[
 RowBox[{"getTransactions", "[", 
  RowBox[{"3", ",", "\"\<from\>\""}], "]"}]], "Input",
 CellLabel->
  "In[196]:=",ExpressionUUID->"8cd8cc89-8223-407f-bc20-3b1615883002"],

Cell[TextData[{
 "Go to each entry in ",
 Cell[BoxData[
 "personData"], "Input",ExpressionUUID->
  "6c0d5558-5d7c-4f0d-b234-d5d683d0a7d6"],
 " and add an \"outgoing\" and \"incoming\" field for the relevant \
transactions:"
}], "CodeText",ExpressionUUID->"977e312e-9db3-4d19-8cc3-2dbe35b345db"],

Cell[BoxData[
 RowBox[{"transactionsFull", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Append", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<outgoing\>\"", "->", 
         RowBox[{"getTransactions", "[", 
          RowBox[{"#id", ",", "\"\<from\>\""}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<incoming\>\"", "->", 
         RowBox[{"getTransactions", "[", 
          RowBox[{"#id", ",", "\"\<to\>\""}], "]"}]}]}], 
       "\[IndentingNewLine]", "}"}]}], "]"}], "&"}], "/@", 
   "personData"}]}]], "Input",
 CellLabel->
  "In[299]:=",ExpressionUUID->"bb1ba0ab-ebca-44a3-9772-6506db4c85d6"],

Cell["\<\
One final step might be to replace the ID numbers with the names in these new \
\"outgoing\" and \"incoming\" transaction fields.\
\>", "Text",ExpressionUUID->"9973a5b7-54df-402f-ae7d-fd2d533e4c30"],

Cell["\<\
This can be done by first creating a mapping between ID numbers and names:\
\>", "CodeText",ExpressionUUID->"64473b6b-ecc6-497c-a6c9-1232c5c685b6"],

Cell[BoxData[
 RowBox[{"idToName", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"#id", "->", "#fullname"}], "&"}], "/@", 
   "personData"}]}]], "Input",
 CellLabel->
  "In[300]:=",ExpressionUUID->"752c80b1-3ed5-4edb-872b-0f12369b4520"],

Cell["\<\
This mapping can then be applied in the step where you append the \
\"outgoing\" and \"incoming\" fields:\
\>", "CodeText",ExpressionUUID->"d92ef16a-4ddf-471c-ab42-19407cd8a9b2"],

Cell[BoxData[
 RowBox[{"transactionsFullNamed", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Append", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<outgoing\>\"", " ", "->", 
         RowBox[{"ReplaceAt", "[", 
          RowBox[{
           RowBox[{"getTransactions", "[", 
            RowBox[{"#id", ",", "\"\<from\>\""}], "]"}], ",", "idToName", ",", 
           RowBox[{"{", 
            RowBox[{"All", ",", 
             RowBox[{"1", ";;", "2"}]}], "}"}]}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<incoming\>\"", " ", "->", " ", 
         RowBox[{"ReplaceAt", "[", 
          RowBox[{
           RowBox[{"getTransactions", "[", 
            RowBox[{"#id", ",", "\"\<to\>\""}], "]"}], ",", "idToName", ",", 
           RowBox[{"{", 
            RowBox[{"All", ",", 
             RowBox[{"1", ";;", "2"}]}], "}"}]}], "]"}]}]}], 
       "\[IndentingNewLine]", "}"}]}], "]"}], "&"}], "/@", 
   "personData"}]}]], "Input",
 CellLabel->
  "In[301]:=",ExpressionUUID->"df39a828-7944-4e82-9980-04d009dc0c28"],

Cell["Check your final dataset:", "Text",ExpressionUUID->"0818a197-ba32-462a-94c8-19626c98ee54"],

Cell[BoxData[
 RowBox[{"Dataset", "[", "transactionsFullNamed", "]"}]], "Input",
 CellLabel->
  "In[195]:=",ExpressionUUID->"1b4b0fe5-ebe4-433c-b182-1cd3b7c90fbd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Querying the Data", "Section",ExpressionUUID->"050a96df-a82e-4503-827f-dd8d6128fc74"],

Cell["\<\
With the dataset fully now fully fleshed out, you can query it in more \
meaningful ways.\
\>", "Text",ExpressionUUID->"334b0572-e00d-4466-b8d3-217713f7c3f8"],

Cell["Check all of the information for ID number 1:", "CodeText",ExpressionUUID->"f7d0390f-a1c1-4f81-b611-be846c444e46"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Dataset", "[", "transactionsFullNamed", "]"}], "[", 
  RowBox[{"[", "1", "]"}], "]"}]], "Input",
 CellLabel->
  "In[199]:=",ExpressionUUID->"8b68fae2-6e21-4cad-88f6-d61b9459db9f"],

Cell["Check all of Deanna's outgoing transaction amounts:", "CodeText",ExpressionUUID->"5f3543fd-7bab-469e-8679-aa045f9a0038"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Dataset", "[", "transactionsFullNamed", "]"}], "[", 
  RowBox[{"[", 
   RowBox[{"1", ",", "\"\<outgoing\>\"", ",", "All", ",", "\"\<amount\>\""}], 
   "]"}], "]"}]], "Input",ExpressionUUID->"51317a53-3a5f-4160-80a6-\
87b9d5d136ea"],

Cell["See all of Megan Campbell's information:", "CodeText",ExpressionUUID->"70f2b0a3-f2a7-4727-bb5a-347318ddc199"],

Cell[BoxData[
 RowBox[{"Dataset", "@", 
  RowBox[{"Select", "[", 
   RowBox[{"transactionsFullNamed", ",", 
    RowBox[{
     RowBox[{"#fullname", "==", "\"\<Megan Campbell\>\""}], "&"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[208]:=",ExpressionUUID->"ae6d9fff-95ec-46ab-8918-c39d9d44f8d6"],

Cell["Count the number of transactions by date:", "CodeText",ExpressionUUID->"8ea8e1be-c7a4-4caa-9128-019d9421eea2"],

Cell[BoxData[
 RowBox[{"ReverseSort", "@", 
  RowBox[{"CountsBy", "[", 
   RowBox[{
    RowBox[{"Flatten", "@", 
     RowBox[{"transactionsFullNamed", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<incoming\>\""}], "]"}], "]"}]}], ",", 
    RowBox[{"#date", "&"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[342]:=",ExpressionUUID->"948b9450-ab15-4152-a3ff-3e84fd4de78c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Visualizing Data", "Section",ExpressionUUID->"36a539ff-d018-4414-af0b-ca32c6ff87ce"],

Cell["Visualizations are fairly simple to make as well.", "Text",ExpressionUUID->"751325cf-7bb4-4ca9-aa43-701e76fe6406"],

Cell["\<\
Make a chart of the total outgoing transaction amounts labeled by name:\
\>", "CodeText",ExpressionUUID->"2b62f38a-b786-4352-aacc-b38eaa41f6d3"],

Cell[BoxData[
 RowBox[{"PieChart", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Total", "[", 
      RowBox[{"#", "[", 
       RowBox[{"[", 
        RowBox[{"\"\<outgoing\>\"", ",", "All", ",", "\"\<amount\>\""}], 
        "]"}], "]"}], "]"}], "&"}], "/@", "transactionsFullNamed"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"ChartLabels", "\[Rule]", 
    RowBox[{"transactionsFullNamed", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "\"\<fullname\>\""}], "]"}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->
  "In[205]:=",ExpressionUUID->"3d82e5bd-d361-4be9-acbb-2b4d5e19d3ca"],

Cell["Recreate the graph from before, now with appropriate names:", "CodeText",ExpressionUUID->"7ac39927-7886-497d-ab7f-d5dd2661aa32"],

Cell[BoxData[
 RowBox[{"Graph", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"#from", "->", "#to"}], "&"}], "/@", 
    RowBox[{"Flatten", "[", 
     RowBox[{"transactionsFullNamed", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "\"\<incoming\>\""}], "]"}], "]"}], "]"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"VertexLabels", "->", 
    RowBox[{"Placed", "[", 
     RowBox[{"\"\<Name\>\"", ",", "Tooltip"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[617]:=",ExpressionUUID->"83b86a6b-1ab8-4320-8985-ee0c8686f684"],

Cell["Check graph structures by date:", "CodeText",ExpressionUUID->"26c92fb6-495f-40e3-b886-f87672f1ff88"],

Cell[BoxData[
 RowBox[{
  RowBox[{"graphByDate", "[", "date_DateObject", "]"}], ":=", 
  RowBox[{"Graph", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"#from", "->", "#to"}], "&"}], "/@", 
     RowBox[{"Select", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{"transactionsFullNamed", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "\"\<incoming\>\""}], "]"}], "]"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"#date", "==", "date"}], "&"}]}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"VertexLabels", "->", 
     RowBox[{"Placed", "[", 
      RowBox[{"\"\<Name\>\"", ",", "Tooltip"}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[618]:=",ExpressionUUID->"4fe32274-219d-41f9-86af-0eee09aeb1d3"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"graphByDate", "[", "date", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"date", ",", 
     RowBox[{"Sort", "[", 
      RowBox[{
       RowBox[{"DateObject", "@*", "FileBaseName"}], "/@", "names"}], "]"}]}],
     "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[619]:=",ExpressionUUID->"5616ccbe-052f-40a7-bfc2-0f2b79efa3e8"]
}, Open  ]],


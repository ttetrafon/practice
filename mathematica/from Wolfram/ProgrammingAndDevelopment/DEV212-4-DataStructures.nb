 " and more) provide their output in association format."
}], "Text",ExpressionUUID->"28e54b2c-ab07-4eaa-96af-e17c747e209e"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Association of entities and their properties", \
"Subsubsection"]], "Subsubsection",ExpressionUUID->"4ee18fff-8a4a-46b5-a5a1-\
8bc16c7cd7f2"],

Cell[TextData[{
 ButtonBox["EntityValue",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/EntityValue.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/EntityValue.html"],
 " can also return associations by using the third argument."
}], "Text",ExpressionUUID->"8d31d603-7faf-4f13-ac2a-57ddfb0a6609"],

Cell["\<\
Association of entities and their corresponding values for a specific \
property:\
\>", "Text",ExpressionUUID->"f62ef3f2-e6b7-4095-82cf-1ae30705d41c"],

Cell[BoxData[
 RowBox[{"EntityValue", "[", "\[IndentingNewLine]", "\t", 
  RowBox[{
   RowBox[{"EntityClass", "[", 
    RowBox[{"\"\<Country\>\"", ",", "\"\<NATO\>\""}], "]"}], ",", 
   "\[IndentingNewLine]", "\t", "\"\<Population\>\"", ",", 
   "\[IndentingNewLine]", "\t", "\"\<EntityAssociation\>\""}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[69]:=",ExpressionUUID->"4b215d87-ee11-4386-a086-63dae77ec219"],

Cell["\<\
Association of the values of the different properties of a particular entity:\
\
\>", "Text",ExpressionUUID->"9cbb7913-be40-4e30-9353-663cc17a22e4"],

Cell[BoxData[
 RowBox[{"EntityValue", "[", 
  RowBox[{
   TemplateBox[{"\"Six Flags New England\"", 
     RowBox[{"Entity", "[", 
       RowBox[{
        "\"AmusementPark\"", ",", "\"SixFlagsNewEngland::HampdenMA::1840\""}],
        "]"}], "\"Entity[\\\"AmusementPark\\\", \
\\\"SixFlagsNewEngland::HampdenMA::1840\\\"]\"", "\"amusement park\""},
    "Entity"], ",", " ", "\"\<PropertyAssociation\>\""}], "]"}]], "Input",
 CellLabel->
  "In[133]:=",ExpressionUUID->"3b8cdeec-05cc-476e-b62f-fd490979bb9a"],

Cell["\<\
An association in which the specified entities are keys, and values are a \
nested association of properties and entity-property values:\
\>", "Text",ExpressionUUID->"69f979db-e639-4111-8c68-2e010586805e"],

Cell[BoxData[
 RowBox[{"EntityValue", "[", "\[IndentingNewLine]", "\t", 
  RowBox[{
   RowBox[{"EntityClass", "[", 
    RowBox[{"\"\<Country\>\"", ",", " ", "\"\<GroupOf8\>\""}], "]"}], ",", 
   "\n", "\t", 
   RowBox[{"{", 
    RowBox[{
    "\"\<Population\>\"", ",", " ", "\"\<MedianAge\>\"", ",", " ", 
     "\"\<LandArea\>\""}], "}"}], ",", "\n", "\t", 
   "\"\<EntityPropertyAssociation\>\""}], "\n", "]"}]], "Input",
 CellLabel->
  "In[134]:=",ExpressionUUID->"b8900a1c-30b1-444a-a7ab-ea50591b8247"],

Cell[BoxData[
 RowBox[{"EntityValue", "[", "\[IndentingNewLine]", "\t", 
  RowBox[{
   RowBox[{"EntityClass", "[", 
    RowBox[{"\"\<Country\>\"", ",", " ", "\"\<GroupOf8\>\""}], "]"}], ",", 
   "\n", "\t", 
   RowBox[{"{", 
    RowBox[{
    "\"\<Population\>\"", ",", " ", "\"\<MedianAge\>\"", ",", " ", 
     "\"\<LandArea\>\""}], "}"}], ",", "\n", "\t", "\"\<Dataset\>\""}], "\n", 
  "]"}]], "Input",
 CellLabel->
  "In[233]:=",ExpressionUUID->"5502a954-c788-400d-92a0-117fc117d777"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Useful Functions to Work with Associations", "Subsection",ExpressionUUID->"dbfa7ca4-626b-47dc-a024-f52a28fbff83"],

Cell[TextData[{
 "All the keys and values of an association can be quickly listed with ",
 ButtonBox["Keys",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Keys.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Keys.html"],
 " or ",
 ButtonBox["Values",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Values.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Values.html"],
 ":"
}], "CodeText",ExpressionUUID->"5382a9fa-b5c7-408a-a760-eb5d7fe97a09"],

Cell[BoxData[
 RowBox[{"Keys", "[", "assoc", "]"}]], "Input",
 CellTags->"Keys",
 CellLabel->
  "In[228]:=",ExpressionUUID->"358dd85f-f87d-4e4e-b93a-704fe571939f"],

Cell[BoxData[
 RowBox[{"Values", "[", "assoc", "]"}]], "Input",
 CellTags->"Values",
 CellLabel->
  "In[229]:=",ExpressionUUID->"edf7344b-54f3-4318-adf0-96061046401b"],

Cell["\<\
Many functions automatically and seamlessly work on the values of an \
association, keeping or removing the keys as appropriate:\
\>", "Text",ExpressionUUID->"a9065a9a-9880-470b-bbf4-2bb5fe32b055"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Sort", "[", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"a", "->", "3"}], ",", 
    RowBox[{"b", "->", "2"}], ",", 
    RowBox[{"c", "->", "1"}]}], "|>"}], "]"}]], "Input",
 CellLabel->"In[89]:=",ExpressionUUID->"13d6c935-30f1-4981-ba62-0302d7b4cbd2"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"c", "\[Rule]", "1"}], ",", 
   RowBox[{"b", "\[Rule]", "2"}], ",", 
   RowBox[{"a", "\[Rule]", "3"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[89]=",ExpressionUUID->"6eea36cc-97c4-44c6-bdb3-3201c7463ab9"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Mean", "[", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"a", "->", "3"}], ",", 
    RowBox[{"b", "->", "2"}], ",", 
    RowBox[{"c", "->", "1"}]}], "|>"}], "]"}]], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"50057c01-3f6b-4b5f-88b7-c2d383399278"],

Cell[BoxData["2"], "Output",
 CellLabel->"Out[90]=",ExpressionUUID->"659a2abe-92c4-4546-8b17-630d178dad7c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Total", "[", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"a", "->", "3"}], ",", 
    RowBox[{"b", "->", "2"}], ",", 
    RowBox[{"c", "->", "1"}]}], "|>"}], "]"}]], "Input",
 CellLabel->"In[91]:=",ExpressionUUID->"deca2feb-d007-4194-be14-dd9a23196534"],

Cell[BoxData["6"], "Output",
 CellLabel->"Out[91]=",ExpressionUUID->"2886b159-c6b1-4998-920f-b334d3cb1eda"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"#", "+", "1"}], "&"}], "/@", 
  RowBox[{"<|", 
   RowBox[{
    RowBox[{"a", "->", "3"}], ",", 
    RowBox[{"b", "->", "2"}], ",", 
    RowBox[{"c", "->", "1"}]}], "|>"}]}]], "Input",
 CellLabel->"In[92]:=",ExpressionUUID->"4a12e49c-becb-4554-9310-d98211430764"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"a", "\[Rule]", "4"}], ",", 
   RowBox[{"b", "\[Rule]", "3"}], ",", 
   RowBox[{"c", "\[Rule]", "2"}]}], "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[92]=",ExpressionUUID->"01d0fb66-ac38-49f5-8090-652e267148c7"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Structured Data: Datasets", "Section",ExpressionUUID->"1df522ae-de1c-4e39-a542-78c272d5775d"],

Cell[TextData[{
 "A ",
 ButtonBox["Dataset",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Dataset.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Dataset.html"],
 " is used to represent hierarchical structured data. "
}], "Text",ExpressionUUID->"d61348f5-38de-48c7-b7b9-11e6e674ce4e"],

Cell["\<\
Here is a simple example of a dataset, formed from a nested association:\
\>", "CodeText",ExpressionUUID->"328049c1-4f10-4e65-b90c-65e8869ab7fd"],

Cell[BoxData[
 RowBox[{"data", "=", 
  RowBox[{"Dataset", "[", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<a\>\"", "\[Rule]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<x\>\"", "\[Rule]", "1"}], ",", 
        RowBox[{"\"\<y\>\"", "\[Rule]", "2"}], ",", 
        RowBox[{"\"\<z\>\"", "\[Rule]", "3"}]}], "|>"}]}], ",", 
     RowBox[{"\"\<b\>\"", "\[Rule]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<x\>\"", "\[Rule]", "5"}], ",", 
        RowBox[{"\"\<y\>\"", "\[Rule]", "10"}], ",", 
        RowBox[{"\"\<z\>\"", "\[Rule]", "7"}]}], "|>"}]}]}], "|>"}], 
   "]"}]}]], "Input",
 CellLabel->"In[63]:=",ExpressionUUID->"d9f387ee-bbcb-4446-862d-648537388e95"],

Cell["\<\
Elements from individual rows and columns can be accessed as follows:\
\>", "CodeText",ExpressionUUID->"3df65dcf-9e7b-4d8b-bfee-a7a2a3145c5e"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"\"\<b\>\"", ",", "\"\<z\>\""}], "]"}]], "Input",ExpressionUUID->\
"6e7a2487-68f2-40a6-bca3-e37a8cb8fe03"],

Cell[BoxData[
 RowBox[{"data", "[", "\"\<b\>\"", "]"}]], "Input",ExpressionUUID->"bd045d99-5a47-47be-8e49-80005aede07c"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"All", ",", "\"\<z\>\""}], "]"}]], "Input",ExpressionUUID->\
"e04e6ffe-4fbd-4782-82f6-dbc037bd6c37"],

Cell["\<\
Anywhere you can ask for a part, you can also give a function that will be \
applied to all parts at that level: \
\>", "CodeText",ExpressionUUID->"72712a2c-6fcc-496f-8ac9-90e5dd32ec11"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"All", ",", "PieChart"}], "]"}]], "Input",
 CellLabel->"In[52]:=",ExpressionUUID->"ad595098-775c-4dbb-b5e8-c6217d45c952"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"Total", ",", "\"\<x\>\""}], "]"}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"722f0802-8e2d-4e6c-b545-c84c5a40c519"],

Cell["You can use any function, not just built-in ones:", "CodeText",ExpressionUUID->"86a4e692-aa46-479e-97e0-777c36958975"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"Select", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Total", "@", "#"}], "<", "7"}], "&"}], "]"}], "]"}]], "Input",
 CellLabel->"In[64]:=",ExpressionUUID->"b23c8d2b-1c9c-4a83-8e62-1f9fd0dfc33e"],

Cell[BoxData[
 RowBox[{"data", "[", 
  RowBox[{"All", ",", 
   RowBox[{
    RowBox[{"Cases", "[", 
     RowBox[{"#", ",", 
      RowBox[{"_", "?", "OddQ"}]}], "]"}], "&"}]}], "]"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"ee040023-e18a-47a8-a4f6-59d6d9e3bfde"],

Cell["\<\
Wolfram Language also provides built-in data in the form of datasets:\
\>", "CodeText",ExpressionUUID->"ac42194c-b12b-4de8-83bf-fd809196108a"],

Cell[BoxData[
 RowBox[{"planets", "=", 
  RowBox[{"ExampleData", "[", 
   RowBox[{"{", 
    RowBox[{"\"\<Dataset\>\"", ",", "\"\<Planets\>\""}], "}"}], 
   "]"}]}]], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"d3e6eafa-4ac7-46b2-bfb4-74ff721a04d7"],

Cell["\<\
You can use the Dataset wrapper on the various types of data structures in \
this notebook, not just nested associations.\
\>", "CodeText",ExpressionUUID->"226ccf25-e451-4259-bb89-7ab3e63dea4c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Possible Data Representations", "Section",ExpressionUUID->"b77e6177-a64d-44da-851b-51ab750e5e31"],

Cell[CellGroupData[{

Cell["Nested Lists", "Subsection",ExpressionUUID->"63ba677a-45a6-4e93-a4f2-f833a4699fcc"],

Cell["The data can be presented as a nested list:", "Text",ExpressionUUID->"ebf1801d-5f32-41c1-b964-9dced67840d0"],

Cell[BoxData[
 RowBox[{"{", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "1", ",", "\"\<Deanna Gardner\>\"", ",", "\"\<F\>\"", ",", "30", ",", 
     "57", ",", "167", ",", "\"\<ECP-8254\>\""}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
    "2", ",", "\"\<Brian Rodriguez\>\"", ",", "\"\<M\>\"", ",", "42", ",", 
     "71", ",", "174", ",", "\"\<50BH7\>\""}], "}"}]}], "\[IndentingNewLine]",
   "}"}]], "Input",ExpressionUUID->"0a3324cc-2de3-46af-a774-4f8b227fd27f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Lists of Associations", "Subsection",ExpressionUUID->"5e53a24c-5459-4eb4-bde6-e99518dea9af"],

Cell["The data can be presented as a list of associations:", "Text",ExpressionUUID->"a7954be7-145f-4c8a-a9ce-13f47e8a2004"],

Cell[BoxData[
 RowBox[{"{", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\"\<sex\>\"", "\[Rule]", "\"\<F\>\""}], ",", 
     RowBox[{"\"\<full_name\>\"", "\[Rule]", "\"\<Deanna Gardner\>\""}]}], 
    "\[RightAssociation]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\"\<sex\>\"", "\[Rule]", "\"\<M\>\""}], ",", 
     RowBox[{"\"\<full_name\>\"", "\[Rule]", "\"\<Brian Rodriguez\>\""}]}], 
    "\[RightAssociation]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\"\<sex\>\"", "\[Rule]", "\"\<F\>\""}], ",", 
     RowBox[{"\"\<full_name\>\"", "\[Rule]", "\"\<Rebecca Burke\>\""}]}], 
    "\[RightAssociation]"}]}], "\[IndentingNewLine]", "}"}]], "Input",Expressi\
onUUID->"719d62cc-7cec-4fa8-8df0-641134ade414"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Nested Associations", "Subsection",ExpressionUUID->"eb2bbfc2-2470-44a3-8e92-437de78b7e18"],

Cell["The data can be presented as a nested association:", "Text",ExpressionUUID->"853a88c3-d550-417f-8b8c-d9d2ce2d8ae8"],

Cell[BoxData[
 RowBox[{"<|", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\"\<Deanna Gardner\>\"", "->", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Sex\>\"", "->", "\"\<F\>\""}], ",", 
      RowBox[{"\"\<Age\>\"", "->", "30"}], ",", 
      RowBox[{"\"\<license_plate\>\"", "->", "\"\<ECP-8254\>\""}]}], "|>"}]}],
    ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<Brian Rodriguez\>\"", "->", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Sex\>\"", "->", "\"\<M\>\""}], ",", 
      RowBox[{"\"\<Age\>\"", "->", "42"}], ",", 
      RowBox[{"\"\<license_plate\>\"", "->", "\"\<50BH7\>\""}]}], "|>"}]}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<Rebecca Burke\>\"", "->", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Sex\>\"", "->", "\"\<F\>\""}], ",", 
      RowBox[{"\"\<Age\>\"", "->", "37"}], ",", 
      RowBox[{"\"\<license_plate\>\"", "->", "\"\<77-QED\>\""}]}], "|>"}]}]}],
   "\[IndentingNewLine]", "|>"}]], "Input",ExpressionUUID->"0d7d9193-4e27-\
4dde-813e-2d58501dac75"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Reshaping Data ", "Section",ExpressionUUID->"7e4d03e4-2332-48bd-aeff-a6d8b62380d6"],

Cell["\<\
This section will explore the data files available in the \"data\" folder and \
try wrangling the data into the structures described above in order to get a \
feel for their differences.\
\>", "Text",ExpressionUUID->"7f07a8a2-55a4-4934-b323-bf49fc2e2cae"],

Cell["Inspect the data files available in the data folder:", "Text",ExpressionUUID->"e94b8e07-4766-4af4-a33b-83a6a3b6326f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"folder", "=", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<data\>\""}], "}"}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"d14fed4b-6bd4-4125-abbe-\
0de3a36f78f6"],

Cell["Import the data:", "Text",ExpressionUUID->"fe056f7a-353f-4340-87e9-1d1af2393beb"],

Cell[BoxData[
 RowBox[{"data", "=", 
  RowBox[{"Import", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<data\>\"", ",", 
      "  ", "\"\<persons.csv\>\""}], "}"}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[40]:=",ExpressionUUID->"0c4124c7-797e-48ed-82bb-da463283ac60"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Nested Lists", "Section",ExpressionUUID->"b1552b03-f11c-4ca9-ac52-cbaea0daf924"],

Cell["\<\
The imported CSV file is already presented as a list of lists:\
\>", "Text",ExpressionUUID->"86b71186-675d-413d-8792-9fc19876531f"],

Cell[BoxData["data"], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"bea3b201-10e3-4be9-84b3-9dd7d3651bae"],

Cell["Separate the header row from the actual data rows:", "Text",ExpressionUUID->"e39cb16a-4a03-4a20-b0f0-6e82a4ea0878"],

Cell[BoxData[
 RowBox[{"headers", "=", 
  RowBox[{"First", "@", "data"}]}]], "Input",ExpressionUUID->"b95ab81c-afd5-\
4b7b-b117-498649935675"],

Cell[BoxData[
 RowBox[{"samples", "=", 
  RowBox[{"Rest", "@", "data"}]}]], "Input",ExpressionUUID->"4ca53569-6f7e-\
4e42-8566-4547dbb2ad6c"],

Cell["\<\
To get the names of all the people in the dataset, just fetch the second \
column:\
\>", "Text",ExpressionUUID->"4b6b591d-a209-4d99-935c-b5819835b02c"],

Cell[BoxData[
 RowBox[{"samples", "[", 
  RowBox[{"[", 
   RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]], "Input",
 CellLabel->"In[57]:=",ExpressionUUID->"b7be0dab-c4e2-498c-9a78-813f3a06ddd3"],

Cell[TextData[{
 "To match the name of the person with their age, pick the second and fifth \
columns and apply a ",
 ButtonBox["Rule",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Rule.html"], None},
  ButtonNote->"https://reference.wolfram.com/language/ref/Rule.html"],
 " on each pair:"
}], "Text",ExpressionUUID->"d8126d8d-bfce-45e6-8704-95fe3467a9f6"],

Cell[BoxData[
 RowBox[{"Rule", "@@@", 
  RowBox[{"samples", "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", " ", 
     RowBox[{"{", 
      RowBox[{"2", ",", " ", "5"}], "}"}]}], "]"}], "]"}]}]], "Input",Expressi\
onUUID->"1bb77bdb-d638-431e-998b-5ce2aec88b17"],

Cell[CellGroupData[{

Cell["Advantages", "Subsection",ExpressionUUID->"b823c79d-6362-4f58-991b-eb051c217f69"],

Cell["Maintains a small size even for large datasets.", "Item",ExpressionUUID->"9781c973-7125-4707-ab3c-79a06a8e66f0"],

Cell["Provides a reasonably efficient structure.", "Item",ExpressionUUID->"d6686e70-daae-4931-8c32-ba94ec4443b1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Disadvantages", "Subsection",ExpressionUUID->"640b46fe-e87f-4f66-8ac9-5bd7875f5eb6"],

Cell["The code to access the data is \"unreadable.\"", "Item",ExpressionUUID->"d94449b1-50db-4512-9407-9042d463120d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Lists of Associations ", "Section",ExpressionUUID->"6e1d5fe6-736c-4a1d-96e8-7a940332deef"],

Cell["\<\
The imported lists of lists and the headers and samples extracted from them \
can be wrangled into a list of associations:\
\>", "Text",ExpressionUUID->"25de332b-64aa-40a3-a6d6-ac3f7da237bf"],

Cell[BoxData[
 RowBox[{"grouped", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"AssociationThread", "[", 
     RowBox[{"headers", "\[Rule]", "#"}], "]"}], "&"}], "/@", " ", 
   "samples"}]}]], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"90830540-3586-4089-a09a-28def2c820ae"],

Cell[BoxData[
 RowBox[{"grouped", "[", 
  RowBox[{"[", 
   RowBox[{"All", ",", "\"\<fullname\>\""}], "]"}], "]"}]], "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"fc97101a-e8e4-45f6-bc33-4509e93fd1e6"],

Cell[BoxData[
 RowBox[{"grouped", "[", 
  RowBox[{"[", 
   RowBox[{"All", ",", 
    RowBox[{"{", 
     RowBox[{"\"\<fullname\>\"", ",", "\"\<age\>\""}], "}"}]}], "]"}], 
  "]"}]], "Input",
 CellLabel->"In[75]:=",ExpressionUUID->"908c0d40-c70d-40b9-b985-f90e0121b060"],

Cell[CellGroupData[{

Cell["Advantages", "Subsection",ExpressionUUID->"7a0b99c5-d8d4-45c5-bbfd-e13cb22bfecd"],

Cell["You can still think in terms of lists of lists.", "Item",ExpressionUUID->"1985b0bf-403c-4823-87e8-8ede10067011"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Disadvantages", "Subsection",ExpressionUUID->"1190ecff-9668-4c48-aa17-56a9f7f99a77"],

Cell["Can be memory inefficient for very large datasets.", "Item",ExpressionUUID->"803bd794-d0e2-45f2-ae20-4f000628cf54"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wrap in a Dataset", "Subsection",ExpressionUUID->"faf7291b-2ee9-4fbe-8e8e-7b45abbb08ba"],

Cell[BoxData[
 RowBox[{"ds", "=", 
  RowBox[{"Dataset", "[", "grouped", "]"}]}]], "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"c51ed5bf-d162-4bf5-9c20-25c5c6532342"],

Cell[BoxData[
 RowBox[{"ds", "[", 
  RowBox[{"All", ",", "\"\<age\>\""}], "]"}]], "Input",
 CellLabel->"In[51]:=",ExpressionUUID->"10184902-771b-4042-acea-86d8cb44192c"],

Cell[BoxData[
 RowBox[{"ds", "[", 
  RowBox[{"Histogram", ",", "\"\<age\>\""}], "]"}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"6aed1396-6e5d-4a75-a597-73d6b650f1dd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rollback to Nested List", "Subsection",ExpressionUUID->"5f790782-cd08-4887-b0a0-4c031d2ee27e"],

Cell[BoxData[
 RowBox[{"Prepend", "[", 
  RowBox[{
   RowBox[{"Values", "@", "grouped"}], ",", 
   RowBox[{"Keys", "@", 
    RowBox[{"grouped", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[61]:=",ExpressionUUID->"482aa226-3d8e-4b18-b43f-4e157a5d425e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Nested Associations ", "Section",ExpressionUUID->"e7a6ce27-8898-4d51-9640-3fea7f9aa2ff"],

Cell["\<\
The data from the CSV can be converted from a nested list into a nested \
association in a few different ways. You need to decide what the primary key \
will be\[LongDash]in this case, using each person's name is a reasonable \
choice:\
\>", "Text",ExpressionUUID->"e2cd8247-9790-4cd4-8a69-e5e6aad1e2e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"names", "=", 
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"2", ";;"}], ",", "2"}], "]"}], "]"}]}], ";"}]], "Input",Express\
ionUUID->"0e4431e8-2098-4b98-a822-edc4dfaf5f7d"],

Cell[BoxData[
 RowBox[{"nestedAssoc", "=", 
  RowBox[{"AssociationThread", "[", 
   RowBox[{"names", "->", "grouped"}], "]"}]}]], "Input",ExpressionUUID->\
"a4e4a915-19b7-4fde-8fd2-d30ad0545a57"],

Cell["\<\
This allows you to access any particular entry by asking for a specific name:\
\
\>", "Text",ExpressionUUID->"daaeca15-dcf4-4a39-be20-33d5774715ca"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"nestedAssoc", "[", "\"\<Megan Campbell\>\"", "]"}]], "Input",
 CellLabel->"In[38]:=",ExpressionUUID->"873c5126-53ce-4819-b632-11054ca29ed2"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"id\"\>", "\[Rule]", "9"}], ",", 
   RowBox[{"\<\"fullname\"\>", "\[Rule]", "\<\"Megan Campbell\"\>"}], ",", 
   RowBox[{"\<\"address\"\>", 
    "\[Rule]", "\<\"27904 Mark Row - South Kiarahaven, NC 26988-3596\"\>"}], 
   ",", 
   RowBox[{"\<\"sex\"\>", "\[Rule]", "\<\"F\"\>"}], ",", 
   RowBox[{"\<\"age\"\>", "\[Rule]", "20"}], ",", 
   RowBox[{"\<\"weight\"\>", "\[Rule]", "46"}], ",", 
   RowBox[{"\<\"height\"\>", "\[Rule]", "156"}], ",", 
   RowBox[{"\<\"license_plate\"\>", "\[Rule]", "\<\"56XS7\"\>"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[38]=",ExpressionUUID->"60383154-1d2b-44e5-a4b8-be6348afa39e"]
}, Open  ]],

Cell["\<\
Additional information can be accessed by going one level deeper into the \
nested association:\
\>", "Text",ExpressionUUID->"67e78e61-25e7-4404-bdc8-fe71db53baa4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"nestedAssoc", "[", 
  RowBox[{"\"\<Megan Campbell\>\"", ",", "\"\<license_plate\>\""}], 
  "]"}]], "Input",
 CellLabel->"In[39]:=",ExpressionUUID->"7dbc08d4-9d17-4732-bab6-3ff62a59c804"],

Cell[BoxData["\<\"56XS7\"\>"], "Output",
 CellLabel->"Out[39]=",ExpressionUUID->"2c75df1b-868b-4e4b-8ec7-f01d7d771fa8"]
}, Open  ]],

Cell["You can still use list-style indexing if needed:", "Text",ExpressionUUID->"5a42a5b7-4823-44b1-ab63-ec011330ee3d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"nestedAssoc", "[", 
  RowBox[{"[", 
   RowBox[{"9", ",", 
    RowBox[{"-", "1"}]}], "]"}], "]"}]], "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"6bed86b3-4a0f-4401-abe9-f573db3add44"],

Cell[BoxData["\<\"56XS7\"\>"], "Output",
 CellLabel->"Out[47]=",ExpressionUUID->"4e8a7e6a-71c1-4dcd-8a0c-1b189a4bbe75"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"nestedAssoc", "[", 
  RowBox[{"[", 
   RowBox[{
    RowBox[{"8", ";;", "11"}], ",", 
    RowBox[{"-", "3"}]}], "]"}], "]"}]], "Input",
 CellLabel->"In[70]:=",ExpressionUUID->"1a0ded39-7098-437c-b47e-61ecefabc1f4"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Matthew Ramirez\"\>", "\[Rule]", "66"}], ",", 
   RowBox[{"\<\"Megan Campbell\"\>", "\[Rule]", "46"}], ",", 
   RowBox[{"\<\"Kenneth Sutton\"\>", "\[Rule]", "83"}], ",", 
   RowBox[{"\<\"Crystal Gonzalez\"\>", "\[Rule]", "60"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[70]=",ExpressionUUID->"aa70868e-ee56-4ed3-84a6-c4c913bda67e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Advantages", "Subsection",ExpressionUUID->"ed409a8c-f4b3-4a1a-8ef7-1f764119e9e1"],

Cell["\<\
You can think in terms of key-value pairs at any level of the structure.\
\>", "Item",ExpressionUUID->"b4979a8f-a328-4dc6-bfe1-b313a5800b7f"],

Cell["Maintains the efficient structure allowed by associations.", "Item",ExpressionUUID->"564c82f2-1b1d-4e1d-afcc-08d2dbc4199e"],

Cell["\<\
Dataset structure keeps top-level keys when extracting lower-level values.\
\>", "Item",ExpressionUUID->"ead9ffef-1cf1-455e-832a-09d2b9865753"],

Cell["Can still use list structure if desired.", "Item",ExpressionUUID->"e68b8878-2df0-4ec2-9485-b993cdacf20d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Disadvantages", "Subsection",ExpressionUUID->"4abd79e1-348b-4263-adbd-224eab39b30e"],

Cell["\<\
Can be slightly unwieldy to work with if you mix list- and association-style \
indexing.\
\>", "Item",ExpressionUUID->"f41550a3-6358-4020-8b61-fab78928f3ad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wrap in a Dataset", "Subsection",ExpressionUUID->"df412e88-f478-4279-bf02-3eba6ddeb201"],

Cell[BoxData[
 RowBox[{"ds2", "=", 
  RowBox[{"Dataset", "[", "nestedAssoc", "]"}]}]], "Input",
 CellLabel->"In[48]:=",ExpressionUUID->"95a2dd02-3797-498b-93db-299dac2a0e68"],

Cell[BoxData[
 RowBox[{"ds2", "[", 
  RowBox[{"All", ",", "\"\<age\>\""}], "]"}]], "Input",
 CellLabel->"In[49]:=",ExpressionUUID->"0d5f22be-b1b2-4341-8e3c-3c27a9e4a5b4"],

Cell[BoxData[
 RowBox[{"ds2", "[", 
  RowBox[{"Histogram", ",", "\"\<age\>\""}], "]"}]], "Input",
 CellLabel->"In[52]:=",ExpressionUUID->"dbafa487-7da2-4c86-9311-fbb7fce94b6a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rollback to Nested List", "Subsection",ExpressionUUID->"e7ea45d9-c5c0-4f76-a46d-00986a47e4a8"],

Cell["\<\
Because the names are \"duplicated\" as the top-level keys of this nested \
association, you can throw them away by using Values and then return to the \
standard nested list structure as before:\
\>", "Text",ExpressionUUID->"e0103630-bac4-4d0f-ac46-09a7288826f9"],

Cell[BoxData[
 RowBox[{"Prepend", "[", 
  RowBox[{
   RowBox[{"Values", "@", 
    RowBox[{"Values", "@", "nestedAssoc"}]}], ",", 
   RowBox[{"Keys", "@", 
    RowBox[{"nestedAssoc", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}]], "Input",
 CellLabel->"In[62]:=",ExpressionUUID->"e480aff3-5731-4547-8a82-46b252e4bfcd"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{WolframUTools`Private`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 

"b43de144-b7a8-48e4-b83b-639f14cb4635"],

Cell[TextData[Cell[BoxData[
 DynamicModuleBox[{$CellContext`cyuOpen$$ = False}, 
  DynamicBox[ToBoxes[
    Grid[
     Join[{{
        Button[
         Mouseover[
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], 
           "CYUButtonActive"]], ($CellContext`cyuOpen$$ = 
         Not[$CellContext`cyuOpen$$])& , Appearance -> None, Evaluator -> 
         Automatic, Method -> "Preemptive"]}}, 
      If[$CellContext`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Which piece of code gives the last part of every third element \
of every second element of myList? (You can assume that myList has a Depth of \
at least 5.)", "Text"], 
            DynamicModule[{$CellContext`qState = None}, 
             RadioButtonBar[
              Dynamic[$CellContext`qState], {1 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 1, {
                    TextCell[
                    "myList[[;; ;; 2, ;; ;; 3, -1]]", "Text", FontColor -> 
                    RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: This spans the levels of the list in the \
correct order by first taking every second element, then taking every third, \
and finally extracting the last element of each of those.", "Text", FontColor -> 
                    RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["myList[[;; ;; 2, ;; ;; 3, -1]]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 2, {
                    TextCell[
                    "myList[[;; ;; 2, ;; ;; 3, All, -1]]", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: This is nearly correct, but after taking \
every third element of every second element, it takes the last element of all \
of the sub-elements rather than just take the last element at that level. Try \
this vs. the correct answer on ArrayReshape[Alphabet[\"Greek\"], {3, 2, 2, \
2}] to see the difference.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["myList[[;; ;; 2, ;; ;; 3, All, -1]]", "Text"]}],
                   BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 3, {
                    TextCell[
                    "myList[[;; ;; 2, ;; ;; 3, Last]]", "Text", FontColor -> 
                    RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Last cannot be used as a specification for \
Part.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["myList[[;; ;; 2, ;; ;; 3, Last]]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[$CellContext`qState === 4, {
                    TextCell[
                    "myList[[;; ;; 2, ;; ;; 3, All, Last]]", "Text", 
                    FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Last cannot be used as a specification for \
Part.", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell[
                    "myList[[;; ;; 2, ;; ;; 3, All, Last]]", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
            Thickness[Large]], RoundingRadius -> 0, Background -> 
          GrayLevel[0.97], FrameMargins -> 15]}}, {}]], Spacings -> 2, 
     Alignment -> {Left, Baseline}, ItemSize -> Scaled[1], BaseStyle -> 
     "Text"], StandardForm],
   ImageSizeCache->{852., {21.959640502929688`, 29.192062377929688`}}],
  DynamicModuleValues:>{}]],ExpressionUUID->"c19771b7-3c7f-4ba4-9cfa-\
7d45bd876b4d"]], "Text",
 CellTags->"CYU",ExpressionUUID->"b7448021-4baa-4e65-a96a-3733752ecb39"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Structured Data: Associations", "Section",ExpressionUUID->"42426bde-6f37-445a-8c69-36efc9bc7c72"],

Cell[TextData[{
 "An ",
 ButtonBox["Association",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/Association.html"], None},
  
  ButtonNote->"https://reference.wolfram.com/language/ref/Association.html"],
 " is a dictionary data structure containing key-value pairs. Associations \
provide generalizations of symbolically indexed lists, associative arrays, \
dictionaries, hashmaps, etc. An Association represents labeled data as ",
 StyleBox["key \[RightArrow] value pairs",
  Background->RGBColor[1, 1, 0]],
 "."
}], "Text",ExpressionUUID->"1df6fb57-7120-4bf1-8529-157192ebe01b"],

Cell["\<\
Say you have to keep a record of quiz scores for students in a class. You \
could have a list of students and a list of their quiz scores:\
\>", "Text",ExpressionUUID->"b74e8398-cf0b-435c-bba8-ba8ef0bbea14"],

Cell[BoxData[
 RowBox[{"students", "=", 
  RowBox[{"{", 
   RowBox[{
   "\"\<Alice\>\"", ",", "\"\<Bob\>\"", ",", "\"\<Charlie\>\"", ",", 
    "\"\<Dan\>\""}], "}"}]}]], "Input",ExpressionUUID->"f2a2eb0c-6c1b-4f7d-\
a5c7-f18d728d41a8"],

Cell[BoxData[
 RowBox[{"quizScores", "=", 
  RowBox[{"{", 
   RowBox[{"90", ",", "20", ",", "70", ",", "75"}], "}"}]}]], "Input",Expressi\
onUUID->"435427b5-bd3b-4371-80d6-0672501c88bb"],

Cell["\<\
Or you could create an association to store the quiz score for each student:\
\>", "CodeText",ExpressionUUID->"34498f48-eaa0-4768-916a-e0ad28c314ae"],

Cell[BoxData[
 RowBox[{"studentQuizScores", " ", "=", 
  RowBox[{"\[LeftAssociation]", 
   RowBox[{
    RowBox[{"\"\<Alice\>\"", "\[Rule]", "90"}], ",", 
    RowBox[{"\"\<Bob\>\"", "\[Rule]", "20"}], ",", 
    RowBox[{"\"\<Charlie\>\"", "\[Rule]", "70"}], ",", 
    RowBox[{"\"\<Dan\>\"", "\[Rule]", "75"}]}], 
   "\[RightAssociation]"}]}]], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"cf9ed97e-b4be-4734-928b-b76cf28c8102"],

Cell[BoxData[
 RowBox[{"studentQuizScores", "[", "\"\<Charlie\>\"", "]"}]], "Input",
 CellLabel->
  "In[133]:=",ExpressionUUID->"80614566-dea3-4b94-bcab-e90434abce1d"],

Cell[CellGroupData[{

Cell["Building Associations", "Subsection",ExpressionUUID->"904d6daa-41eb-43e9-92d5-c61dfdf86ba9"],

Cell["You can use special syntax to create an association.", "Text",ExpressionUUID->"d4ca130c-41e6-4dc9-83c6-2978f100076e"],

Cell["Create an association from scratch:", "CodeText",ExpressionUUID->"cf08d0f4-f57a-4603-97d1-cda395028fbe"],

Cell[BoxData[
 RowBox[{"Association", "[", 
  RowBox[{
   RowBox[{"a", "\[Rule]", "1"}], ",", 
   RowBox[{"b", "\[Rule]", "2"}]}], "]"}]], "Input",
 CellLabel->
  "In[214]:=",ExpressionUUID->"aab399e7-1a8c-4c0c-9cb4-560908ae3c09"],

Cell[BoxData[
 RowBox[{"<|", 
  RowBox[{
   RowBox[{"a", "\[Rule]", "1"}], ",", 
   RowBox[{"b", "\[Rule]", "2"}]}], "|>"}]], "Input",ExpressionUUID->\
"ec048c17-fafa-4091-a1c8-5af625adae35"],

Cell["\<\
An association can have any Wolfram Language expression as a key or value, \
but the keys must be unique:\
\>", "CodeText",ExpressionUUID->"6ad97f96-7d81-4509-85b8-3d0a7d884005"],

Cell[BoxData[
 RowBox[{"assoc", "=", 
  RowBox[{"<|", 

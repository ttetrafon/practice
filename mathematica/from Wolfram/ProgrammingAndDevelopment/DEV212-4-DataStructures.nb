            BaseStyle -> "Text"], "CYUButton"], 
          TextCell[
           Framed[
            Style["Check Your Understanding", "CYUButton"], RoundingRadius -> 
            5, FrameMargins -> {{18, 18}, {15, 15}}, ImageSize -> Automatic, 
            BaseStyle -> "Text"], "CYUButtonActive"]], (
         WolframUTools`Private`cyuOpen$$ = 
         Not[WolframUTools`Private`cyuOpen$$])& , Appearance -> None, 
         Evaluator -> Automatic, Method -> "Preemptive"]}}, 
      If[WolframUTools`Private`cyuOpen$$, {{
         Framed[
          Column[{
            TextCell[
            "Which hierarchical data structure allows you to use either \
labels or indices at every level?", "Text"], 
            DynamicModule[{WolframUTools`Private`qState = None}, 
             RadioButtonBar[
              Dynamic[WolframUTools`Private`qState], {1 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 1, {
                    TextCell["List", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: Lists are only accessible via indices (or \
functions like Last or Most that always stand in for a set index or set of \
indices).", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["List", "Text"]}], BaselinePosition -> {1, 1}, 
                  Spacings -> 0]], 2 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 2, {
                    TextCell["Association", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: A simple association's parts can be accessed \
either by key or index. (This is not the only correct answer: find the \
other!)", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["Association", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 3 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 3, {
                    TextCell["Nested list", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: A nested list can only use indices to access \
its parts (or functions like Last or Most that always stand in for a set \
index or set of indices).", "Text", FontColor -> RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["Nested list", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 4 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 4, {
                    TextCell[
                    "List of associations", "Text", FontColor -> RGBColor[
                    Rational[4, 9], 0, 0], FontWeight -> Bold], 
                    TextCell[
                    "Incorrect: While you can access any element of a list of \
associations with indices, you cannot use labels or keys at the top level \
because the list structure requires only an index.", "Text", FontColor -> 
                    RGBColor[
                    Rational[2, 3], 0, 0]]}, {
                    TextCell["List of associations", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]], 5 -> Dynamic[
                 Column[
                  If[WolframUTools`Private`qState === 5, {
                    TextCell[
                    "Nested association", "Text", FontColor -> RGBColor[0, 
                    Rational[4, 9], 0], FontWeight -> Bold], 
                    TextCell[
                    "Correct: Since an association's parts can be accessed \
with either keys or indices, the subsequent lower levels of a nested \
association can as well. This option provides you the most flexibility in \
terms of how you extract parts.", "Text", FontColor -> RGBColor[0, 
                    Rational[2, 3], 0]]}, {
                    TextCell["Nested association", "Text"]}], 
                  BaselinePosition -> {1, 1}, Spacings -> 0]]}, Appearance -> 
              "Vertical", BaselinePosition -> Automatic], 
             DynamicModuleValues :> {}]}], FrameStyle -> Directive[
            GrayLevel[0.92], 
